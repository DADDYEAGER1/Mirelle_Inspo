function generateInspoSitemap() {
  console.log('📄 Generating inspo sitemap...');
  try {
    const inspoDir = path.join(process.cwd(), 'src/content/inspo-images');
    const files = fs.readdirSync(inspoDir).filter(f => f.endsWith('.json'));

