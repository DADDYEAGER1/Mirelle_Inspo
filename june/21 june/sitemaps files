        changefreq: 'weekly',
        priority: 0.8,
        lastmod: new Date().toISOString(),
      })),
    ];

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-inspo.xml'), createSitemap(urls));
    console.log(`✅ sitemap-inspo.xml created (${files.length} categories)`);
  } catch (error) {
    console.error('❌ Error generating inspo sitemap:', error.message);
  }
}

function generateInspoImageSitemap() {
  console.log('📸 Generating inspo image sitemap...');
  try {
    const inspoJsonDir = path.join(process.cwd(), 'src/content/inspo-images');
    if (!fs.existsSync(inspoJsonDir)) return null;

    const jsonFiles = fs.readdirSync(inspoJsonDir).filter(f => f.endsWith('.json'));
    const inspoImages = [];
    const currentYear = new Date().getFullYear();
    const season = getCurrentSeason();

    jsonFiles.forEach(jsonFile => {
      const category = jsonFile.replace('.json', '');
      const jsonPath = path.join(inspoJsonDir, jsonFile);
      try {
        const data = JSON.parse(fs.readFileSync(jsonPath, 'utf8'));
        const images = Array.isArray(data) ? data : data.images ? data.images : Object.values(data);

        images.forEach((image, index) => {
          let imageUrl = typeof image === 'string' ? image : image.url || image.src || image.image;
          if (!imageUrl) return;
          if (imageUrl.startsWith('/')) imageUrl = `${SITE_URL}${imageUrl}`;
          else if (!imageUrl.startsWith('http')) imageUrl = `${SITE_URL}/inspo/${category}/${imageUrl}`;

          const altText = typeof image === 'object' ? (image.alt || image.altText || image.description) : null;
          inspoImages.push({
            pageUrl: `${SITE_URL}/inspo/${category}`,
            imageUrl,
            title: `${category.replace(/-/g, ' ')} nail inspiration ${index + 1}`,
            caption: altText || `${category.replace(/-/g, ' ')} nail art design - trending style for ${season} ${currentYear}`,
          });
        });
      } catch (error) {
        console.error(`   ❌ ${category}:`, error.message);
      }
    });

    if (inspoImages.length === 0) return null;

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-images-inspo.xml'), createImageSitemap(inspoImages));
    console.log(`✅ sitemap-images-inspo.xml created (${inspoImages.length} images)`);
    return 'sitemap-images-inspo.xml';
  } catch (error) {
    console.error('❌ Error generating inspo image sitemap:', error.message);
    return null;
  }
}

// ─── BUSINESS SITEMAPS ────────────────────────────────────────────────────────

function generateBusinessSitemaps() {
  console.log('📄 Generating business sitemaps...');
  try {
    const businessDir = path.join(process.cwd(), 'src/content/business');
    const generatedSitemaps = [];

    if (!fs.existsSync(businessDir)) {
      fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-business-index.xml'), createSitemapIndex([]));
      console.log('✅ sitemap-business-index.xml created (no content yet)');
      return ['sitemap-business-index.xml'];
    }

    const countries = fs.readdirSync(businessDir).filter(f =>
      fs.statSync(path.join(businessDir, f)).isDirectory()
    );

    const rootPageUrls = [
      { loc: `${SITE_URL}/business`, changefreq: 'daily', priority: 0.9, lastmod: new Date().toISOString() },
    ];

    countries.forEach(country => {
      const countrySlug = country.toLowerCase();
      const countryDir = path.join(businessDir, country);

      rootPageUrls.push({
        loc: `${SITE_URL}/business/${countrySlug}`,
        changefreq: 'weekly',
        priority: 0.8,
        lastmod: new Date().toISOString(),
      });

      const states = fs.readdirSync(countryDir).filter(f =>
        fs.statSync(path.join(countryDir, f)).isDirectory()
      );

      const countryUrls = [];

      states.forEach(state => {
        const stateSlug = state.toLowerCase();
        const stateDir = path.join(countryDir, state);
        const files = readContentFiles(stateDir);

        countryUrls.push({
          loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}`,
          changefreq: 'weekly',
          priority: 0.8,
          lastmod: new Date().toISOString(),
        });

        const byClientType = {};
        files.forEach(file => {
          const slug = file.replace(/\.mdx?$/, '');
          const filePath = path.join(stateDir, file);
          const fileContent = fs.readFileSync(filePath, 'utf8');
          const { data } = matter(fileContent);
          const clientType = (data.clientType || 'general').toLowerCase();
          if (!byClientType[clientType]) byClientType[clientType] = [];
          byClientType[clientType].push({ slug, data });
        });

        const stateUrls = [];
        Object.entries(byClientType).forEach(([clientType, posts]) => {
          stateUrls.push({
            loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}/${clientType}`,
            changefreq: 'weekly',
            priority: 0.7,
            lastmod: new Date().toISOString(),
          });

          const clientTypeUrls = posts.map(({ slug, data }) => ({
            loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}/${clientType}/${slug}`,
            changefreq: 'weekly',
            priority: 0.7,
            lastmod: data.dateModified || data.date || new Date().toISOString(),
          }));

          const clientTypeSitemapName = `sitemap-business-${countrySlug}-${stateSlug}-${clientType}.xml`;
          fs.writeFileSync(path.join(PUBLIC_DIR, clientTypeSitemapName), createSitemap(clientTypeUrls));
          console.log(`✅ ${clientTypeSitemapName} created (${clientTypeUrls.length} URLs)`);
          generatedSitemaps.push(clientTypeSitemapName);
        });

        const stateSitemapName = `sitemap-business-${countrySlug}-${stateSlug}.xml`;
        fs.writeFileSync(path.join(PUBLIC_DIR, stateSitemapName), createSitemap(stateUrls));
        console.log(`✅ ${stateSitemapName} created (${stateUrls.length} URLs)`);
        generatedSitemaps.push(stateSitemapName);
      });

      const countrySitemapName = `sitemap-business-${countrySlug}.xml`;
      fs.writeFileSync(path.join(PUBLIC_DIR, countrySitemapName), createSitemap(countryUrls));
      console.log(`✅ ${countrySitemapName} created (${countryUrls.length} URLs)`);
      generatedSitemaps.push(countrySitemapName);
    });

    const rootPageSitemapName = 'sitemap-business-root.xml';
    fs.writeFileSync(path.join(PUBLIC_DIR, rootPageSitemapName), createSitemap(rootPageUrls));
    console.log(`✅ ${rootPageSitemapName} created`);
    generatedSitemaps.push(rootPageSitemapName);

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-business-index.xml'), createSitemapIndex(generatedSitemaps));
    console.log(`✅ sitemap-business-index.xml created (index of ${generatedSitemaps.length} sitemaps)`);
    generatedSitemaps.unshift('sitemap-business-index.xml');

    return generatedSitemaps;
  } catch (error) {
    console.error('❌ Error generating business sitemaps:', error.message);
    return [];
  }
}

