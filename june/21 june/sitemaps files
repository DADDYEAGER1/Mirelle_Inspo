// ─── BLOG SITEMAP (frontmatter-aware, recursive) ─────────────────────────────

function generateBlogSitemap() {
  console.log('📄 Generating blog sitemap (frontmatter-aware)...');
  try {
    const blogsDir = path.join(process.cwd(), 'src/content/blogs');
    if (!fs.existsSync(blogsDir)) {
      console.warn('⚠️  src/content/blogs not found');
      return;
    }

    const urls = [
      {
        loc: `${SITE_URL}/blog`,
        changefreq: 'daily',
        priority: 0.9,
        lastmod: new Date().toISOString(),
      },
    ];

    const registeredHubs = new Set();
    let pillarCount = 0;
    let clusterCount = 0;
    let flatCount = 0;

    const processFile = (filePath) => {
      const fileContent = fs.readFileSync(filePath, 'utf8');
      const { data } = matter(fileContent);
      const slug = data.slug || path.basename(filePath).replace(/\.mdx?$/, '');
      const topic = data.topic || null;
      const isPillar = data.topicalMap?.position === 'pillar';
      const lastmod = data.dateModified || data.date || new Date().toISOString();

      if (topic) {
        if (isPillar && !registeredHubs.has(topic)) {
          urls.push({
            loc: `${SITE_URL}/blog/${topic}`,
            changefreq: 'weekly',
            priority: 0.8,
            lastmod,
          });
          registeredHubs.add(topic);
          pillarCount++;
        }

        urls.push({
          loc: `${SITE_URL}/blog/${topic}/${slug}`,
          changefreq: 'weekly',
          priority: isPillar ? 0.8 : 0.7,
          lastmod,
        });

        if (!isPillar) clusterCount++;
      } else {
        urls.push({
          loc: `${SITE_URL}/blog/${slug}`,
          changefreq: 'weekly',
          priority: 0.7,
          lastmod,
        });
        flatCount++;
      }
    };

    const entries = fs.readdirSync(blogsDir);

    entries.forEach(entry => {
      const entryPath = path.join(blogsDir, entry);
      const stat = fs.statSync(entryPath);

      if (stat.isDirectory()) {
        readContentFiles(entryPath).forEach(file =>
          processFile(path.join(entryPath, file))
        );
      } else if (entry.endsWith('.md') || entry.endsWith('.mdx')) {
        processFile(entryPath);
      }
    });

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-blog.xml'), createSitemap(urls));
    console.log(`✅ sitemap-blog.xml created (${registeredHubs.size} hub pages, ${pillarCount} pillars, ${clusterCount} clusters, ${flatCount} flat posts)`);
  } catch (error) {
    console.error('❌ Error generating blog sitemap:', error.message);
  }
}

// ─── BLOG IMAGE SITEMAP (frontmatter-aware, recursive) ───────────────────────

function generateBlogImageSitemap() {
  console.log('📸 Generating blog image sitemap (frontmatter-aware)...');
  try {
    const blogsDir = path.join(process.cwd(), 'src/content/blogs');
    if (!fs.existsSync(blogsDir)) return null;

    const allImages = [];
    const currentYear = new Date().getFullYear();
    const season = getCurrentSeason();

    const processFile = (filePath) => {
      const fileContent = fs.readFileSync(filePath, 'utf8');
      const { data, content } = matter(fileContent);
      const slug = data.slug || path.basename(filePath).replace(/\.mdx?$/, '');
      const topic = data.topic || null;

      const pageUrl = topic
        ? `${SITE_URL}/blog/${topic}/${slug}`
        : `${SITE_URL}/blog/${slug}`;

      const imageBasePath = topic
        ? `/images/blog/${topic}/${slug}`
        : `/images/blog/${slug}`;

      const images = extractImagesFromContent(content, slug, data, imageBasePath);
      const cleanTitle = data.title || slug.replace(/-/g, ' ');

      images.forEach(img => {
        allImages.push({
          pageUrl,
          imageUrl: img.url,
          title: `${cleanTitle} - ${img.type} image`,
          caption: img.alt || `${cleanTitle} - nail art inspiration for ${season} ${currentYear}`,
        });
      });

      if (images.length > 0) {
        console.log(`   ✔ ${pageUrl.replace(SITE_URL, '')}: ${images.length} image(s)`);
      }
    };

    const entries = fs.readdirSync(blogsDir);

    entries.forEach(entry => {
      const entryPath = path.join(blogsDir, entry);
      const stat = fs.statSync(entryPath);

      if (stat.isDirectory()) {
        readContentFiles(entryPath).forEach(file =>
          processFile(path.join(entryPath, file))
        );
      } else if (entry.endsWith('.md') || entry.endsWith('.mdx')) {
        processFile(entryPath);
      }
    });

    if (allImages.length === 0) {
      console.warn('⚠️  No images found for blog');
      return null;
    }

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-images-blog.xml'), createImageSitemap(allImages));
    console.log(`✅ sitemap-images-blog.xml created (${allImages.length} images)`);
    return 'sitemap-images-blog.xml';
  } catch (error) {
    console.error('❌ Error generating blog image sitemap:', error.message);
    return null;
  }
}

