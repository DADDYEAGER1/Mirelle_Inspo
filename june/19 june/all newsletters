acking-wider hover:opacity-80 transition-opacity disabled:opacity-50 whitespace-nowrap\"\n          >\n            {status === 'loading' ? 'SUBSCRIBING...' : status === 'success' ? '✓ SUBSCRIBED' : 'SUBSCRIBE NOW'}\n          </button>\n        </form>\n      </div>\n\n      {/* Mobile */}\n      <div className=\"md:hidden flex items-center justify-center py-2 px-4 gap-3\">\n        <div className=\"flex-shrink-0\">\n          <Image src=\"/logo.png\" alt=\"Mirellé Inspo\" width={45} height={45} className=\"object-contain\" />\n        </div>\n        <div className=\"flex flex-col gap-2\">\n          <p className=\"font-body text-foreground text-sm leading-tight\">\n            Elevate the Season with <span className=\"italic\">Mirellé</span>\n          </p>\n          <form onSubmit={handleSubmit} className=\"flex\">\n            <input\n              type=\"email\"\n              value={email}\n              onChange={(e) => setEmail(e.target.value)}\n              placeholder=\"Your email\"\n              required\n              className=\"px-3 py-2 border border-gray-300 font-ui text-xs focus:outline-none focus:ring-2 focus:ring-foreground bg-white flex-1\"\n            />\n            <button\n              type=\"submit\"\n              disabled={status === 'loading'}\n              className=\"bg-foreground text-white px-3 py-2 font-ui text-xs uppercase tracking-wider hover:opacity-80 transition-opacity disabled:opacity-50 whitespace-nowrap\"\n            >\n              {status === 'loading' ? '...' : status === 'success' ? '✓' : 'SUBSCRIBE'}\n            </button>\n          </form>\n        </div>\n      </div>\n\n      {status === 'error' && (\n        <p className=\"text-red-600 font-ui text-xs text-center mt-2\">Failed to subscribe. Try again.</p>\n      )}\n    </section>\n  );\n}"
