4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z\" />\n                </svg>\n              </div>\n              <h3 className=\"font-heading text-2xl text-foreground mb-4\">\n                Weekly Inspiration\n              </h3>\n              <p className=\"font-body text-base text-foreground leading-relaxed\">\n                Fresh nail art ideas, seasonal trends, and Pinterest-worthy designs delivered every week.\n              </p>\n            </div>\n\n            {/* Benefit 2 */}\n            <div className=\"text-center\">\n              <div className=\"w-16 h-16 border-2 border-foreground mx-auto mb-6 flex items-center justify-center\">\n                <svg className=\"w-8 h-8 text-foreground\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" strokeWidth={1.5}>\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5\" />\n                </svg>\n              </div>\n              <h3 className=\"font-heading text-2xl text-foreground mb-4\">\n                Expert Tutorials\n              </h3>\n              <p className=\"font-body text-base text-foreground leading-relaxed\">\n                Step-