      "path": "src/app/shop/page.tsx",
      "content": "// src/app/shop/page.tsx\n// Shop index  lists all shop posts by category.\n\nimport { getAllShopPosts } from '@/lib/shop';\nimport { ShopPost } from '@/types/shop';\nimport Link from 'next/link';\nimport type { Metadata } from 'next';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nexport const dynamic = 'force-static'\nexport const revalidate = false\nexport const metadata: Metadata = {\n  title: 'Shop | Mirellé',\n  description: 'Curated nail products, tools, and picks from the Mirellé team.',\n  alternates: { canonical: 'https://mirelleinspo.com/shop' },\n};\n\nfunction ShopCard({ post }: { post: ShopPost }) {\n  return (\n    <Link\n      href={`/shop/${post.productType}/${post.slug}`}\n      className=\"group block border border-gray-200 bg-white hover:shadow-md transition-shadow duration-300\"\n    >\n      {/* Image  card thumbnail only, post page has no hero */}\n      {post.image && (\n        <div className=\"w-full aspect-[4/3] overflow-hidden bg-gray-50\">\n          <img\n            src={post.image}\n            alt={post.imageAlt || post.title}\n            className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\"\n            loading=\"lazy\"\n          />\n        </div>\n      )}\n\n      {/* Content */}\n      <div className=\"p-5\">\n        {post.category && (\n          <p className=\"font-ui text-[10px] uppercase tracking-widest text-gray-400 mb-2\">\n            {post.category}\n          </p>\n        )}\n        <h2\n          className=\"font-heading text-[19px] md:text-[21px] leading-snug mb-2 group-hover:opacity-70 transition-opacity duration-200\"\n          style={{ color: '#252220' }}\n        >\n          {post.title}\n        </h2>\n        {post.excerpt && (\n          <p className=\"font-body text-[16px] leading-relaxed text-gray-600 line-clamp-2 mb-4\">\n            {post.excerpt}\n          </p>\n        )}\n        <div className=\"flex items-center justify-between\">\n          <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400\">\n            {new Date(post.date).toLocaleDateString('en-US', {\n              month: 'short',\n              year: 'numeric',\n            })}\n            {post.readTime && ` · ${post.readTime}`}\n          </p>\n          {post.products && post.products.length > 0 && (\n            <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400\">\n              {post.products.length} picks\n            </p>\n          )}\n        </div>\n      </div>\n    </Link>\n  );\n}\n\nexport default async function ShopIndexPage() {\n  const posts = await getAllShopPosts();\n\n  // Group by category\n  const byCategory: Record<string, ShopPost[]> = {};\n  for (const post of posts) {\n    const cat = post.category || 'Shop';\n    if (!byCategory[cat]) byCategory[cat] = [];\n    byCategory[cat].push(post);\n  }\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n      <InlineNewsletter />\n\n      {/* Hero */}\n      <div className=\"text-center py-14 md:py-20 px-6\" style={{ backgroundColor: '#f9fafb' }}>\n        <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400 mb-4\">\n          Curated Picks\n        </p>\n        <h1\n          className=\"font-heading text-[40px] md:text-[52px] leading-tight mb-4\"\n          style={{ color: '#252220' }}\n        >\n          Shop\n        </h1>\n        <p className=\"font-body text-[18px] md:text-[20px] text-gray-600 max-w-xl mx-auto\">\n          Products we actually use, tested and recommended by the Mirellé team.\n        </p>\n      </div>\n\n      {/* Posts */}\n      <div className=\"w-full max-w-7xl mx-auto px-6 md:px-12 lg:px-16 py-14\">\n        {posts.length === 0 ? (\n          <p className=\"font-body text-[18px] text-gray-500 text-center py-20\">\n            Shop posts coming soon.\n          </p>\n        ) : Object.keys(byCategory).length === 1 ? (\n          // Single category  just grid\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8\">\n            {posts.map(post => (\n              <ShopCard key={`${post.productType}/${post.slug}`} post={post} />\n            ))}\n          </div>\n        ) : (\n          // Multiple categories  grouped\n          <div className=\"space-y-16\">\n            {Object.entries(byCategory).map(([category, categoryPosts]) => (\n              <section key={category}>\n                <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400 mb-6 pb-3 border-b border-gray-200\">\n                  {category}\n                </p>\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8\">\n                  {categoryPosts.map(post => (\n                    <ShopCard key={`${post.productType}/${post.slug}`} post={post} />\n                  ))}\n                </div>\n              </section>\n            ))}\n          </div>\n        )}\n      </div>\n\n      <FinalNewsletter />\n    </div>\n  );\n}"
    }
