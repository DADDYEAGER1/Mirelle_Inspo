      "path": "src/app/blog/page.tsx",
      "content": "import { Metadata } from 'next';\nimport { getAllBlogPosts, getPostsByCategory, getAllClusters, getStandalonePosts } from '@/lib/blog';\nimport { BlogMetadata } from '@/types/blog';\nimport MainHeroSection from '@/components/Blog/MainHeroSection';\nimport MustReadSection from '@/components/Blog/MustReadSection';\nimport CarouselSection from '@/components/Blog/CarouselSection';\nimport LatestStoriesSection from '@/components/Blog/LatestStoriesSection';\nimport NextPageButton from '@/components/Blog/NextPageButton';\nimport BlogCategoryNav from '@/components/Blog/BlogCategoryNav';\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\nexport const metadata: Metadata = {\n  title: \"Nail Care Blog - Expert Tips & Trends | Mirellé\",\n  description: 'Discover trending nail tutorials, seasonal trends, and professional nail care advice. Step-by-step guides and inspiration.',\n};\n\ninterface PageProps {\n  searchParams: Promise<{\n    page?: string;\n    category?: string;\n  }>;\n}\n\nconst CLUSTERS_PER_PAGE = 3; // 1 hero + 2 carousel\nconst MUST_READ_COUNT = 3;\nconst LATEST_EDITS_PER_PAGE = 6;\nconst HERO_TARGET_COUNT = 12;\n\ninterface PageAllocation {\n  heroPosts: BlogMetadata[];\n  carousel1: { pillar: BlogMetadata; clusters: BlogMetadata[] } | undefined;\n  carousel2: { pillar: BlogMetadata; clusters: BlogMetadata[] } | undefined;\n  mustReadPosts: BlogMetadata[];\n  latestEditsPosts: BlogMetadata[];\n  hasNextPage: boolean;\n}\n\n/**\n * Builds the full page-by-page allocation up through `targetPage`,\n * tracking every slug already used (across hero overflow, carousels,\n * must-read, and latest-edits on every prior page) in one shared set.\n * This guarantees:\n *   - No post is ever duplicated across pages or within a page.\n *   - Cluster overflow (when a pillar+children exceeds HERO_TARGET_COUNT)\n *     is never dropped  extra posts flow into the standalone-eligible\n *     pool and surface later via Must Read / Latest Edits.\n *   - Cluster underflow (pillar+children below HERO_TARGET_COUNT) pulls\n *     filler from standalone posts not already used anywhere.\n */\nasync function buildPageAllocation(targetPage: number): Promise<PageAllocation> {\n  const allClusters = await getAllClusters();\n  const standalonePosts = await getStandalonePosts();\n\n  const usedSlugs = new Set<string>();\n  // Overflow posts from hero clusters that exceeded HERO_TARGET_COUNT \n  // these still need a home, so they get queued into the standalone pool.\n  const overflowQueue: BlogMetadata[] = [];\n\n  let result: PageAllocation | null = null;\n\n  for (let page = 1; page <= targetPage; page++) {\n    const clusterStartIndex = (page - 1) * CLUSTERS_PER_PAGE;\n    const clustersForPage = allClusters.slice(clusterStartIndex, clusterStartIndex + CLUSTERS_PER_PAGE);\n    const [heroCluster, carousel1, carousel2] = clustersForPage;\n\n    // Carousel clusters consume their own pillar + clusters as a self-contained unit.\n    if (carousel1) {\n      usedSlugs.add(carousel1.pillar.slug);\n      carousel1.clusters.forEach(p => usedSlugs.add(p.slug));\n    }\n    if (carousel2) {\n      usedSlugs.add(carousel2.pillar.slug);\n      carousel2.clusters.forEach(p => usedSlugs.add(p.slug));\n    }\n\n    // Hero: pillar + its cluster children, padded or trimmed to HERO_TARGET_COUNT.\n    let heroPosts: BlogMetadata[] = [];\n    if (heroCluster) {\n      const family = [heroCluster.pillar, ...heroCluster.clusters];\n      family.forEach(p => usedSlugs.add(p.slug));\n\n      if (family.length > HERO_TARGET_COUNT) {\n        // Overflow: keep first HERO_TARGET_COUNT in hero, queue the rest\n        // so they still appear later (Must Read / Latest Edits), never dropped.\n        heroPosts = family.slice(0, HERO_TARGET_COUNT);\n        const overflow = family.slice(HERO_TARGET_COUNT);\n        overflow.forEach(p => {\n          usedSlugs.delete(p.slug); // free it up so it can be picked from the standalone-eligible pool\n          overflowQueue.push(p);\n        });\n      } else if (family.length < HERO_TARGET_COUNT) {\n        // Underflow: pad with standalone posts not used anywhere yet.\n        const needed = HERO_TARGET_COUNT - family.length;\n        const filler = standalonePosts.filter(p => !usedSlugs.has(p.slug)).slice(0, needed);\n        filler.forEach(p => usedSlugs.add(p.slug));\n        heroPosts = [...family, ...filler];\n      } else {\n        heroPosts = family;\n      }\n    }\n\n    // Standalone-eligible pool for this page: regular standalone posts\n    // PLUS any queued overflow posts from earlier hero clusters, minus\n    // anything already used. Overflow posts get priority placement so\n    // they surface as soon as possible rather than being pushed indefinitely.\n    const eligiblePool = [\n      ...overflowQueue.filter(p => !usedSlugs.has(p.slug)),\n      ...standalonePosts.filter(p => !usedSlugs.has(p.slug)),\n    ];\n    // De-dupe the pool itself (overflow posts are also standalone-flagged\n    // in some cases, so guard against listing the same post twice here).\n    const seenInPool = new Set<string>();\n    const dedupedPool = eligiblePool.filter(p => {\n      if (seenInPool.has(p.slug)) return false;\n      seenInPool.add(p.slug);\n      return true;\n    });\n\n    const mustReadPosts = dedupedPool.slice(0, MUST_READ_COUNT);\n    mustReadPosts.forEach(p => usedSlugs.add(p.slug));\n\n    const remainingPool = dedupedPool.filter(p => !mustReadPosts.some(mp => mp.slug === p.slug));\n    const latestEditsPosts = remainingPool.slice(0, LATEST_EDITS_PER_PAGE);\n    latestEditsPosts.forEach(p => usedSlugs.add(p.slug));\n\n    // Remove consumed posts from the overflow queue so they aren't re-queued.\n    for (const p of [...mustReadPosts, ...latestEditsPosts]) {\n      const qIdx = overflowQueue.findIndex(o => o.slug === p.slug);\n      if (qIdx !== -1) overflowQueue.splice(qIdx, 1);\n    }\n\n    const hasMoreClusters = allClusters.length > clusterStartIndex + CLUSTERS_PER_PAGE;\n    const remainingStandalone = standalonePosts.filter(p => !usedSlugs.has(p.slug)).length;\n    const hasMoreOverflow = overflowQueue.length > 0;\n    const hasNextPage = hasMoreClusters || remainingStandalone > 0 || hasMoreOverflow;\n\n    if (page === targetPage) {\n      result = { heroPosts, carousel1, carousel2, mustReadPosts, latestEditsPosts, hasNextPage };\n    }\n  }\n\n  return result!;\n}\n\nexport default async function BlogPage({ searchParams }: PageProps) {\n  const params = await searchParams;\n  const currentPage = Math.max(1, Number(params.page) || 1);\n  const selectedCategory = params.category;\n\n  // ── Category filtered view ───────────────────────────────────────────\n  if (selectedCategory) {\n    const allCategoryPosts = await getPostsByCategory(selectedCategory);\n    const postsPerPage = 12;\n    const totalPages = Math.ceil(allCategoryPosts.length / postsPerPage);\n    const startIndex = (currentPage - 1) * postsPerPage;\n    const posts = allCategoryPosts.slice(startIndex, startIndex + postsPerPage);\n\n    return (\n      <div className=\"min-h-screen bg-[#f9fafb]\">\n        <section className=\"py-16 bg-[#f9fafb] border-b border-gray-100\">\n          <div className=\"max-w-[1200px] mx-auto px-6 text-center\">\n            <h1\n              className=\"text-4xl md:text-5xl uppercase\"\n              style={{ fontFamily: 'Larken, Georgia, serif' }}\n            >\n              {selectedCategory.replace('-', ' ')}\n            </h1>\n          </div>\n        </section>\n\n        <BlogCategoryNav />\n\n        <LatestStoriesSection posts={posts} />\n\n        {currentPage < totalPages && (\n          <NextPageButton href={`/blog?category=${selectedCategory}&page=${currentPage + 1}`} />\n        )}\n      </div>\n    );\n  }\n\n  // ── Unified pagination with global allocation tracking ──────────────\n  const { heroPosts, carousel1, carousel2, mustReadPosts, latestEditsPosts, hasNextPage } =\n    await buildPageAllocation(currentPage);\n\n  return (\n    <div className=\"min-h-screen bg-[#f9fafb]\">\n      {/* Hero title */}\n      <section className=\"py-16 md:py-24 bg-[#f9fafb] border-b border-gray-100\">\n        <div className=\"max-w-[1200px] mx-auto px-6 text-center\">\n          <h1\n            className=\"text-5xl md:text-6xl\"\n            style={{ fontFamily: 'Larken, serif' }}\n          >\n            Nails\n          </h1>\n        </div>\n      </section>\n\n      {/* Search bar  visible on every page including page 1 */}\n      <BlogCategoryNav />\n\n      {/* Hero  1 cluster */}\n      {heroPosts.length > 0 && <MainHeroSection posts={heroPosts} />}\n\n      {/* Carousel 1  2nd cluster */}\n      {carousel1 && <CarouselSection clusterGroup={carousel1} />}\n\n      {/* Must Read  standalone slice (includes overflow posts when applicable) */}\n      {mustReadPosts.length > 0 && <MustReadSection posts={mustReadPosts} />}\n\n      {/* Carousel 2  3rd cluster */}\n      {carousel2 && <CarouselSection clusterGroup={carousel2} />}\n\n      {/* Latest Edits  standalone slice (includes overflow posts when applicable) */}\n      {latestEditsPosts.length > 0 && <LatestStoriesSection posts={latestEditsPosts} />}\n\n      {hasNextPage && <NextPageButton href={`/blog?page=${currentPage + 1}`} />}\n    </div>\n  );\n}"
    },
    {
      "path": "src/app/page.tsx",
      "content": "// src/app/page.tsx\nimport type { Metadata } from 'next';\nimport SubscribeSection from '@/components/Homepage/SubscribeSection';\nimport TrendTimelineHero from '@/components/Homepage/TrendTimelineHero';\nimport Hero1Section from '@/components/Homepage/Hero1Section';\nimport Hero2Section from '@/components/Homepage/Hero2Section';\nimport BlogCarousel from '@/components/Homepage/BlogCarousel';\nimport WorkNailsCarousel from '@/components/Homepage/WorkNailsCarousel';\nimport MustReadSection from '@/components/Homepage/MustReadSection';\nimport InspoCategoriesCarousel from '@/components/Homepage/InspoCategoriesCarousel';\nimport InspoMasonryGrid from '@/components/Homepage/InspoMasonryGrid';\nimport SpotlightCarousel from '@/components/Homepage/SpotlightCarousel';\nimport BusinessCarousel from '@/components/Homepage/BusinessCarousel';\nimport { getPillarClusterPosts } from '@/lib/blog';\nimport { getAllDesignSlugs, getDesignImages, getLatestDesigns } from '@/lib/inspo';\nimport { getAllSpotlightPosts } from '@/lib/spotlight';\nimport { getAllBusinessPosts } from '@/lib/business';\nimport { getAllWorkNailsPosts } from '@/lib/workNails';\nimport FaqCarousel from '@/components/Homepage/FaqCarousel';\nimport { getAllFaqs } from '@/lib/faqs';\nexport const revalidate = false\n\nexport const metadata: Metadata = {\n  title: 'Mirellé - Premium Nail Design & Inspiration',\n  description: 'Discover trending nail designs, expert tutorials, and premium press-ons. Your destination for nail art inspiration.',\n  keywords: 'nail designs, nail art, press on nails, nail inspiration, nail tutorials, trending nails',\n  openGraph: {\n    title: 'Mirellé - Premium Nail Design & Inspiration',\n    description: 'Discover trending nail designs, expert tutorials, and premium press-ons.',\n    type: 'website',\n    url: 'https://mirelleinspo.com',\n    siteName: 'Mirellé Inspo',\n  },\n};\n\nconst BLOG_CAROUSEL_PILLAR_SLUG = 'nail-colors-for-every-skin-tone';\n\nexport default async function Home() {\n  const pillarData = await getPillarClusterPosts(BLOG_CAROUSEL_PILLAR_SLUG);\n\n  const inspoCategories = getLatestDesigns(6);\n\n  const inspoSlugs = getAllDesignSlugs();\n  const masonryImages = inspoSlugs.length > 0\n    ? await getDesignImages(inspoSlugs[0])\n    : [];\n\n  const allSpotlightPosts = await getAllSpotlightPosts();\n  const allBusinessPosts = await getAllBusinessPosts();\n  const allWorkNailsPosts = await getAllWorkNailsPosts();\n  const allFaqs = await getAllFaqs();\n\n  return (\n    <div className=\"font-body bg-background text-foreground\">\n      <SubscribeSection />\n      <TrendTimelineHero />\n      <Hero1Section />\n      <Hero2Section />\n\n      {allWorkNailsPosts.length > 0 && (\n        <WorkNailsCarousel\n          posts={allWorkNailsPosts}\n          heading=\"Work Nails\"\n        />\n      )}\n\n      {pillarData && (\n        <BlogCarousel\n          posts={pillarData.clusters}\n          heading={pillarData.pillar.title}\n        />\n      )}\n\n      <MustReadSection />\n\n      {allFaqs.length > 0 && (\n      <FaqCarousel faqs={allFaqs} heading=\"Nail FAQs\" />\n      )}\n\n      {inspoCategories.length > 0 && (\n        <InspoCategoriesCarousel categories={inspoCategories} />\n      )}\n\n      {masonryImages.length > 0 && (\n        <InspoMasonryGrid images={masonryImages} />\n      )}\n\n      <SpotlightCarousel posts={allSpotlightPosts} />\n      <BusinessCarousel posts={allBusinessPosts} />\n\n      <SubscribeSection />\n    </div>\n  );\n}"
