      "content": "// src/components/Inspo/ImageModal.tsx\n'use client';\n\nimport { useEffect, useState, useCallback, useRef } from 'react';\nimport type { DesignImage } from '@/types/inspo';\n\ninterface ImageModalProps {\n  image: DesignImage | null;\n  images: DesignImage[];\n  onClose: () => void;\n  onNavigate?: (direction: 'prev' | 'next') => void;\n}\n\nconst SOCIALS = [\n  {\n    key: 'pinterest',\n    label: 'Pinterest',\n    color: '#E60023',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) =>\n      `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(imageUrl)}`,\n  },\n  {\n    key: 'facebook',\n    label: 'Facebook',\n    color: '#1877F2',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) =>\n      `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`,\n  },\n  {\n    key: 'twitter',\n    label: 'X (Twitter)',\n    color: '#000000',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) =>\n      `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent('Love this nail inspo 💅')}`,\n  },\n  {\n    key: 'whatsapp',\n    label: 'WhatsApp',\n    color: '#25D366',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) =>\n      `https://wa.me/?text=${encodeURIComponent('Love this nail inspo 💅 ' + pageUrl)}`,\n  },\n  {\n    key: 'instagram',\n    label: 'Instagram',\n    color: '#E1306C',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) =>\n      // Instagram doesn't support direct share via URL — copy link fallback\n      null,\n    copyFallback: true,\n  },\n  {\n    key: 'tiktok',\n    label: 'TikTok',\n    color: '#010101',\n    icon: (\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" className=\"w-5 h-5\">\n        <path d=\"M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z\" />\n      </svg>\n    ),\n    getUrl: (imageUrl: string, pageUrl: string) => null,\n    copyFallback: true,\n  },\n];\n\nexport default function ImageModal({ image, images, onClose, onNavigate }: ImageModalProps) {\n  const [touchStart, setTouchStart] = useState<number | null>(null);\n  const [touchEnd, setTouchEnd] = useState<number | null>(null);\n  const [mouseStart, setMouseStart] = useState<number | null>(null);\n  const [isDragging, setIsDragging] = useState(false);\n  const [showShare, setShowShare] = useState(false);\n  const [copied, setCopied] = useState(false);\n  const [downloading, setDownloading] = useState(false);\n  const shareRef = useRef<HTMLDivElement>(null);\n\n  const minSwipeDistance = 50;\n\n  const currentIndex = image ? images.findIndex(img => img.id === image.id) : -1;\n  const isFirst = currentIndex === 0;\n  const isLast = currentIndex === images.length - 1;\n\n  const pageUrl = typeof window !== 'undefined' ? window.location.href : '';\n\n  // Close share panel on outside click\n  useEffect(() => {\n    const handleClickOutside = (e: MouseEvent) => {\n      if (shareRef.current && !shareRef.current.contains(e.target as Node)) {\n        setShowShare(false);\n      }\n    };\n    if (showShare) document.addEventListener('mousedown', handleClickOutside);\n    return () => document.removeEventListener('mousedown', handleClickOutside);\n  }, [showShare]);\n\n  const handleKeyDown = useCallback((e: KeyboardEvent) => {\n    if (!image) return;\n    switch (e.key) {\n      case 'Escape':\n        onClose();\n        break;\n      case 'ArrowLeft':\n        if (!isFirst && onNavigate) onNavigate('prev');\n        break;\n      case 'ArrowRight':\n        if (!isLast && onNavigate) onNavigate('next');\n        break;\n    }\n  }, [image, isFirst, isLast, onClose, onNavigate]);\n\n  useEffect(() => {\n    document.addEventListener('keydown', handleKeyDown);\n    return () => document.removeEventListener('keydown', handleKeyDown);\n  }, [handleKeyDown]);\n\n  useEffect(() => {\n    if (image) {\n      document.body.style.overflow = 'hidden';\n    } else {\n      document.body.style.overflow = '';\n    }\n    return () => { document.body.style.overflow = ''; };\n  }, [image]);\n\n  // Reset share panel on image change\n  useEffect(() => {\n    setShowShare(false);\n    setCopied(false);\n  }, [image?.id]);\n\n  // Touch swipe\n  const onTouchStart = (e: React.TouchEvent) => {\n    setTouchEnd(null);\n    setTouchStart(e.targetTouches[0].clientX);\n  };\n  const onTouchMove = (e: React.TouchEvent) => {\n    setTouchEnd(e.targetTouches[0].clientX);\n  };\n  const onTouchEnd = () => {\n    if (!touchStart || !touchEnd) return;\n    const distance = touchStart - touchEnd;\n    if (distance > minSwipeDistance && !isLast && onNavigate) onNavigate('next');\n    else if (distance < -minSwipeDistance && !isFirst && onNavigate) onNavigate('prev');\n  };\n\n  // Mouse drag swipe (desktop)\n  const onMouseDown = (e: React.MouseEvent) => {\n    setMouseStart(e.clientX);\n    setIsDragging(false);\n  };\n  const onMouseMove = (e: React.MouseEvent) => {\n    if (mouseStart !== null && Math.abs(e.clientX - mouseStart) > 5) setIsDragging(true);\n  };\n  const onMouseUp = (e: React.MouseEvent) => {\n    if (mouseStart === null) return;\n    const distance = mouseStart - e.clientX;\n    if (Math.abs(distance) > minSwipeDistance) {\n      if (distance > 0 && !isLast && onNavigate) onNavigate('next');\n      else if (distance < 0 && !isFirst && onNavigate) onNavigate('prev');\n    }\n    setMouseStart(null);\n    setTimeout(() => setIsDragging(false), 0);\n  };\n\n  // Download\n  const handleDownload = async () => {\n    if (!image) return;\n    setDownloading(true);\n    try {\n      const res = await fetch(image.url);\n      const blob = await res.blob();\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url;\n      a.download = `mirelle-inspo-${image.id}.jpg`;\n      a.click();\n      URL.revokeObjectURL(url);\n    } catch {\n      // fallback: open in new tab\n      window.open(image.url, '_blank');\n    } finally {\n      setDownloading(false);\n    }\n  };\n\n  // Copy link\n  const handleCopyLink = async () => {\n    try {\n      await navigator.clipboard.writeText(pageUrl);\n      setCopied(true);\n      setTimeout(() => setCopied(false), 2000);\n    } catch {}\n  };\n\n  // Social share\n  const handleSocialShare = (social: typeof SOCIALS[0]) => {\n    if (!image) return;\n    if ((social as any).copyFallback) {\n      handleCopyLink();\n      setShowShare(false);\n      return;\n    }\n    const url = social.getUrl(image.url, pageUrl);\n    if (url) window.open(url, '_blank', 'width=600,height=500');\n    setShowShare(false);\n  };\n\n  if (!image) return null;\n\n  return (\n    <div\n      className=\"fixed inset-0 z-[9999] bg-black/95 backdrop-blur-sm\"\n      onClick={onClose}\n    >\n      {/* Close */}\n      <button\n        onClick={onClose}\n        className=\"fixed top-4 right-4 z-50 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-md flex items-center justify-center transition-all duration-200\"\n        aria-label=\"Close\"\n      >\n        <svg className=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M6 18L18 6M6 6l12 12\" />\n        </svg>\n      </button>\n\n      {/* Main container */}\n      <div\n        className=\"h-full flex items-center justify-center p-4 md:p-8 select-none\"\n        onTouchStart={onTouchStart}\n        onTouchMove={onTouchMove}\n        onTouchEnd={onTouchEnd}\n        onMouseDown={onMouseDown}\n        onMouseMove={onMouseMove}\n        onMouseUp={onMouseUp}\n        onClick={(e) => e.stopPropagation()}\n        style={{ cursor: isDragging ? 'grabbing' : 'grab' }}\n      >\n        {/* Prev */}\n        {!isFirst && onNavigate && (\n          <button\n            onClick={(e) => { e.stopPropagation(); onNavigate('prev'); }}\n            className=\"fixed left-3 md:left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/15 hover:bg-white/30 backdrop-blur-md flex items-center justify-center transition-all duration-200\"\n            aria-label=\"Previous\"\n          >\n            <svg className=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M15 19l-7-7 7-7\" />\n            </svg>\n          </button>\n        )}\n\n        {/* Next */}\n        {!isLast && onNavigate && (\n          <button\n            onClick={(e) => { e.stopPropagation(); onNavigate('next'); }}\n            className=\"fixed right-3 md:right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white/15 hover:bg-white/30 backdrop-blur-md flex items-center justify-center transition-all duration-200\"\n            aria-label=\"Next\"\n          >\n            <svg className=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M9 5l7 7-7 7\" />\n            </svg>\n          </button>\n        )}\n\n        {/* Image */}\n        <img\n          src={image.url}\n          alt={image.alt}\n          className=\"max-h-[85vh] max-w-full object-contain pointer-events-none\"\n          draggable={false}\n        />\n\n        {/* ── Bottom bar: counter + action buttons ── */}\n        <div\n          className=\"fixed bottom-5 left-0 right-0 flex items-center justify-center gap-3 px-4\"\n          onClick={(e) => e.stopPropagation()}\n        >\n          {/* Counter */}\n          <div\n            className=\"px-3 py-1.5 bg-black/60 backdrop-blur-md rounded-full text-white/80 tabular-nums\"\n            style={{ fontFamily: 'General Sans, sans-serif', fontSize: '13px' }}\n          >\n            {currentIndex + 1} / {images.length}\n          </div>\n\n          {/* Download button */}\n          <button\n            onClick={handleDownload}\n            disabled={downloading}\n            className=\"flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white text-black text-[13px] font-medium hover:bg-white/90 active:scale-95 transition-all duration-150 disabled:opacity-60\"\n            style={{ fontFamily: 'General Sans, sans-serif' }}\n            aria-label=\"Download image\"\n          >\n            {downloading ? (\n              <svg className=\"w-4 h-4 animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z\" />\n              </svg>\n            ) : (\n              <svg className=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n              </svg>\n            )}\n            Save\n          </button>\n\n          {/* Share button + panel */}\n          <div className=\"relative\" ref={shareRef}>\n            <button\n              onClick={() => setShowShare(v => !v)}\n              className=\"flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-white text-[13px] font-medium hover:bg-white/20 active:scale-95 transition-all duration-150 backdrop-blur-md\"\n              style={{ fontFamily: 'General Sans, sans-serif' }}\n              aria-label=\"Share\"\n            >\n              <svg className=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z\" />\n              </svg>\n              Share\n            </button>\n\n            {/* Share panel — opens upward */}\n            {showShare && (\n              <div\n                className=\"absolute bottom-full mb-2 right-0 w-52 rounded-2xl overflow-hidden shadow-2xl border border-white/10\"\n                style={{ background: 'rgba(18,18,18,0.96)', backdropFilter: 'blur(16px)' }}\n              >\n                {/* Copy link row */}\n                <button\n                  onClick={handleCopyLink}\n                  className=\"w-full flex items-center gap-3 px-4 py-3 text-white/90 hover:bg-white/10 transition-colors duration-150 border-b border-white/10\"\n                  style={{ fontFamily: 'General Sans, sans-serif', fontSize: '13px' }}\n                >\n                  <span className=\"w-7 h-7 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0\">\n                    {copied ? (\n                      <svg className=\"w-4 h-4 text-green-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M5 13l4 4L19 7\" />\n                      </svg>\n                    ) : (\n                      <svg className=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1\" />\n                      </svg>\n                    )}\n                  </span>\n                  {copied ? 'Link copied!' : 'Copy link'}\n                </button>\n\n                {/* Social rows */}\n                {SOCIALS.map((social) => (\n                  <button\n                    key={social.key}\n                    onClick={() => handleSocialShare(social)}\n                    className=\"w-full flex items-center gap-3 px-4 py-3 text-white/90 hover:bg-white/10 transition-colors duration-150 last:rounded-b-2xl\"\n                    style={{ fontFamily: 'General Sans, sans-serif', fontSize: '13px' }}\n                  >\n                    <span\n                      className=\"w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-white\"\n                      style={{ background: social.color }}\n                    >\n                      {social.icon}\n                    </span>\n                    {(social as any).copyFallback ? `${social.label} (copy link)` : social.label}\n                  </button>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
