      "path": "src/components/Inspo/CategoryClient.tsx",
      "content": "// src/components/Inspo/CategoryClient.tsx\n'use client';\n\nimport { useState } from 'react';\nimport type { DesignData, DesignImage } from '@/types/inspo';\nimport type { BlogMetadata } from '@/types/blog';\nimport CategoryHero from './CategoryHero';\nimport MasonryGallery from './MasonryGallery';\nimport ImageModal from './ImageModal';\nimport InspoRelatedArticles from '@/components/Inspo/InspoRelatedArticles';\n\ninterface CategoryClientProps {\n  designData: DesignData;\n  initialImages: DesignImage[];\n  relatedDesigns: DesignData[];\n  faqs?: Array<{ question: string; answer: string }>;\n  relatedArticles?: { pillar: BlogMetadata; clusters: BlogMetadata[] } | null;\n}\n\nexport default function CategoryClient({\n  designData,\n  initialImages,\n  relatedDesigns,\n  faqs,\n  relatedArticles,\n}: CategoryClientProps) {\n  const [selectedImage, setSelectedImage] = useState<DesignImage | null>(null);\n\n  const handleNavigate = (direction: 'prev' | 'next') => {\n    if (!selectedImage) return;\n\n    const currentIndex = initialImages.findIndex(img => img.id === selectedImage.id);\n    let newIndex: number;\n\n    if (direction === 'prev') {\n      newIndex = currentIndex > 0 ? currentIndex - 1 : initialImages.length - 1;\n    } else {\n      newIndex = currentIndex < initialImages.length - 1 ? currentIndex + 1 : 0;\n    }\n\n    setSelectedImage(initialImages[newIndex]);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#f9fafb]\">\n      {/* Hero Section */}\n      <CategoryHero designData={designData} />\n\n      {/* Masonry Gallery */}\n      <MasonryGallery\n        images={initialImages}\n        onImageClick={setSelectedImage}\n      />\n\n      {/* Related Articles */}\n      {relatedArticles && (\n        <InspoRelatedArticles\n          pillar={relatedArticles.pillar}\n          clusters={relatedArticles.clusters}\n        />\n      )}\n\n      {/* Image Modal */}\n      <ImageModal\n        image={selectedImage}\n        images={initialImages}\n        onClose={() => setSelectedImage(null)}\n        onNavigate={handleNavigate}\n      />\n    </div>\n  );\n}"
    }
