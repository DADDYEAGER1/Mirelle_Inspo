      "path": "src/data/authors.ts",
      "content": "// src/data/authors.ts\n\nimport { Author } from '@/types/author';\n\nexport const authors: Author[] = [\n  {\n    slug: 'ri-mirelle',\n    name: 'Ri',\n    role: 'Co-Founder, Trend Researcher & Editorial Director',\n    bio: 'Ri leads research, content planning, and editorial direction at Mirellé Inspo. He tracks nail trends through Pinterest data, search analysis, and market research — and oversees the business and client side of the publication.',\n    longBio: 'Ri is the co-founder of Mirellé Inspo and the driving force behind its research and editorial operations. He tracks nail trends through Pinterest analytics, SEO and search data, and broader market research — turning raw data into content strategies and editorial direction. On the business side, he manages client content, trend reports, and topic planning. Ri built Mirellé on the belief that the nail space deserved a publication grounded in real research, not guesswork.',\n    image: '/images/team/ri-mirelle.webp',\n  },\n  {\n    slug: 'jyoti-mirelle',\n    name: 'Jyoti',\n    role: 'Co-Founder, Content Manager & Community Lead',\n    bio: 'Jyoti writes the content, manages Mirellé\\'s social media and Pinterest presence, and keeps the community at the center of everything. She is the voice behind the posts and the connection to the nail world.',\n    longBio: 'Jyoti is the co-founder of Mirellé Inspo and leads content creation, community engagement, and social media management. She writes the blogs, FAQs, work-nail guides, and spotlight features — bringing Ri\\'s research to life in a voice that resonates with the nail community. She manages Mirellé\\'s Pinterest presence and social channels, and stays closely connected to the audience that makes the publication worth building. Jyoti is the reason Mirellé feels human.',\n    image: '/images/team/jyoti-mirellee.webp',\n  },\n];"
