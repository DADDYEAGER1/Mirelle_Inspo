'use client';

// src/components/FooterClient.tsx
// "Latest from Mirellé"  collapsed by default on all screens.
// Uses native <details>/<summary> for guaranteed collapse behavior, no state bugs.

import Link from 'next/link';

interface FooterLink {
  title: string;
  url: string;
}

interface Props {
  blogs: FooterLink[];
  shop: FooterLink[];
  inspo: FooterLink[];
}

function LinkGrid({ links }: { links: FooterLink[] }) {
  return (
    <ul className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-2">
      {links.map((link) => (
        <li key={link.url}>
          <Link
            href={link.url}
            className="font-body text-[#f9fafb]/55 hover:text-[#f9fafb] transition-colors text-xs leading-snug block py-1 line-clamp-1"
          >
            {link.title}
          </Link>
        </li>
      ))}
    </ul>
  );
}

function SubSection({ title, links }: { title: string; links: FooterLink[] }) {
  return (
    <details className="group border-t border-[#f9fafb]/10">
      <summary className="w-full py-3 flex items-center justify-between text-left cursor-pointer list-none">
        <span className="font-ui text-xs uppercase tracking-widest text-[#f9fafb]/40">
          {title}
        </span>
        <svg
          className="w-4 h-4 transition-transform duration-200 group-open:rotate-180"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div className="pb-5">
        <LinkGrid links={links} />
      </div>
    </details>
  );
}

export default function FooterClient({ blogs, shop, inspo }: Props) {
  return (
    <details className="group mb-10 border-b border-[#f9fafb]/20 pb-10">
      <summary className="w-full py-4 flex items-center justify-between text-left cursor-pointer list-none">
        <h3 className="font-ui text-sm uppercase tracking-widest text-[#f9fafb]">
          Latest from Mirellé
        </h3>
        <svg
          className="w-4 h-4 transition-transform duration-200 group-open:rotate-180"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5} d="M19 9l-7 7-7-7" />
        </svg>
      </summary>

      <div className="mt-1">
        <SubSection title="Edits" links={blogs} />
        <SubSection title="Shop" links={shop} />
        <SubSection title="Inspo" links={inspo} />
      </div>
    </details>
  );
}
