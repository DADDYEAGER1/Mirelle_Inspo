      "path": "src/app/nail-encyclopedia/EncyclopediaClient.tsx",
      "content": "'use client';\n\n// src/app/nail-encyclopedia/EncyclopediaClient.tsx\n// Handles search, filter, sidebar navigation, and pagination  all in browser.\n// The heavy data work already happened on the server.\n\nimport { useState, useMemo, useRef, useCallback } from 'react';\nimport Link from 'next/link';\nimport { EncyclopediaSection, EncyclopediaEntry } from '@/lib/encyclopedia';\n\nexport const revalidate = false;\n\ninterface Props {\n  sections: EncyclopediaSection[];\n}\n\nconst CONTENT_TYPE_LABELS: Record<EncyclopediaEntry['contentType'], string> = {\n  blog: 'Guide',\n  faq: 'FAQ',\n  'work-nails': 'Work',\n  topic: 'Topic',\n  spotlight: 'Spotlight',\n};\n\nconst PAGE_SIZE = 20;\n\nexport default function EncyclopediaClient({ sections }: Props) {\n  const [query, setQuery] = useState('');\n  const [activeFilter, setActiveFilter] = useState<string>('all');\n  const [page, setPage] = useState(1);\n  const sectionRefs = useRef<Record<string, HTMLElement | null>>({});\n  const topRef = useRef<HTMLDivElement | null>(null);\n\n  const filterOptions = [\n    { value: 'all',        label: 'All'        },\n    { value: 'blog',       label: 'Guides'     },\n    { value: 'faq',        label: 'FAQs'       },\n    { value: 'work-nails', label: 'Work Nails' },\n    { value: 'topic',      label: 'Topics'     },\n    { value: 'spotlight',  label: 'Spotlights' },\n  ];\n\n  // All entries matching search + filter, flattened\n  const filteredEntries = useMemo(() => {\n    const q = query.toLowerCase().trim();\n    const entries: Array<{ entry: EncyclopediaEntry; sectionTitle: string }> = [];\n\n    for (const section of sections) {\n      for (const entry of section.entries) {\n        const matchesFilter = activeFilter === 'all' || entry.contentType === activeFilter;\n        const matchesQuery =\n          !q ||\n          entry.title.toLowerCase().includes(q) ||\n          entry.excerpt.toLowerCase().includes(q) ||\n          (entry.tags || []).some((tag) => tag.toLowerCase().includes(q));\n        if (matchesFilter && matchesQuery) {\n          entries.push({ entry, sectionTitle: section.title });\n        }\n      }\n    }\n\n    return entries;\n  }, [sections, query, activeFilter]);\n\n  // Sections visible in the sidebar (for search/filter awareness)\n  const filteredSections = useMemo(() => {\n    const q = query.toLowerCase().trim();\n    return sections\n      .map((section) => ({\n        ...section,\n        entries: section.entries.filter((entry) => {\n          const matchesFilter = activeFilter === 'all' || entry.contentType === activeFilter;\n          const matchesQuery =\n            !q ||\n            entry.title.toLowerCase().includes(q) ||\n            entry.excerpt.toLowerCase().includes(q) ||\n            (entry.tags || []).some((tag) => tag.toLowerCase().includes(q));\n          return matchesFilter && matchesQuery;\n        }),\n      }))\n      .filter((s) => s.entries.length > 0);\n  }, [sections, query, activeFilter]);\n\n  const totalEntries = filteredEntries.length;\n  const totalPages = Math.ceil(totalEntries / PAGE_SIZE);\n  const start = (page - 1) * PAGE_SIZE;\n  const visibleEntries = filteredEntries.slice(start, start + PAGE_SIZE);\n\n  const goTo = useCallback((p: number) => {\n    setPage(p);\n    topRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' });\n  }, []);\n\n  // Reset to page 1 when search or filter changes\n  function handleQueryChange(val: string) {\n    setQuery(val);\n    setPage(1);\n  }\n\n  function handleFilterChange(val: string) {\n    setActiveFilter(val);\n    setPage(1);\n  }\n\n  function scrollToSection(id: string) {\n    const el = sectionRefs.current[id];\n    if (el) {\n      const top = el.getBoundingClientRect().top + window.scrollY - 24;\n      window.scrollTo({ top, behavior: 'smooth' });\n    }\n  }\n\n  return (\n    <div ref={topRef} className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10\">\n\n      {/* Search */}\n      <div className=\"relative mb-6\">\n        <span className=\"absolute left-4 top-1/2 -translate-y-1/2 text-foreground/30 font-ui text-sm pointer-events-none\">\n          ↳\n        </span>\n        <input\n          type=\"search\"\n          value={query}\n          onChange={(e) => handleQueryChange(e.target.value)}\n          placeholder=\"Search any nail term, shape, technique or style…\"\n          className=\"w-full pl-9 pr-4 py-3 bg-background border border-foreground/15 font-ui text-sm text-foreground placeholder:text-foreground/30 focus:outline-none focus:border-foreground/40 transition-colors\"\n          aria-label=\"Search encyclopedia\"\n        />\n      </div>\n\n      {/* Filter tabs */}\n      <div className=\"flex flex-wrap gap-2 mb-8 border-b border-foreground/10 pb-6\">\n        {filterOptions.map((opt) => (\n          <button\n            key={opt.value}\n            onClick={() => handleFilterChange(opt.value)}\n            className={`font-ui text-xs tracking-wider uppercase px-4 py-2 border transition-colors ${\n              activeFilter === opt.value\n                ? 'border-foreground bg-foreground text-background'\n                : 'border-foreground/20 text-foreground/50 hover:border-foreground/50 hover:text-foreground'\n            }`}\n          >\n            {opt.label}\n          </button>\n        ))}\n        <span className=\"font-ui text-xs text-foreground/30 self-center ml-auto\">\n          {totalEntries} {totalEntries === 1 ? 'entry' : 'entries'}\n        </span>\n      </div>\n\n      {/* Two-column layout */}\n      <div className=\"flex gap-12 lg:gap-16 items-start\">\n\n        {/* Sidebar */}\n        <aside className=\"hidden lg:block w-48 flex-shrink-0 sticky top-8\">\n          <p className=\"font-ui text-xs tracking-widest uppercase text-foreground/30 mb-4\">\n            Sections\n          </p>\n          <nav aria-label=\"Encyclopedia sections\">\n            <ul className=\"space-y-1\">\n              {filteredSections.map((section) => (\n                <li key={section.id}>\n                  <button\n                    onClick={() => scrollToSection(section.id)}\n                    className=\"group w-full text-left font-ui text-xs text-foreground/50 hover:text-foreground transition-colors py-1 flex items-center justify-between gap-2\"\n                  >\n                    <span className=\"group-hover:underline underline-offset-2\">\n                      {section.title}\n                    </span>\n                    <span className=\"text-foreground/25 flex-shrink-0\">\n                      {section.entries.length}\n                    </span>\n                  </button>\n                </li>\n              ))}\n            </ul>\n          </nav>\n        </aside>\n\n        {/* Main content */}\n        <div className=\"flex-1 min-w-0\">\n          {totalEntries === 0 ? (\n            <div className=\"py-20 text-center\">\n              <p className=\"font-body text-lg text-foreground/40\">\n                No entries found for &ldquo;{query}&rdquo;\n              </p>\n              <button\n                onClick={() => { handleQueryChange(''); handleFilterChange('all'); }}\n                className=\"font-ui text-xs uppercase tracking-wider text-foreground/40 hover:text-foreground mt-4 underline underline-offset-2 transition-colors\"\n              >\n                Clear search\n              </button>\n            </div>\n          ) : (\n            <>\n              {/* Entry grid  flat, paginated */}\n              <div\n                className=\"grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-px bg-foreground/8\"\n                ref={(el) => {\n                  // attach section refs for sidebar scroll (first entry of each section)\n                  visibleEntries.forEach(({ entry, sectionTitle }) => {\n                    const id = sectionTitle.toLowerCase().replace(/\\s+/g, '-');\n                    if (!sectionRefs.current[id]) {\n                      sectionRefs.current[id] = el;\n                    }\n                  });\n                }}\n              >\n                {visibleEntries.map(({ entry }) => (\n                  <EntryCard key={entry.canonical} entry={entry} />\n                ))}\n              </div>\n\n              {/* Pagination */}\n              {totalPages > 1 && (\n                <div className=\"mt-16 flex flex-col items-center gap-6\">\n                  <div className=\"flex items-center gap-1\">\n\n                    {/* Prev */}\n                    <button\n                      onClick={() => goTo(page - 1)}\n                      disabled={page === 1}\n                      aria-label=\"Previous page\"\n                      className=\"w-9 h-9 flex items-center justify-center font-ui text-xs text-foreground/60 hover:text-foreground border border-foreground/20 hover:border-foreground transition-colors disabled:opacity-20 disabled:cursor-not-allowed\"\n                    >\n                      ←\n                    </button>\n\n                    {/* Page numbers */}\n                    {Array.from({ length: totalPages }, (_, i) => i + 1)\n                      .filter(p => p === 1 || p === totalPages || Math.abs(p - page) <= 2)\n                      .reduce<(number | 'ellipsis')[]>((acc, p, idx, arr) => {\n                        if (idx > 0 && p - (arr[idx - 1] as number) > 1) acc.push('ellipsis');\n                        acc.push(p);\n                        return acc;\n                      }, [])\n                      .map((item, idx) =>\n                        item === 'ellipsis' ? (\n                          <span\n                            key={`ellipsis-${idx}`}\n                            className=\"w-9 h-9 flex items-center justify-center font-ui text-xs text-foreground/30\"\n                          >\n                            ...\n                          </span>\n                        ) : (\n                          <button\n                            key={item}\n                            onClick={() => goTo(item as number)}\n                            aria-label={`Page ${item}`}\n                            aria-current={page === item ? 'page' : undefined}\n                            className={`w-9 h-9 flex items-center justify-center border font-ui text-xs transition-colors ${\n                              page === item\n                                ? 'border-foreground bg-foreground text-background'\n                                : 'border-foreground/20 text-foreground/60 hover:text-foreground hover:border-foreground'\n                            }`}\n                          >\n                            {item}\n                          </button>\n                        )\n                      )}\n\n                    {/* Next */}\n                    <button\n                      onClick={() => goTo(page + 1)}\n                      disabled={page === totalPages}\n                      aria-label=\"Next page\"\n                      className=\"w-9 h-9 flex items-center justify-center font-ui text-xs text-foreground/60 hover:text-foreground border border-foreground/20 hover:border-foreground transition-colors disabled:opacity-20 disabled:cursor-not-allowed\"\n                    >\n                      →\n                    </button>\n\n                  </div>\n\n                  {/* Count */}\n                  <p className=\"font-ui text-xs text-foreground/30\">\n                    {start + 1} to {Math.min(start + PAGE_SIZE, totalEntries)} of {totalEntries} entries\n                  </p>\n                </div>\n              )}\n            </>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n\n// Entry card  unchanged\nfunction EntryCard({ entry }: { entry: EncyclopediaEntry }) {\n  const label = CONTENT_TYPE_LABELS[entry.contentType];\n\n  return (\n    <Link\n      href={entry.canonical}\n      className=\"group block bg-background p-5 hover:bg-foreground/[0.02] transition-colors\"\n    >\n      <span className=\"font-ui text-xs tracking-widest uppercase text-foreground/30 block mb-2\">\n        {label}\n      </span>\n      <h3 className=\"font-heading text-lg text-foreground leading-snug mb-3 group-hover:opacity-70 transition-opacity\">\n        {entry.title}\n      </h3>\n      {entry.excerpt && (\n        <p className=\"font-body text-sm text-foreground/55 leading-relaxed line-clamp-3 mb-4\">\n          {entry.excerpt}\n        </p>\n      )}\n      <span className=\"font-ui text-xs uppercase tracking-wider text-foreground/30 group-hover:text-foreground transition-colors\">\n        Read →\n      </span>\n    </Link>\n  );\n}"
    }
  ],
