      "path": "src/app/nail-encyclopedia/page.tsx",
      "content": "// src/app/nail-encyclopedia/page.tsx\n// Server component  all data reading happens at build time, zero runtime cost.\n\nimport { getEncyclopediaData, EncyclopediaEntry, EncyclopediaSection } from '@/lib/encyclopedia';\nimport type { Metadata } from 'next';\nimport Link from 'next/link';\nimport EncyclopediaClient from './EncyclopediaClient';\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\nexport const metadata: Metadata = {\n  title: 'The Nail Encyclopedia  Every Shape, Technique & Style | Mirellé',\n  description:\n    'The complete nail reference  every shape, technique, aesthetic, colour, occasion and care guide on Mirellé in one place. Your starting point for wherever you want to go.',\n  alternates: {\n    canonical: 'https://mirelleinspo.com/nail-encyclopedia',\n  },\n  openGraph: {\n    title: 'The Nail Encyclopedia | Mirellé',\n    description:\n      'Every nail shape, technique, aesthetic, colour guide and FAQ on Mirellé  one page, everything linked.',\n    url: 'https://mirelleinspo.com/nail-encyclopedia',\n    siteName: 'Mirellé',\n    type: 'website',\n  },\n  twitter: {\n    card: 'summary_large_image',\n    title: 'The Nail Encyclopedia | Mirellé',\n    description: 'Every nail topic on Mirellé in one place.',\n    site: '@mirelleinspo',\n  },\n};\n\nexport default function NailEncyclopediaPage() {\n  const data = getEncyclopediaData();\n\n  // Schema  DefinedTermSet tells Google + AI agents this is a structured knowledge base\n  const schemaDefinedTermSet = {\n    '@context': 'https://schema.org',\n    '@type': 'DefinedTermSet',\n    '@id': 'https://mirelleinspo.com/nail-encyclopedia',\n    name: 'The Mirellé Nail Encyclopedia',\n    description:\n      'A comprehensive reference of nail shapes, techniques, aesthetics, colours, occasions and care guides curated by the Mirellé editorial team.',\n    url: 'https://mirelleinspo.com/nail-encyclopedia',\n    publisher: {\n      '@type': 'Organization',\n      name: 'Mirellé',\n      url: 'https://mirelleinspo.com',\n    },\n    hasDefinedTerm: data.sections.flatMap((section) =>\n      section.entries.map((entry) => ({\n        '@type': 'DefinedTerm',\n        name: entry.title,\n        description: entry.excerpt,\n        url: entry.canonical,\n        inDefinedTermSet: 'https://mirelleinspo.com/nail-encyclopedia',\n      }))\n    ),\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },\n      {\n        '@type': 'ListItem',\n        position: 2,\n        name: 'Nail Encyclopedia',\n        item: 'https://mirelleinspo.com/nail-encyclopedia',\n      },\n    ],\n  };\n\n  return (\n    <>\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemaDefinedTermSet) }}\n      />\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }}\n      />\n\n      <main className=\"min-h-screen bg-background\">\n        {/* ── Breadcrumb ── */}\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6\">\n          <nav aria-label=\"Breadcrumb\">\n            <ol className=\"flex items-center gap-2 font-ui text-xs text-foreground/50\">\n              <li>\n                <Link href=\"/\" className=\"hover:text-foreground transition-colors\">\n                  Home\n                </Link>\n              </li>\n              <li>/</li>\n              <li className=\"text-foreground\">Nail Encyclopedia</li>\n            </ol>\n          </nav>\n        </div>\n\n        {/* ── Hero ── */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20\">\n            <span className=\"font-ui text-xs tracking-widest uppercase text-foreground/40 block mb-4\">\n              Mirellé · Complete Reference\n            </span>\n            <h1 className=\"font-heading text-5xl md:text-6xl lg:text-7xl text-foreground mb-5 leading-none\">\n              The Nail Encyclopedia\n            </h1>\n            <p className=\"font-body text-lg md:text-xl text-foreground/60 max-w-2xl leading-relaxed mb-10\">\n              Every shape, technique, aesthetic, colour and care guide  with everything we've\n              written about it. Your starting point for wherever you want to go.\n            </p>\n\n            {/* Stats */}\n            <div className=\"flex flex-wrap gap-10\">\n              <div>\n                <p className=\"font-heading text-3xl text-foreground\">{data.totalEntries}+</p>\n                <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1\">\n                  Articles & guides\n                </p>\n              </div>\n              <div>\n                <p className=\"font-heading text-3xl text-foreground\">{data.totalSections}</p>\n                <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1\">\n                  Sections\n                </p>\n              </div>\n              <div>\n                <p className=\"font-heading text-3xl text-foreground\">{data.imageCount.toLocaleString()}+</p>\n                <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1\">\n                  Inspo images\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {/* ── Body: sidebar + content (client handles search/filter) ── */}\n        <EncyclopediaClient sections={data.sections} />\n      </main>\n    </>\n  );\n}"
