      "path": "src/components/Homepage/TrendTimelineHero.tsx",
      "content": "'use client';\n\nimport { useState, useEffect, useRef, useCallback } from 'react';\nimport Image from 'next/image';\nimport Link from 'next/link';\n\n// ─── TYPE DEFINITIONS ───────────────────────────────────────────────────────\n\ninterface BlogPost {\n  slug: string;\n  title: string;\n  excerpt: string;\n  image: string | null;\n  date: string;\n  readTime: string;\n}\n\ninterface InspoImage {\n  src: string;\n  alt: string;\n}\n\ninterface TimelineEventDef {\n  id: string;\n  name: string;\n  date: string;        // ISO date  used to compute status at runtime\n  seasonLabel: string; // e.g. \"Spring '26\"\n  isMajor: boolean;\n  desc: string;\n  editSlug: string | null;\n  gallerySlug: string | null;\n}\n\n// Runtime-enriched version with computed status\ninterface TimelineEvent extends TimelineEventDef {\n  status: 'past' | 'now' | 'upcoming';\n  season: string;      // alias for seasonLabel kept for JSX compat\n}\n\ntype CardType = 'edit' | 'gallery' | null;\n\n// ─── RAW EVENT DEFINITIONS (no hardcoded status) ─────────────────────────────\n\nconst EVENT_DEFS: TimelineEventDef[] = [\n  {\n    id: 'nye-recap',\n    name: 'NYE Recap',\n    date: '2026-01-01',\n    seasonLabel: \"Winter '26\",\n    isMajor: false,\n    desc: 'The glitter has settled. Here are the nail looks that defined the countdown.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'valentines',\n    name: \"Valentine's Day\",\n    date: '2026-02-14',\n    seasonLabel: \"Winter '26\",\n    isMajor: false,\n    desc: 'Love in every layer. The softest reds, jelly hearts, and velvet finishes.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'st-patricks',\n    name: \"St. Patrick's\",\n    date: '2026-03-17',\n    seasonLabel: \"Spring '26\",\n    isMajor: false,\n    desc: 'Lucky greens, clover art, and the shimmer of something rare.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'easter',\n    name: 'Easter',\n    date: '2026-04-05',\n    seasonLabel: \"Spring '26\",\n    isMajor: false,\n    desc: 'Pastel eggs, speckled finishes, and the return of soft everything.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'spring',\n    name: 'Spring Season',\n    date: '2026-03-20',\n    seasonLabel: \"Spring '26\",\n    isMajor: true,\n    desc: 'The season of bloom, soap nails, and everything softly luminous. Spring is having its moment.',\n    editSlug: 'spring-nail-ideas',\n    gallerySlug: 'spring-nails-2026',\n  },\n  {\n    id: 'mothers-day',\n    name: \"Mother's Day\",\n    date: '2026-05-10',\n    seasonLabel: \"Spring '26\",\n    isMajor: false,\n    desc: 'Floral, feminine, and forever elegant. Nail looks made for the women who raised us.',\n    editSlug: 'mothers-day-nail-ideas',\n    gallerySlug: 'mothers-day-nails-2026',\n  },\n  {\n    id: 'prom',\n    name: 'Prom / Grad',\n    date: '2026-05-01',\n    seasonLabel: \"Spring '26\",\n    isMajor: false,\n    desc: 'Your night, your nails. Glamour that photographs perfectly.',\n    editSlug: 'prom-nails-2026',\n    gallerySlug: 'prom-nails-2026',\n  },\n  {\n    id: 'wedding',\n    name: 'Wedding Season',\n    date: '2026-06-01',\n    seasonLabel: \"Summer '26\",\n    isMajor: false,\n    desc: 'Something borrowed, something blue and nails that make the photos.',\n    editSlug: 'wedding-nail-ideas',\n    gallerySlug: 'wedding-nails-inspiration-gallery',\n  },\n  {\n    id: 'pride',\n    name: 'Pride',\n    date: '2026-06-01',\n    seasonLabel: \"Summer '26\",\n    isMajor: false,\n    desc: 'Bold, joyful, and unapologetically expressive. Every color has its moment.',\n    editSlug: 'pride-month-nails',\n    gallerySlug: 'lgbtq-inspiration-gallery',\n  },\n  {\n    id: 'summer',\n    name: 'Summer Season',\n    date: '2026-06-21',\n    seasonLabel: \"Summer '26\",\n    isMajor: true,\n    desc: 'Sun-drenched hues, jelly textures, and the nails that go everywhere this summer.',\n    editSlug: 'summer-nail-trends-2026',\n    gallerySlug: 'summer-nails-2026',\n  },\n  {\n    id: '4th-july',\n    name: '4th of July',\n    date: '2026-07-04',\n    seasonLabel: \"Summer '26\",\n    isMajor: false,\n    desc: 'Red, white, and glossy. Stars, stripes, and the perfect summer red.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'back-school',\n    name: 'Back to School',\n    date: '2026-08-01',\n    seasonLabel: \"Summer '26\",\n    isMajor: false,\n    desc: 'Fresh start energy. Clean nails, bold statements, and back-to-basics cool.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'fall',\n    name: 'Fall Season',\n    date: '2026-09-22',\n    seasonLabel: \"Fall '26\",\n    isMajor: true,\n    desc: 'Burgundy, chocolate, moody plums. The richest season for nail colour has arrived.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'halloween',\n    name: 'Halloween',\n    date: '2026-10-31',\n    seasonLabel: \"Fall '26\",\n    isMajor: false,\n    desc: 'Dark, dramatic, and deliciously spooky. The one night nails go all out.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'thanksgiving',\n    name: 'Thanksgiving',\n    date: '2026-11-26',\n    seasonLabel: \"Fall '26\",\n    isMajor: false,\n    desc: 'Warm tones, harvest hues, and nails as cozy as the season.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'christmas',\n    name: 'Christmas',\n    date: '2026-12-25',\n    seasonLabel: \"Winter '26\",\n    isMajor: false,\n    desc: 'The most magical nail season of the year. Velvet, plaid, and holiday chrome.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n  {\n    id: 'nye-26',\n    name: \"NYE '26\",\n    date: '2026-12-31',\n    seasonLabel: \"Winter '26\",\n    isMajor: false,\n    desc: 'End the year with your best nails yet. Glitter, gold, and midnight magic.',\n    editSlug: null,\n    gallerySlug: null,\n  },\n];\n\n// ─── RUNTIME STATUS COMPUTATION ──────────────────────────────────────────────\n// Status is never hardcoded  computed fresh from today's date every call.\n// \"now\" = the closest future-or-present major event, or the nearest event overall.\n// Everything before it = 'past', everything after = 'upcoming'.\n\nfunction computeEvents(): TimelineEvent[] {\n  const now = Date.now();\n  let nowId: string | null = null;\n\n  // Sort a copy by date ascending so we can reason about time ordering\n  const byDate = [...EVENT_DEFS].sort((a, b) =>\n    new Date(a.date).getTime() - new Date(b.date).getTime()\n  );\n\n  // Step 1: Among all events whose date has already passed, find the one that\n  // is most \"current\"  prefer the most recent MAJOR event first,\n  // then fall back to the single most recent event of any kind.\n  const WINDOW_MS = 90 * 24 * 60 * 60 * 1000; // 90-day lookback window\n  const pastInWindow = byDate.filter((e) => {\n    const t = new Date(e.date).getTime();\n    return t <= now && now - t <= WINDOW_MS;\n  });\n\n  const THREE_DAYS_MS = 3 * 24 * 60 * 60 * 1000;\n\n  // If the very next upcoming event is within 3 days, promote it to \"now\"\n  // so the timeline switches ahead of time rather than waiting for the date to pass.\n  const nextEvent = byDate.find((e) => new Date(e.date).getTime() > now);\n  const nextIsImminent =\n    nextEvent !== undefined &&\n    new Date(nextEvent.date).getTime() - now <= THREE_DAYS_MS;\n\n  if (nextIsImminent && nextEvent) {\n    nowId = nextEvent.id;\n  } else if (pastInWindow.length > 0) {\n    // Most recent major takes priority; fall back to most recent overall\n    nowId = pastInWindow[pastInWindow.length - 1].id;\n  } else {\n    // Nothing in the lookback window  pick the next upcoming event\n    const future = byDate.filter((e) => new Date(e.date).getTime() > now);\n    nowId = future.length > 0\n      ? future[0].id\n      : EVENT_DEFS[EVENT_DEFS.length - 1].id;\n  }\n\n  // Assign status: everything before nowId in the original array = past,\n  // nowId = now, everything after = upcoming.\n    return EVENT_DEFS.map((def) => {\n      let status: 'past' | 'now' | 'upcoming';\n      if (def.id === nowId) {\n        status = 'now';\n      } else if (new Date(def.date).getTime() <= Date.now()) {\n        status = 'past';\n      } else {\n        status = 'upcoming';\n      }\n      return { ...def, status, season: def.seasonLabel };\n    });\n}\n\n// ─── HELPERS ─────────────────────────────────────────────────────────────────\n\nfunction getTimeUntil(dateStr: string) {\n  const target = new Date(dateStr).getTime();\n  const now = Date.now();\n  const diff = Math.max(0, target - now);\n  const weeks = Math.floor(diff / (1000 * 60 * 60 * 24 * 7));\n  const days = Math.floor((diff % (1000 * 60 * 60 * 24 * 7)) / (1000 * 60 * 60 * 24));\n  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n  const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));\n  const secs = Math.floor((diff % (1000 * 60)) / 1000);\n  return { weeks, days, hours, mins, secs };\n}\n\n// FIX: Past events with slugs are always accessible.\n// Upcoming/now events need content AND be within 30 days.\nfunction isCardAccessible(event: TimelineEvent): boolean {\n  const hasContent = event.editSlug !== null || event.gallerySlug !== null;\n  if (!hasContent) return false;\n  if (event.status === 'past') return true; // past content is always accessible\n  if (event.status === 'now') return true;\n  // upcoming: only within 30-day window\n  const target = new Date(event.date).getTime();\n  const diff = target - Date.now();\n  const thirtyDays = 30 * 24 * 60 * 60 * 1000;\n  return diff <= thirtyDays;\n}\n\nfunction getSeasonGroups(events: TimelineEvent[]) {\n  const groups: { season: string; events: TimelineEvent[] }[] = [];\n  events.forEach((ev) => {\n    const last = groups[groups.length - 1];\n    if (last && last.season === ev.season) {\n      last.events.push(ev);\n    } else {\n      groups.push({ season: ev.season, events: [ev] });\n    }\n  });\n  return groups;\n}\n\n// ─── SUB-COMPONENTS ──────────────────────────────────────────────────────────\n\n// FIX: key prop on CountdownTimer forces full remount on event change,\n// so each event gets its own independent interval  no bleed-over, no zeroing out.\nfunction CountdownTimer({ dateStr, timerKey }: { dateStr: string; timerKey: string }) {\n  const [time, setTime] = useState(() => getTimeUntil(dateStr));\n\n  // Reset immediately when dateStr changes (belt-and-suspenders alongside key)\n  useEffect(() => {\n    setTime(getTimeUntil(dateStr));\n    const id = setInterval(() => setTime(getTimeUntil(dateStr)), 1000);\n    return () => clearInterval(id);\n  }, [dateStr]);\n\n  const units = [\n    { label: 'Weeks', value: time.weeks },\n    { label: 'Days', value: time.days },\n    { label: 'Hours', value: time.hours },\n    { label: 'Min', value: time.mins },\n    { label: 'Sec', value: time.secs },\n  ];\n\n  return (\n    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '0', marginTop: '28px' }}>\n      {units.map((u, i) => (\n        <div key={u.label} style={{ display: 'flex', alignItems: 'center' }}>\n          <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', padding: '0 16px' }}>\n            <span style={{\n              fontFamily: 'var(--font-ui)',\n              fontSize: 'clamp(22px, 3vw, 36px)',\n              fontWeight: 400,\n              letterSpacing: '-0.02em',\n              color: 'var(--foreground)',\n              fontVariantNumeric: 'tabular-nums',\n              lineHeight: 1,\n            }}>\n              {String(u.value).padStart(2, '0')}\n            </span>\n            <span style={{\n              fontFamily: 'var(--font-ui)',\n              fontSize: '9px',\n              letterSpacing: '0.12em',\n              textTransform: 'uppercase',\n              color: 'var(--foreground)',\n              opacity: 0.35,\n              marginTop: '5px',\n            }}>\n              {u.label}\n            </span>\n          </div>\n          {i < units.length - 1 && (\n            <span style={{ color: 'var(--foreground)', opacity: 0.15, fontSize: '20px', userSelect: 'none' }}>|</span>\n          )}\n        </div>\n      ))}\n    </div>\n  );\n}\n\nfunction EventCards({\n  event,\n  onCardClick,\n}: {\n  event: TimelineEvent;\n  onCardClick: (type: CardType) => void;\n}) {\n  const accessible = isCardAccessible(event);\n\n  const cards = [\n    { type: 'edit' as CardType, label: 'The Edit', hasSlug: !!event.editSlug },\n    { type: 'gallery' as CardType, label: 'Inspo Gallery', hasSlug: !!event.gallerySlug },\n  ];\n\n  return (\n    <div style={{\n      display: 'flex',\n      gap: '12px',\n      justifyContent: 'center',\n      marginTop: '32px',\n    }}>\n      {cards.map(({ type, label, hasSlug }) => {\n        const clickable = accessible && hasSlug;\n        return (\n          <button\n            key={type}\n            onClick={() => clickable && onCardClick(type)}\n            disabled={!clickable}\n            style={{\n              fontFamily: 'var(--font-ui)',\n              fontSize: '10px',\n              letterSpacing: '0.14em',\n              textTransform: 'uppercase',\n              padding: '11px 28px',\n              border: `1px solid ${clickable ? 'rgba(37,34,32,0.45)' : 'rgba(37,34,32,0.15)'}`,\n              background: 'transparent',\n              color: clickable ? 'var(--foreground)' : 'rgba(37,34,32,0.25)',\n              cursor: clickable ? 'pointer' : 'not-allowed',\n              borderRadius: '2px',\n              transition: 'border-color 220ms ease, background 220ms ease',\n            }}\n            onMouseEnter={(e) => {\n              if (clickable) {\n                (e.currentTarget as HTMLButtonElement).style.borderColor = 'var(--foreground)';\n                (e.currentTarget as HTMLButtonElement).style.background = 'rgba(37,34,32,0.04)';\n              }\n            }}\n            onMouseLeave={(e) => {\n              if (clickable) {\n                (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(37,34,32,0.45)';\n                (e.currentTarget as HTMLButtonElement).style.background = 'transparent';\n              }\n            }}\n          >\n            {/* FIX: Past events with content never show \"Coming Soon\" */}\n            {!accessible ? 'Coming Soon' : label}\n          </button>\n        );\n      })}\n    </div>\n  );\n}\n\n// ─── SHARED PORTRAIT CARD ────────────────────────────────────────────────────\n\nfunction PortraitCard({\n  href,\n  imageSrc,\n  imageAlt,\n  title,\n  readTime,\n  onClick,\n}: {\n  href?: string;\n  imageSrc: string | null;\n  imageAlt: string;\n  title?: string;\n  readTime?: string;\n  onClick?: () => void;\n}) {\n  const cardStyle: React.CSSProperties = {\n    flexShrink: 0,\n    position: 'relative',\n    overflow: 'hidden',\n    borderRadius: '4px',\n    background: 'rgba(37,34,32,0.05)',\n    border: '1px solid rgba(37,34,32,0.08)',\n    transition: 'border-color 220ms ease, transform 220ms ease',\n    cursor: href || onClick ? 'pointer' : 'default',\n    display: 'block',\n    textDecoration: 'none',\n    color: 'inherit',\n    width: '100%',\n    height: '100%',\n  };\n\n  const inner = (\n    <>\n      {imageSrc && (\n        <Image\n          src={imageSrc}\n          alt={imageAlt}\n          fill\n          style={{ objectFit: 'cover' }}\n          sizes=\"(max-width: 768px) 45vw, 22vw\"\n        />\n      )}\n      {title && (\n        <div style={{\n          position: 'absolute',\n          bottom: 0,\n          left: 0,\n          right: 0,\n          padding: '40px 14px 14px',\n          background: 'linear-gradient(to top, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.6) 55%, transparent 100%)',\n        }}>\n          <p style={{\n            fontFamily: 'var(--font-body)',\n            fontSize: 'clamp(11px, 1.4vw, 13px)',\n            lineHeight: 1.4,\n            color: '#1a1816',\n            margin: 0,\n            fontWeight: 500,\n          }}>\n            {title}\n          </p>\n          {readTime && (\n            <span style={{\n              fontFamily: 'var(--font-ui)',\n              fontSize: '8px',\n              letterSpacing: '0.1em',\n              textTransform: 'uppercase',\n              color: '#1a1816',\n              opacity: 0.5,\n              marginTop: '4px',\n              display: 'block',\n            }}>\n              {readTime}\n            </span>\n          )}\n        </div>\n      )}\n    </>\n  );\n\n  const hoverHandlers = {\n    onMouseEnter: (e: React.MouseEvent<HTMLElement>) => {\n      (e.currentTarget as HTMLElement).style.borderColor = 'rgba(37,34,32,0.3)';\n      (e.currentTarget as HTMLElement).style.transform = 'translateY(-2px)';\n    },\n    onMouseLeave: (e: React.MouseEvent<HTMLElement>) => {\n      (e.currentTarget as HTMLElement).style.borderColor = 'rgba(37,34,32,0.08)';\n      (e.currentTarget as HTMLElement).style.transform = 'translateY(0)';\n    },\n  };\n\n  if (href) {\n    return (\n      <Link href={href} style={cardStyle} {...hoverHandlers}>\n        {inner}\n      </Link>\n    );\n  }\n\n  return (\n    <div style={cardStyle} onClick={onClick} {...hoverHandlers}>\n      {inner}\n    </div>\n  );\n}\n\n// ─── SHARED CAROUSEL GRID ────────────────────────────────────────────────────\n\nfunction CarouselGrid({ children }: { children: React.ReactNode }) {\n  const scrollRef = useRef<HTMLDivElement>(null);\n  const isDragging = useRef(false);\n  const startX = useRef(0);\n  const scrollLeft = useRef(0);\n\n  const onMouseDown = (e: React.MouseEvent) => {\n    isDragging.current = true;\n    startX.current = e.pageX - (scrollRef.current?.offsetLeft ?? 0);\n    scrollLeft.current = scrollRef.current?.scrollLeft ?? 0;\n  };\n  const onMouseMove = (e: React.MouseEvent) => {\n    if (!isDragging.current || !scrollRef.current) return;\n    e.preventDefault();\n    const x = e.pageX - scrollRef.current.offsetLeft;\n    scrollRef.current.scrollLeft = scrollLeft.current - (x - startX.current) * 1.2;\n  };\n  const stopDrag = () => { isDragging.current = false; };\n\n  return (\n    <>\n      <style>{`\n        .carousel-scroll {\n          overflow-x: auto;\n          overflow-y: hidden;\n          scrollbar-width: none;\n          cursor: grab;\n          user-select: none;\n          height: 100%;\n          display: flex;\n          align-items: center;\n          padding: 0 48px 0 16px;\n        }\n        .carousel-grid {\n          display: grid;\n          grid-auto-flow: column;\n          grid-template-rows: calc((100vh - 174px) * 0.80);\n          gap: 10px;\n          align-items: center;\n          height: 100%;\n        }\n        .carousel-card-wrap {\n          height: 100%;\n          width: calc((100vh - 174px) * 0.80 * 0.75);\n          flex-shrink: 0;\n        }\n        @media (min-width: 768px) {\n          .carousel-scroll {\n            padding: 0 24px;\n            align-items: stretch;\n          }\n          .carousel-grid {\n            grid-template-rows: 1fr 1fr;\n            align-items: start;\n          }\n          .carousel-card-wrap {\n            height: 100%;\n            width: clamp(140px, 18vw, 220px);\n          }\n        }\n      `}</style>\n      <div\n        ref={scrollRef}\n        className=\"carousel-scroll\"\n        onMouseDown={onMouseDown}\n        onMouseMove={onMouseMove}\n        onMouseUp={stopDrag}\n        onMouseLeave={stopDrag}\n      >\n        <div\n          className=\"carousel-grid\"\n          style={{ minWidth: 'max-content', padding: '8px 0' }}\n        >\n          {children}\n        </div>\n      </div>\n    </>\n  );\n}\n\n// ─── THE EDIT CAROUSEL ───────────────────────────────────────────────────────\n\nfunction EditCarousel({ editSlug, onBack }: { editSlug: string; onBack: () => void }) {\n  const [posts, setPosts] = useState<BlogPost[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    setLoading(true);\n    fetch(`/api/timeline/blog-cluster?pillar=${editSlug}`)\n      .then((r) => r.json())\n      .then((data) => setPosts(data.posts || []))\n      .catch(() => setPosts([]))\n      .finally(() => setLoading(false));\n  }, [editSlug]);\n\n  return (\n    <div style={{ width: '100%', height: '100%', display: 'flex', flexDirection: 'column', position: 'relative' }}>\n      <div style={{ flexShrink: 0, padding: '14px 24px 10px', display: 'flex', alignItems: 'center' }}>\n        <button\n          onClick={onBack}\n          style={{\n            fontFamily: 'var(--font-ui)', fontSize: '10px', letterSpacing: '0.12em',\n            textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.5,\n            background: 'none', border: 'none', cursor: 'pointer',\n            display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 0',\n            transition: 'opacity 200ms',\n          }}\n          onMouseEnter={(e) => { (e.currentTarget as HTMLButtonElement).style.opacity = '1'; }}\n          onMouseLeave={(e) => { (e.currentTarget as HTMLButtonElement).style.opacity = '0.5'; }}\n        >\n          ← The Edit\n        </button>\n      </div>\n      <div style={{ flex: 1, minHeight: 0 }}>\n        <CarouselGrid>\n          {loading ? (\n            Array.from({ length: 6 }).map((_, i) => (\n              <div key={i} className=\"carousel-card-wrap\" style={{ borderRadius: '4px', background: 'rgba(37,34,32,0.05)', border: '1px solid rgba(37,34,32,0.06)', opacity: 0.4 }} />\n            ))\n          ) : posts.length === 0 ? (\n            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', width: '80vw', opacity: 0.35 }}>\n              <span style={{ fontFamily: 'var(--font-ui)', fontSize: '10px', letterSpacing: '0.14em', textTransform: 'uppercase' }}>No posts found</span>\n            </div>\n          ) : (\n            posts.map((post) => (\n              <div key={post.slug} className=\"carousel-card-wrap\">\n                <PortraitCard href={`/blog/${post.slug}`} imageSrc={post.image} imageAlt={post.title} title={post.title} readTime={post.readTime} />\n              </div>\n            ))\n          )}\n        </CarouselGrid>\n      </div>\n    </div>\n  );\n}\n\n// ─── INSPO GALLERY CAROUSEL ──────────────────────────────────────────────────\n\nfunction InspoGalleryCarousel({ gallerySlug, onBack }: { gallerySlug: string; onBack: () => void }) {\n  const [images, setImages] = useState<InspoImage[]>([]);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    setLoading(true);\n    fetch(`/api/timeline/inspo-images?slug=${gallerySlug}`)\n      .then((r) => r.json())\n      .then((data) => setImages(data.images || []))\n      .catch(() => setImages([]))\n      .finally(() => setLoading(false));\n  }, [gallerySlug]);\n\n  return (\n    <div style={{ width: '100%', height: '100%', display: 'flex', flexDirection: 'column', position: 'relative' }}>\n      <div style={{ flexShrink: 0, padding: '14px 24px 10px', display: 'flex', alignItems: 'center' }}>\n        <button\n          onClick={onBack}\n          style={{\n            fontFamily: 'var(--font-ui)', fontSize: '10px', letterSpacing: '0.12em',\n            textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.5,\n            background: 'none', border: 'none', cursor: 'pointer',\n            display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 0',\n            transition: 'opacity 200ms',\n          }}\n          onMouseEnter={(e) => { (e.currentTarget as HTMLButtonElement).style.opacity = '1'; }}\n          onMouseLeave={(e) => { (e.currentTarget as HTMLButtonElement).style.opacity = '0.5'; }}\n        >\n          ← Inspo Gallery\n        </button>\n      </div>\n      <div style={{ flex: 1, minHeight: 0 }}>\n        <CarouselGrid>\n          {loading ? (\n            Array.from({ length: 6 }).map((_, i) => (\n              <div key={i} className=\"carousel-card-wrap\" style={{ borderRadius: '4px', background: 'rgba(37,34,32,0.05)', border: '1px solid rgba(37,34,32,0.06)', opacity: 0.4 }} />\n            ))\n          ) : images.length === 0 ? (\n            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', width: '80vw', opacity: 0.35 }}>\n              <span style={{ fontFamily: 'var(--font-ui)', fontSize: '10px', letterSpacing: '0.14em', textTransform: 'uppercase' }}>No images found</span>\n            </div>\n          ) : (\n            <>\n              {images.map((img, i) => (\n                <div key={i} className=\"carousel-card-wrap\">\n                  <PortraitCard imageSrc={img.src} imageAlt={img.alt || 'Inspo'} />\n                </div>\n              ))}\n              <div className=\"carousel-card-wrap\">\n                <Link\n                  href={`/inspo/${gallerySlug}`}\n                  style={{\n                    display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center',\n                    width: '100%', height: '100%', border: '1px dashed rgba(37,34,32,0.22)',\n                    borderRadius: '4px', textDecoration: 'none',\n                    transition: 'border-color 220ms ease, background 220ms ease', gap: '8px',\n                  }}\n                  onMouseEnter={(e) => {\n                    (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(37,34,32,0.5)';\n                    (e.currentTarget as HTMLAnchorElement).style.background = 'rgba(37,34,32,0.02)';\n                  }}\n                  onMouseLeave={(e) => {\n                    (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(37,34,32,0.22)';\n                    (e.currentTarget as HTMLAnchorElement).style.background = 'transparent';\n                  }}\n                >\n                  <span style={{ fontFamily: 'var(--font-ui)', fontSize: '16px', opacity: 0.3, color: 'var(--foreground)' }}>→</span>\n                  <span style={{ fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.14em', textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.4, textAlign: 'center', padding: '0 12px' }}>\n                    View Full Gallery\n                  </span>\n                </Link>\n              </div>\n            </>\n          )}\n        </CarouselGrid>\n      </div>\n    </div>\n  );\n}\n\n// ─── TIMELINE TRACK ──────────────────────────────────────────────────────────\n\nfunction TimelineTrack({\n  events,\n  selectedId,\n  onSelect,\n}: {\n  events: TimelineEvent[];\n  selectedId: string;\n  onSelect: (ev: TimelineEvent) => void;\n}) {\n  const trackRef = useRef<HTMLDivElement>(null);\n  const isDragging = useRef(false);\n  const startX = useRef(0);\n  const scrollLeft = useRef(0);\n\n  // FIX: scroll to \"now\" event whenever events array recomputes (e.g. status changes mid-session)\n  useEffect(() => {\n    const nowIdx = events.findIndex((e) => e.status === 'now');\n    if (nowIdx < 0 || !trackRef.current) return;\n    const el = trackRef.current.querySelector(`[data-event-id=\"${events[nowIdx].id}\"]`) as HTMLElement;\n    if (el) {\n      const containerW = trackRef.current.offsetWidth;\n      trackRef.current.scrollLeft = el.offsetLeft - containerW / 2 + el.offsetWidth / 2;\n    }\n  }, [events]);\n\n  const onMouseDown = (e: React.MouseEvent) => {\n    isDragging.current = true;\n    startX.current = e.pageX - (trackRef.current?.offsetLeft ?? 0);\n    scrollLeft.current = trackRef.current?.scrollLeft ?? 0;\n  };\n  const onMouseMove = (e: React.MouseEvent) => {\n    if (!isDragging.current || !trackRef.current) return;\n    e.preventDefault();\n    const x = e.pageX - trackRef.current.offsetLeft;\n    trackRef.current.scrollLeft = scrollLeft.current - (x - startX.current) * 1.2;\n  };\n  const stopDrag = () => { isDragging.current = false; };\n\n  // FIX: nowIdx is derived from computed events, not hardcoded\n  const nowIdx = events.findIndex((e) => e.status === 'now');\n  const progressRatio = nowIdx >= 0 ? (nowIdx + 0.5) / events.length : 0;\n  const seasonGroups = getSeasonGroups(events);\n\n  return (\n    <div style={{\n      position: 'relative',\n      height: '130px',\n      borderTop: '1px solid rgba(37,34,32,0.10)',\n      background: 'var(--background)',\n      overflow: 'hidden',\n    }}>\n      <div style={{ position: 'absolute', left: 0, top: 0, bottom: 0, width: '80px', background: 'linear-gradient(to right, var(--background), transparent)', zIndex: 3, pointerEvents: 'none' }} />\n      <div style={{ position: 'absolute', right: 0, top: 0, bottom: 0, width: '80px', background: 'linear-gradient(to left, var(--background), transparent)', zIndex: 3, pointerEvents: 'none' }} />\n\n      <div\n        ref={trackRef}\n        onMouseDown={onMouseDown}\n        onMouseMove={onMouseMove}\n        onMouseUp={stopDrag}\n        onMouseLeave={stopDrag}\n        style={{\n          overflowX: 'auto', overflowY: 'hidden', height: '100%',\n          scrollbarWidth: 'none', cursor: 'grab', userSelect: 'none', position: 'relative',\n        }}\n      >\n        <div style={{\n          display: 'flex', alignItems: 'center', height: '100%',\n          padding: '0 120px', minWidth: 'max-content', position: 'relative',\n        }}>\n          <div style={{\n            position: 'absolute', top: '50%', transform: 'translateY(-50%)',\n            left: '120px', right: '120px', height: '1px',\n            background: 'rgba(37,34,32,0.15)',\n          }} />\n\n          {seasonGroups.map((group, gIdx) => {\n            const firstIdx = events.findIndex((e) => e.id === group.events[0].id);\n            const lastIdx = events.findIndex((e) => e.id === group.events[group.events.length - 1].id);\n            return (\n              <div\n                key={`${group.season}-${gIdx}`}\n                style={{\n                  position: 'absolute', bottom: '12px',\n                  left: `calc(120px + ${firstIdx * 120}px)`,\n                  width: `${(lastIdx - firstIdx + 1) * 120}px`,\n                  display: 'flex', justifyContent: 'center', pointerEvents: 'none',\n                }}\n              >\n                <span style={{\n                  fontFamily: 'var(--font-ui)', fontSize: '8px',\n                  letterSpacing: '0.14em', textTransform: 'uppercase',\n                  color: 'var(--foreground)', opacity: 0.25,\n                }}>\n                  {group.season}\n                </span>\n              </div>\n            );\n          })}\n\n          {events.map((ev) => {\n            const isSelected = ev.id === selectedId;\n            const isNow = ev.status === 'now';\n            const isPast = ev.status === 'past';\n            const isUpcoming = ev.status === 'upcoming';\n            const dotSize = ev.isMajor ? 10 : 7;\n\n            return (\n              <div\n                key={ev.id}\n                data-event-id={ev.id}\n                onClick={() => onSelect(ev)}\n                style={{\n                  display: 'flex', flexDirection: 'column', alignItems: 'center',\n                  width: '120px', flexShrink: 0, cursor: 'pointer',\n                  position: 'relative', height: '100%', justifyContent: 'center',\n                }}\n              >\n                <div style={{\n                  display: 'flex', flexDirection: 'column', alignItems: 'center',\n                  position: 'absolute', top: '10px', left: 0, right: 0,\n                }}>\n                  <span style={{\n                    fontFamily: 'var(--font-ui)', fontSize: '8px',\n                    letterSpacing: '0.1em', textTransform: 'uppercase',\n                    color: 'var(--foreground)',\n                    opacity: isSelected ? 0.9 : isPast ? 0.35 : isNow ? 0.8 : 0.45,\n                    textAlign: 'center', lineHeight: 1.3, maxWidth: '90px',\n                    fontWeight: isSelected || isNow ? 500 : 400,\n                  }}>\n                    {ev.name}\n                  </span>\n                  <span style={{\n                    fontFamily: 'var(--font-ui)', fontSize: '7px',\n                    letterSpacing: '0.06em', color: 'var(--foreground)',\n                    opacity: 0.25, marginTop: '2px',\n                  }}>\n                    {new Date(ev.date).toLocaleDateString('en-US', { month: 'short', year: '2-digit' })}\n                  </span>\n                </div>\n\n                <div style={{\n                  position: 'relative', display: 'flex', alignItems: 'center',\n                  justifyContent: 'center', zIndex: 1, width: '30px', height: '30px',\n                }}>\n                  {isSelected && (\n                    <>\n                      <div style={{ position: 'absolute', width: '28px', height: '28px', borderRadius: '50%', border: '1px solid rgba(37,34,32,0.15)' }} />\n                      <div style={{ position: 'absolute', width: '20px', height: '20px', borderRadius: '50%', border: '1px solid rgba(37,34,32,0.3)' }} />\n                    </>\n                  )}\n                  {isNow && (\n                    <div style={{\n                      position: 'absolute', width: '18px', height: '18px',\n                      borderRadius: '50%', border: '1px solid rgba(37,34,32,0.3)',\n                      animation: 'timelinePulse 2s ease-in-out infinite',\n                    }} />\n                  )}\n                  <div style={{\n                    width: isSelected ? '14px' : `${dotSize}px`,\n                    height: isSelected ? '14px' : `${dotSize}px`,\n                    borderRadius: '50%',\n                    background: isNow ? 'var(--foreground)' : isPast ? 'rgba(37,34,32,0.25)' : 'transparent',\n                    border: isNow ? 'none' : isUpcoming ? '1px dashed rgba(37,34,32,0.35)' : 'none',\n                    transition: 'width 300ms ease, height 300ms ease',\n                    flexShrink: 0,\n                  }} />\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      <div style={{\n        position: 'absolute', bottom: 0, left: 0,\n        height: '1px', width: `${progressRatio * 100}%`,\n        background: 'rgba(37,34,32,0.35)', transition: 'width 500ms ease',\n      }} />\n    </div>\n  );\n}\n\n// ─── EVENT PANEL ─────────────────────────────────────────────────────────────\n\nfunction EventPanel({\n  event,\n  onCardClick,\n}: {\n  event: TimelineEvent;\n  onCardClick: (type: CardType) => void;\n}) {\n  const isNow = event.status === 'now';\n  const isUpcoming = event.status === 'upcoming';\n  const eyebrow = isNow ? '● Now Trending' : isUpcoming ? 'Coming Up' : 'Season Recap';\n\n  return (\n    <div style={{\n      display: 'flex', flexDirection: 'column', alignItems: 'center',\n      justifyContent: 'center', height: '100%', padding: '32px 24px', textAlign: 'center',\n    }}>\n      <span style={{\n        fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.18em',\n        textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.45,\n        marginBottom: '20px', display: 'flex', alignItems: 'center', gap: '6px',\n      }}>\n        {isNow ? (\n          <>\n            <span style={{\n              display: 'inline-block', width: '5px', height: '5px', borderRadius: '50%',\n              background: 'var(--foreground)', animation: 'pulse 2s cubic-bezier(0.4,0,0.6,1) infinite',\n            }} />\n            Now Trending\n          </>\n        ) : eyebrow}\n      </span>\n\n      <h1 style={{\n        fontFamily: 'var(--font-heading)', fontSize: 'clamp(32px, 5vw, 64px)',\n        fontWeight: 400, lineHeight: 1.1, letterSpacing: '-0.01em',\n        color: 'var(--foreground)', margin: '0 0 12px', maxWidth: '700px',\n      }}>\n        {event.name}\n      </h1>\n\n      <span style={{\n        fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.14em',\n        textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.35, marginBottom: '18px',\n      }}>\n        {event.season}\n      </span>\n\n      <p style={{\n        fontFamily: 'var(--font-body)', fontStyle: 'italic',\n        fontSize: 'clamp(14px, 1.5vw, 16px)', lineHeight: 1.7,\n        color: 'var(--foreground)', opacity: 0.6, maxWidth: '540px', margin: 0,\n      }}>\n        {event.desc}\n      </p>\n\n      {/* FIX: give CountdownTimer a key so it fully remounts on event change */}\n      {isUpcoming && new Date(event.date).getTime() > Date.now() && (\n        <CountdownTimer\n          key={event.id}\n          dateStr={event.date}\n          timerKey={event.id}\n        />\n      )}\n\n      <EventCards event={event} onCardClick={onCardClick} />\n    </div>\n  );\n}\n\n// ─── MAIN COMPONENT ──────────────────────────────────────────────────────────\n\nexport default function TrendTimelineHero() {\n  // FIX: EVENTS is computed at runtime from today's date  never hardcoded\n  const [EVENTS, setEVENTS] = useState<TimelineEvent[]>(() => computeEvents());\n\n  // Re-derive events at midnight so the component self-updates day-to-day\n  useEffect(() => {\n    const msUntilMidnight = () => {\n      const now = new Date();\n      const midnight = new Date(now);\n      midnight.setHours(24, 0, 0, 0);\n      return midnight.getTime() - now.getTime();\n    };\n\n    let timeout: ReturnType<typeof setTimeout>;\n    const scheduleNextUpdate = () => {\n      timeout = setTimeout(() => {\n        setEVENTS(computeEvents());\n        scheduleNextUpdate(); // schedule next midnight\n      }, msUntilMidnight());\n    };\n    scheduleNextUpdate();\n    return () => clearTimeout(timeout);\n  }, []);\n\n  const nowEvent = EVENTS.find((e) => e.status === 'now') ?? EVENTS[0];\n  const [selectedEvent, setSelectedEvent] = useState<TimelineEvent>(nowEvent);\n  const [activeCard, setActiveCard] = useState<CardType>(null);\n  const [panelVisible, setPanelVisible] = useState(true);\n  const [carouselVisible, setCarouselVisible] = useState(false);\n\n  // FIX: current season derived from the live-computed \"now\" event  not hardcoded\n  const currentSeason = nowEvent.season;\n\n  // Keep selectedEvent in sync if EVENTS recomputes and changes the selected event's status\n  useEffect(() => {\n    const updated = EVENTS.find((e) => e.id === selectedEvent.id);\n    if (updated) setSelectedEvent(updated);\n  }, [EVENTS]);\n\n  const handleEventSelect = useCallback((ev: TimelineEvent) => {\n    if (ev.id === selectedEvent.id && !activeCard) return;\n    setPanelVisible(false);\n    setCarouselVisible(false);\n    setTimeout(() => {\n      setSelectedEvent(ev);\n      setActiveCard(null);\n      setPanelVisible(true);\n    }, 260);\n  }, [selectedEvent.id, activeCard]);\n\n  const handleCardClick = useCallback((type: CardType) => {\n    setPanelVisible(false);\n    setTimeout(() => {\n      setActiveCard(type);\n      setCarouselVisible(true);\n    }, 260);\n  }, []);\n\n  const handleBack = useCallback(() => {\n    setCarouselVisible(false);\n    setTimeout(() => {\n      setActiveCard(null);\n      setPanelVisible(true);\n    }, 260);\n  }, []);\n\n  return (\n    <>\n      <style>{`\n        @keyframes timelinePulse {\n          0%, 100% { transform: scale(1); opacity: 0.4; }\n          50% { transform: scale(1.6); opacity: 0; }\n        }\n        @keyframes blinkDot {\n          0%, 100% { opacity: 1; }\n          50% { opacity: 0.2; }\n        }\n        @keyframes pulse {\n          0%, 100% { opacity: 1; }\n          50% { opacity: 0.4; }\n        }\n        .panel-enter {\n          animation: panelFadeIn 0.5s cubic-bezier(.22,1,.36,1) forwards;\n        }\n        @keyframes panelFadeIn {\n          from { opacity: 0; transform: translateY(12px); }\n          to { opacity: 1; transform: translateY(0); }\n        }\n        div::-webkit-scrollbar { display: none; }\n      `}</style>\n\n      <section style={{\n        height: '100vh', display: 'flex', flexDirection: 'column',\n        background: 'var(--background)', overflow: 'hidden',\n      }}>\n        {/* TOP BAR */}\n        <div style={{\n          height: '44px', display: 'flex', alignItems: 'center',\n          justifyContent: 'space-between', padding: '0 32px',\n          borderBottom: '1px solid rgba(37,34,32,0.10)', flexShrink: 0,\n        }}>\n          <span style={{\n            fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.16em',\n            textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.4,\n          }}>\n            Nail Trend Index · 2025–2026\n          </span>\n          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>\n            <span style={{\n              display: 'inline-block', width: '5px', height: '5px', borderRadius: '50%',\n              background: 'var(--foreground)', animation: 'blinkDot 1.8s ease-in-out infinite',\n            }} />\n            <span style={{\n              fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.14em',\n              textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.5,\n            }}>\n              {/* FIX: derived from live computed nowEvent, not hardcoded */}\n              Now In · {currentSeason}\n            </span>\n          </div>\n        </div>\n\n        {/* CONTENT STAGE */}\n        <div style={{\n          flex: 1, position: 'relative', overflow: 'hidden',\n          display: 'flex', alignItems: 'center', justifyContent: 'center',\n        }}>\n          <div\n            className={panelVisible ? 'panel-enter' : ''}\n            style={{\n              position: 'absolute', inset: 0,\n              display: 'flex', alignItems: 'center', justifyContent: 'center',\n              opacity: panelVisible ? 1 : 0,\n              pointerEvents: panelVisible && !activeCard ? 'auto' : 'none',\n              transition: 'opacity 260ms ease',\n            }}\n          >\n            {!activeCard && (\n              <EventPanel event={selectedEvent} onCardClick={handleCardClick} />\n            )}\n          </div>\n\n          <div\n            className={carouselVisible ? 'panel-enter' : ''}\n            style={{\n              position: 'absolute', inset: 0,\n              opacity: carouselVisible ? 1 : 0,\n              pointerEvents: carouselVisible ? 'auto' : 'none',\n              transition: 'opacity 260ms ease',\n            }}\n          >\n            {activeCard === 'edit' && selectedEvent.editSlug && (\n              <EditCarousel editSlug={selectedEvent.editSlug} onBack={handleBack} />\n            )}\n            {activeCard === 'gallery' && selectedEvent.gallerySlug && (\n              <InspoGalleryCarousel gallerySlug={selectedEvent.gallerySlug} onBack={handleBack} />\n            )}\n          </div>\n        </div>\n\n        {/* TIMELINE TRACK */}\n        <TimelineTrack\n          events={EVENTS}\n          selectedId={selectedEvent.id}\n          onSelect={handleEventSelect}\n        />\n      </section>\n    </>\n  );\n}"
    }
