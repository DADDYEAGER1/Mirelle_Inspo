rInteractive\"\n          data-grow-initializer=\"\"\n          dangerouslySetInnerHTML={{\n            __html: `!(function(){window.growMe||((window.growMe=function(e){window.growMe._.push(e);}),(window.growMe._=[]));var e=document.createElement(\"script\");(e.type=\"text/javascript\"),(e.src=\"https://faves.grow.me/main.js\"),(e.defer=!0),e.setAttribute(\"data-grow-faves-site-id\",\"U2l0ZTpkOTY1ZGVlYy0yZmM1LTRjMWItODZjNS04YzdjOTk4NDhmNGE=\");var t=document.getElementsByTagName(\"script\")[0];t.parentNode.insertBefore(e,t);})();`,\n          }}\n        />\n\n        {/* infolinks - disabled */}\n        {/* <script type=\"text/javascript\"> var infolinks_pid = 3445345; var infolinks_wsid = 0; </script> <script type=\"text/javascript\" src=\"//resources.infolinks.com/js/infolinks_main.js\"></script> */}\n      </body>\n    </html>\n  );\n}\n"
