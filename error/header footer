      "path": "src/components/Footer.tsx",
      "content": "'use client';\nimport Link from 'next/link';\nimport Image from 'next/image';\nimport { useState } from 'react';\n\n// Accordion Section Component for Mobile\nfunction AccordionSection({ \n  title, \n  children, \n  defaultOpen = false \n}: { \n  title: string; \n  children: React.ReactNode; \n  defaultOpen?: boolean;\n}) {\n  const [isOpen, setIsOpen] = useState(defaultOpen);\n\n  return (\n    <div className=\"border-b border-[#f9fafb]/20 lg:border-none\">\n      <button\n        onClick={() => setIsOpen(!isOpen)}\n        className=\"w-full py-4 flex items-center justify-between text-left lg:cursor-default\"\n        aria-expanded={isOpen}\n      >\n        <h3 className=\"font-ui text-base uppercase tracking-wider text-[#f9fafb]\">\n          {title}\n        </h3>\n        <svg\n          className={`w-5 h-5 transition-transform duration-200 lg:hidden ${\n            isOpen ? 'rotate-180' : ''\n          }`}\n          fill=\"none\"\n          stroke=\"currentColor\"\n          viewBox=\"0 0 24 24\"\n        >\n          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n        </svg>\n      </button>\n      <div\n        className={`overflow-hidden transition-all duration-300 ease-in-out lg:block lg:max-h-none ${\n          isOpen ? 'max-h-96 pb-4' : 'max-h-0'\n        }`}\n      >\n        {children}\n      </div>\n    </div>\n  );\n}\n\nexport default function Footer() {\n  const currentYear = new Date().getFullYear();\n\n  return (\n    <footer className=\"bg-[#252220] text-[#f9fafb]\">\n      {/* Main Footer Content */}\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12\">\n        \n       {/* Logo & Description - Always Visible */}\n        <div className=\"mb-8 pb-6 border-b border-[#f9fafb]/20\">\n          <Link href=\"/\" className=\"flex items-center space-x-2 mb-4\">\n            <Image \n              src=\"/logo.png\" \n              alt=\"Mirell\u00e9 Inspo\" \n              width={32} \n              height={32}\n              className=\"lg:w-10 lg:h-10\"\n            />\n            <span className=\"font-brand text-xl lg:text-2xl\" data-logo=\"true\">Mirell\u00e9 Inspo</span>\n          </Link>\n\n          <p className=\"font-body text-[#f9fafb]/70 text-sm lg:text-base max-w-md leading-relaxed\">\n            Your trusted source for curated nail trends, honest product reviews, and artist discoveries. \n            We find the best so you don't have to scroll for hours.\n          </p>\n        </div>\n\n        {/* Social Icons - Always Visible on Mobile */}\n        <div className=\"mb-6 pb-6 border-b border-[#f9fafb]/20\">\n          <h3 className=\"font-ui text-sm uppercase tracking-wider mb-3 text-[#f9fafb]\">\n            Follow Us\n          </h3>\n          <div className=\"flex space-x-5\">\n            <a \n              href=\"https://in.pinterest.com/mirelle_inspo/\" \n              target=\"_blank\" \n              rel=\"noopener noreferrer\"\n              className=\"text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors\"\n              aria-label=\"Pinterest\"\n            >\n              <svg className=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path d=\"M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.37