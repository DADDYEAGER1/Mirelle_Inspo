      "content": "// src/app/api/timeline/inspo-images/route.ts\n//\n// Returns: first 7 images for a given inspo gallery slug.\n// Used by TrendTimelineHero \u2192 InspoGalleryCarousel\n//\n// GET /api/timeline/inspo-images?slug=spring-nails\n\nimport { NextRequest, NextResponse } from 'next/server';\nimport { getDesignImages } from '@/lib/inspo';\n\nexport async function GET(request: NextRequest) {\n  const { searchParams } = new URL(request.url);\n  const slug = searchParams.get('slug');\n\n  if (!slug) {\n    return NextResponse.json({ error: 'Missing slug param' }, { status: 400 });\n  }\n\n  try {\n    const allImages = await getDesignImages(slug);\n\n    // Return only first 7 the component adds \"View Full Gallery\" as the 8th card\n    const images = allImages.slice(0, 7).map((img) => ({\n      src: img.url,\n      alt: img.alt || '',\n    }));\n\n    return NextResponse.json({ images });\n  } catch (error) {\n    console.error('Error fetching inspo images:', error);\n    return NextResponse.json({ error: 'Internal server error' }, { status: 500 });\n  }\n}"
