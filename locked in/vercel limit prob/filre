      "path": "src/app/api/timeline/blog-cluster/route.ts",
      "content": "// src/app/api/timeline/blog-cluster/route.ts\n//\n// Returns: pillar post + all cluster posts for a given pillar slug.\n// Used by TrendTimelineHero \u2192 EditCarousel\n//\n// GET /api/timeline/blog-cluster?pillar=spring-nail-trends-2026\n\nimport { NextRequest, NextResponse } from 'next/server';\nimport { getBlogPost, getAllBlogPosts } from '@/lib/blog';\n\nexport async function GET(request: NextRequest) {\n  const { searchParams } = new URL(request.url);\n  const pillarSlug = searchParams.get('pillar');\n\n  if (!pillarSlug) {\n    return NextResponse.json({ error: 'Missing pillar param' }, { status: 400 });\n  }\n\n  try {\n    const [pillar, allPosts] = await Promise.all([\n      getBlogPost(pillarSlug),\n      getAllBlogPosts(),\n    ]);\n\n    if (!pillar) {\n      return NextResponse.json({ posts: [] });\n    }\n\n    // Get all cluster posts whose parentPillar matches this slug\n    const clusterPosts = allPosts.filter(\n      (post) =>\n        post.topicalMap?.position === 'cluster' &&\n        (\n          post.topicalMap?.parentPillar === `/blog/${pillarSlug}` ||\n          post.topicalMap?.parentPillar === pillarSlug\n        )\n    );\n\n    // Return pillar first, then clusters\n    const posts = [\n      {\n        slug: pillar.slug,\n        title: pillar.title,\n        excerpt: pillar.excerpt,\n        image: pillar.image,\n        date: pillar.date,\n        readTime: pillar.readTime,\n      },\n      ...clusterPosts.map((p) => ({\n        slug: p.slug,\n        title: p.title,\n        excerpt: p.excerpt,\n        image: p.image,\n        date: p.date,\n        readTime: p.readTime,\n      })),\n    ];\n\n    return NextResponse.json({ posts });\n  } catch (error) {\n    console.error('Error fetching blog cluster:', error);\n    return NextResponse.json({ error: 'Internal server error' }, { status: 500 });\n  }\n}"
    },
