  excerpt: string;
  date: string;
  dateModified?: string;
  author: string;
  category: string;
  image: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageCaption?: string;
  readTime?: number | string;
  wordCount?: number;
  canonical?: string;
  tags?: string[];
  topicalMap?: {
    position?: string;
    parentPillar?: string;
    relatedClusters?: string[];
    primaryKeyword?: string;
    searchIntent?: string;
    topicalBoundary?: string;
    hierarchyLevel?: number;
    secondaryKeywords?: string[];
    contentType?: string;
    semanticRelationships?: {
      technique?: string[];
      style?: string[];
      occasions?: string[];
      relatedTechniques?: string[];
    };
    contentMetrics?: {
      technicalComplexity?: string;
      timeToImplement?: string;
      requiredSkills?: string[];
      requiredTools?: string[];
    };
  };
  navigationContext?: {
    pillarPost?: {
      slug: string;
      title: string;
    };
  };
}

