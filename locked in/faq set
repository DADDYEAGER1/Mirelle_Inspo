            <article className="prose-content-magazine">
              <MDXRemote source={faq.content} components={mdxComponents} />
            </article>
          </div>

          <div className="w-full my-12">
            <FaqInlineNewsletter />
          </div>
        </div>

        <FaqFinalNewsletter />
        <FaqAbout />
        <FaqReadMore currentSlug={faq.slug} />
      </div>
    </>
  );
}


// src/lib/faqs.ts
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import { Faq, FaqMetadata, FaqCategory } from '@/types/faqs';

const faqsDirectory = path.join(process.cwd(), 'src/content/faqs');

export async function getAllFaqSlugs(): Promise<string[]> {
  if (!fs.existsSync(faqsDirectory)) return [];
  return fs
    .readdirSync(faqsDirectory)
    .filter((f) => f.endsWith('.mdx'))
    .map((f) => f.replace(/\.mdx$/, ''));
}

export async function getFaq(slug: string): Promise<Faq | null> {
  try {
    const fullPath = path.join(faqsDirectory, `${slug}.mdx`);
    if (!fs.existsSync(fullPath)) return null;

    const fileContents = fs.readFileSync(fullPath, 'utf8');
    const { data, content } = matter(fileContents);

    return {
      slug,
      title: data.title || '',
      excerpt: data.excerpt || '',
      date: data.date || new Date().toISOString(),
      dateModified: data.dateModified,
      author: data.author || 'Mirellé',
      category: data.category || 'UNCATEGORIZED',
      image: data.image || '/images/default-faq.jpg',
      imageAlt: data.imageAlt,
      imageWidth: data.imageWidth,
      imageHeight: data.imageHeight,
      imageCaption: data.imageCaption,
      readTime: data.readTime,
      wordCount: data.wordCount,
      canonical: data.canonical || `https://mirelleinspo.com/nail-faqs/${slug}`,
      tags: data.tags,
      topicalMap: data.topicalMap,
      navigationContext: data.navigationContext,
      content, // raw MDX  no remark processing
    };
  } catch (error) {
    console.error(`Error loading faq ${slug}:`, error);
    return null;
  }
}

export async function getAllFaqs(): Promise<FaqMetadata[]> {
  const slugs = await getAllFaqSlugs();
  const faqs = await Promise.all(
    slugs.map(async (slug) => {
      const faq = await getFaq(slug);
      if (!faq) return null;
      const { content, ...metadata } = faq;
      return metadata;
    })
  );
  return faqs
    .filter((f): f is FaqMetadata => f !== null)
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
}

export async function getFaqsByCategory(categorySlug: string): Promise<FaqMetadata[]> {
  const allFaqs = await getAllFaqs();
  const normalize = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
  return allFaqs.filter((f) => normalize(f.category) === categorySlug.toLowerCase());
}

export async function getAllFaqCategories(): Promise<FaqCategory[]> {
  const allFaqs = await getAllFaqs();
  const map = new Map<string, number>();
  allFaqs.forEach((f) => map.set(f.category, (map.get(f.category) || 0) + 1));
  return Array.from(map.entries())
    .map(([name, count]) => ({ name, slug: name.toLowerCase().replace(/\s+/g, '-'), count }))
    .sort((a, b) => a.name.localeCompare(b.name));
}

export async function getRelatedFaqs(currentSlug: string, limit = 3): Promise<FaqMetadata[]> {
  const current = await getFaq(currentSlug);
  if (!current) return [];
  const all = await getAllFaqs();
  const others = all.filter((f) => f.slug !== currentSlug);
  const sameCategory = others.filter((f) => f.category === current.category);
  const rest = others.filter((f) => f.category !== current.category);
  return [...sameCategory, ...rest].slice(0, limit);
}

export async function getPaginatedFaqs(page = 1, perPage = 12) {
  const all = await getAllFaqs();
  const total = all.length;
  const totalPages = Math.ceil(total / perPage);
  const start = (page - 1) * perPage;
  return {
    faqs: all.slice(start, start + perPage),
    currentPage: page,
    totalPages,
    totalFaqs: total,
    hasNextPage: page < totalPages,
    hasPreviousPage: page > 1,
  };
}


