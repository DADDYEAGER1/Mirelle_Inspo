// src/app/nail-faqs/[slug]/page.tsx
import { notFound } from 'next/navigation';
import { getFaq, getAllFaqSlugs } from '@/lib/faqs';
import { MDXRemote } from 'next-mdx-remote/rsc';
import Breadcrumbs from '@/components/Breadcrumbs';
import FaqInlineNewsletter from '@/components/Faqs/FaqInlineNewsletter';
import FaqFinalNewsletter from '@/components/Faqs/FaqFinalNewsletter';
import FaqAbout from '@/components/Faqs/FaqAbout';
import FaqReadMore from '@/components/Faqs/FaqReadMore';
import type { Metadata } from 'next';

// Add any JSX components usable inside .mdx files here
const mdxComponents = {
  FaqInlineNewsletter,
};

interface PageProps {
  params: Promise<{ slug: string }>;
}

export const revalidate = 86400;

export async function generateStaticParams() {
  const slugs = await getAllFaqSlugs();
  return slugs.map((slug) => ({ slug }));
}

export async function generateMetadata({ params }: PageProps): Promise<Metadata> {
  const { slug } = await params;
  const faq = await getFaq(slug);
  if (!faq) return { title: 'Not Found', robots: { index: false, follow: false } };

  const canonicalUrl = faq.canonical || `https://mirelleinspo.com/nail-faqs/${slug}`;
  const imageUrl = faq.image.startsWith('http') ? faq.image : `https://mirelleinspo.com${faq.image}`;

  return {
    title: `${faq.title} | Mirellé`,
    description: faq.excerpt,
    authors: [{ name: faq.author }],
    alternates: { canonical: canonicalUrl },
    openGraph: {
      title: faq.title,
      description: faq.excerpt,
      type: 'article',
      url: canonicalUrl,
      siteName: 'Mirellé',
      images: [{ url: imageUrl, width: faq.imageWidth || 1200, height: faq.imageHeight || 1200, alt: faq.imageAlt || faq.title }],
      publishedTime: faq.date,
      modifiedTime: faq.dateModified || faq.date,
      authors: [faq.author],
      section: faq.category,
    },
    twitter: {
      card: 'summary_large_image',
      title: faq.title,
      description: faq.excerpt,
      images: [imageUrl],
    },
  };
}

export default async function NailFaqPage({ params }: PageProps) {
  const { slug } = await params;
  const faq = await getFaq(slug);
  if (!faq) notFound();

  const articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: faq.title,
    description: faq.excerpt,
    image: faq.image.startsWith('http') ? faq.image : `https://mirelleinspo.com${faq.image}`,
    datePublished: faq.date,
    dateModified: faq.dateModified || faq.date,
    author: { '@type': 'Person', name: faq.author },
    publisher: {
      '@type': 'Organization',
      name: 'Mirellé Inspo',
      logo: { '@type': 'ImageObject', url: 'https://mirelleinspo.com/logo.png' },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://mirelleinspo.com/nail-faqs/${slug}` },
  };

  const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },
      { '@type': 'ListItem', position: 2, name: 'Nail FAQs', item: 'https://mirelleinspo.com/nail-faqs' },
      { '@type': 'ListItem', position: 3, name: faq.title },
    ],
  };

  return (
    <>
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />
      <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />

      <div className="min-h-screen bg-background">
        {/* Hero */}
        <div className="w-full px-[6px] md:px-[12px] py-8 md:py-12">
          <p className="text-sm uppercase tracking-wide text-gray-700 mb-4">{faq.category}</p>
          <h1 className="font-heading text-[36px] md:text-[42px] leading-tight mb-4">{faq.title}</h1>
          <div className="text-sm text-gray-700 mb-8">
            <p className="uppercase tracking-wide mb-1">BY {faq.author}</p>
            <time dateTime={faq.date} className="text-gray-600">
              {new Date(faq.date).toLocaleDateString('en-US', {
                month: 'long',
                day: 'numeric',
                year: 'numeric',
              })}
            </time>
          </div>
          <div className="w-full mb-8">
            <img src={faq.image} alt={faq.imageAlt || faq.title} className="w-full h-auto" />
            {faq.imageCaption && (
              <p className="font-ui text-xs text-gray-500 mt-2 text-center">{faq.imageCaption}</p>
            )}
          </div>
        </div>

        {/* Content */}
        <div className="w-full flex flex-col items-start">
          <div className="w-full max-w-[700px] px-6 md:px-12 lg:px-16">
            <div className="mb-8">
              <Breadcrumbs
                items={[{ label: 'Nail FAQs', href: '/nail-faqs' }]}
                currentPage={faq.title}
                includeSchema={false}
              />
            </div>
            <article className="prose-content-magazine">
              <MDXRemote source={faq.content} components={mdxComponents} />
            </article>
          </div>

          <div className="w-full my-12">
            <FaqInlineNewsletter />
          </div>
        </div>

        <FaqFinalNewsletter />
        <FaqAbout />
        <FaqReadMore currentSlug={faq.slug} />
      </div>
    </>
  );
}
