      "path": "src/components/Faqs/FaqsGrid.tsx",
      "content": "// src/components/Faqs/FaqsGrid.tsx\nimport Link from 'next/link';\nimport { FaqMetadata } from '@/types/faqs';\n\ninterface FaqsGridProps {\n  faqs: FaqMetadata[];\n}\n\nexport default function FaqsGrid({ faqs }: FaqsGridProps) {\n  return (\n    <section className=\"max-w-[1200px] mx-auto px-6 py-12\">\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10\">\n        {faqs.map((faq) => (\n          <Link key={faq.slug} href={`/nail-faqs/${faq.slug}`} className=\"group block\">\n            <div className=\"aspect-square overflow-hidden mb-4 bg-gray-100\">\n              <img\n                src={faq.image}\n                alt={faq.imageAlt || faq.title}\n                className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-300\"\n              />\n            </div>\n            <p className=\"font-ui text-xs uppercase tracking-wide text-gray-600 mb-2\">{faq.category}</p>\n            <h2 className=\"font-heading text-xl md:text-2xl mb-2 line-clamp-2 group-hover:text-gray-600 transition-colors\">\n              {faq.title}\n            </h2>\n            <p className=\"font-body text-sm text-gray-600 line-clamp-2 mb-3\">{faq.excerpt}</p>\n            <p className=\"font-ui text-xs uppercase tracking-wide text-gray-700\">BY {faq.author}</p>\n          </Link>\n        ))}\n      </div>\n    </section>\n  );\n}"
    },
    {
      "path": "src/components/Faqs/FaqReadMore.tsx",
      "content": "// src/components/Faqs/FaqReadMore.tsx\nimport { getRelatedFaqs } from '@/lib/faqs';\nimport Link from 'next/link';\n\ninterface FaqReadMoreProps {\n  currentSlug: string;\n}\n\nexport default async function FaqReadMore({ currentSlug }: FaqReadMoreProps) {\n  const related = await getRelatedFaqs(currentSlug, 3);\n  if (related.length === 0) return null;\n\n  return (\n    <section className=\"py-20 md:py-24 px-6 md:px-8\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"flex items-center gap-4 mb-12 md:mb-16\">\n          <div className=\"flex-grow h-px bg-foreground\" />\n          <h2 className=\"font-ui text-2xl uppercase tracking-wide whitespace-nowrap\">READ MORE</h2>\n          <div className=\"flex-grow h-px bg-foreground\" />\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10\">\n          {related.map((faq) => (\n            <Link key={faq.slug} href={`/nail-faqs/${faq.slug}`} className=\"group block\">\n              <div className=\"aspect-square overflow-hidden rounded-lg mb-4 bg-gray-100\">\n                <img\n                  src={faq.image}\n                  alt={faq.imageAlt || faq.title}\n                  className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-300\"\n                />\n              </div>\n              <p className=\"font-ui text-xs uppercase tracking-wide text-gray-600 mb-2\">{faq.category}</p>\n              <h3 className=\"font-heading text-xl md:text-2xl mb-2 line-clamp-2 group-hover:text-gray-600 transition-colors\">\n                {faq.title}\n              </h3>\n              <p className=\"font-ui text-sm uppercase tracking-wide text-gray-700\">BY {faq.author}</p>\n            </Link>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}"
    },
    {
      "path": "src/app/nail-faqs/page.tsx",
      "content": "// src/app/nail-faqs/page.tsx\nimport { Metadata } from 'next';\nimport { getAllFaqs, getFaqsByCategory } from '@/lib/faqs';\nimport FaqsGrid from '@/components/Faqs/FaqsGrid';\nimport NextPageButton from '@/components/Blog/NextPageButton';\n\nexport const metadata: Metadata = {\n  title: 'Nail FAQs | Mirell\u00e9',\n  description: 'Real answers to real nail questions  for nail techs, nail lovers, and everyone in between.',\n  alternates: { canonical: 'https://mirelleinspo.com/nail-faqs' },\n};\n\nexport const revalidate = 604800;\n\ninterface PageProps {\n  searchParams: Promise<{ page?: string; category?: string }>;\n}\n\nexport default async function NailFaqsPage({ searchParams }: PageProps) {\n  const params = await searchParams;\n  const currentPage = Number(params.page) || 1;\n  const selectedCategory = params.category;\n  const postsPerPage = 12;\n\n  if (selectedCategory) {\n    const categoryFaqs = await getFaqsByCategory(selectedCategory);\n    const totalPages = Math.ceil(categoryFaqs.length / postsPerPage);\n    const faqs = categoryFaqs.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);\n\n    return (\n      <div className=\"min-h-screen bg-[#f9fafb]\">\n        <section className=\"py-16 bg-[#f9fafb] border-b border-gray-100\">\n          <div className=\"max-w-[1200px] mx-auto px-6 text-center\">\n            <h1 className=\"text-4xl md:text-5xl uppercase\" style={{ fontFamily: 'Larken, Georgia, serif' }}>\n              {selectedCategory.replace(/-/g, ' ')}\n            </h1>\n          </div>\n        </section>\n        <FaqsGrid faqs={faqs} />\n        {currentPage < totalPages && (\n          <NextPageButton href={`/nail-faqs?category=${selectedCategory}&page=${currentPage + 1}`} />\n        )}\n      </div>\n    );\n  }\n\n  const allFaqs = await getAllFaqs();\n  const totalPages = Math.ceil(allFaqs.length / postsPerPage);\n  const faqs = allFaqs.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);\n\n  return (\n    <div className=\"min-h-screen bg-[#f9fafb]\">\n      <section className=\"py-24 bg-[#f9fafb] border-b border-gray-100\">\n        <div className=\"max-w-[700px] mx-auto px-6 text-center\">\n          <h1 className=\"text-5xl md:text-6xl mb-6\" style={{ fontFamily: 'Larken, serif' }}>\n            Nail FAQs\n          </h1>\n          <p className=\"text-lg md:text-xl text-gray-500 italic\" style={{ fontFamily: 'Larken, Georgia, serif' }}>\n            &ldquo;Real answers to real nail questions  from techs, for everyone.&rdquo;\n          </p>\n        </div>\n      </section>\n      <FaqsGrid faqs={faqs} />\n      {currentPage < totalPages && (\n        <NextPageButton href={`/nail-faqs?page=${currentPage + 1}`} />\n      )}\n    </div>\n  );\n}"
    },
