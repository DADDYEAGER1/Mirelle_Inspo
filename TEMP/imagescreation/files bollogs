      "path": "src/app/blog/[slug]/templates/SplitLeftTemplate.tsx",
      "content": "import { BlogPost } from '@/types/blog';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport ImageCarousel from '@/components/Blog/ImageCarousel';\nimport ProductGrid from '@/components/Blog/ProductGrid';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport AboutEEAT from '@/components/Blog/AboutEEAT';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport ReadMoreSection from '@/components/Blog/ReadMoreSection';\n\ninterface SplitLeftTemplateProps {\n  post: BlogPost;\n}\n\nexport default function SplitLeftTemplate({ post }: SplitLeftTemplateProps) {\n  // FIXED: Better content splitting that preserves HTML structure\n  const contentSections = post.content.split(/<h2/);\n  const totalSections = contentSections.length;\n  \n  const section1End = Math.max(1, Math.floor(totalSections * 0.25));\n  const section2End = Math.max(2, Math.floor(totalSections * 0.5));\n  const section3End = Math.max(3, Math.floor(totalSections * 0.75));\n  \n  const firstSection = contentSections.slice(0, section1End).join('<h2');\n  const middleSection = contentSections.slice(section1End, section2End).join('<h2');\n  const moreContent = contentSections.slice(section2End, section3End).join('<h2');\n  const remainingContent = contentSections.slice(section3End).join('<h2');\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n      {/* Meta Section */}\n      <div className=\"text-center pt-12 md:pt-16 px-6\">\n        {post.category && (\n          <p className=\"font-ui text-sm uppercase tracking-wider text-gray-600 mb-4\">\n            {post.category}\n          </p>\n        )}\n        <h1 className=\"font-heading text-4xl md:text-6xl mb-6 max-w-4xl mx-auto\">\n          {post.title}\n        </h1>\n        <p className=\"font-ui text-sm uppercase tracking-wide mb-2\">\n          BY {post.author}\n        </p>\n        <p className=\"font-ui text-sm text-gray-600\">\n          {new Date(post.date).toLocaleDateString('en-US', { \n            year: 'numeric', \n            month: 'long', \n            day: 'numeric' \n          })}\n        </p>\n      </div>\n\n      {/* Hero - Split Left */}\n      <div className=\"mt-12 md:mt-16\">\n        {/* Desktop: 50/50 split */}\n        <div className=\"hidden md:grid md:grid-cols-2 h-[600px]\">\n          <div className=\"flex items-center justify-center bg-gray-50 p-12\">\n            {post.image && (\n              <img\n                src={post.image}\n                alt={post.imageAlt || post.title}\n                className=\"max-w-full max-h-full object-contain\"\n              />\n            )}\n          </div>\n          <div className=\"bg-gray-100\"></div>\n        </div>\n\n        {/* Mobile: Centered image */}\n        <div className=\"md:hidden px-6\">\n          {post.image && (\n            <img\n              src={post.image}\n              alt={post.imageAlt || post.title}\n              className=\"w-full h-auto rounded-lg shadow-lg\"\n            />\n          )}\n        </div>\n      </div>\n\n      {/* Breadcrumbs */}\n      <div className=\"max-w-6xl mx-auto mt-8 px-6\">\n        <Breadcrumbs\n          items={[{ label: 'Blog', href: '/blog' }]}\n          currentPage={post.title}\n          includeSchema={false}\n        />\n      </div>\n\n      {/* Article Content */}\n      <article className=\"max-w-3xl mx-auto px-6 mt-12 prose prose-lg prose-headings:font-heading prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-p:text-gray-700 prose-p:leading-relaxed prose-strong:text-gray-900 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg prose-img:shadow-md\">\n        <div dangerouslySetInnerHTML={{ __html: firstSection }} />\n\n        {post.carouselImages && post.carouselImages.length > 0 && (\n          <ImageCarousel images={post.carouselImages} />\n        )}\n\n        <div dangerouslySetInnerHTML={{ __html: middleSection }} />\n\n        {post.products && post.products.length > 0 && (\n          <ProductGrid products={post.products} layout=\"dual\" />\n        )}\n\n        <div dangerouslySetInnerHTML={{ __html: moreContent }} />\n\n        <InlineNewsletter />\n\n        <div dangerouslySetInnerHTML={{ __html: remainingContent }} />\n      </article>\n\n      {/* End Sections */}\n      <AboutEEAT />\n      <FinalNewsletter />\n      <ReadMoreSection currentSlug={post.slug} />\n    </div>\n  );\n}"
