    "path": "src/components/Homepage/Hero2Section.tsx",
    "content": "import React from 'react';\nimport Link from 'next/link';\n\ninterface ClusterItem {\n  type: 'blog' | 'shop' | 'inspo' | 'topic';\n  slug: string;\n  title: string;\n  image: string;\n  category?: string;\n  author?: string;\n}\n\ninterface Hero2Props {\n  clusters: {\n    left: ClusterItem[];      // 2 large items (shop/inspo)\n    middle: ClusterItem[];     // 1 medium item (blog)\n    right: ClusterItem[];      // 2 small items (blog/topics)\n  };\n}\n\nconst Hero2Section = ({ clusters }: Hero2Props) => {\n  const renderCard = (item: ClusterItem, size: 'large' | 'medium' | 'small') => {\n    const sizeClasses = {\n      large: 'aspect-[3/4]',\n      medium: 'aspect-[3/4]',\n      small: 'aspect-[4/3]',\n    };\n\n    const href = item.type === 'blog' \n      ? `/blog/${item.slug}` \n      : item.type === 'shop'\n      ? `/shop/${item.slug}`\n      : item.type === 'inspo'\n      ? `/inspo/${item.slug}`\n      : `/topics/${item.slug}`;\n\nimport React from 'react';\nimport Link from 'next/link';\n\ninterface ClusterItem {\n  type: 'blog' | 'shop' | 'inspo' | 'topic';\n  slug: string;\n  title: string;\n  image: string;\n  category?: string;\n  author?: string;\n}\n\ninterface Hero2Props {\n  clusters: {\n    left: ClusterItem[];      // 2 large items (shop/inspo)\n    middle: ClusterItem[];     // 1 medium item (blog)\n    right: ClusterItem[];      // 2 small items (blog/topics)\n  };\n}\n\nconst Hero2Section = ({ clusters }: Hero2Props) => {\n  const renderCard = (item: ClusterItem, size: 'large' | 'medium' | 'small') => {\n    const sizeClasses = {\n      large: 'aspect-[3/4]',\n      medium: 'aspect-[3/4]',\n      small: 'aspect-[4/3]',\n    };\n\n    const href = item.type === 'blog' \n      ? `/blog/${item.slug}` \n      : item.type === 'shop'\n      ? `/shop/${item.slug}`\n      : item.type === 'inspo'\n      ? `/inspo/${item.slug}`\n      : `/topics/${item.slug}`;\n\n    return (\n      <Link href={href} className=\"block group relative overflow-hidden\">\n        <div className={`relative ${sizeClasses[size]} w-full overflow-hidden`}>\n          <img\n            src={item.image}\n            alt={item.title}\n            className=\"absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\"\n          />\n          {/* Overlay with title */}\n          <div className=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end p-3 md:p-4\">\n            <div>\n              {item.category && (\n                <p className=\"font-product text-[9px] md:text-[10px] tracking-widest uppercase text-white/90 mb-1\">\n                  {item.category}\n                </p>\n              )}\n              <h3 className=\"font-heading text-white text-base md:text-xl leading-tight\">\n                {item.title}\n              </h3>\n              {item.author && (\n                <p className=\"font-product text-[9px] md:text-[10px] tracking-widest uppercase text-white/70 mt-1\">\n                  BY {item.author}\n                </p>\n              )}\n            </div>\n          </div>\n        </div>\n      </Link>\n    );\n  };\n\n  return (\n    <section className=\"py-12 md:py-16\">\n      <div className=\"max-w-[1200px] mx-auto px-6 md:px-20\">\n        {/* Desktop Grid */}\n        <div className=\"hidden md:grid grid-cols-12 gap-4\">\n          {/* Left: 2 Large Items */}\n          <div className=\"col-span-4 space-y-4\">\n            {clusters.left.map((item, idx) => (\n              <div key={idx}>{renderCard(item, 'large')}</div>\n            ))}\n          </div>\n\n          {/* Middle: 1 Medium Item */}\n          <div className=\"col-span-4\">\n            {clusters.middle.map((item, idx) => (\n              <div key={idx}>{renderCard(item, 'medium')}</div>\n            ))}\n          </div>\n\n          {/* Right: 2 Small Items */}\n          <div className=\"col-span-4 space-y-4\">\n            {clusters.right.map((item, idx) => (\n              <div key={idx}>{renderCard(item, 'small')}</div>\n            ))}\n          </div>\n        </div>\n\n        {/* Mobile Stack */}\n        <div className=\"md:hidden space-y-4\">\n          {[...clusters.left, ...clusters.middle, ...clusters.right].map((item, idx) => (\n            <div key={idx}>{renderCard(item, 'large')}</div>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n};\n\nexport default Hero2Section;"
  },
