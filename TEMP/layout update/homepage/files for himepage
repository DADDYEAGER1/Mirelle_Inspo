    "content": "{\n  \"designs\": {\n    \"chrome-metallic-winter-nails\": {\n      \"slug\": \"chrome-metallic-winter-nails\",\n      \"name\": \"Chrome & Metallic Winter Nails\",\n      \"displayName\": \"Chrome & Metallic Winter Nails\",\n      \"category\": \"Seasonal\",\n      \"year\": 2025,\n      \"description\": \"Mirror-finish chrome and metallic winter nails in icy silver, holographic aurora and vanilla chrome perfect for holiday glamour\",\n      \"heroImage\": \"/inspo/chrome-metallic-winter.webp\",\n      \"gradientFrom\": \"slate-300\",\n      \"gradientVia\": \"zinc-200\",\n      \"gradientTo\": \"gray-100\",\n      \"emojis\": [\"\u2728\", \"\ud83e\udea9\", \"\u2744\ufe0f\", \"\ud83d\udc8e\"],\n      \"ctas\": [\"Icy Chrome\", \"Mirror Magic\", \"Metallic Winter\", \"Frozen Shine\"],\n      \"tldr\": {\n        \"summary\": [\n          \"65+ chrome designs from icy silver mirror finish to holographic aurora effects perfect for winter party season and celebrations\",\n          \"Trending icy chrome over white base creates vanilla chrome effect while silver mirror finish reflects winter light beautifully\",\n          \"Application techniques using chrome powder over gel base with magnetic cat eye effects creating dimensional winter looks\",\n          \"Perfect for New Year Eve parties and winter celebrations featuring rose gold, platinum and holographic metallic finishes\"\n        ],\n        \"keyTakeaways\": [\"Mirror finish trending\", \"Icy chrome perfect\", \"Party season ready\", \"65+ metallic ideas\"]\n      },\n      \"seo\": {\n        \"title\": \"Winter Chrome Nails 2025: 65+ Icy Metallic Designs | Mirell\u00e9\",\n        \"description\": \"Get 65+ winter chrome: icy silver, aurora holographic & vanilla chrome. Mirror finish tutorials, trending 2025 metallic winter nails!\",\n        \"keywords\": \"chrome nails winter 2025, icy chrome nails, silver mirror nails, holographic winter nails, vanilla chrome, metallic winter manicure, aur