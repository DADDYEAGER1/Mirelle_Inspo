    "path": "src/app/globals.css",
    "content": "/* Import ALL fonts FIRST - both old and new */\n@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:wght@400;600;700&display=swap');\n@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');\n\n@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n/* Custom Fonts */\n@font-face {\n  font-family: 'Jeremiah';\n  src: url('/fonts/Jeremiah.otf') format('opentype');\n  font-weight: normal;\n  font-display: swap;\n}\n\n@font-face {\n  font-family: 'Boriboon';\n  src: url('/fonts/BoriboonDemoRegular-RpZeE.otf') format('opentype');\n  font-weight: 400;\n  font-display: swap;\n}\n\n@font-face {\n  font-family: 'Boriboon';\n  src: url('/fonts/BoriboonDemoBold-MVemP.otf') format('opentype');\n  font-weight: 700;\n  font-display: swap;\n}\n\n/* COLOR SYSTEM - Keep both until migration complete */\n:root {\n  /* NEW COLORS */\n  --background: #f9fafb;\n  --foreground: #252220;\n  \n  /* OLD COLORS - Keep these */\n  --accent: #E30088;\n  --accent-light: #FF1AA3;\n  --accent-dark: #B0006B;\n  --text-secondary: #666666;\n  --border-color: #E0E0E0;\n  --card-bg: #FFFFFF;\n}\n\n/* BASE STYLES */\nbody {\n  background: var(--background);\n  color: var(--foreground);\n  font-family: 'Crimson Text', Georgia, serif;\n  font-size: 16px;\n  line-height: 1.7;\n  -webkit-font-smoothing: antialiased;\n}\n\nh1, h2, h3, h4, h5, h6 {\n  font-family: 'Jeremiah', Georgia, serif;\n  font-weight: 600;\n  color: var(--foreground);\n}\n\n/* Links in body text get underline */\nmain a:not(.btn):not(button),\narticle a:not(.btn):not(button),\np a:not(.btn):not(button) {\n  color: var(--foreground);\n  text-decoration: underline;\n  text-underline-offset: 3px;\n  transition: opacity 0.3s ease;\n}\n\nmain a:not(.btn):not(button):hover,\narticle a:not(.btn):not(button):hover,\np a:not(.btn):not(button):hover {\n  opacity: 0.7;\n}\n\n/* Header and Footer - NO underlines */\nheader a,\nfooter a,\nnav a {\n  text-decoration: none !important;\n}\n\n/* Header/Footer styles */\nheader {\n  background-color: #252220 !important;\n}\n\nheader a,\nheader button,\nheader span {\n  color: #F7F7F7 !important;\n}\n\nfooter {\n  background-color: #252220 !important;\n}\n\nfooter a,\nfooter span,\nfooter p,\nfooter h1,\nfooter h2,\nfooter h3,\nfooter h4,\nfooter h5,\nfooter h6 {\n  color: #F7F7F7 !important;\n}\n\nfooter input,\nfooter textarea {\n  background-color: #F7F7F7 !important;\n  color: #252220 !important;\n}\n\n/* Hide scrollbar but keep functionality */\n.scrollbar-hide {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n.scrollbar-hide::-webkit-scrollbar {\n  display: none;\n}\n\n/* Smooth scroll snap */\n.snap-x {\n  scroll-snap-type: x mandatory;\n}\n\n.snap-start {\n  scroll-snap-align: start;\n}\n\n.snap-mandatory {\n  scroll-snap-type: x mandatory;\n}\n\n/* Article Content Styling */\n.prose {\n  color: #252220;\n}\n\n.prose h2 {\n  font-family: 'Jeremiah', Georgia, serif;\n  font-size: 28px;\n  margin-top: 60px;\n  margin-bottom: 20px;\n  font-weight: 600;\n}\n\n\n.prose h3 {\n  font-family: 'Jeremiah', Georgia, serif;\n  font-size: 22px;\n  margin-top: 40px;\n  margin-bottom: 16px;\n  font-weight: 600;\n}\n\n.prose p {\n  margin-bottom: 24px;\n  line-height: 1.7;\n  font-size: 17px;\n}\n\n.prose img {\n  margin: 40px 0;\n  width: 100%;\n}\n\n.prose a {\n  color: #252220;\n  text-decoration: underline;\n  text-underline-offset: 3px;\n}\n\n.prose a:hover {\n  opacity: 0.7;\n}\n\n.prose ul, .prose ol {\n  margin: 24px 0;\n  padding-left: 24px;\n}\n\n.prose li {\n  margin-bottom: 8px;\n}\n\n.prose blockquote {\n  border-left: 4px solid #252220;\n  padding-left: 24px;\n  margin: 24px 0;\n  font-style: italic;\n}\n\n/* Mobile Hero adjustments */\n@media (max-width: 768px) {\n  /* Hero title on mobile */\n  .inspo-hero-title {\n    font-size: 28px !important;\n  }\n  \n  /* Hero description on mobile */\n  .inspo-hero-description {\n    font-size: 16px !important;\n  }\n}\n\n/* Desktop Hero adjustments */\n@media (min-width: 769px) {\n  /* Hero title on desktop */\n  .inspo-hero-title {\n    font-size: 42px !important;\n  }\n  \n  /* Hero description on desktop */\n  .inspo-hero-description {\n    font-size: 18px !important;\n  }\n}\n\n/* Scrollbar hide utility */\n.scrollbar-hide {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n.scrollbar-hide::-webkit-scrollbar {\n  display: none;\n}\n\n/* Smooth scroll snap */\n.snap-x {\n  scroll-snap-type: x mandatory;\n}\n\n.snap-start {\n  scroll-snap-align: start;\n}\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n/* OLD Typography - Keep until migration */\nh1 {\n  font-size: clamp(2.5rem, 5vw, 4.5rem);\n  line-height: 1.1;\n  letter-spacing: -0.02em;\n}\n\nh2 {\n  font-size: clamp(2rem, 4vw, 3.5rem);\n  line-height: 1.15;\n}\n\nh3 {\n  font-size: clamp(1.5rem, 3vw, 2.25rem);\n  line-height: 1.3;\n}\n\np {\n  margin-bottom: 1.5em;\n  color: var(--foreground);\n}\n\na {\n  color: var(--accent);\n  text-decoration: none;\n  transition: color 0.3s ease, opacity 0.3s ease;\n}\n\na:hover {\n  opacity: 0.8;\n}\n\n/* OLD Scrollbar */\n::-webkit-scrollbar {\n  width: 6px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--background);\n}\n\n::-webkit-scrollbar-thumb {\n  background: var(--accent);\n  border-radius: 3px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  opacity: 0.8;\n}\n\n/* OLD Selection */\n::selection {\n  background: var(--accent);\n  color: white;\n}\n\n/* OLD Button Styles */\n.btn-primary {\n  background-color: var(--accent);\n  color: white;\n  padding: 0.75rem 1.5rem;\n  border-radius: 0.375rem;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.btn-primary:hover {\n  background-color: var(--accent-dark);\n  transform: translateY(-1px);\n  box-shadow: 0 4px 12px rgba(227, 0, 136, 0.3);\n}\n\n.btn-secondary {\n  background-color: var(--card-bg);\n  color: var(--foreground);\n  border: 2px solid var(--border-color);\n  padding: 0.75rem 1.5rem;\n  border-radius: 0.375rem;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.btn-secondary:hover {\n  border-color: var(--accent);\n  color: var(--accent);\n  transform: translateY(-1px);\n}\n\n.btn-ghost {\n  background-color: transparent;\n  color: var(--accent);\n  padding: 0.75rem 1.5rem;\n  border-radius: 0.375rem;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.btn-ghost:hover {\n  background-color: rgba(227, 0, 136, 0.1);\n}\n\nhr {\n  border: none;\n  height: 1px;\n  background: var(--border-color);\n  margin: 3rem 0;\n}\n\n*:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n\n/* Utilities */\n@layer utilities {\n  .thumb-zone {\n    padding-bottom: 80px;\n  }\n\n  .touch-target {\n    min-height: 48px;\n    min-width: 48px;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(10px);\n    -webkit-backdrop-filter: blur(10px);\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .glass-card-dark {\n    background: rgba(0, 0, 0, 0.4);\n    backdrop-filter: blur(10px);\n    -webkit-backdrop-filter: blur(10px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .glass-card-accent {\n    background: rgba(227, 0, 136, 0.15);\n    backdrop-filter: blur(10px);\n    -webkit-backdrop-filter: blur(10px);\n    border: 1px solid rgba(227, 0, 136, 0.2);\n  }\n\n  @supports not (backdrop-filter: blur(10px)) {\n    .glass-card {\n      background: rgba(255, 255, 255, 0.95);\n    }\n    .glass-card-dark {\n      background: rgba(0, 0, 0, 0.85);\n    }\n    .glass-card-accent {\n      background: rgba(227, 0, 136, 0.85);\n    }\n  }\n}\n\n/* Animations */\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(20px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes slideUp {\n  from { opacity: 0; transform: translateY(40px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes tilt {\n  0%, 100% { transform: perspective(1000px) rotateX(0deg) rotateY(0deg); }\n  50% { transform: perspective(1000px) rotateX(2deg) rotateY(2deg); }\n}\n\n@keyframes shimmer {\n  0% { background-position: -200% 0; }\n  100% { background-position: 200% 0; }\n}\n\n@keyframes slideInFromTop {\n  from { opacity: 0; transform: translateY(-10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes slideInFromBottom {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes pulse-soft {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.8; }\n}\n\n@keyframes scaleUp {\n  from { opacity: 0; transform: scale(0.9); }\n  to { opacity: 1; transform: scale(1); }\n}\n\n@keyframes scaleIn {\n  from { opacity: 0; transform: scale(0.95); }\n  to { opacity: 1; transform: scale(1); }\n}\n\n.animate-shimmer {\n  animation: shimmer 2s infinite linear;\n  background: linear-gradient(90deg, #f3f4f6 0%, #e5e7eb 20%, #f3f4f6 40%, #f3f4f6 100%);\n  background-size: 200% 100%;\n}\n\n.animate-slide-in-top { animation: slideInFromTop 0.2s ease-out; }\n.animate-slide-in-bottom { animation: slideInFromBottom 0.2s ease-out; }\n.animate-pulse-soft { animation: pulse-soft 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }\n.animate-scale-up { animation: scaleUp 0.3s ease-out; }\n.animate-fade-in { animation: fadeIn 0.6s ease-out; }\n.animate-slide-up { animation: slideUp 0.6s ease-out; }\n.animate-tilt { animation: tilt 10s ease-in-out infinite; }\n\n@media (hover: none) and (pointer: coarse) {\n  button:focus, a:focus, input:focus, textarea:focus, select:focus {\n    outline: 3px solid var(--accent);\n    outline-offset: 3px;\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  *, *::before, *::after {\n    animation-duration: 0.01ms !important;\n    animation-iteration-count: 1 !important;\n    transition-duration: 0.01ms !important;\n    scroll-behavior: auto !important;\n  }\n  .animate-tilt { animation: none !important; }\n}\n\n.modal-backdrop {\n  animation: fadeIn 0.3s ease-out;\n  background: rgba(0, 0, 0, 0.75);\n}\n\n.modal-container {\n  animation: scaleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.modal-container::-webkit-scrollbar { width: 8px; }\n.modal-container::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.05); border-radius: 4px; }\n.modal-container::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.2); border-radius: 4px; }\n.modal-container::-webkit-scrollbar-thumb:hover { background: rgba(0, 0, 0, 0.3); }\n\n.line-clamp-2 {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n}\n\n.line-clamp-3 {\n  display: -webkit-box;\n  -webkit-line-clamp: 3;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n}\n\n.hover-lift {\n  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;\n}\n\n.hover-lift:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);\n}\n\n.gradient-text {\n  background: linear-gradient(135deg, #E30088 0%, #B0006B 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.hover-glow {\n  position: relative;\n  transition: all 0.3s ease;\n}\n\n.hover-glow::before {\n  content: '';\n  position: absolute;\n  inset: -2px;\n  background: linear-gradient(135deg, rgba(227, 0, 136, 0.3), rgba(176, 0, 107, 0.3));\n  border-radius: inherit;\n  opacity: 0;\n  transition: opacity 0.3s ease;\n  z-index: -1;\n  filter: blur(10px);\n}\n\n.hover-glow:hover::before {\n  opacity: 1;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nimg {\n  transition: opacity 0.4s ease;\n}\n\nbutton, .btn {\n  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;\n  font-weight: 500;\n  letter-spacing: 0.02em;\n  transition: all 0.3s ease;\n}"
