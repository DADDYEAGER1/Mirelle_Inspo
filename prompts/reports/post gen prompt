        "Regional variation — how demand differs by market",
        "Product and brand investment signals",
        "Technical or formulation innovation driving the trend"
      ]
    },

    "paragraph_length": "Maximum 4 sentences per paragraph. No walls of text. If a paragraph runs longer than 4 sentences — split it. This is non-negotiable on mobile.",

    "data_presentation_rules": [
      "Every data claim is attributed to a named source inline — 'Fresha booking data shows...', 'According to Spate figures reported by Nailpro...'",
      "Statistics presented with context and comparison — '47% year-on-year' not just '47%'",
      "No fabricated data — if exact figures are not available from research, use directional language: 'Scratch Magazine reports sustained growth...' not invented percentages",
      "Specific beats generic in every sentence",
      "Key stats pulled out of prose using ReportStatCallout — do not leave important numbers buried in paragraphs"
    ]
  },

  "editorial_rules": {
    "voice": "Industry analyst at a credible trade publication. Authoritative, data-led, precise. Not a beauty blogger. Not a listicle. A journalist should read this and think: this is worth citing.",
    "closing": "Always the forward-looking section — what this trend means going forward. Never a recap of what was just said.",
    "sentence_rhythm": "Vary intentionally. Tight factual sentences for data. Flowing sentences for analysis. Uniform rhythm signals AI generation and reduces credibility.",
    "banned_punctuation": ["Em dash — banned entirely", "Ellipsis for dramatic effect"],
    "banned_constructions": [
      "'X is more than just Y'",
      "'Not only X but also Y'",
      "Rhetorical questions as transitions",
      "'It is worth noting that'",
      "'It is important to remember that'"
    ],
    "banned_transitions": ["Furthermore", "Moreover", "Additionally", "In conclusion", "To summarise", "Overall", "Thus", "Hence", "Consequently", "Nevertheless"],
    "banned_vocabulary": ["Elevate", "Effortless", "Stunning", "Game-changing", "Transformative", "Dive into", "Delve into", "Seamlessly", "Unlock", "Leverage", "Curated", "Innovative", "Cutting-edge", "Empower", "Journey (metaphorically)"]
  },

  "frontmatter": {
    "awareness": "This site is Next.js. Reports are parsed by src/lib/reports.ts and typed by src/types/reports.ts. Files live at src/content/reports/[slug].mdx. The page route is src/app/trend-reports/[slug]/page.tsx. Auto-generated schemas on this route: Article + BreadcrumbList + FAQPage (when faqs present in frontmatter). Do NOT write any schema blocks in the MDX body.",
    "critical_yaml_rule": "ALL string values in double quotes. No exceptions.",
    "no_images": "Do not include image, imageAlt, imageWidth, imageHeight, or imageCaption fields. This section has no images.",

    "required_fields": {
      "slug": "\"[trend-topic-slug — lowercase, hyphens, clean]\"",
      "title": "\"[50–60 chars — primary keyword first 3 words — written as a professional hook not a description]\"",
      "excerpt": "\"[120–160 chars strict — hook for confirmed audience segment — tempting and specific — no apostrophes]\"",
      "date": "\"YYYY-MM-DDTHH:MM:SS-05:00\"",
      "dateModified": "\"YYYY-MM-DD\"",
      "author": "\"Mirellé Team\"",
      "category": "\"Trend Report\"",
      "readTime": "\"[X] min\"",
      "wordCount": "[number only]",
      "canonical": "\"https://mirelleinspo.com/trend-reports/[slug]\""
    },

    "recommended_fields": {
      "tags": "Array of 8–12 strings — primary keyword, professional terminology, audience segment terms, data source names, related trend terms. Not consumer tags.",
      "faqs": "Array of 5–7 objects with question and answer string fields. See faqs_format below."
    },

    "faqs_format": {
      "description": "The faqs array in frontmatter drives three things: (1) the visible FAQ accordion rendered after the article body, (2) the FAQPage JSON-LD schema auto-generated by page.tsx, (3) GEO/AEO citation surface area. It is mandatory.",
      "yaml_format": "faqs:\n  - question: \"[exact query phrasing from tier4 research — professional segment language]\"\n    answer: \"[2–4 sentences. Specific. Attributed. Actionable. British English. No apostrophes in YAML strings — use HTML entity &apos; if needed or rephrase to avoid.]\"\n  - question: \"...\"\n    answer: \"...\"",
      "question_rules": [
        "Sourced from tier4 GEO query mapping research — exact language the audience segment uses",
        "Professional intent only — not consumer questions",
        "5–7 questions per post",
        "Questions in double quotes, answers in double quotes"
      ],
      "answer_rules": [
        "2–4 sentences per answer",
        "At least one named data source per answer where applicable",
        "Actionable — what should the reader do or know",
        "British English",
        "No apostrophes in YAML — rephrase contractions or use full words"
      ]
    },

    "excluded_fields": [
      "image — no images in this section",
      "imageAlt — no images",
      "imageWidth — no images",
      "imageHeight — no images",
      "imageCaption — no images",
      "topicalMap — standalone posts, no cluster",
