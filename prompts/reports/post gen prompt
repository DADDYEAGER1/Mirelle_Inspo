    "report_body": {
      "mandatory_h2_sections": [
        {
          "section": "What the data shows",
          "purpose": "Lead with evidence — search volume trajectory, booking data, social velocity. Specific numbers. Named sources. This is what gets cited.",
          "h2_style": "Data-first headline e.g. 'Chrome Nail Searches Up 47% — What the Numbers Show'"
        },
        {
          "section": "Why this trend is happening now",
          "purpose": "Context and causation — runway influence, cultural moment, product innovation, social catalyst. Answers 'why now' for the audience.",
          "h2_style": "Causation-focused e.g. 'Why Chrome Is Dominating Salon Requests Right Now'"
        },
        {
          "section": "What it means for professionals",
          "purpose": "Actionable insight for the confirmed audience segment. Nail tech reads this → knows what to stock. Brand marketer reads this → knows what to develop. Editor reads this → has a citable angle.",
          "h2_style": "Segment-specific e.g. 'What Nail Technicians Should Know Before the Peak Hits'"
