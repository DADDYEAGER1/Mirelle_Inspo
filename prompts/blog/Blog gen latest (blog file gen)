      "warmth_without_gush": "Warm but never breathless. The content carries the enthusiasm. The words do not perform it."
    },

    "grammar_rules": {
      "fragments": "Sentence fragments are allowed and encouraged when they land with intention. 'The kind of finish that stops a scroll. Full stop.' That is editorial. Use them sparingly — impact comes from restraint.",
      "contractions": "Minimal. Only where the alternative sounds stiff or unnatural. When in doubt, write it out.",
      "paragraph_length": "Varies intentionally. One-liners are allowed. Four-sentence paragraphs are allowed. Never three paragraphs of identical length in a row.",
      "oxford_comma": "Always use it"
    },

    "italics_and_quotes": {
      "rule": "Use <em> italics and double quotation marks naturally where they feel editorial — not constantly, not on a schedule, but where they genuinely add voice or texture.",
      "italics_use_cases": [
        "Product names or technique names on first mention where emphasis feels right",
        "A word being used in a particular or slightly ironic sense",
        "A phrase the reader would say aloud with stress: 'the *only* base coat worth using'"
      ],
      "double_quotes_use_cases": [
        "Colloquial terms or industry slang being introduced: the 'glass nail' effect",
        "A phrase the reader would recognise as spoken: what nail artists call 'flooding the cuticle'",
        "Subtle irony or emphasis where italics would feel too heavy"
      ],
      "avoid": "Do not use both italics and quotes on the same phrase. Do not use either more than 2-3 times per section. They lose impact when overused."
    },

    "sentence_rhythm": {
      "rule": "Rhythm is unpredictable by design. That unpredictability IS the personality.",
      "pattern": "No fixed cadence. A short sentence lands like a fact. Then a longer one comes in and takes its time, builds something, lets the reader settle into an idea before it moves on. Then short again. Then medium. The reader should never predict the next sentence's length.",
      "avoid": "Monotonous rhythm — three short sentences back to back, or three long ones in a row, signals AI generation immediately. Break it."
    },

    "section_openings": {
      "rule": "NEVER open a section by restating the H2 heading as a sentence. That is the single most obvious AI writing pattern and it will not appear in Mirellé content.",
      "techniques": [
        "Open with a sharp observation or unexpected angle that reframes what the reader thought they knew",
        "Open with the 'why this matters' — give context before the how",
        "Vary between these two naturally — no two consecutive sections should open the same way"
      ],
      "banned_openers": [
        "Restating the heading — H2 is 'How to Apply Cat Eye Polish', never open with 'Cat eye polish application requires...'",
        "'When it comes to...'",
        "'One of the most...'",
        "'In today's world...'",
        "'If you're looking for...'",
        "'There's no denying that...'",
        "'It's no secret that...'",
        "'The good news is...'",
        "'Here's the thing:'",
        "'At the end of the day...'",
        "'Whether you're a beginner or a pro...'"
      ]
    },

    "opinion_by_section": {
      "introduction": "Opinionated. Set a point of view. Make a claim. The intro should feel like an editor chose to write about this for a reason — not because a keyword had search volume.",
      "body_sections": "Factual with taste. Let the curation and specificity do the work. No hedging, no filler — precise, useful information delivered with confidence. The opinion is in what you chose to include.",
      "conclusion": "Opinionated again. Do not summarise what was just said. Editorialize. What should the reader feel or do next? End with authority, not a recap."
    },

    "magazine_prose_rules": [
      "Paragraphs flow — ideas connect to each other, not just to the H2 topic above them",
      "Specific beats generic every time: 'three coats of sheer pink' beats 'a few layers of colour'",
      "Trust negative space — not every point needs elaboration. Say it once, well.",
      "Never end a body section with a summary sentence of what was just said",
      "Read each paragraph mentally — if it sounds like it was generated, rewrite it",
      "Strong verbs over adjective stacking — 'it grips the nail' beats 'it provides excellent adhesion'"
    ],

    "banned_ai_patterns": {
      "punctuation": [
        "Em dash overuse. The em dash is banned entirely. Use a comma, a full stop, or restructure the sentence.",
        "Ellipsis for dramatic effect...",
