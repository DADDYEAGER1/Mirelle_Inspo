        "pillar_and_standalone": {
          "range": "2500–3500 words",
          "how_to_decide": "Research SERP depth — how comprehensive are top ranking posts? How many subtopics does the audience need covered? Set the number within range based on actual content depth required.",
          "rule": "Never exceed 3500. Never go below 2500 for pillar or standalone."
        },
        "cluster_spokes": {
          "cap": "2800 words absolute maximum",
          "how_to_decide": "Research SERP depth for this specific primary keyword. Set word count based on what depth the topic actually needs.",
          "rule": "If SERP analysis suggests more than 2800 — set exactly 2800. If SERP suggests less — set that lower number. Never exceed 2800 for spoke posts."
