          "trigger": "Post intent = tutorial",
          "image_count": "5 images total (including hero)"
        },
        "rule_4_comparison": {
          "trigger": "Post intent = comparison",
          "image_count": "8 images total (including hero)"
        },
        "rule_5_everything_else": {
          "trigger": "Any post not matching rules 1-4",
          "image_count": "9 images total (including hero)"
