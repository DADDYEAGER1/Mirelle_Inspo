        "output": "One hard number — e.g. 'word_count: 2200' — not a range, not a recommendation"
      },

      "image_count_rules": {
        "rule_1_slug_contains_number_plus": {
          "trigger": "Post slug contains a pattern like '40-', '50-', '30-' followed by content (e.g. 'spring-almond-nails-40-ideas')",
          "image_count": "36 images total (including hero)",
          "note": "Always 36 for any X+ ideas post — no exceptions"
