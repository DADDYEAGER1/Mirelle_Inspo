  "research_execution_rule": {
    "critical": "ACTUALLY EXECUTE EVERY RESEARCH STEP. Use real tool calls — Google search, site: searches, autocomplete mining. Do NOT write from memory. Do NOT summarise what you think the research would find. Do NOT present research findings to the user. Research all phases → output the file. No intermediate steps shown to user."
  },

  "primary_keyword_lock_rule": {
    "critical": "ALL research in every phase is locked to this_post_primary_keyword ONLY. If the post is 'spring almond nails' — every SERP search, every audience query, every semantic term, every H2 — is built around 'spring almond nails' specifically. NEVER drift into the parent keyword ('almond nails') or the cluster keyword ('spring nails'). Those are other posts' territory. This post ranks for its own primary keyword and nothing else.",
    "cannibalization_enforcement": "Before finalising ANY keyword, term, or H2 — ask: could this term cause this post to compete with another post in the cluster or on the site? If yes — drop it or differentiate it until it cannot. The keyword_do_not_use list from cluster_context.json is a hard wall."
  },

  "mode_detection": {
    "objective": "Determine operating mode before doing anything else",
    "how_to_detect": {
      "cluster_mode": "User attaches or pastes cluster_context.json alongside the topic",
      "solo_mode": "User provides only a topic — no cluster_context.json present"
    },
    "cluster_mode_behavior": "Read cluster_context.json fully before starting any research. Extract all constraints listed in phase_1. These become hard locks for every research phase.",
    "solo_mode_behavior": "No cluster context. Proceed freely — no keyword restrictions, no cluster linking requirements. Ask user for post type and intent before researching.",
    "confirm_mode": "State at the start: 'CLUSTER MODE — cluster context loaded' OR 'SOLO MODE — no cluster context'"
  },

  "mandatory_research_sources": {
    "rule": "Every source below is accessed via Google site: search or direct Google search — never by fetching URLs directly. AI agents are blocked by most sites. Always use site: operator.",
    "sources": {
      "google_direct": [
        "Google autocomplete — type primary keyword + every letter A-Z, + how, what, best, ideas, types, for, with",
        "Google PAA (People Also Ask) — extract ALL questions shown for the primary keyword SERP",
        "Google related searches — bottom of SERP for primary keyword",
        "Google Trends — 12-month + 5-year view for primary keyword specifically"
      ],
      "site_searches": [
        "site:quora.com [primary keyword] — real audience questions and pain points",
        "site:pinterest.com [primary keyword] — visual demand signals and popular angles",
        "site:youtube.com [primary keyword] — top video titles = proven demand; read indexed descriptions for audience language",
        "site:salongeek.com [primary keyword] — professional and enthusiast conversations",
        "site:byrdie.com [primary keyword] — editorial coverage gaps",
        "site:allure.com [primary keyword] — editorial coverage gaps",
        "site:nailpro.com [primary keyword] — industry coverage"
      ],
      "validation_rule": "A keyword or topic angle only qualifies if demand is confirmed on AT LEAST 2 sources. Single-source signals are weak — flag them."
    }
  },

