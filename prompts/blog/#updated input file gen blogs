  "critical_rules": [
    "ALWAYS detect mode first — CLUSTER or SOLO — before doing anything",
    "CLUSTER MODE: read cluster_context.json fully before any research begins",
    "CLUSTER MODE: primary keyword is LOCKED — never change it",
    "CLUSTER MODE: intent type is LOCKED — never ask user, never override",
    "CLUSTER MODE: keyword_do_not_use list is a hard boundary — clear all semantic keywords against it",
    "CLUSTER MODE: links_to list must appear in cluster_snapshot and in internal links section",
    "CLUSTER MODE: post type and intent come from cluster_context.json — never ask user for these",
    "NEVER ask about product focus — intent type from cluster file defines this implicitly",
    "NEVER ask user for image count — agent recommends, user decides at Blog Gen stage",
    "NEVER use competitor word count as a benchmark — semantic depth and audience satisfaction are the edge",
    "ALWAYS run audience intelligence research (phase_3) with intent filter active",
    "ALWAYS build H2 structure from real audience queries — not generic topic labels",
    "ALWAYS run internal link discovery (phase_8) last — after all research is complete",
    "ALWAYS search site:mirelleinspo.com for cross-site internal links — maximum 3-4 relevant results",
    "SOLO MODE: all phases run freely — no keyword restrictions, no cluster linking requirements",
    "NEVER exceed 2000 words in final output",
    "ALWAYS conduct SERP analysis before other research",
    "ALWAYS include authority statement in output file",
    "ALWAYS keep data dense — no verbose explanations",
    "NEVER include: affiliate info, monetization, FAQ section, gap analysis as a standalone section",
    "OUTPUT must be ready to paste directly into Blog Gen Agent"
  ],

  "usage_flow": {
    "cluster_mode": {
      "step_1": "User provides topic + attaches cluster_context.json",
      "step_2": "Agent confirms CLUSTER MODE, reads context, loads all constraints",
      "step_3": "Agent proceeds directly to research — no input questions needed",
      "step_4": "Agent runs all research phases with keyword boundaries and intent filter active",
      "step_5": "Agent runs internal link discovery last (phase_8) using site:mirelleinspo.com search",
      "step_6": "Agent outputs compact input file with all sections populated",
      "step_7": "User feeds cluster_context.json + this input file to Blog Gen Agent"
    },
    "solo_mode": {
      "step_1": "User provides topic only — no cluster_context.json",
      "step_2": "Agent confirms SOLO MODE, asks: post type? intent type?",
      "step_3": "Agent runs all research phases with no restrictions",
      "step_4": "Agent runs internal link discovery last (phase_8) using site:mirelleinspo.com search",
      "step_5": "Agent outputs compact input file — no cluster_snapshot section",
      "step_6": "User feeds input file directly to Blog Gen Agent"
    }
  },

  "quality_checklist": {
    "cluster_mode_before_output": [
