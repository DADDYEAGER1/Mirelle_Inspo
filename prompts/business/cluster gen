    "MODE_B_REGION": {
      "trigger": "Founder names a region AND attaches country_master_file.json",
      "objective": "Deep-dive a specific region from the master file — research at city and area level, find every rankable post opportunity in this region, map keywords and internal links, output the Region Cluster File",

      "step_0_read_master_file": {
        "mandatory": true,
        "agent_must": [
          "Read the attached country_master_file.json fully before doing anything",
          "Note which region is being worked on",
          "Extract all posts already assigned to this region",
          "Load the keyword_do_not_use list — enforce throughout all research",
          "Note brand_geo_level confirmed by founder — do not re-question unless founder raises it",
          "Do NOT re-research anything already in the master file"
        ]
      },

      "phase_0_region_deep_research": {
        "objective": "Understand this specific region at city, area, and district level — go deep",
        "research_targets": [
          "Every major city in this region + population and nail salon density estimates",
          "Key areas, districts, boroughs within major cities — where are nail businesses concentrated",
          "Local nail culture — which services dominate in this region specifically",
          "Seasonal patterns — any local events, seasons, or cultural moments that affect nail bookings",
          "Regional beauty spend patterns vs country average",
          "How nail business owners in this region talk about their problems — exact language",
          "What local competitors rank for nail business terms in this region right now"
        ],
        "mandatory_sources": [
          "site:quora.com [region/city] nail salon — extract owner language and pain points",
          "site:linkedin.com [region/city] nail — brand vocabulary, regional market framing",
          "nailsmag.com — search for region-specific content or US state coverage",
          "scratchmagazine.co.uk — especially for UK regions and counties",
          "beautylaunchpad.com — regional nail business advice",
          "Web fetch top-ranking nail directories for this region — what they cover, what they miss",
          "Web fetch 2-3 local nail brand or supplier websites — extract their regional language and targeting",
          "Google autocomplete — [city] nail salon marketing, [city] nail tech get clients, [area] nail salon visibility",
          "People Also Ask — for each major city in this region",
          "Google Trends — regional breakdown for nail business keywords"
        ]
      },

      "phase_1_city_and_area_mapping": {
        "objective": "Map every city and sub-area worth targeting in this region",
        "per_city": {
          "nail_salon_density": "estimated count or density signal",
          "key_areas_districts": ["list of areas worth area-level posts"],
          "dominant_services": ["what nail services are most searched here"],
          "influencer_presence": "is there a nail creator community worth targeting",
          "brand_opportunity": "only if brand_geo_level = state — is this city relevant for brand content"
        },
        "area_level_rule": "Only go area level if: (a) the city is large enough that city-level posts won't rank quickly, AND (b) there is clear search demand at area level. Flag borderline cases for founder."
      },

      "phase_2_deep_keyword_research": {
        "objective": "Find every rankable keyword for every post in this region — deeper than Mode A",
        "method": {
          "step_1": [
            "Google autocomplete — [area] nail salon [service], [city] nail tech [service], [district] nail [client type]",
            "People Also Ask — for each city and major area in this region",
            "Google related searches — for each seed keyword",
            "site:quora.com [city] nail — extract real question phrasing from thread titles",
            "site:linkedin.com [city] nail salon marketing — regional business vocabulary",
            "Fetch top-ranking competitor posts for each keyword — analyse what they cover and where the gap is",
            "nailsmag.com + scratchmagazine.co.uk — any region-specific keyword signals in article titles",
            "Google Trends — compare keyword variants within this region to find strongest signal"
          ],
          "step_2_competition_assessment": {
            "for_every_keyword": [
              "What ranks page 1 for this exact phrase in this region?",
              "Is it a large directory — Yelp, Treatwell, Google Maps? Can editorial compete?",
              "Is it thin or outdated content Mirellé can outrank?",
              "Difficulty: Low / Medium / High / Very High"
            ],
            "actions": {
              "Low_Medium": "Lock as primary keyword — fast-rank opportunity",
              "High": "Find intent-matching variant. Same user intent, different phrasing, lower competition. Must validate on 2+ sources.",
              "Very_High": "Kill or park — log reason. Suggest alternative angle if one exists."
            }
          },
          "step_3_semantic_data_mining": {
            "objective": "Extract the language nail business owners in this region actually use — feeds post writer",
            "sources": [
              "site:quora.com — exact phrases nail owners use when describing their pain",
              "site:linkedin.com — how industry professionals frame growth, visibility, marketing problems",
              "nailsmag.com business section — how trade press talks about nail business challenges",
              "scratchmagazine.co.uk — UK regional nail business language",
              "Brand websites (OPI, CND, Gelish, Kiara Sky, regional brands) — how they address nail professionals, what problems they acknowledge, what solutions they claim to offer",
              "beautylaunchpad.com — real nail tech business pain vocabulary"
            ],
            "capture": [
              "Exact phrases and sentences that express business owner pain",
              "Words they use to describe their visibility problem",
              "How they talk about getting clients",
              "Objections they raise about spending money on marketing",
              "Industry jargon specific to this region or country",
              "Brand messaging language that nail owners respond to"
            ],
            "output": "semantic_vocabulary block — stored in cluster file, passed to input file generator"
          },
          "step_4_validation": "Every keyword validated on minimum 2 sources AND passes competition check"
        }
      },

      "phase_3_post_opportunity_mapping": {
        "objective": "Map every post for this region — complete and precise",
        "rules": [
          "Pull base posts from master file for this region",
          "Add any new opportunities uncovered in deep research",
          "Enforce keyword_do_not_use list from master file",
          "1 post = 1 location + 1 client type + 1 service",
          "Every post must have validated primary keyword",
          "Check for conflicts against keyword_ownership_registry in master file"
        ]
      },

      "phase_4_internal_linking_map": {
        "objective": "Build the complete internal linking map for this region's posts",
        "rules": [
          "Salon posts link only to other salon posts in the same city",
          "Nail tech posts link only to other nail tech posts in the same city",
          "Influencer posts link to brand collab listing post",
          "Every post links to /business hub",
          "Maximum 2-3 internal links per post",
          "No cross-linking between client types",
          "No orphan posts — every post receives at least 2 inbound links"
        ]
      },

      "phase_5_presentation_to_founder": {
        "objective": "Present the full region plan for approval before generating any file",
        "present": [
          "1. Region summary — what was found, what the opportunity looks like",
          "2. City and area breakdown — what is being targeted and why",
          "3. Full post opportunity table for this region",
          "4. Keyword ownership map — no conflicts confirmed",
          "5. Killed opportunities log",
          "6. Merged opportunities log",
          "7. Semantic vocabulary sample — key phrases captured for post writer"
