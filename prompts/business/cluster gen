          "Client Type",
          "City",
          "Area/District",
          "Service",
          "Primary Keyword",
          "Competition Level",
          "Rankability Note",
          "Internal Links"
        ],
        "STOP": "Wait for founder approval. Do NOT generate the cluster file until approved.",
        "after_approval": "Proceed to phase_6"
      },

      "phase_6_output_generation": {
