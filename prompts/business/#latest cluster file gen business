  "dual_mode": {

    "MODE_A_COUNTRY": {
      "trigger": "Founder provides a country name only — no file attached",
      "objective": "Research the entire nail business market for that country, plan all content opportunities across all regions, map every post to a service + client type + geo level, assign rankable B2B keywords, and output the Country Master File",

      "phase_0_market_research": {
        "objective": "Understand the full nail business landscape in this country before planning any content",
        "research_targets": [
          "Total nail salon count and growth rate",
          "Independent nail tech and home salon operator market size",
          "Nail brand market — key players, indie brands, dominant product categories",
          "How nail businesses currently get clients — what marketing they use and why it fails",
          "Dominant nail services by culture and regional preference",
          "Market gaps — what is missing in nail business visibility, discovery, and marketing",
          "Beauty spend per capita and disposable income by region",
          "Urban vs suburban vs rural nail business distribution"
        ],
        "mandatory_sources": [
          "nailsmag.com — search for country-specific business and market data",
          "scratchmagazine.co.uk — especially for UK, Europe, Australia",
          "beautylaunchpad.com — industry business intelligence",
          "site:quora.com [country] nail salon marketing — real owner pain language",
          "site:linkedin.com [country] nail salon business — brand vocabulary and market framing",
          "Google search — industry reports, market sizing, salon directory counts",
          "Government or trade body statistics where available",
          "Web fetch brand websites — OPI, CND, Gelish, Kiara Sky, local dominant brands — scrape positioning language, messaging, how they talk to nail businesses",
          "Google autocomplete — [country] nail salon marketing, [country] nail tech get clients, [country] nail business visibility"
        ],
        "output": "Internal only — do NOT present to founder. Proceed directly to table."
      },

      "phase_1_region_opportunity_analysis": {
        "objective": "Rank every region/state in the country by content opportunity",
        "signals_to_research_per_region": [
          "Nail salon and nail tech density (salons per capita)",
          "Urban density and major city count",
          "Estimated B2B search demand for nail business growth keywords in that region",
          "Competition level — what nail directories or editorial sites already rank there",
          "Average beauty spend and disposable income",
          "Underserved markets — high density of nail businesses, low visibility solutions available",
          "Cultural nail preferences — which services dominate in this region"
        ],
        "output": "Internal only — feeds table. Do NOT present prose to founder."
      },

      "phase_2_geo_level_decision": {
        "objective": "Decide what gets targeted at national vs state vs city vs area level",
        "rules": {
          "salons": "Always city + area/district level — never broader",
          "nail_techs": "Always city + area/district level — never broader",
          "influencers": "City level only",
          "brands": {
            "default_assumption": "None — agent researches and recommends",
            "decision_factors": [
              "Does this brand sell nationwide or is it regionally distributed?",
              "Is there measurable B2B search demand at state level for this brand type?",
              "Is national-level competition too strong — would state level produce faster rankings?",
              "Is there a regional nail culture that makes state-specific brand content relevant?"
            ],
            "agent_must": "Include geo level recommendation as a column in the approval table. Founder confirms before locked."
          }
        }
      },

      "phase_3_keyword_research": {
        "objective": "Find every rankable B2B keyword for every post opportunity in this country — deep, validated, real. All keywords must reflect nail business owner search intent.",
        "keyword_intent_check": "Before including any keyword — ask: is this what a nail BUSINESS OWNER types when looking for more clients, better visibility, or growth solutions? If a consumer could type it to book a nail appointment, discard it.",
        "keyword_research_method": {
          "step_1_seed_discovery": [
            "Google autocomplete — '[city] nail salon how to get more clients', '[city] nail tech marketing', '[city] nail salon visibility', '[city] nail salon not showing Google'",
            "Google autocomplete — '[client type] + [location] + how to, get more, fill bookings, get found, marketing, visibility'",
            "People Also Ask boxes — extract all B2B questions for nail business topics in this country",
            "Google related searches — bottom of SERP for each B2B seed",
            "site:quora.com [location] nail salon marketing — extract real owner search questions from thread titles",
            "site:linkedin.com [location] nail salon growth — extract topic framing and vocabulary",
            "nailsmag.com, scratchmagazine.co.uk — extract business-focused article titles as keyword signals",
            "Google Trends — 12-month view for seasonality, regional interest breakdown for B2B nail queries"
          ],
          "step_2_competition_assessment": {
            "for_every_keyword": [
              "What currently ranks on page 1 for this exact B2B phrase?",
              "Is it a large directory or generic advice site — can editorial content compete?",
              "Is it thin content that Mirellé can outrank with depth?",
              "Estimated difficulty: Low / Medium / High / Very High"
            ],
            "competition_actions": {
              "Low_Medium": "Include as primary keyword — flag as fast-rank opportunity",
              "High": "Tweak intent — find a longer-tail or semantic B2B variant with same intent but lower competition",
              "Very_High": "Kill or park — flag for future when domain authority builds. Suggest alternative B2B angle."
            }
          },
          "step_3_validation_rule": "A keyword only qualifies if: (a) it is B2B owner intent — not consumer, (b) it shows demand on at least 2 sources, AND (c) it passes competition assessment",
          "step_4_keyword_ownership": [
            "Each post owns exactly ONE primary keyword",
            "No two posts share a primary keyword or close variant",
            "Secondary keywords of Post A cannot be the primary of Post B",
            "All primaries cross-checked before finalising — conflicts resolved by merging or splitting"
          ]
        }
      },

      "phase_4_post_opportunity_mapping": {
        "objective": "Map every valid post opportunity across the country — service × client type × location × B2B keyword",
        "mapping_rules": [
          "Use fixed services only — never invent",
          "1 post = 1 location + 1 client type + 1 service",
          "Brands: only at geo level confirmed in phase_2",
          "Influencers: city level only",
          "Salons + nail techs: city + area level",
          "Every opportunity must have a validated B2B primary keyword from phase_3"
        ],
        "also_log": [
          "Opportunities that were KILLED — reason: no demand / too competitive / no rankable B2B variant found",
          "Opportunities that were MERGED — reason: too similar, combined into one post"
        ]
      },

      "phase_5_internal_linking_architecture": {
        "objective": "Map which posts link to which — done at country level so cluster files inherit the structure",
        "rules": [
          "Salon posts in a city link only to other salon posts in that city",
          "Nail tech posts in a city link only to other nail tech posts in that city",
          "Influencer posts link to the brand collab listing post",
          "Every post links back to the Mirellé /business hub page",
          "Maximum 2-3 internal links per post",
          "Never cross-link between different client types",
          "No orphan posts — every post must receive at least 2 internal links"
        ],
        "output_per_post": {
          "links_to": ["list of post slugs this post links to"],
          "receives_links_from": ["list of post slugs that link to this post"]
        }
      },

