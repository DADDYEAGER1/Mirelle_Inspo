        "rule": "Must feel like the writer read their mind. No generic opener. Use exact_phrases_they_use from input file as inspiration.",
        "placement": "First sentence of the post body — before any H2"
      },
      "3_pain_block": {
        "what": "2-3 paragraphs in the business owner's language. Make them feel understood.",
        "source": "top_5_pain_points and exact_phrases_they_use and emotional_state from input file",
        "rule": "Primary keyword appears naturally twice in this block. Never forced. Sounds like someone who lives in their world wrote it."
      },
      "4_solution_bridge": {
        "what": "Introduce Mirellé as the answer. Editorial tone — not a sales pitch.",
        "rule": "Never say 'we are the best' or use superlatives. Let the logic do the work. The bridge says: here is why what you have been doing is not enough, and here is what changes that."
      },
      "5_what_you_offer": {
        "what": "3-4 bullet points. What the business owner gets from Mirellé.",
        "rule": "Benefits not features. What happens for them — not what the platform does.",
        "format": "Clean scannable list — this is the one place bullets are appropriate"
      },
      "6_stats_credibility": {
        "what": "3 real market stats with context",
        "source": "stat_block from input file — all three stats required",
        "rule": "Each stat gets one framing sentence that connects it to this business owner's situation. Stats land harder when the reader understands why the number matters to them specifically."
      },
      "7_faq": {
