  "phase_0_product_discovery": {
    "objective": "Agent independently finds 4-5 relevant MelodySusie products for the post — does not rely on any product list in the cluster map",
    "how": [
      "Search melodysusie.com for products matching the post's primary keyword and topic",
      "Cross-reference with SERP — identify what product types top ranking competitors feature for this keyword",
      "Select 4-5 products that best match: the post type (best-of/review/comparison), the primary keyword intent, and the buyer profile for this post",
      "Prioritise products with ratings, reviews, and clear pricing — these make stronger posts",
      "For best-of posts: select a range covering different price points or use cases",
      "For review posts: select 1 primary product, max 1 variant",
      "For comparison posts: select 2-3 directly comparable products"
    ],
    "winner_selection": "Agent selects the winner product itself — the product that best fits the primary keyword and post angle. winnerIndex: 0. Card/OG image = winner product image. Agent does not ask user to choose.",
    "no_ask_rule": "Agent never asks user which product should be the card image or winner. Agent decides based on research."
  },

  "phase_1_and_2_product_fetch_verification_and_extraction": {
    "objective": "Fetch every selected product page from MelodySusie, verify it is a real working page, and extract all product data including image URLs and review data — all in this single pass. No second or later re-fetch of the same page for any purpose, including reviews.",
    "page_verification": {
      "rule": "Before extracting any data, confirm the product page actually loads and shows a real, currently-available product. If a page is broken, returns an error, is discontinued, or does not match the product it was selected for — drop that product immediately, return to phase_0 logic, find a replacement product, and repeat this entire fetch-and-verify step for the replacement.",
      "must_not_happen": "A broken, dead, or mismatched product page must never end up in the final products[] array. This is checked before any data from that page is used anywhere."
    },
    "for_each_verified_product": [
      "Fetch the product page URL from melodysusie.com",
      "Extract: full product name, brand, exact sale price, compare-at price (if shown — crossed out original price)",
      "If no compare-at price found — omit the compareAtPrice field. Do NOT ask user. Do NOT fabricate.",
      "Extract: wattage, cure time, dimensions, weight, compatibility, all listed features and specs",
      "Extract: product description — buyer-facing copy MelodySusie uses",
      "Extract: all customer reviews from the product page in this same pass — note recurring praise, recurring complaints, exact phrases, overall rating, and review count. This is the only time review data is pulled from MelodySusie product pages — there is no separate later review-mining fetch of these same pages.",
      "Extract: product image URL directly from the page — this is the image used in the post listing card and OG/Twitter meta. No asking user.",
      "Record the verified product page URL — this becomes the base for the affiliate URL generated in affiliate_url_rule"
    ],
    "no_reviews_rule": "If a product has no reviews or very few reviews — agent writes 2-3 editorial lines about the product based on its specs and description. No 'we tested' language. Tone: informed editorial observation. Example: 'The [product name] is built for [use case] — its [key spec] makes it a strong pick for [buyer type] who want [benefit] without [pain point].'",
    "image_rule": "Agent extracts image URLs from product pages itself. Card/OG image = winner product (winnerIndex: 0) image. No user input needed for images.",
    "pricing_rule": "Show compare-at price crossed out + sale price if both exist. If only sale price — omit compareAtPrice field silently.",
    "discount_coupons": "Check MelodySusie site for any active sitewide discount codes or minimum order promotions — record for post conversion use."
  },

  "phase_2b_affiliate_url_generation": {
    "objective": "Convert every verified product page URL into its affiliate version automatically, then display the list",
    "rule": "Follow affiliate_url_rule exactly. No user input required or requested at this step.",
