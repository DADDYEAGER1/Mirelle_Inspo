          "must_avoid": "Information dumps, technical explanations without visual payoff, anything that breaks the aspirational flow"
        },
        "decision_comparison": {
          "arrival_state": "Uncertain, slightly anxious, comparing two options, wants to commit",
          "journey": "Acknowledge the exact decision they're stuck on \u2192 give a clear framework \u2192 resolve each comparison point definitively \u2192 close with a direct recommendation",
          "must_avoid": "Sitting on the fence, using 'it depends' without a resolution, leaving them as uncertain as when they arrived"
        },
        "how_to_tutorial": {
          "arrival_state": "Motivated but intimidated, wants reassurance they can do this",
          "journey": "Open by removing the fear \u2192 promise the outcome upfront \u2192 walk through each step with encouragement \u2192 close with what success looks like",
          "must_avoid": "Jargon without explanation, skipping steps, making the process sound harder than it is"
        },
        "informational": {
          "arrival_state": "Curious, wants to understand, not yet ready to act",
          "journey": "Answer the core question directly \u2192 build depth progressively \u2192 connect to what they should do with this knowledge \u2192 close with a natural next step",
          "must_avoid": "Circular explanations, over-qualification, not connecting the information to action"
        },
        "seasonal_trend": {
