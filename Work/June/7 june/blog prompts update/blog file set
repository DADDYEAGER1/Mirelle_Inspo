      "content": "// src/app/blog/[...slug]/page.tsx\n\nimport { notFound, redirect } from 'next/navigation';\nimport { getBlogPost, getAllBlogPosts, getPillarClusterPosts } from '@/lib/blog';\nimport type { Metadata } from 'next';\nimport { generateSchemas } from '@/lib/generateSchemas';\nimport Link from 'next/link';\n\nimport CenterTemplate from '../templates/CenterTemplate';\nimport SplitLeftTemplate from '../templates/SplitLeftTemplate';\nimport SplitRightTemplate from '../templates/SplitRightTemplate';\nimport GridTemplate from '../templates/GridTemplate';\n\nexport const revalidate = false; // Static: built at deploy, no ISR reads\n\ninterface PageProps {\n  params: Promise<{\n    slug?: string[];\n  }>;\n}\n\n// ─── Static Params ────────────────────────────────────────────────────────────\n\nexport async function generateStaticParams() {\n  const allPosts = await getAllBlogPosts();\n  const paths: { slug: string[] }[] = [];\n  const registeredTopics = new Set<string>();\n\n  for (const post of allPosts) {\n    if (post.topic) {\n      paths.push({ slug: [post.topic, post.slug] });\n      if (post.topicalMap?.position === 'pillar' && !registeredTopics.has(post.topic)) {\n        paths.push({ slug: [post.topic] });\n        registeredTopics.add(post.topic);\n      }\n    } else {\n      paths.push({ slug: [post.slug] });\n    }\n  }\n\n  return paths;\n}\n\n// ─── Metadata ─────────────────────────────────────────────────────────────────\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug: segments } = await params;\n\n  if (!segments || segments.length === 0) return { title: 'Not Found' };\n\n  if (segments.length === 1) {\n    const [segment] = segments;\n    const allPosts = await getAllBlogPosts();\n\n    const pillar = allPosts.find(\n      p => p.topic === segment && p.topicalMap?.position === 'pillar'\n    );\n\n    if (pillar) {\n      return {\n        title: `${pillar.title} | Mirellé`,\n        description: pillar.excerpt,\n        alternates: { canonical: `https://mirelleinspo.com/blog/${segment}` },\n        robots: { index: true, follow: true },\n      };\n    }\n\n    const post = await getBlogPost(segment);\n    if (!post) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n    const canonicalUrl = post.canonical || `https://mirelleinspo.com/blog/${segment}`;\n    const imageUrl = post.image\n      ? `https://mirelleinspo.com${post.image}`\n      : 'https://mirelleinspo.com/og-default.png';\n\n    return buildPostMetadata(post, canonicalUrl, imageUrl, post.imageAlt || post.title);\n  }\n\n  if (segments.length === 2) {\n    const [topic, postSlug] = segments;\n    const post = await getBlogPost(postSlug);\n    if (!post) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n    const canonicalUrl =\n      post.canonical || `https://mirelleinspo.com/blog/${topic}/${postSlug}`;\n    const imageUrl = post.image\n      ? `https://mirelleinspo.com${post.image}`\n      : 'https://mirelleinspo.com/og-default.png';\n\n    return buildPostMetadata(post, canonicalUrl, imageUrl, post.imageAlt || post.title);\n  }\n\n  return { title: 'Not Found', robots: { index: false, follow: false } };\n}\n\n// ─── Page ──────────────────────────────────────────────────────────────────────\n\nexport default async function BlogCatchAllPage({ params }: PageProps) {\n  const { slug: segments } = await params;\n\n  if (!segments || segments.length === 0) notFound();\n\n  if (segments.length === 1) {\n    const [segment] = segments;\n    const allPosts = await getAllBlogPosts();\n\n    const pillarPost = allPosts.find(\n      p => p.topic === segment && p.topicalMap?.position === 'pillar'\n    );\n\n    if (pillarPost) {\n      return <PillarHub topic={segment} />;\n    }\n\n    const post = await getBlogPost(segment);\n    if (!post) notFound();\n\n    if (post.topic) {\n      redirect(`/blog/${post.topic}/${post.slug}`);\n    }\n\n    return <PostPage post={post} slug={segment} />;\n  }\n\n  if (segments.length === 2) {\n    const [topic, postSlug] = segments;\n    const post = await getBlogPost(postSlug);\n    if (!post) notFound();\n\n    if (post.topic && post.topic !== topic) notFound();\n\n    return <PostPage post={post} slug={postSlug} />;\n  }\n\n  notFound();\n}\n\n// ─── Post renderer ─────────────────────────────────────────────────────────────\n\nasync function PostPage({ post, slug }: { post: any; slug: string }) {\n  const schemas = generateSchemas({ post, slug });\n\n  const templates: Record<string, any> = {\n    center: CenterTemplate,\n    'split-left': SplitLeftTemplate,\n    'split-right': SplitRightTemplate,\n    grid: GridTemplate,\n  };\n\n  const Template = templates[post.template || 'center'];\n\n  const postWithCoverImage = {\n    ...post,\n    coverImage: post.image || '/images/default-blog.jpg',\n  };\n\n  return (\n    <>\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.articleSchema) }}\n      />\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.breadcrumbSchema) }}\n      />\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.websiteSchema) }}\n      />\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.organizationSchema) }}\n      />\n      <Template post={postWithCoverImage} />\n    </>\n  );\n}\n\n// ─── Pillar hub renderer ───────────────────────────────────────────────────────\n\nasync function PillarHub({ topic }: { topic: string }) {\n  const allPosts = await getAllBlogPosts();\n  const pillar = allPosts.find(\n    p => p.topic === topic && p.topicalMap?.position === 'pillar'\n  );\n\n  if (!pillar) notFound();\n\n  const data = await getPillarClusterPosts(pillar.slug);\n  if (!data) notFound();\n\n  const { clusters } = data;\n\n  return (\n    <main className=\"max-w-4xl mx-auto px-4 py-12\">\n      <div className=\"mb-12\">\n        <p className=\"text-sm uppercase tracking-widest text-gray-400 mb-2\">Topic Hub</p>\n        <h1 className=\"text-4xl font-bold mb-4\">{pillar.title}</h1>\n        {pillar.excerpt && (\n          <p className=\"text-lg text-gray-600\">{pillar.excerpt}</p>\n        )}\n      </div>\n\n      {clusters.length > 0 && (\n        <section>\n          <h2 className=\"text-xl font-semibold mb-6 border-b pb-2\">\n            All Posts in This Topic\n          </h2>\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n            {clusters.map(post => (\n              <Link\n                key={post.slug}\n                href={`/blog/${topic}/${post.slug}`}\n                className=\"group block border rounded-xl p-5 hover:shadow-md transition-shadow\"\n              >\n                <p className=\"text-xs text-gray-400 mb-1\">{post.readTime}</p>\n                <h3 className=\"font-semibold text-lg group-hover:underline\">\n                  {post.title}\n                </h3>\n                {post.excerpt && (\n                  <p className=\"text-sm text-gray-500 mt-2 line-clamp-2\">\n                    {post.excerpt}\n                  </p>\n                )}\n              </Link>\n            ))}\n          </div>\n        </section>\n      )}\n    </main>\n  );\n}\n\n// ─── Metadata helper ───────────────────────────────────────────────────────────\n\nfunction buildPostMetadata(\n  post: any,\n  canonicalUrl: string,\n  imageUrl: string,\n  imageAltText: string\n): Metadata {\n  return {\n    title: `${post.title} | Mirellé`,\n    description:\n      post.excerpt ||\n      `Discover ${post.title} - expert nail tips, trends, and tutorials from Mirellé.`,\n    authors: [{ name: post.author || 'Mirellé' }],\n    creator: post.author || 'Mirellé',\n    publisher: 'Mirellé',\n    alternates: { canonical: canonicalUrl },\n    robots: {\n      index: true,\n      follow: true,\n      nocache: false,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-video-preview': -1,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n    openGraph: {\n      title: `${post.title} | Mirellé`,\n      description:\n        post.excerpt ||\n        `Discover ${post.title} - expert nail inspiration from Mirellé.`,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirellé',\n      locale: 'en_US',\n      images: [\n        {\n          url: imageUrl,\n          width: post.imageWidth || 1200,\n          height: post.imageHeight || 630,\n          alt: imageAltText,\n          type: 'image/jpeg',\n        },\n      ],\n      publishedTime: post.date,\n      modifiedTime: post.date,\n      authors: [post.author || 'Mirellé'],\n      section: post.category || 'Nail Care',\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: `${post.title} | Mirellé`,\n      description:\n        post.excerpt ||\n        `Discover ${post.title} - expert nail inspiration from Mirellé.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    other: {\n      'article:published_time': post.date,\n      'article:modified_time': post.date,\n      'article:author': post.author || 'Mirellé',\n      'article:section': post.category || 'Nail Care',\n      'og:image:width': (post.imageWidth || 1200).toString(),\n      'og:image:height': (post.imageHeight || 630).toString(),\n      'og:image:alt': imageAltText,\n      'og:image:type': 'image/jpeg',\n      ...(post.readTime && {\n        'twitter:label1': 'Reading time',\n        'twitter:data1': post.readTime,\n      }),\n    },\n  };\n}"
