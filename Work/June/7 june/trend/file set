      "path": "src/app/trend-reports/[slug]/page.tsx",
      "content": "// src/app/trend-reports/[slug]/page.tsx\n\nimport { notFound } from 'next/navigation';\nimport { getReport, getAllReportSlugs } from '@/lib/reports';\nimport { MDXRemote } from 'next-mdx-remote/rsc';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport ReportInlineNewsletter from '@/components/Reports/ReportInlineNewsletter';\nimport ReportFinalNewsletter from '@/components/Reports/ReportFinalNewsletter';\nimport ReportAbout from '@/components/Reports/ReportAbout';\nimport ReportReadMore from '@/components/Reports/ReportReadMore';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\nimport type { Metadata } from 'next';\nexport const revalidate = false;\nexport const dynamicParams = false;\nconst mdxComponents = {\n  ReportInlineNewsletter,\n};\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\n\n\nexport async function generateStaticParams() {\n  const slugs = await getAllReportSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug } = await params;\n  const report = await getReport(slug);\n  if (!report) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n  const canonicalUrl = report.canonical || `https://mirelleinspo.com/trend-reports/${slug}`;\n  const imageUrl = report.image.startsWith('http') ? report.image : `https://mirelleinspo.com${report.image}`;\n\n  return {\n    title: `${report.title} | Mirellé`,\n    description: report.excerpt,\n    authors: [{ name: report.author }],\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: report.title,\n      description: report.excerpt,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirellé',\n      images: [{ url: imageUrl, width: report.imageWidth || 1200, height: report.imageHeight || 1200, alt: report.imageAlt || report.title }],\n      publishedTime: report.date,\n      modifiedTime: report.dateModified || report.date,\n      authors: [report.author],\n      section: report.category,\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: report.title,\n      description: report.excerpt,\n      images: [imageUrl],\n    },\n  };\n}\n\nexport default async function TrendReportPage({ params }: PageProps) {\n  const { slug } = await params;\n  const report = await getReport(slug);\n  if (!report) notFound();\n\n  const author = report.author ? getAuthor(report.author) : null;\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    headline: report.title,\n    description: report.excerpt,\n    image: report.image.startsWith('http') ? report.image : `https://mirelleinspo.com${report.image}`,\n    datePublished: report.date,\n    dateModified: report.dateModified || report.date,\n    author: { '@type': 'Person', name: report.author },\n    publisher: {\n      '@type': 'Organization',\n      name: 'Mirellé Inspo',\n      logo: { '@type': 'ImageObject', url: 'https://mirelleinspo.com/logo.png' },\n    },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://mirelleinspo.com/trend-reports/${slug}` },\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },\n      { '@type': 'ListItem', position: 2, name: 'Trend Reports', item: 'https://mirelleinspo.com/trend-reports' },\n      { '@type': 'ListItem', position: 3, name: report.title },\n    ],\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n\n      <div className=\"min-h-screen bg-background\">\n        <div className=\"w-full px-[6px] md:px-[12px] py-8 md:py-12\">\n          <p className=\"text-sm uppercase tracking-wide text-gray-700 mb-4\">{report.category}</p>\n          <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\">{report.title}</h1>\n          <div className=\"text-sm text-gray-700 mb-8\">\n            <p className=\"uppercase tracking-wide mb-1\">BY {report.author}</p>\n            <time dateTime={report.date} className=\"text-gray-600\">\n              {new Date(report.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}\n            </time>\n          </div>\n          <div className=\"w-full mb-8\">\n            <img src={report.image} alt={report.imageAlt || report.title} className=\"w-full h-auto\" />\n            {report.imageCaption && (\n              <p className=\"font-ui text-xs text-gray-500 mt-2 text-center\">{report.imageCaption}</p>\n            )}\n          </div>\n        </div>\n\n        <div className=\"w-full flex flex-col items-start\">\n          <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16\">\n            <div className=\"mb-8\">\n              <Breadcrumbs items={[{ label: 'Trend Reports', href: '/trend-reports' }]} currentPage={report.title} includeSchema={false} />\n            </div>\n            <article className=\"prose-content-magazine\">\n              <MDXRemote source={report.content} components={mdxComponents} />\n            </article>\n          </div>\n          <div className=\"w-full my-12\">\n            <ReportInlineNewsletter />\n          </div>\n        </div>\n\n        {author && <AuthorCard author={author} />}\n        <ReportAbout />\n        <ReportFinalNewsletter />\n        <ReportReadMore currentSlug={report.slug} />\n      </div>\n    </>\n  );\n}"
    },
