      "path": "src/app/trend-reports/page.tsx",
      "content": "// src/app/trend-reports/page.tsx\nimport { Metadata } from 'next';\nimport { getAllReports, getReportsByCategory } from '@/lib/reports';\nimport ReportsGrid from '@/components/Reports/ReportsGrid';\nimport NextPageButton from '@/components/Blog/NextPageButton';\n\nexport const metadata: Metadata = {\n  title: 'Trend Reports | Mirellé',\n  description: 'Real answers to real nail trends and research  for nail professionals and trend enthusiasts.',\n  alternates: { canonical: 'https://mirelleinspo.com/trend-reports' },\n};\n\n\n\ninterface PageProps {\n  searchParams: Promise<{ page?: string; category?: string }>;\n}\n\nexport default async function TrendReportsPage({ searchParams }: PageProps) {\n  const params = await searchParams;\n  const currentPage = Number(params.page) || 1;\n  const selectedCategory = params.category;\n  const postsPerPage = 12;\n\n  if (selectedCategory) {\n    const categoryFaqs = await getReportsByCategory(selectedCategory);\n    const totalPages = Math.ceil(categoryFaqs.length / postsPerPage);\n    const faqs = categoryFaqs.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);\n\n    return (\n      <div className=\"min-h-screen bg-[#f9fafb]\">\n        <section className=\"py-16 bg-[#f9fafb] border-b border-gray-100\">\n          <div className=\"max-w-[1200px] mx-auto px-6 text-center\">\n            <h1 className=\"text-4xl md:text-5xl uppercase\" style={{ fontFamily: 'Larken, Georgia, serif' }}>\n              {selectedCategory.replace(/-/g, ' ')}\n            </h1>\n          </div>\n        </section>\n        <ReportsGrid reports={faqs} />\n        {currentPage < totalPages && (\n          <NextPageButton href={`/trend-reports?category=${selectedCategory}&page=${currentPage + 1}`} />\n        )}\n      </div>\n    );\n  }\n\n  const allFaqs = await getAllReports();\n  const totalPages = Math.ceil(allFaqs.length / postsPerPage);\n  const faqs = allFaqs.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);\n\n  return (\n    <div className=\"min-h-screen bg-[#f9fafb]\">\n      <section className=\"py-24 bg-[#f9fafb] border-b border-gray-100\">\n        <div className=\"max-w-[700px] mx-auto px-6 text-center\">\n          <h1 className=\"text-5xl md:text-6xl mb-6\" style={{ fontFamily: 'Larken, serif' }}>\n            Trend Reports\n          </h1>\n          <p className=\"text-lg md:text-xl text-gray-500 italic\" style={{ fontFamily: 'Larken, Georgia, serif' }}>\n            &ldquo;Real answers to real nail trends and research  from techs, for everyone.&rdquo;\n          </p>\n        </div>\n      </section>\n      <ReportsGrid reports={faqs} />\n      {currentPage < totalPages && (\n        <NextPageButton href={`/trend-reports?page=${currentPage + 1}`} />\n      )}\n    </div>\n  );\n}"
    },
