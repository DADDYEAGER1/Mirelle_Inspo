      "path": "next.config.ts",
      "content": "import type { NextConfig } from \"next\";\nimport fs from \"fs\";\nimport path from \"path\";\nimport matter from \"gray-matter\";\n\n// ─── Blog redirect helper (config-safe, no server-only imports) ───────────────\n\nconst BLOG_DIRECTORY = path.join(process.cwd(), \"src/content/blogs\");\n\nfunction getAllBlogFilesRecursive(dir: string, base = \"\"): string[] {\n  let results: string[] = [];\n  let entries: fs.Dirent[];\n  try {\n    entries = fs.readdirSync(dir, { withFileTypes: true });\n  } catch {\n    return [];\n  }\n  for (const entry of entries) {\n    const relativePath = base ? `${base}/${entry.name}` : entry.name;\n    if (entry.isDirectory()) {\n      results = results.concat(\n        getAllBlogFilesRecursive(path.join(dir, entry.name), relativePath)\n      );\n    } else if (\n      entry.isFile() &&\n      (entry.name.endsWith(\".md\") || entry.name.endsWith(\".mdx\"))\n    ) {\n      results.push(relativePath);\n    }\n  }\n  return results;\n}\n\nfunction getBlogRedirects() {\n  try {\n    const files = getAllBlogFilesRecursive(BLOG_DIRECTORY);\n    return files\n      .map((relativePath) => {\n        const slug = path.basename(relativePath.replace(/\\.mdx?$/, \"\"));\n        const filePath = path.join(BLOG_DIRECTORY, relativePath);\n        const content = fs.readFileSync(filePath, \"utf8\");\n        const { data } = matter(content);\n        return { slug, topic: data.topic as string | undefined };\n      })\n      .filter((post): post is { slug: string; topic: string } => !!post.topic)\n      .map((post) => ({\n        source: `/blog/${post.slug}`,\n        destination: `/blog/${post.topic}/${post.slug}`,\n        permanent: true,\n      }));\n  } catch (err) {\n    console.error(\"Failed to generate blog redirects:\", err);\n    return [];\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst nextConfig: NextConfig = {\n  // ✅ Image Optimization\n  images: {\n    unoptimized: true,\n    remotePatterns: [\n      {\n        protocol: \"https\",\n        hostname: \"mirelleinspo.com\",\n      },\n      {\n        protocol: \"https\",\n        hostname: \"images.unsplash.com\",\n      },\n      {\n        protocol: \"https\",\n        hostname: \"m.media-amazon.com\",\n      },\n      {\n        protocol: \"https\",\n        hostname: \"*.media-amazon.com\",\n      },\n    ],\n    dangerouslyAllowSVG: true,\n    contentDispositionType: \"attachment\",\n    contentSecurityPolicy: \"default-src 'self'; script-src 'none'; sandbox;\",\n  },\n\n  // ✅ Headers\n  async headers() {\n    return [\n      {\n        source: \"/((?!api|_next/static|_next/image|favicon.ico).*)\",\n        headers: [\n          {\n            key: \"Cache-Control\",\n            value: \"public, max-age=31536000, immutable\",\n          },\n        ],\n      },\n      {\n        source: \"/:path*\",\n        headers: [\n          { key: \"X-Content-Type-Options\", value: \"nosniff\" },\n          { key: \"X-Frame-Options\", value: \"SAMEORIGIN\" },\n          { key: \"X-XSS-Protection\", value: \"1; mode=block\" },\n          {\n            key: \"Referrer-Policy\",\n            value: \"strict-origin-when-cross-origin\",\n          },\n          {\n            key: \"Permissions-Policy\",\n            value: \"camera=(), microphone=(), geolocation=()\",\n          },\n        ],\n      },\n      {\n        source: \"/images/shop/:path*\",\n        headers: [\n          {\n            key: \"Cache-Control\",\n            value: \"public, max-age=31536000, immutable\",\n          },\n        ],\n      },\n      {\n        source: \"/images/:path*\",\n        headers: [\n          {\n            key: \"Cache-Control\",\n            value: \"public, max-age=31536000, immutable\",\n          },\n        ],\n      },\n      {\n        source: \"/_next/static/:path*\",\n        headers: [\n          {\n            key: \"Cache-Control\",\n            value: \"public, max-age=31536000, immutable\",\n          },\n        ],\n      },\n      {\n        source: \"/_next/image/:path*\",\n        headers: [\n          {\n            key: \"Cache-Control\",\n            value: \"public, max-age=31536000, immutable\",\n          },\n        ],\n      },\n    ];\n  },\n\n  compress: true,\n  generateEtags: true,\n  trailingSlash: false,\n  reactStrictMode: true,\n\n  experimental: {\n    optimizePackageImports: [\"lodash-es\", \"fuse.js\"],\n    optimizeCss: true,\n  },\n\n  webpack: (config, { isServer, dev }) => {\n    if (!isServer && !dev) {\n      config.optimization = {\n        ...config.optimization,\n        splitChunks: {\n          chunks: \"all\",\n          cacheGroups: {\n            default: false,\n            vendors: false,\n            vendor: {\n              name: \"vendor\",\n              chunks: \"all\",\n              test: /node_modules/,\n              priority: 20,\n            },\n            common: {\n              name: \"common\",\n              minChunks: 2,\n              chunks: \"all\",\n              priority: 10,\n              reuseExistingChunk: true,\n              enforce: true,\n            },\n            lib: {\n              test: /[\\\\/]node_modules[\\\\/](react|react-dom|next)[\\\\/]/,\n              name: \"lib\",\n              chunks: \"all\",\n              priority: 30,\n            },\n          },\n        },\n        minimize: true,\n      };\n    }\n\n    config.module.rules.push({\n      test: /\\.svg$/,\n      use: [\"@svgr/webpack\"],\n    });\n\n    return config;\n  },\n\n  productionBrowserSourceMaps: false,\n\n  // ✅ Redirects (301)\n  async redirects() {\n    const blogRedirects = getBlogRedirects();\n\n    return [\n      // Legacy\n      { source: \"/posts/test2\", destination: \"/blog/valentine-nails-2026\", permanent: true },\n\n      // Blog removals → /blog\n      { source: \"/blog/candy-cane-christmas-nails-2025-sweet-holiday-designs\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/christmas-nail-designs-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/easy-halloween-nail-designs\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/goddess-nails-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/halloween-nail-ideas-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/new-year-nails-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/red-green-christmas-nails-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/santa-reindeer-gingerbread-christmas-nails-2025-character-nail-art\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/short-christmas-nails-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/thanksgiving-nails-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/white-christmas-nails-snowflake-designs-2025\", destination: \"/blog\", permanent: true },\n      { source: \"/blog/winter-nails-2025\", destination: \"/blog\", permanent: true },\n\n      // Inspo removals → /inspo\n      { source: \"/inspo/velvet-cat-eye-winter-nails\", destination: \"/inspo\", permanent: true },\n      { source: \"/inspo/chocolate-brown-winter-nails\", destination: \"/inspo\", permanent: true },\n      { source: \"/inspo/burgundy-wine-winter-nails\", destination: \"/inspo\", permanent: true },\n      { source: \"/inspo/chrome-metallic-winter-nails\", destination: \"/inspo\", permanent: true },\n      { source: \"/inspo/minimalist-winter-nails\", destination: \"/inspo\", permanent: true },\n      { source: \"/inspo/ombre-gradient-nails-2026\", destination: \"/inspo\", permanent: true },\n\n      // Dynamic blog slug → topic/slug redirects\n      ...blogRedirects,\n    ];\n  },\n};\n\nexport default nextConfig;"
