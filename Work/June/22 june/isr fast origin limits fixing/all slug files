      "path": "src/app/page.tsx",
      "content": "// src/app/page.tsx\nimport type { Metadata } from 'next';\nimport SubscribeSection from '@/components/Homepage/SubscribeSection';\nimport TrendTimelineHero from '@/components/Homepage/TrendTimelineHero';\nimport Hero1Section from '@/components/Homepage/Hero1Section';\nimport Hero2Section from '@/components/Homepage/Hero2Section';\nimport BlogCarousel from '@/components/Homepage/BlogCarousel';\nimport WorkNailsCarousel from '@/components/Homepage/WorkNailsCarousel';\nimport MustReadSection from '@/components/Homepage/MustReadSection';\nimport InspoCategoriesCarousel from '@/components/Homepage/InspoCategoriesCarousel';\nimport InspoMasonryGrid from '@/components/Homepage/InspoMasonryGrid';\nimport SpotlightCarousel from '@/components/Homepage/SpotlightCarousel';\nimport BusinessCarousel from '@/components/Homepage/BusinessCarousel';\nimport { getPillarClusterPosts } from '@/lib/blog';\nimport { getAllDesignSlugs, getDesignImages, getLatestDesigns } from '@/lib/inspo';\nimport { getAllSpotlightPosts } from '@/lib/spotlight';\nimport { getAllBusinessPosts } from '@/lib/business';\nimport { getAllWorkNailsPosts } from '@/lib/workNails';\nimport FaqCarousel from '@/components/Homepage/FaqCarousel';\nimport { getAllFaqs } from '@/lib/faqs';\nexport const revalidate = 7776000;\n\nexport const metadata: Metadata = {\n  title: 'Mirellé - Premium Nail Design & Inspiration',\n  description: 'Discover trending nail designs, expert tutorials, and premium press-ons. Your destination for nail art inspiration.',\n  keywords: 'nail designs, nail art, press on nails, nail inspiration, nail tutorials, trending nails',\n  openGraph: {\n    title: 'Mirellé - Premium Nail Design & Inspiration',\n    description: 'Discover trending nail designs, expert tutorials, and premium press-ons.',\n    type: 'website',\n    url: 'https://mirelleinspo.com',\n    siteName: 'Mirellé Inspo',\n  },\n};\n\nconst BLOG_CAROUSEL_PILLAR_SLUG = 'nail-colors-for-every-skin-tone';\n\nexport default async function Home() {\n  const pillarData = await getPillarClusterPosts(BLOG_CAROUSEL_PILLAR_SLUG);\n\n  const inspoCategories = getLatestDesigns(6);\n\n  const inspoSlugs = getAllDesignSlugs();\n  const masonryImages = inspoSlugs.length > 0\n    ? await getDesignImages(inspoSlugs[0])\n    : [];\n\n  const allSpotlightPosts = await getAllSpotlightPosts();\n  const allBusinessPosts = await getAllBusinessPosts();\n  const allWorkNailsPosts = await getAllWorkNailsPosts();\n  const allFaqs = await getAllFaqs();\n\n  return (\n    <div className=\"font-body bg-background text-foreground\">\n      <SubscribeSection />\n      <TrendTimelineHero />\n      <Hero1Section />\n      <Hero2Section />\n\n      {allWorkNailsPosts.length > 0 && (\n        <WorkNailsCarousel\n          posts={allWorkNailsPosts}\n          heading=\"Work Nails\"\n        />\n      )}\n\n      {pillarData && (\n        <BlogCarousel\n          posts={pillarData.clusters}\n          heading={pillarData.pillar.title}\n        />\n      )}\n\n      <MustReadSection />\n\n      {allFaqs.length > 0 && (\n      <FaqCarousel faqs={allFaqs} heading=\"Nail FAQs\" />\n      )}\n\n      {inspoCategories.length > 0 && (\n        <InspoCategoriesCarousel categories={inspoCategories} />\n      )}\n\n      {masonryImages.length > 0 && (\n        <InspoMasonryGrid images={masonryImages} />\n      )}\n\n      <SpotlightCarousel posts={allSpotlightPosts} />\n      <BusinessCarousel posts={allBusinessPosts} />\n\n      <SubscribeSection />\n    </div>\n  );\n}"
