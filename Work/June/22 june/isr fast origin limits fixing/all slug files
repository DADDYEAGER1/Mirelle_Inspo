      "path": "src/app/authors/[slug]/page.tsx",
      "content": "// src/app/authors/[slug]/page.tsx\n\nimport { notFound } from 'next/navigation';\nimport { Metadata } from 'next';\nimport Image from 'next/image';\nimport Link from 'next/link';\nimport { getAuthor, getAllAuthors, getPostsByAuthor } from '@/lib/authors';\nimport AuthorPostsList from './AuthorPostsList';\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\nexport async function generateStaticParams() {\n  const authors = getAllAuthors();\n  return authors.map((a) => ({ slug: a.slug }));\n}\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug } = await params;\n  const author = getAuthor(slug);\n  if (!author) return { title: 'Not Found' };\n\n  return {\n    title: `${author.name}  ${author.role} | Mirellé`,\n    description: author.bio,\n    alternates: { canonical: `https://mirelleinspo.com/authors/${slug}` },\n    openGraph: {\n      title: `${author.name}  ${author.role} | Mirellé`,\n      description: author.bio,\n      url: `https://mirelleinspo.com/authors/${slug}`,\n      siteName: 'Mirellé',\n      images: [{ url: `https://mirelleinspo.com${author.image}`, alt: author.name }],\n    },\n  };\n}\n\n// SVG icons  inline, no external dependency\nfunction InstagramIcon() {\n  return (\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"18\"\n      height=\"18\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      strokeWidth=\"1.5\"\n      strokeLinecap=\"round\"\n      strokeLinejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" ry=\"5\" />\n      <circle cx=\"12\" cy=\"12\" r=\"4\" />\n      <circle cx=\"17.5\" cy=\"6.5\" r=\"0.5\" fill=\"currentColor\" stroke=\"none\" />\n    </svg>\n  );\n}\n\nfunction LinkedInIcon() {\n  return (\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"18\"\n      height=\"18\"\n      viewBox=\"0 0 24 24\"\n      fill=\"currentColor\"\n      aria-hidden=\"true\"\n    >\n      <path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\" />\n      <rect x=\"2\" y=\"9\" width=\"4\" height=\"12\" />\n      <circle cx=\"4\" cy=\"4\" r=\"2\" />\n    </svg>\n  );\n}\n\nexport default async function AuthorPage({ params }: PageProps) {\n  const { slug } = await params;\n\n  const author = getAuthor(slug);\n  if (!author) notFound();\n\n  const posts = await getPostsByAuthor(slug);\n\n  const personSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Person',\n    name: author.name,\n    jobTitle: author.role,\n    description: author.bio,\n    url: `https://mirelleinspo.com/authors/${slug}`,\n    image: `https://mirelleinspo.com${author.image}`,\n    worksFor: {\n      '@type': 'Organization',\n      name: 'Mirellé Inspo',\n      url: 'https://mirelleinspo.com',\n    },\n  };\n\n  return (\n    <>\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(personSchema) }}\n      />\n\n      <div className=\"min-h-screen bg-background\">\n\n        {/* Hero */}\n        <section className=\"py-24 border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-6 sm:px-8 lg:px-12\">\n            <div className=\"grid grid-cols-1 md:grid-cols-[280px_1fr] gap-12 items-start\">\n\n              <div className=\"relative w-full pb-[100%] md:pb-0 md:h-[320px] overflow-hidden\">\n                <Image\n                  src={author.image}\n                  alt={author.name}\n                  fill\n                  className=\"object-cover\"\n                  sizes=\"(max-width: 768px) 100vw, 280px\"\n                  priority\n                />\n              </div>\n\n              <div className=\"flex flex-col justify-center space-y-4\">\n                <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/50\">\n                  {author.role}\n                </p>\n                <h1\n                  className=\"text-5xl md:text-6xl text-foreground\"\n                  style={{ fontFamily: 'Larken, Georgia, serif' }}\n                >\n                  {author.name}\n                </h1>\n                <p\n                  className=\"text-xl text-foreground/70 leading-relaxed\"\n                  style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n                >\n                  {author.longBio}\n                </p>\n\n                {/* Social icons */}\n                {(author.instagram || author.linkedin) && (\n                  <div className=\"flex gap-4 pt-2\">\n                    {author.instagram && (\n                      <a\n                        href={author.instagram}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        aria-label={`${author.name} on Instagram`}\n                        className=\"flex items-center justify-center text-foreground/50 hover:text-foreground transition-colors duration-200\"\n                      >\n                        <InstagramIcon />\n                      </a>\n                    )}\n                    {author.linkedin && (\n                      <a\n                        href={author.linkedin}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        aria-label={`${author.name} on LinkedIn`}\n                        className=\"flex items-center justify-center text-foreground/50 hover:text-foreground transition-colors duration-200\"\n                      >\n                        <LinkedInIcon />\n                      </a>\n                    )}\n                  </div>\n                )}\n\n                <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40 pt-2\">\n                  {posts.length} {posts.length === 1 ? 'article' : 'articles'} published\n                </p>\n              </div>\n\n            </div>\n          </div>\n        </section>\n\n        {/* Posts */}\n        <section className=\"py-20\">\n          <div className=\"max-w-4xl mx-auto px-6 sm:px-8 lg:px-12\">\n            <h2\n              className=\"text-3xl md:text-4xl text-foreground mb-12\"\n              style={{ fontFamily: 'Larken, Georgia, serif' }}\n            >\n              Articles by {author.name}\n            </h2>\n\n            {posts.length === 0 ? (\n              <p\n                className=\"text-foreground/50 text-lg\"\n                style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n              >\n                Articles coming soon.\n              </p>\n            ) : (\n              <AuthorPostsList posts={posts} authorName={author.name} />\n            )}\n          </div>\n        </section>\n\n        {/* Back to team */}\n        <section className=\"py-12 border-t border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-6 sm:px-8 lg:px-12\">\n            <Link\n              href=\"/authors\"\n              className=\"font-ui text-sm uppercase tracking-wide underline hover:no-underline text-foreground transition-opacity hover:opacity-70\"\n            >\n              Meet the full team\n            </Link>\n          </div>\n        </section>\n\n      </div>\n    </>\n  );\n}"
    },
