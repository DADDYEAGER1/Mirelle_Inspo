      "path": "src/app/topics/[slug]/page.tsx",
      "content": "// src/app/topics/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { getTopic, getAllTopicSlugs } from '@/lib/topic';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\nimport AdUnit from '@/components/AdUnit';\nimport AdSidebar from '@/components/AdSidebar';\nimport type { Metadata } from 'next';\nimport Link from 'next/link';\n\nexport const revalidate = false\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\nexport async function generateStaticParams() {\n  const slugs = await getAllTopicSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug } = await params;\n  const topic = await getTopic(slug);\n  if (!topic) return { title: 'Topic Not Found - Mirellé', robots: { index: false, follow: false } };\n\n  const canonicalUrl = topic.canonical || `https://mirelleinspo.com/topics/${slug}`;\n  const imageUrl = topic.image ? `https://mirelleinspo.com${topic.image}` : 'https://mirelleinspo.com/og-default.png';\n\n  return {\n    title: `${topic.title} | Mirellé`,\n    description: topic.excerpt || `Comprehensive guide on ${topic.title} - nail tips and techniques from Mirellé.`,\n    authors: [{ name: topic.author || 'Mirellé' }],\n    creator: topic.author || 'Mirellé',\n    publisher: 'Mirellé',\n    alternates: { canonical: canonicalUrl },\n    robots: { index: true, follow: true, nocache: false, googleBot: { index: true, follow: true, 'max-video-preview': -1, 'max-image-preview': 'large', 'max-snippet': -1 } },\n    openGraph: {\n      title: `${topic.title} | Mirellé`,\n      description: topic.excerpt || `Comprehensive guide on ${topic.title}`,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirellé',\n      locale: 'en_US',\n      images: [{ url: imageUrl, width: topic.imageWidth || 1200, height: topic.imageHeight || 630, alt: topic.imageAlt || topic.title, type: 'image/jpeg' }],\n      publishedTime: topic.date,\n      modifiedTime: topic.dateModified,\n      authors: [topic.author || 'Mirellé'],\n      section: topic.category || 'Nail Care',\n    },\n    twitter: { card: 'summary_large_image', title: `${topic.title} | Mirellé`, description: topic.excerpt || `Comprehensive guide on ${topic.title}`, images: [imageUrl], creator: '@mirelleinspo', site: '@mirelleinspo' },\n  };\n}\n\nexport default async function TopicPage({ params }: PageProps) {\n  const { slug } = await params;\n  const topic = await getTopic(slug);\n  if (!topic) notFound();\n\n  const author = topic.author ? getAuthor(topic.author) : null;\n\n  // Split compiled HTML at ~50% for in-article ad placement\n  const h2Blocks = topic.content.split(/(?=<h2[\\s>])/);\n  const total = h2Blocks.length;\n  const mid = Math.max(1, Math.floor(total * 0.5));\n  const firstHalf  = h2Blocks.slice(0, mid).join('');\n  const secondHalf = h2Blocks.slice(mid).join('');\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    '@id': `https://mirelleinspo.com/topics/${slug}#article`,\n    headline: topic.title,\n    description: topic.excerpt,\n    image: topic.image ? `https://mirelleinspo.com${topic.image}` : 'https://mirelleinspo.com/og-default.png',\n    datePublished: topic.date,\n    dateModified: topic.dateModified,\n    author: { '@type': 'Person', name: topic.author },\n    publisher: { '@type': 'Organization', name: 'Mirellé Inspo', logo: { '@type': 'ImageObject', url: 'https://mirelleinspo.com/logo.png' } },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://mirelleinspo.com/topics/${slug}` },\n    ...(topic.sameAs && { sameAs: topic.sameAs }),\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },\n      { '@type': 'ListItem', position: 2, name: 'Topics', item: 'https://mirelleinspo.com/topics' },\n      { '@type': 'ListItem', position: 3, name: topic.title, item: `https://mirelleinspo.com/topics/${slug}` },\n    ],\n  };\n\n  const faqSchema = topic.faqItems?.length ? {\n    '@context': 'https://schema.org',\n    '@type': 'FAQPage',\n    mainEntity: topic.faqItems.map((faq: any) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })),\n  } : null;\n\n  const howToSchema = topic.tutorial?.length ? {\n    '@context': 'https://schema.org',\n    '@type': 'HowTo',\n    name: topic.title,\n    description: topic.excerpt,\n    image: topic.image ? `https://mirelleinspo.com${topic.image}` : undefined,\n    step: topic.tutorial.map((step: any, index: number) => ({ '@type': 'HowToStep', position: index + 1, name: step.step, text: step.description, ...(step.image && { image: `https://mirelleinspo.com${step.image}` }) })),\n  } : null;\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n      {faqSchema && <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(faqSchema) }} />}\n      {howToSchema && <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(howToSchema) }} />}\n\n      <main className=\"min-h-screen bg-background\">\n        {/* Header */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20\">\n            <nav className=\"mb-8\" aria-label=\"Breadcrumb\">\n              <ol className=\"flex items-center space-x-2 font-ui text-xs text-foreground/60\">\n                <li><Link href=\"/\" className=\"hover:text-foreground transition-colors\">Home</Link></li>\n                <li>/</li>\n                <li><Link href=\"/topics\" className=\"hover:text-foreground transition-colors\">Topics</Link></li>\n                <li>/</li>\n                <li className=\"text-foreground\">{topic.title}</li>\n              </ol>\n            </nav>\n            <span className=\"font-ui text-xs tracking-wider text-foreground/60 uppercase block mb-6\">{topic.category}</span>\n            <h1 className=\"font-heading text-4xl sm:text-5xl md:text-6xl text-foreground mb-6 leading-tight\">{topic.title}</h1>\n            <p className=\"font-body text-lg md:text-xl text-foreground/70 leading-relaxed mb-8\">{topic.excerpt}</p>\n            <div className=\"flex items-center space-x-4 font-ui text-sm text-foreground/60\">\n              <span>{topic.author}</span>\n              <span>•</span>\n              <span>{topic.readTime}</span>\n              <span>•</span>\n              <time dateTime={topic.date}>{new Date(topic.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>\n            </div>\n          </div>\n        </section>\n\n        {topic.image && (\n          <section className=\"border-b border-foreground/10\">\n            <div className=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12\">\n              <div className=\"relative w-full overflow-hidden bg-foreground/5\">\n                <img src={topic.image} alt={topic.imageAlt || topic.title} className=\"w-full h-auto\" />\n              </div>\n            </div>\n          </section>\n        )}\n\n        {/* Below-header banner */}\n        <div className=\"w-full flex justify-center bg-white border-b border-gray-100\">\n          <div className=\"w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-3\">\n            <AdUnit slot=\"7344844991\" type=\"banner\" />\n          </div>\n        </div>\n\n        {/* Content + Sidebar */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16\">\n            <div className=\"flex gap-12 items-start\">\n              <div className=\"flex-1 min-w-0 max-w-[700px]\">\n                <article className=\"prose-content-magazine\">\n                  <div dangerouslySetInnerHTML={{ __html: firstHalf }} />\n\n                  {/* In-article native ad at ~50% */}\n                  <AdUnit slot=\"3142865785\" type=\"inArticle\" className=\"my-8\" />\n\n                  <div dangerouslySetInnerHTML={{ __html: secondHalf }} />\n                </article>\n              </div>\n\n              {/* Desktop sidebar */}\n              <AdSidebar />\n            </div>\n          </div>\n        </section>\n\n        {author && <AuthorCard author={author} />}\n      </main>\n    </>\n  );\n}"
