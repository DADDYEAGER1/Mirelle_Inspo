      "path": "src/lib/encyclopedia.ts",
      "content": "// src/lib/encyclopedia.ts\n// Reads all content files at build time and organises them into encyclopedia sections.\n// No API calls, no cost. Runs during next build automatically.\n\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\n\nexport interface EncyclopediaEntry {\n  title: string;\n  excerpt: string;\n  canonical: string;\n  slug: string;\n  contentType: 'blog' | 'faq' | 'work-nails' | 'topic' | 'spotlight';\n  tags?: string[];\n  image?: string;\n  imageAlt?: string;\n}\n\nexport interface EncyclopediaSection {\n  id: string;\n  title: string;\n  entries: EncyclopediaEntry[];\n}\n\n// ─── Section definitions ────────────────────────────────────────────────────\n// Each section has a matcher function that decides if a post belongs there.\n// Order matters — first match wins, so put more specific sections first.\n\nconst SECTIONS: { id: string; title: string; match: (entry: RawEntry) => boolean }[] = [\n  {\n    id: 'nail-shapes',\n    title: 'Nail Shapes',\n    match: (e) =>\n      /\\b(coffin|almond|stiletto|square|oval|squoval|ballerina|round nail|nail shape|short nail|long nail)\\b/i.test(\n        e.title + ' ' + e.tags\n      ) && !/work|professional|office/i.test(e.title),\n  },\n  {\n    id: 'nail-techniques',\n    title: 'Nail Techniques & Finishes',\n    match: (e) =>\n      /\\b(chrome|cat eye|jelly|french tip|french manicure|ombre|glazed donut|velvet|syrup|blooming|barcode|mismatched|gel nails|acrylic|press.on|BIAB|manicure type|reverse french|micro french|double french|colored french|jelly french)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'nail-aesthetics',\n    title: 'Nail Aesthetics & Vibes',\n    match: (e) =>\n      /\\b(aesthetic|quiet luxury|old money|rich girl|dark feminine|mob wife|soft girl|office siren|goth|pastel goth|whimsigoth|witchy|cyber goth|clean girl|coquette|glazed|bambi|pucci|plaid|argyle|lace|floral|celestial|goddess|vampire|vampy)\\b/i.test(\n        e.title\n      ) && !/work|professional|office|pride|lgbtq|lesbian|bisexual|trans|nonbinary|pan/i.test(e.title),\n  },\n  {\n    id: 'nail-colors',\n    title: 'Nail Colors',\n    match: (e) =>\n      /\\b(nail colo(u)?r|black nails|white nails|red nails|pink nails|blue nails|green nails|purple nails|nude nails|burgundy|coral nails|orange nails|sage|lavender nails|chocolate brown|turquoise|sky blue|jade|chartreuse|wasabi|plum nails|butter yellow|blueberry|tomato red|hot pink|neon|milky pink|rose gold|silver|icy blue|mermaid chrome|white chrome|pink chrome|green cat eye|galaxy cat eye|pink cat eye)\\b/i.test(\n        e.title\n      ) && !/skin tone/i.test(e.title),\n  },\n  {\n    id: 'work-professional',\n    title: 'Work & Professional Nails',\n    match: (e) =>\n      /\\b(work nail|professional nail|office nail|workplace|job interview|corporate|conservative|customer.facing|new job|neutral nail|nail length.*work|work.*nail length|gel.*work|acrylic.*work|nail polish.*work|clear nail polish|colou?red nail polish.*work|unprofessional)\\b/i.test(\n        e.title\n      ) || e.contentType === 'work-nails',\n  },\n  {\n    id: 'by-occasion',\n    title: 'By Occasion',\n    match: (e) =>\n      /\\b(prom|wedding|bridal|bride|valentine|mother.s day|holiday|vacation|graduation|christmas|halloween|new year|thanksgiving|cinco de mayo|EDC|rave|beach|summer nail|spring nail|winter nail|fall nail|seasonal|trend 202[0-9]|nail trend)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'nail-art-diy',\n    title: 'Nail Art & DIY',\n    match: (e) =>\n      /\\b(at.home|DIY|how to|step.by.step|beginner|easy nail|hacks|tutorial|apply chrome|shape.*home|do.*home)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'by-skin-tone',\n    title: 'By Skin Tone',\n    match: (e) =>\n      /\\b(skin tone|fair skin|dark skin|olive skin|medium skin|brunette|blonde|redhead|undertone)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'zodiac',\n    title: 'Zodiac & Astrology Nails',\n    match: (e) =>\n      /\\b(zodiac|astrology|aries|taurus|gemini|cancer|leo|virgo|libra|scorpio|sagittarius|capricorn|aquarius|pisces|birth chart)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'lgbtq-pride',\n    title: 'LGBTQ+ & Pride Nails',\n    match: (e) =>\n      /\\b(pride|lgbtq|lesbian|bisexual|trans|nonbinary|non.binary|pansexual|gay nails|WLW|enby|rainbow nail|bi flag|pride flag)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'nail-faqs',\n    title: 'Nail FAQs & Care',\n    match: (e) =>\n      e.contentType === 'faq' ||\n      /\\b(are.*worth|can i|can you|should i|how long|how much|how often|why do|what are|what is|what.s the|what should|what nail|how do i|how to care|how to grow|how to keep|remove.*gel|remove.*nail|allergic|doctor|health|pregnant|surgery|stronger|healthy nail|nail care|manicure cost|tip.*nail tech|nail salon near)\\b/i.test(\n        e.title\n      ),\n  },\n  {\n    id: 'spotlights',\n    title: 'Artist Spotlights',\n    match: (e) => e.contentType === 'spotlight',\n  },\n];\n\n// ─── Business page exclusion ─────────────────────────────────────────────────\nconst BUSINESS_KEYWORDS =\n  /\\b(georgia|atlanta|augusta|savannah|columbus|marietta|buckhead|roswell|midtown|sandy springs|gwinnett|decatur|shelby township|michigan)\\b/i;\n\n// ─── Internal types ───────────────────────────────────────────────────────────\ninterface RawEntry {\n  title: string;\n  excerpt: string;\n  canonical: string;\n  slug: string;\n  contentType: EncyclopediaEntry['contentType'];\n  tags: string[];\n  image?: string;\n  imageAlt?: string;\n}\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\nfunction readContentDir(\n  dirPath: string,\n  contentType: EncyclopediaEntry['contentType'],\n  slugPrefix: string\n): RawEntry[] {\n  if (!fs.existsSync(dirPath)) return [];\n\n  const entries: RawEntry[] = [];\n\n  function walk(dir: string) {\n    const items = fs.readdirSync(dir);\n    for (const item of items) {\n      const fullPath = path.join(dir, item);\n      const stat = fs.statSync(fullPath);\n      if (stat.isDirectory()) {\n        walk(fullPath);\n      } else if (item.endsWith('.md') || item.endsWith('.mdx')) {\n        try {\n          const raw = fs.readFileSync(fullPath, 'utf-8');\n          const { data } = matter(raw);\n\n          // Skip business pages\n          const titleAndCanon = (data.title || '') + ' ' + (data.canonical || '');\n          if (BUSINESS_KEYWORDS.test(titleAndCanon)) continue;\n\n          // Skip if no title\n          if (!data.title) continue;\n\n          const slug = data.slug || item.replace(/\\.mdx?$/, '');\n          const canonical = `https://mirelleinspo.com/${slugPrefix}/${slug}`;\n\n          entries.push({\n            title: data.title,\n            excerpt: data.excerpt || '',\n            canonical,\n            slug,\n            contentType,\n            tags: Array.isArray(data.tags) ? data.tags : [],\n            image: data.image,\n            imageAlt: data.imageAlt,\n          });\n        } catch {\n          // skip malformed files\n        }\n      }\n    }\n  }\n\n  walk(dirPath);\n  return entries;\n}\n\n// ─── Image counter ────────────────────────────────────────────────────────────\nconst IMAGE_EXTENSIONS = new Set(['.jpg', '.jpeg', '.webp', '.png', '.gif', '.avif']);\n\nfunction countImages(dirs: string[]): number {\n  let count = 0;\n  function walk(dir: string) {\n    if (!fs.existsSync(dir)) return;\n    for (const item of fs.readdirSync(dir)) {\n      const full = path.join(dir, item);\n      if (fs.statSync(full).isDirectory()) {\n        walk(full);\n      } else if (IMAGE_EXTENSIONS.has(path.extname(item).toLowerCase())) {\n        count++;\n      }\n    }\n  }\n  dirs.forEach(walk);\n  return count;\n}\n\n// ─── Main export ──────────────────────────────────────────────────────────────\nexport interface EncyclopediaData {\n  sections: EncyclopediaSection[];\n  totalEntries: number;\n  totalSections: number;\n  imageCount: number; // static number you update manually\n}\n\nexport function getEncyclopediaData(): EncyclopediaData {\n  const contentRoot = path.join(process.cwd(), 'src', 'content');\n\n  // Read every content type\n  const allEntries: RawEntry[] = [\n    ...readContentDir(path.join(contentRoot, 'blogs'), 'blog', 'blog'),\n    ...readContentDir(path.join(contentRoot, 'faqs'), 'faq', 'nail-faqs'),\n    ...readContentDir(path.join(contentRoot, 'work-nails'), 'work-nails', 'work-nails'),\n    ...readContentDir(path.join(contentRoot, 'topics'), 'topic', 'topics'),\n    ...readContentDir(path.join(contentRoot, 'spotlights'), 'spotlight', 'spotlight'),\n    // inspo-images are JSON galleries — we link to the inspo section pages, not individual files\n  ];\n\n  // Remove duplicates by canonical URL\n  const seen = new Set<string>();\n  const unique = allEntries.filter((e) => {\n    if (seen.has(e.canonical)) return false;\n    seen.add(e.canonical);\n    return true;\n  });\n\n  // Assign each entry to its first matching section\n  const sectionMap = new Map<string, RawEntry[]>();\n  SECTIONS.forEach((s) => sectionMap.set(s.id, []));\n\n  for (const entry of unique) {\n    let assigned = false;\n    for (const section of SECTIONS) {\n      if (section.match(entry)) {\n        sectionMap.get(section.id)!.push(entry);\n        assigned = true;\n        break;\n      }\n    }\n    // If nothing matched, drop into FAQs as a catch-all\n    if (!assigned) {\n      sectionMap.get('nail-faqs')!.push(entry);\n    }\n  }\n\n  // Build final sections, sorted alphabetically within each\n  const sections: EncyclopediaSection[] = SECTIONS.map((s) => ({\n    id: s.id,\n    title: s.title,\n    entries: (sectionMap.get(s.id) || []).sort((a, b) =>\n      a.title.localeCompare(b.title)\n    ),\n  })).filter((s) => s.entries.length > 0);\n\n  const totalEntries = sections.reduce((sum, s) => sum + s.entries.length, 0);\n\n  // Image count — reads directly from your public image folders at build time\n  const imageCount = countImages([\n    path.join(process.cwd(), 'public', 'images'),\n    path.join(process.cwd(), 'public', 'inspo'),\n  ]);\n\n  return {\n    sections,\n    totalEntries,\n    totalSections: sections.length,\n    imageCount,\n  };\n}"
    }
  ],
  "missing_files": []
}
