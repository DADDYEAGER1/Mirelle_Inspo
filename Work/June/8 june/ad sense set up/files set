"w-full flex justify-center mt-12\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <div className=\"mb-8\">\n            <Breadcrumbs items={[{ label: 'Work Nails', href: '/work-nails' }]} currentPage={post.title} includeSchema={false} />\n          </div>\n          <div className=\"block lg:hidden mb-8\">\n            <TableOfContents content={post.content} />\n          </div>\n          <div className=\"flex gap-12 items-start\">\n            <div className=\"flex-1 max-w-[700px]\">\n              <article className=\"prose-content-magazine\">\n                <MDXContent source={post.content} products={postProducts} />\n              </article>\n            </div>\n            <aside className=\"hidden lg:block w-[280px] flex-shrink-0 self-start\" style={{ position: 'sticky', top: '6rem' }}>\n              <TableOfContents content={post.content} />\n            </aside>\n          </div>\n        </div>\n      </div>\n\n      {author && <AuthorCard author={author} />}\n      <AboutEEAT />\n      <FinalNewsletter />\n      <ReadMoreSection currentSlug={post.slug} />\n    </div>\n  );\n}"
