      "path": "src/app/nail-faqs/[slug]/page.tsx",
      "content": "// src/app/nail-faqs/[slug]/page.tsx\n\nimport { notFound } from 'next/navigation';\nimport { getFaq, getAllFaqSlugs } from '@/lib/faqs';\nimport { MDXRemote } from 'next-mdx-remote/rsc';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport FaqFinalNewsletter from '@/components/Faqs/FaqFinalNewsletter';\nimport FaqAbout from '@/components/Faqs/FaqAbout';\nimport FaqReadMore from '@/components/Faqs/FaqReadMore';\nimport FaqAskQuestion from '@/components/Faqs/FaqAskQuestion';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\nimport type { Metadata } from 'next';\n\nexport const revalidate = 7776000;\n\n\nconst mdxComponents = {};\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\n\n\nexport async function generateStaticParams() {\n  const slugs = await getAllFaqSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\nconst SITE_URL = 'https://mirelleinspo.com';\nconst FALLBACK_OG_IMAGE = `${SITE_URL}/og-default.png`;\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n  if (!faq) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n  const canonicalUrl = faq.canonical || `${SITE_URL}/nail-faqs/${slug}`;\n\n  return {\n    title: `${faq.title} | Mirellé`,\n    description: faq.excerpt,\n    authors: [{ name: faq.author }],\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: faq.title,\n      description: faq.excerpt,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirellé',\n      images: [{ url: FALLBACK_OG_IMAGE, alt: faq.title }],\n      publishedTime: faq.date,\n      modifiedTime: faq.dateModified || faq.date,\n      authors: [faq.author],\n      section: faq.category,\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: faq.title,\n      description: faq.excerpt,\n      images: [FALLBACK_OG_IMAGE],\n    },\n  };\n}\n\nexport default async function NailFaqPage({ params }: PageProps) {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n  if (!faq) notFound();\n\n  const author = faq.author ? getAuthor(faq.author) : null;\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    headline: faq.title,\n    description: faq.excerpt,\n    image: FALLBACK_OG_IMAGE,\n    datePublished: faq.date,\n    dateModified: faq.dateModified || faq.date,\n    author: { '@type': 'Person', name: faq.author },\n    publisher: {\n      '@type': 'Organization',\n      name: 'Mirellé Inspo',\n      logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },\n    },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/nail-faqs/${slug}` },\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },\n      { '@type': 'ListItem', position: 2, name: 'Nail FAQs', item: `${SITE_URL}/nail-faqs` },\n      { '@type': 'ListItem', position: 3, name: faq.title },\n    ],\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n\n      <div className=\"min-h-screen bg-background\">\n        <div className=\"w-full flex flex-col items-start\">\n          <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16 py-8 md:py-12\">\n            <div className=\"mb-6\">\n              <Breadcrumbs items={[{ label: 'Nail FAQs', href: '/nail-faqs' }]} currentPage={faq.title} includeSchema={false} />\n            </div>\n            <p className=\"text-sm uppercase tracking-wide text-gray-700 mb-4\">{faq.category}</p>\n            <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\">{faq.title}</h1>\n            <div className=\"text-sm text-gray-700 mb-8\">\n              <p className=\"uppercase tracking-wide mb-1\">BY {faq.author}</p>\n              <time dateTime={faq.date} className=\"text-gray-600\">\n                {new Date(faq.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}\n              </time>\n            </div>\n            <article className=\"prose-content-magazine\">\n              <MDXRemote source={faq.content} components={mdxComponents} />\n            </article>\n\n            {/* Mid-post: Ask Your Question */}\n            <FaqAskQuestion />\n          </div>\n        </div>\n\n        {author && <AuthorCard author={author} />}\n        <FaqAbout />\n\n        {/* End of post: Ask Your Question */}\n        <FaqAskQuestion />\n\n        <FaqFinalNewsletter />\n        <FaqReadMore currentSlug={faq.slug} />\n      </div>\n    </>\n  );\n}"
    },
    {
      "path": "src/components/business/BusinessTemplate.tsx",
      "content": "'use client';\n\nimport { useState } from 'react';\nimport Image from 'next/image';\nimport { MDXRemote, MDXRemoteSerializeResult } from 'next-mdx-remote';\nimport { BusinessPost } from '@/types/business';\nimport { Author } from '@/types/author';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport AuthorCard from '@/components/Blog/AuthorCard';\n\ninterface BusinessTemplateProps {\n  post: BusinessPost;\n  mdxSource?: MDXRemoteSerializeResult;\n  author?: Author;\n}\n\n// ─── FAQ Accordion ─────────────────────────────────────────────────────────────\n\nfunction FAQAccordion({ faqs }: { faqs: BusinessPost['faqSchema'] }) {\n  const [openIndex, setOpenIndex] = useState<number | null>(null);\n\n  return (\n    <div className=\"divide-y divide-[#E0E0E0]\">\n      {faqs.map((faq, i) => (\n        <div key={i} className=\"py-5\">\n          <button\n            onClick={() => setOpenIndex(openIndex === i ? null : i)}\n            className=\"w-full flex items-start justify-between gap-4 text-left\"\n            aria-expanded={openIndex === i}\n          >\n            <span className=\"font-heading text-h4-mobile md:text-h4 text-foreground\">\n              {faq.question}\n            </span>\n            <span className=\"font-ui text-ui text-[#666666] flex-shrink-0 mt-1\">\n              {openIndex === i ? '−' : '+'}\n            </span>\n          </button>\n          {openIndex === i && (\n            <p className=\"mt-4 font-body text-body text-foreground leading-relaxed\">\n              {faq.answer}\n            </p>\n          )}\n        </div>\n      ))}\n    </div>\n  );\n}\n\n// ─── Main Template ─────────────────────────────────────────────────────────────\n\nexport default function BusinessTemplate({ post, mdxSource, author }: BusinessTemplateProps) {\n  const emailSubject = encodeURIComponent(`Collaboration Enquiry  ${post.region}`);\n  const emailHref = `mailto:${post.contact.email}?subject=${emailSubject}`;\n  const whatsappHref = post.contact.whatsapp\n    ? `https://wa.me/${post.contact.whatsapp.replace(/\\D/g, '')}`\n    : null;\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n\n      {/* ── 1. HERO ──────────────────────────────────────────────────────────── */}\n      <section className=\"w-full\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n            <div className=\"mb-8\">\n              <Breadcrumbs\n                items={[{ label: 'Business', href: '/business' }]}\n                currentPage={post.region}\n                includeSchema={false}\n              />\n            </div>\n            <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">\n              {post.city} · {post.country}\n            </p>\n            <h1 className=\"font-heading text-h1-mobile md:text-h1 text-foreground max-w-[700px] leading-tight mb-8\">\n              {post.title}\n            </h1>\n            <div className=\"max-w-[700px] border-l-2 border-foreground pl-6 mb-10 business-tldr\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-2\">\n                TL;DR\n              </p>\n              <p className=\"font-body text-body-lg text-foreground leading-relaxed\">\n                {post.tldr}\n              </p>\n            </div>\n            <a\n              href={emailHref}\n              className=\"inline-block font-ui text-ui uppercase tracking-wider bg-foreground text-background px-8 py-4 hover:opacity-80 transition-opacity\"\n            >\n              Get in Touch\n            </a>\n          </div>\n        </div>\n      </section>\n\n      {/* ── 1.5 PAIN BLOCK ──────────────────────────────────────────────── */}\n      {post.painPoint && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"max-w-[700px]\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">\n                  The Problem\n                </p>\n                <p className=\"font-heading text-h2-mobile md:text-h2 text-foreground leading-tight\">\n                  {post.painPoint}\n                </p>\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* ── 2. SERVICES ──────────────────────────────────────────────────────── */}\n      {post.services.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">\n                What We Offer\n              </p>\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10\">\n                {post.services.map((service, i) => (\n                  <div key={i} className=\"border-t border-[#E0E0E0] pt-6\">\n                    <h2 className=\"font-heading text-h3-mobile md:text-h3 text-foreground mb-3\">\n                      {service.title}\n                    </h2>\n                    <p className=\"font-body text-body text-foreground leading-relaxed\">\n                      {service.description}\n                    </p>\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* ── 2.5 STATS BLOCK ─────────────────────────────────────────────── */}\n      {post.statBlock && post.statBlock.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-10\">\n                {post.statBlock.map((item, i) => (\n                  <div key={i} className=\"border-t border-[#E0E0E0] pt-6\">\n                    <p className=\"font-heading text-h2-mobile md:text-h2 text-foreground mb-2\">\n                      {item.stat}\n                    </p>\n                    <p className=\"font-body text-body text-[#666666] leading-relaxed\">\n                      {item.context}\n                    </p>\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* ── 3. GALLERY ───────────────────────────────────────────────────────── */}\n      {post.galleryImages && post.galleryImages.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">\n                Our Work\n              </p>\n              <div className=\"columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4\">\n                {post.galleryImages.map((img, i) => (\n                  <div key={i} className=\"break-inside-avoid overflow-hidden\">\n                    <Image\n                      src={img.url}\n                      alt={img.alt}\n                      width={img.width || 800}\n                      height={img.height || 1000}\n                      className=\"w-full h-auto object-cover\"\n                      sizes=\"(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw\"\n                    />\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* ── 4. BODY CONTENT + ABOUT ──────────────────────────────────────────── */}\n      <section className=\"w-full border-t border-[#E0E0E0]\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n            <div className=\"max-w-[700px]\">\n              <article className=\"prose-content-magazine mb-16 business-about\">\n                {post.isMDX && mdxSource ? (\n                  <MDXRemote {...mdxSource} />\n                ) : (\n                  <div dangerouslySetInnerHTML={{ __html: post.content }} />\n                )}\n              </article>\n              <div className=\"border-t border-[#E0E0E0] pt-10\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">\n                  About Mirellé\n                </p>\n                <h2 className=\"font-heading text-h2-mobile md:text-h2 text-foreground mb-4\">\n                  An editorial nail platform\n                </h2>\n                <p className=\"font-body text-body text-foreground leading-relaxed\">\n                  Mirellé is a nail inspiration and editorial platform dedicated to the art,\n                  aesthetics, and culture of nails. We produce original content trends,\n                  editorials, and campaign direction for brands and salons that hold a\n                  standard. Based online, working globally.\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* ── 5. FAQ ───────────────────────────────────────────────────────────── */}\n      {post.faqSchema.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"max-w-[700px]\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">\n                  Frequently Asked\n                </p>\n                <FAQAccordion faqs={post.faqSchema} />\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* ── 6. AUTHOR CARD ───────────────────────────────────────────────────── */}\n      {author && <AuthorCard author={author} />}\n\n      {/* ── 7. CTA BLOCK ─────────────────────────────────────────────────────── */}\n      <section className=\"w-full border-t border-[#E0E0E0] bg-foreground\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-16 md:py-24\">\n            <p className=\"font-ui text-ui uppercase tracking-wider text-background opacity-60 mb-6\">\n              Work with us · {post.region}\n            </p>\n            <h2 className=\"font-heading text-h1-mobile md:text-h1 text-background max-w-[600px] leading-tight mb-10\">\n              Let's make something worth looking at.\n            </h2>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <a\n                href={emailHref}\n                className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\"\n              >\n                Email Us\n              </a>\n              {whatsappHref && (\n                <a\n                  href={whatsappHref}\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\"\n                >\n                  WhatsApp\n                </a>\n              )}\n              {post.contact.instagram && (\n                <a\n                  href={post.contact.instagram}\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\"\n                >\n                  Instagram\n                </a>\n              )}\n            </div>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  );\n}"
    }
  ],
  "missing_files": []
}
