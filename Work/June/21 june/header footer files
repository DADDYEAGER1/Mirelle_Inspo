// src/components/Footer.tsx
// Server component  fetches latest blog/shop/inspo at build time, zero runtime cost.

import Link from 'next/link';
import Image from 'next/image';
import { getAllBlogPosts } from '@/lib/blog';
import { getAllShopPosts } from '@/lib/shop';
import { getAllDesignSlugs, getDesignData } from '@/lib/inspo';
import FooterClient from './FooterClient';

async function getFooterData() {
  const [allBlogs, allShop] = await Promise.all([
    getAllBlogPosts(),
    getAllShopPosts(),
  ]);

  const blogs = allBlogs.slice(0, 50).map(p => ({
    title: p.title,
    url: p.url.replace('https://mirelleinspo.com', ''),
  }));

  const shop = allShop.slice(0, 40).map(p => ({
    title: p.title,
    url: `/shop/${p.slug}`,
  }));

  const allInspoSlugs = getAllDesignSlugs();
  const inspoSlugs = allInspoSlugs.slice(-10).reverse();
  const inspo = inspoSlugs
    .map(slug => {
      const d = getDesignData(slug);
      if (!d) return null;
      return { title: d.displayName, url: `/inspo/${slug}` };
    })
    .filter(Boolean) as { title: string; url: string }[];

  return { blogs, shop, inspo };
}

