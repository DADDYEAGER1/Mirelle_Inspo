      "path": "src/components/Blog/MustReadSection.tsx",
      "content": "import CompactBlogCard from './CompactBlogCard';\nimport { BlogMetadata } from '@/types/blog';\n\ninterface MustReadSectionProps {\n  posts: BlogMetadata[];\n}\n\nexport default function MustReadSection({ posts }: MustReadSectionProps) {\n  // Take first 3 posts\n  const displayPosts = posts.slice(0, 3);\n\n  return (\n    <section className=\"py-16 bg-white\">\n      <div className=\"max-w-[1200px] mx-auto px-6 md:px-16 lg:px-20\">\n        {/* Section Heading */}\n        <h2 \n          className=\"text-3xl md:text-4xl text-center mb-12\"\n          style={{ fontFamily: 'Larken, Georgia, serif' }}\n        >\n          MUST READ\n        </h2>\n\n        {/* Cards Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12\">\n          {displayPosts.map((post) => (\n            <CompactBlogCard key={post.slug} post={post} />\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}"
