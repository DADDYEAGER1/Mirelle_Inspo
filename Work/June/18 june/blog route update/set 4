      "path": "src/app/api/search/route.ts",
      "content": "// src/app/api/search/route.ts\nimport { NextRequest, NextResponse } from 'next/server';\nimport { getAllBlogPosts } from '@/lib/blog';\nimport { getAllFaqs } from '@/lib/faqs';\nimport { getAllWorkNailsPosts } from '@/lib/workNails';\nimport { getAllTopics } from '@/lib/topic';\nimport { getAllSpotlightPosts } from '@/lib/spotlight';\nimport { getAllBusinessPosts } from '@/lib/business';\nimport { getAllReports } from '@/lib/reports';\nimport { getAllDesignSlugs, getDesignData } from '@/lib/inspo';\n\nexport interface SearchResult {\n  title: string;\n  excerpt: string;\n  url: string;\n  type: 'blog' | 'inspo' | 'faq' | 'work-nails' | 'topic' | 'spotlight' | 'business' | 'report';\n  slug: string;\n}\n\nfunction fuzzyMatch(text: string, query: string): boolean {\n  const normalizedText = text.toLowerCase();\n  const normalizedQuery = query.toLowerCase().trim();\n  if (!normalizedQuery) return false;\n\n  // Direct substring match\n  if (normalizedText.includes(normalizedQuery)) return true;\n\n  // Word-by-word match — all words must appear somewhere in text\n  const words = normalizedQuery.split(/\\s+/).filter(Boolean);\n  if (words.length > 1) {\n    return words.every(word => normalizedText.includes(word));\n  }\n\n  return false;\n}\n\nfunction scoreResult(title: string, excerpt: string, query: string): number {\n  const q = query.toLowerCase().trim();\n  let score = 0;\n  const t = title.toLowerCase();\n  const e = excerpt.toLowerCase();\n\n  if (t === q) score += 100;\n  else if (t.startsWith(q)) score += 80;\n  else if (t.includes(q)) score += 60;\n  else score += 20; // word match via excerpt\n\n  if (e.includes(q)) score += 10;\n\n  return score;\n}\n\nexport async function GET(request: NextRequest) {\n  const { searchParams } = new URL(request.url);\n  const query = searchParams.get('q')?.trim() || '';\n\n  if (!query || query.length < 2) {\n    return NextResponse.json({ results: [] });\n  }\n\n  const results: (SearchResult & { score: number })[] = [];\n\n  try {\n    // --- Blogs ---\n    const blogs = await getAllBlogPosts();\n    for (const post of blogs) {\n      const searchable = `${post.title} ${post.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        const url = post.topic\n          ? `/blog/${post.topic}/${post.slug}`\n          : `/blog/${post.slug}`;\n        results.push({\n          title: post.title,\n          excerpt: post.excerpt,\n          url,\n          type: 'blog',\n          slug: post.slug,\n          score: scoreResult(post.title, post.excerpt, query),\n        });\n      }\n    }\n\n    // --- Inspo Designs (category-level only) ---\n    const designSlugs = getAllDesignSlugs();\n    for (const slug of designSlugs) {\n      const design = getDesignData(slug);\n      if (!design) continue;\n      if (fuzzyMatch(`${design.displayName} ${design.description || ''}`, query)) {\n        results.push({\n          title: design.displayName,\n          excerpt: design.description || '',\n          url: `/inspo/${slug}`,\n          type: 'inspo',\n          slug,\n          score: scoreResult(design.displayName, design.description || '', query),\n        });\n      }\n    }\n\n    // --- FAQs ---\n    const faqs = await getAllFaqs();\n    for (const faq of faqs) {\n      const searchable = `${faq.title} ${faq.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: faq.title,\n          excerpt: faq.excerpt,\n          url: `/nail-faqs/${faq.slug}`,\n          type: 'faq',\n          slug: faq.slug,\n          score: scoreResult(faq.title, faq.excerpt, query),\n        });\n      }\n    }\n\n    // --- Work Nails ---\n    const workNails = await getAllWorkNailsPosts();\n    for (const post of workNails) {\n      const searchable = `${post.title} ${post.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: post.title,\n          excerpt: post.excerpt,\n          url: `/work-nails/${post.slug}`,\n          type: 'work-nails',\n          slug: post.slug,\n          score: scoreResult(post.title, post.excerpt, query),\n        });\n      }\n    }\n\n    // --- Topics ---\n    const topics = await getAllTopics();\n    for (const topic of topics) {\n      const searchable = `${topic.title} ${topic.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: topic.title,\n          excerpt: topic.excerpt,\n          url: `/topics/${topic.slug}`,\n          type: 'topic',\n          slug: topic.slug,\n          score: scoreResult(topic.title, topic.excerpt, query),\n        });\n      }\n    }\n\n    // --- Spotlights ---\n    const spotlights = await getAllSpotlightPosts();\n    for (const post of spotlights) {\n      const searchable = `${post.title} ${post.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: post.title,\n          excerpt: post.excerpt,\n          url: `/spotlight/${post.slug}`,\n          type: 'spotlight',\n          slug: post.slug,\n          score: scoreResult(post.title, post.excerpt, query),\n        });\n      }\n    }\n\n    // --- Business ---\n    const business = await getAllBusinessPosts();\n    for (const post of business) {\n      const searchable = `${post.title} ${post.excerpt} ${post.city} ${post.state}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: post.title,\n          excerpt: post.excerpt,\n          url: post.url,\n          type: 'business',\n          slug: post.slug,\n          score: scoreResult(post.title, post.excerpt, query),\n        });\n      }\n    }\n\n    // --- Reports ---\n    const reports = await getAllReports();\n    for (const report of reports) {\n      const searchable = `${report.title} ${report.excerpt}`;\n      if (fuzzyMatch(searchable, query)) {\n        results.push({\n          title: report.title,\n          excerpt: report.excerpt,\n          url: `/trend-reports/${report.slug}`,\n          type: 'report',\n          slug: report.slug,\n          score: scoreResult(report.title, report.excerpt, query),\n        });\n      }\n    }\n\n    // Sort by score descending, cap at 20 results\n    results.sort((a, b) => b.score - a.score);\n    const topResults = results.slice(0, 20).map(({ score, ...rest }) => rest);\n\n    return NextResponse.json({ results: topResults });\n  } catch (error) {\n    console.error('Search error:', error);\n    return NextResponse.json({ results: [], error: 'Search failed' }, { status: 500 });\n  }\n}"
