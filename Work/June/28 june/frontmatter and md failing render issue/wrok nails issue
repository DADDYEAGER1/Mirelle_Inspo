      "content": "// src/lib/workNails.ts\nimport 'server-only';\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\nimport { WorkNailsPost, WorkNailsMetadata } from '@/types/workNails';\n\nconst WORK_NAILS_DIRECTORY = path.join(process.cwd(), 'src/content/work-nails');\n\n// ─── Helpers ─────────────────────────────────────────────────────────────────\n\n/**\n * Returns the .mdx file path for a slug, or null if not found.\n * work-nails is MDX-only  no .md fallback.\n */\nfunction resolveFilePath(slug: string): string | null {\n  const mdxPath = path.join(WORK_NAILS_DIRECTORY, `${slug}.mdx`);\n  if (fs.existsSync(mdxPath)) return mdxPath;\n  return null;\n}\n\n/**\n * Returns all .mdx files from the content directory.\n */\nfunction getAllWorkNailsFiles(): string[] {\n  try {\n    return fs.readdirSync(WORK_NAILS_DIRECTORY).filter(file => file.endsWith('.mdx'));\n  } catch {\n    return [];\n  }\n}\n\n/**\n * Strips .mdx extension from a filename to get the slug.\n */\nfunction fileToSlug(filename: string): string {\n  return filename.replace(/\\.mdx$/, '');\n}\n\n// ─── Cache ───────────────────────────────────────────────────────────────────\n\ninterface CacheEntry<T> {\n  data: T;\n  timestamp: number;\n}\n\nclass WorkNailsCache {\n  private cache = new Map<string, CacheEntry<any>>();\n  private readonly TTL = 3600000;\n\n  get<T>(key: string): T | null {\n    const entry = this.cache.get(key);\n    if (!entry) return null;\n    if (Date.now() - entry.timestamp > this.TTL) {\n      this.cache.delete(key);\n      return null;\n    }\n    return entry.data as T;\n  }\n\n  set<T>(key: string, data: T): void {\n    this.cache.set(key, { data, timestamp: Date.now() });\n  }\n\n  clear(): void {\n    this.cache.clear();\n  }\n}\n\nconst workNailsCache = new WorkNailsCache();\nworkNailsCache.clear();\n\n// ─── Public API ───────────────────────────────────────────────────────────────\n\nexport async function getAllWorkNailsPosts(): Promise<WorkNailsMetadata[]> {\n  const cacheKey = 'all-work-nails-posts';\n\n  const cached = workNailsCache.get<WorkNailsMetadata[]>(cacheKey);\n  if (cached) return cached;\n\n  try {\n    const files = getAllWorkNailsFiles();\n\n    const posts = files\n      .map(file => {\n        const slug     = fileToSlug(file);\n        const filePath = path.join(WORK_NAILS_DIRECTORY, file);\n        const content  = fs.readFileSync(filePath, 'utf8');\n        const { data } = matter(content);\n\n        return {\n          slug,\n          title:             data.title      || 'Untitled',\n          excerpt:           data.excerpt    || '',\n          date:              data.date       || new Date().toISOString(),\n          author:            data.author     || 'Mirellé Team',\n          category:          data.category,\n          image:             data.image      || null,\n          imageAlt:          data.imageAlt,\n          imageWidth:        data.imageWidth  || 1200,\n          imageHeight:       data.imageHeight || 630,\n          readTime:          data.readTime   || '5 min',\n          canonical:         data.canonical  || `https://mirelleinspo.com/work-nails/${slug}`,\n          template:          data.template   || 'center',\n          topicalMap:        data.topicalMap,\n          navigationContext: data.navigationContext,\n          url:               `https://mirelleinspo.com/work-nails/${slug}`,\n        } as WorkNailsMetadata;\n      })\n      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n\n    workNailsCache.set(cacheKey, posts);\n    return posts;\n  } catch (error) {\n    console.error('Error reading work-nails posts:', error);\n    return [];\n  }\n}\n\nexport async function getWorkNailsPost(slug: string): Promise<WorkNailsPost | null> {\n  const cacheKey = `work-nails-post:${slug}`;\n\n  const cached = workNailsCache.get<WorkNailsPost>(cacheKey);\n  if (cached) return cached;\n\n  try {\n    const filePath = resolveFilePath(slug);\n    if (!filePath) {\n      console.error(`Work-nails post not found: ${slug}`);\n      return null;\n    }\n\n    const fileContent = fs.readFileSync(filePath, 'utf8');\n    const { data, content: rawContent } = matter(fileContent);\n\n    // MDX only  return raw source for next-mdx-remote to compile\n    const post: WorkNailsPost = {\n      slug,\n      title:             data.title      || 'Untitled',\n      excerpt:           data.excerpt    || '',\n      content:           rawContent,\n      isMDX:             true,\n      date:              data.date       || new Date().toISOString(),\n      author:            data.author     || 'Mirellé Team',\n      category:          data.category,\n      image:             data.image      || null,\n      imageAlt:          data.imageAlt,\n      imageWidth:        data.imageWidth  || 1200,\n      imageHeight:       data.imageHeight || 630,\n      readTime:          data.readTime   || '5 min',\n      canonical:         data.canonical  || `https://mirelleinspo.com/work-nails/${slug}`,\n      template:          data.template   || 'center',\n      topicalMap:        data.topicalMap,\n      navigationContext: data.navigationContext,\n      carouselImages:    data.carouselImages,\n      products:          data.products,\n      coverImage:        data.image      || '/images/default-blog.jpg',\n      tags:              data.tags,\n      imageCaption:      data.imageCaption,\n      dateModified:      data.dateModified,\n      wordCount:         data.wordCount,\n      faqItems:          data.faqItems,\n    };\n\n    workNailsCache.set(cacheKey, post);\n    return post;\n  } catch (error) {\n    console.error(`Error reading work-nails post ${slug}:`, error);\n    return null;\n  }\n}\n\nexport async function getAllWorkNailsSlugs(): Promise<string[]> {\n  try {\n    return getAllWorkNailsFiles().map(fileToSlug);\n  } catch (error) {\n    console.error('Error reading work-nails slugs:', error);\n    return [];\n  }\n}\n\nexport async function getWorkNailsPostsByCategory(categorySlug: string): Promise<WorkNailsMetadata[]> {\n  const allPosts = await getAllWorkNailsPosts();\n  return allPosts.filter(post => post.category === categorySlug);\n}\n\nexport async function getRelatedWorkNailsPosts(\n  currentSlug: string,\n  limit: number = 9\n): Promise<WorkNailsMetadata[]> {\n  const currentPost = await getWorkNailsPost(currentSlug);\n  if (!currentPost) return [];\n\n  const allPosts = await getAllWorkNailsPosts();\n\n  const sameCategoryPosts = allPosts\n    .filter(post => post.slug !== currentSlug && post.category === currentPost.category)\n    .slice(0, limit);\n\n  if (sameCategoryPosts.length < limit) {\n    const remaining  = limit - sameCategoryPosts.length;\n    const otherPosts = allPosts\n      .filter(post =>\n        post.slug !== currentSlug &&\n        !sameCategoryPosts.some(sp => sp.slug === post.slug)\n      )\n      .slice(0, remaining);\n\n    return [...sameCategoryPosts, ...otherPosts];\n  }\n\n  return sameCategoryPosts;\n}\n\nexport function clearWorkNailsCache() {\n  workNailsCache.clear();\n}"
