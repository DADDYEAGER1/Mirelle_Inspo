      "content": "// src/app/work-nails/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { getWorkNailsPost, getAllWorkNailsSlugs } from '@/lib/workNails';\nimport type { Metadata } from 'next';\nimport { generateSchemas } from '@/lib/generateSchemas';\n\nimport CenterTemplate from './templates/CenterTemplate';\nimport SplitLeftTemplate from './templates/SplitLeftTemplate';\nimport { resolveAuthor } from '@/data/authors';\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\ninterface PageProps {\n  params: Promise<{\n    slug: string;\n  }>;\n}\n\n\n\nexport async function generateStaticParams() {\n  const slugs = await getAllWorkNailsSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\n \n\nexport async function generateMetadata({\n  params,\n}: {\n  params: Promise<{ slug: string }>;\n}): Promise<Metadata> {\n  const { slug } = await params;\n  const post = await getWorkNailsPost(slug);\n \n  if (!post) {\n    return {\n      title: 'Post Not Found',\n      robots: { index: false, follow: false },\n    };\n  }\n \n  const canonicalUrl =\n    post.canonical || `https://mirelleinspo.com/work-nails/${slug}`;\n  const imageUrl = post.image\n    ? `https://mirelleinspo.com${post.image}`\n    : 'https://mirelleinspo.com/logo.png';\n  const resolvedAuthor = resolveAuthor(post.author || '');\n  const authorFullName = resolvedAuthor?.fullName || 'Jyotika Verma';\n  const authorUrl =\n    resolvedAuthor?.authorPageUrl || 'https://mirelleinspo.com/authors/jyoti-mirelle';\n \n  return {\n    title: post.title,\n    description:\n      post.excerpt ||\n      `${post.title} — professional nail inspiration and advice from Mirellé Inspo.`,\n    authors: [{ name: authorFullName, url: authorUrl }],\n    creator: authorFullName,\n    publisher: 'Mirellé Inspo',\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: post.title,\n      description:\n        post.excerpt ||\n        `${post.title} — professional nail inspiration from Mirellé Inspo.`,\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      type: 'article',\n      locale: 'en_US',\n      images: [\n        {\n          url: imageUrl,\n          width: post.imageWidth || 1200,\n          height: post.imageHeight || 630,\n          alt: post.imageAlt || post.title,\n        },\n      ],\n      publishedTime: post.date,\n      modifiedTime: post.dateModified || post.date,\n      authors: [authorUrl],\n      section: post.category || 'Work Nails',\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: post.title,\n      description:\n        post.excerpt ||\n        `${post.title} — professional nail inspiration from Mirellé Inspo.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    robots: {\n      index: true,\n      follow: true,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n    other: {\n      'article:published_time': post.date,\n      'article:modified_time': post.dateModified || post.date,\n      'article:author': authorUrl,\n      'article:section': post.category || 'Work Nails',\n    },\n  };\n}\n \n\nexport default async function WorkNailsPostPage({ params }: PageProps) {\n  const { slug } = await params;\n  const post = await getWorkNailsPost(slug);\n\n  if (!post) notFound();\n\n  const schemas = generateSchemas({\n    post: {\n      ...post,\n      canonical: post.canonical || `https://mirelleinspo.com/work-nails/${slug}`,\n    },\n    slug,\n  });\n\n  const templates = {\n    'center':     CenterTemplate,\n    'split-left': SplitLeftTemplate,\n  } as const;\n\n  const postWithCoverImage = {\n    ...post,\n    coverImage: post.image || '/images/default-blog.jpg',\n  };\n\n  const Template = templates[post.template || 'center'];\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.breadcrumbSchema) }} />\n      <Template post={postWithCoverImage} />\n    </>\n  );\n}"
