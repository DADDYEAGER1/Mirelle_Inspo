      "path": "src/lib/shop.ts",
      "content": "// src/lib/shop.ts\nimport 'server-only';\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\nimport { marked } from 'marked';\nimport { ShopPost } from '@/types/shop';\n\n// ─── marked config — mirrors blog.ts exactly ─────────────────────────────────\n\nmarked.setOptions({\n  breaks: true,\n  gfm: true,\n});\n\nconst renderer = new marked.Renderer();\n\nrenderer.html = (html: string) => {\n  return html.replace(/src=\"images\\//g, 'src=\"/images/');\n};\n\nrenderer.image = (href: string, title: string | null, text: string) => {\n  const fixedHref = href.startsWith('images/') ? `/${href}` : href;\n  const titleAttr = title ? ` title=\"${title}\"` : '';\n  return `<img src=\"${fixedHref}\" alt=\"${text}\"${titleAttr} loading=\"lazy\" />`;\n};\n\nmarked.use({ renderer });\n\n// ─── Cache ────────────────────────────────────────────────────────────────────\n\ninterface CacheEntry<T> {\n  data: T;\n  timestamp: number;\n}\n\nclass ShopCache {\n  private cache = new Map<string, CacheEntry<any>>();\n  private readonly TTL = 3600000;\n\n  get<T>(key: string): T | null {\n    const entry = this.cache.get(key);\n    if (!entry) return null;\n    if (Date.now() - entry.timestamp > this.TTL) {\n      this.cache.delete(key);\n      return null;\n    }\n    return entry.data as T;\n  }\n\n  set<T>(key: string, data: T): void {\n    this.cache.set(key, { data, timestamp: Date.now() });\n  }\n}\n\nconst shopCache = new ShopCache();\n\n// ─── Constants ────────────────────────────────────────────────────────────────\n\nconst SHOP_DIR = path.join(process.cwd(), 'src/content/shop');\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction getAllShopFilesRecursive(dir: string, base = ''): string[] {\n  let results: string[] = [];\n  let entries: fs.Dirent[];\n\n  try {\n    entries = fs.readdirSync(dir, { withFileTypes: true });\n  } catch {\n    return [];\n  }\n\n  for (const entry of entries) {\n    const relativePath = base ? `${base}/${entry.name}` : entry.name;\n    if (entry.isDirectory()) {\n      results = results.concat(getAllShopFilesRecursive(path.join(dir, entry.name), relativePath));\n    } else if (entry.isFile() && (entry.name.endsWith('.md') || entry.name.endsWith('.mdx'))) {\n      results.push(relativePath);\n    }\n  }\n\n  return results;\n}\n\nfunction fileToSlug(relativePath: string): string {\n  return relativePath.replace(/\\.mdx?$/, '');\n}\n\n// Convert markdown to HTML with H2 IDs for TOC — mirrors blog.ts\nasync function markdownToHtml(rawContent: string): Promise<string> {\n  let compiled = await marked(rawContent);\n\n  // Add IDs to H2s for TOC active tracking\n  compiled = compiled.replace(\n    /<h2>(.*?)<\\/h2>/g,\n    (_match, text) => {\n      const cleanText = text.replace(/<[^>]*>/g, '');\n      const id = cleanText\n        .toLowerCase()\n        .replace(/[^a-z0-9]+/g, '-')\n        .replace(/^-+|-+$/g, '');\n      return `<h2 id=\"${id}\">${text}</h2>`;\n    }\n  );\n\n  // Also add IDs to H3s for TOC\n  compiled = compiled.replace(\n    /<h3>(.*?)<\\/h3>/g,\n    (_match, text) => {\n      const cleanText = text.replace(/<[^>]*>/g, '');\n      const id = cleanText\n        .toLowerCase()\n        .replace(/[^a-z0-9]+/g, '-')\n        .replace(/^-+|-+$/g, '');\n      return `<h3 id=\"${id}\">${text}</h3>`;\n    }\n  );\n\n  return compiled;\n}\n\nfunction buildPost(slug: string, data: any, content: string, isMDX: boolean): ShopPost {\n  return {\n    slug,\n    title:             data.title             ?? '',\n    excerpt:           data.excerpt           ?? '',\n    date:              data.date              ?? '',\n    author:            data.author            ?? 'Mirellé',\n    category:          data.category          ?? 'Shop',\n    image:             data.image             ?? '',\n    imageAlt:          data.imageAlt          ?? data.title ?? '',\n    imageWidth:        data.imageWidth        ?? 1200,\n    imageHeight:       data.imageHeight       ?? 630,\n    readTime:          data.readTime          ?? '',\n    canonical:         data.canonical         ?? '',\n    isMDX,\n    content,\n    template:          'shop',\n    postType:          data.postType          ?? 'best-of',\n    winnerIndex:       data.winnerIndex       ?? undefined,\n    showComparison:    data.showComparison    ?? false,\n    showProscons:      data.showProscons      ?? false,\n    comparisonCaption: data.comparisonCaption ?? '',\n    products:          data.products          ?? [],\n    comparisonTable:   data.comparisonTable   ?? null,\n    faqs:              data.faqs              ?? [],\n    tldr:              data.tldr              ?? [],\n  };\n}\n\n// ─── Public API ───────────────────────────────────────────────────────────────\n\nexport async function getShopPost(slug: string): Promise<ShopPost | null> {\n  const cacheKey = `shop-post:${slug}`;\n  const cached = shopCache.get<ShopPost>(cacheKey);\n  if (cached) return cached;\n\n  try {\n    const mdxPath = path.join(SHOP_DIR, `${slug}.mdx`);\n    const mdPath  = path.join(SHOP_DIR, `${slug}.md`);\n\n    let filePath: string;\n    let isMDX = false;\n\n    if (fs.existsSync(mdxPath)) {\n      filePath = mdxPath;\n      isMDX = true;\n    } else if (fs.existsSync(mdPath)) {\n      filePath = mdPath;\n    } else {\n      return null;\n    }\n\n    const raw = fs.readFileSync(filePath, 'utf-8');\n    const { data, content: rawContent } = matter(raw);\n\n    // MDX: pass raw content (rendered by MDXRemote), MD: convert to HTML\n    const content = isMDX ? rawContent : await markdownToHtml(rawContent);\n\n    const post = buildPost(slug, data, content, isMDX);\n    shopCache.set(cacheKey, post);\n    return post;\n\n  } catch (err) {\n    console.error(`Error reading shop post ${slug}:`, err);\n    return null;\n  }\n}\n\nexport async function getAllShopPosts(): Promise<ShopPost[]> {\n  const cacheKey = 'all-shop-posts';\n  const cached = shopCache.get<ShopPost[]>(cacheKey);\n  if (cached) return cached;\n\n  if (!fs.existsSync(SHOP_DIR)) return [];\n\n  try {\n    const files = getAllShopFilesRecursive(SHOP_DIR);\n\n    const posts = await Promise.all(\n      files.map(async relativePath => {\n        const slug     = fileToSlug(relativePath);\n        const filePath = path.join(SHOP_DIR, relativePath);\n        const raw      = fs.readFileSync(filePath, 'utf-8');\n        const { data, content: rawContent } = matter(raw);\n        const isMDX    = relativePath.endsWith('.mdx');\n        const content  = isMDX ? rawContent : await markdownToHtml(rawContent);\n        return buildPost(slug, data, content, isMDX);\n      })\n    );\n\n    const sorted = posts.sort(\n      (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()\n    );\n\n    shopCache.set(cacheKey, sorted);\n    return sorted;\n\n  } catch (err) {\n    console.error('Error reading shop posts:', err);\n    return [];\n  }\n}\n\nexport async function getShopStaticParams(): Promise<{ slug: string[] }[]> {\n  const posts = await getAllShopPosts();\n  return posts.map(post => ({ slug: post.slug.split('/') }));\n}"
