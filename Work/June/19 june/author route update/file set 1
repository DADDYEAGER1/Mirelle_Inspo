      "content": "// src/app/authors/page.tsx\n\nimport { Metadata } from 'next';\nimport Image from 'next/image';\nimport Link from 'next/link';\nimport { getAllAuthorsWithStats } from '@/lib/authors';\n\nexport const metadata: Metadata = {\n  title: 'Meet the Team | Mirellé',\n  description: 'Ri and Jyoti are the researchers and curators behind Mirellé Inspo — tracking nail trends across Pinterest, search data, and the nail community.',\n  alternates: { canonical: 'https://mirelleinspo.com/authors' },\n};\n\nexport default async function AuthorsPage() {\n  const authors = await getAllAuthorsWithStats();\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n\n      {/* Hero */}\n      <section className=\"py-24 border-b border-foreground/10\">\n        <div className=\"max-w-2xl mx-auto px-6 text-center\">\n          <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/50 mb-4\">\n            The Team\n          </p>\n          <h1\n            className=\"text-5xl md:text-6xl mb-6 text-foreground\"\n            style={{ fontFamily: 'Larken, Georgia, serif' }}\n          >\n            Behind Mirellé\n          </h1>\n          <p\n            className=\"text-xl text-foreground/70 leading-relaxed\"\n            style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n          >\n            We are two siblings who research nail trends so you don&apos;t have to.\n            Everything on this site is built on real data — what people are searching,\n            pinning, and wearing right now.\n          </p>\n        </div>\n      </section>\n\n      {/* Authors */}\n      <section className=\"py-20\">\n        <div className=\"max-w-4xl mx-auto px-6 sm:px-8 lg:px-12\">\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-16\">\n            {authors.map((author) => (\n              <Link\n                key={author.slug}\n                href={`/authors/${author.slug}`}\n                className=\"group block\"\n              >\n                {/* Headshot */}\n                <div className=\"relative w-full pb-[100%] overflow-hidden mb-6\">\n                  <Image\n                    src={author.image}\n                    alt={author.name}\n                    fill\n                    className=\"object-cover transition-transform duration-700 group-hover:scale-105\"\n                    sizes=\"(max-width: 768px) 100vw, 50vw\"\n                  />\n                </div>\n\n                {/* Info */}\n                <div className=\"space-y-3\">\n                  <p\n                    className=\"text-xs uppercase tracking-widest text-foreground/50 font-ui\"\n                  >\n                    {author.role}\n                  </p>\n                  <h2\n                    className=\"text-3xl md:text-4xl text-foreground\"\n                    style={{ fontFamily: 'Larken, Georgia, serif' }}\n                  >\n                    {author.name}\n                  </h2>\n                  <p\n                    className=\"text-lg text-foreground/70 leading-relaxed\"\n                    style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n                  >\n                    {author.bio}\n                  </p>\n                  <div className=\"flex items-center gap-4 pt-2\">\n                    <span\n                      className=\"text-xs uppercase tracking-wide font-ui text-foreground/50\"\n                    >\n                      {author.postCount} {author.postCount === 1 ? 'article' : 'articles'}\n                    </span>\n                    <span\n                      className=\"text-xs uppercase tracking-wide font-ui underline hover:no-underline text-foreground transition-opacity hover:opacity-70\"\n                    >\n                      View all work →\n                    </span>\n                  </div>\n                </div>\n              </Link>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* What we do */}\n      <section className=\"py-20 border-t border-foreground/10\">\n        <div className=\"max-w-2xl mx-auto px-6 text-center\">\n          <p\n            className=\"text-xl md:text-2xl text-foreground/70 leading-relaxed italic\"\n            style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n          >\n            &ldquo;We curate so you don&apos;t have to. Every trend, style guide,\n            and inspo drop on Mirellé starts with research — not guesswork.&rdquo;\n          </p>\n          <div className=\"mt-10\">\n            <Link\n              href=\"/about\"\n              className=\"inline-block bg-foreground text-background px-8 py-4 font-ui text-sm uppercase tracking-wider transition-opacity hover:opacity-70\"\n            >\n              About Mirellé\n            </Link>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  );\n}"
