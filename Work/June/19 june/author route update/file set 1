      "content": "// src/components/Blog/AuthorCard.tsx\n\nimport Image from 'next/image';\nimport Link from 'next/link';\nimport { Author } from '@/types/author';\n\ninterface AuthorCardProps {\n  author: Author;\n}\n\nexport default function AuthorCard({ author }: AuthorCardProps) {\n  if (!author) return null;\n\n  return (\n    <section className=\"bg-background py-12 px-[6px] md:px-3 lg:px-[12px] border-t border-foreground/10\">\n      <div className=\"max-w-3xl mx-auto\">\n        <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40 mb-6\">\n          Researched &amp; Written By\n        </p>\n\n        <div className=\"flex items-start gap-6\">\n          {/* Headshot */}\n          <div className=\"relative w-16 h-16 md:w-20 md:h-20 flex-shrink-0 overflow-hidden\">\n            <Image\n              src={author.image}\n              alt={author.name}\n              fill\n              className=\"object-cover\"\n              sizes=\"80px\"\n            />\n          </div>\n\n          {/* Info */}\n          <div className=\"flex-1 space-y-2\">\n            <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/50\">\n              {author.role}\n            </p>\n            <h3\n              className=\"text-2xl text-foreground\"\n              style={{ fontFamily: 'Larken, Georgia, serif' }}\n            >\n              {author.name}\n            </h3>\n            <p\n              className=\"text-base text-foreground/70 leading-relaxed\"\n              style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n            >\n              {author.bio}\n            </p>\n            <Link\n              href={`/authors/${author.slug}`}\n              className=\"inline-block font-ui text-xs uppercase tracking-wide underline hover:no-underline text-foreground transition-opacity hover:opacity-70 pt-1\"\n            >\n              More by {author.name} →\n            </Link>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"
