      "path": "src/app/authors/[slug]/AuthorPostsList.tsx",
      "content": "'use client';\n\nimport { useState } from 'react';\nimport Image from 'next/image';\nimport Link from 'next/link';\n\nconst TYPE_LABELS: Record<string, string> = {\n  blog:        'Blog',\n  faq:         'FAQ',\n  'work-nail': 'Work Nails',\n  spotlight:   'Spotlight',\n  topic:       'Topic',\n  report:      'Trend Report',\n  business:    'Business',\n};\n\ninterface Post {\n  slug: string;\n  title: string;\n  excerpt: string;\n  date: string;\n  image?: string;\n  type: string;\n  url: string;\n}\n\ninterface AuthorPostsListProps {\n  posts: Post[];\n  authorName: string;\n}\n\nconst PAGE_SIZE = 50;\n\nexport default function AuthorPostsList({ posts, authorName }: AuthorPostsListProps) {\n  const [visible, setVisible] = useState(PAGE_SIZE);\n\n  const shown = posts.slice(0, visible);\n  const hasMore = visible < posts.length;\n\n  return (\n    <>\n      <div className=\"divide-y divide-foreground/10\">\n        {shown.map((post) => (\n          <Link\n            key={`${post.type}-${post.slug}`}\n            href={post.url}\n            className=\"group flex items-start gap-6 py-8 transition-opacity hover:opacity-70\"\n          >\n            {post.image && (\n              <div className=\"relative w-20 h-20 flex-shrink-0 overflow-hidden\">\n                <Image\n                  src={post.image}\n                  alt={post.title}\n                  fill\n                  className=\"object-cover\"\n                  sizes=\"80px\"\n                />\n              </div>\n            )}\n            <div className=\"flex-1 space-y-1\">\n              <p className=\"font-ui text-xs uppercase tracking-widest text-foreground/40\">\n                {TYPE_LABELS[post.type] || post.type}\n              </p>\n              <h3\n                className=\"text-xl md:text-2xl text-foreground leading-snug\"\n                style={{ fontFamily: 'Larken, Georgia, serif' }}\n              >\n                {post.title}\n              </h3>\n              {post.excerpt && (\n                <p\n                  className=\"text-base text-foreground/60 line-clamp-2\"\n                  style={{ fontFamily: 'Crimson Text, Georgia, serif' }}\n                >\n                  {post.excerpt}\n                </p>\n              )}\n              <p className=\"font-ui text-xs text-foreground/40 pt-1\">\n                {new Date(post.date).toLocaleDateString('en-US', {\n                  year: 'numeric',\n                  month: 'long',\n                  day: 'numeric',\n                })}\n              </p>\n            </div>\n          </Link>\n        ))}\n      </div>\n\n      {hasMore && (\n        <div className=\"mt-12 text-center\">\n          <button\n            onClick={() => setVisible(v => v + PAGE_SIZE)}\n            className=\"font-ui text-sm uppercase tracking-wide bg-foreground text-background px-8 py-4 hover:opacity-80 transition-opacity\"\n          >\n            Show More Posts\n          </button>\n          <p className=\"font-ui text-xs text-foreground/40 mt-3\">\n            Showing {shown.length} of {posts.length}\n          </p>\n        </div>\n      )}\n    </>\n  );\n}"
