      "path": "src/app/blog/templates/CenterTemplate.tsx",
      "content": "// src/app/blog/templates/CenterTemplate.tsx\nimport { BlogPost } from '@/types/blog';\nimport MDXContent from './MDXContent';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport ImageCarousel from '@/components/Blog/ImageCarousel';\nimport ProductGrid from '@/components/Blog/ProductGrid';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport AboutEEAT from '@/components/Blog/AboutEEAT';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport ReadMoreSection from '@/components/Blog/ReadMoreSection';\nimport TableOfContents from '@/components/Blog/TableOfContents';\nimport WrapUp from '@/components/Blog/WrapUp';\nimport { getAuthor } from '@/lib/authors';\nimport ShareButton from '@/components/Blog/ShareButton';\nimport Lightbox from '@/components/Blog/Lightbox';\n\ninterface CenterTemplateProps {\n  post: BlogPost;\n}\n\nfunction renderContentWithProducts(html: string, products: BlogPost['products']): React.ReactNode {\n  if (!products || products.length === 0) return <div dangerouslySetInnerHTML={{ __html: html }} />;\n  const parts = html.split(/({{PRODUCTS:\\d+:[\\d,]+}})/g);\n  if (parts.length === 1) return <div dangerouslySetInnerHTML={{ __html: html }} />;\n  return (\n    <>\n      {parts.map((part, index) => {\n        const match = part.match(/^{{PRODUCTS:(\\d+):([\\d,]+)}}$/);\n        if (match) {\n          const count = parseInt(match[1]) as 1 | 2 | 4;\n          const indices = match[2].split(',').map((i) => parseInt(i.trim()));\n          if (![1, 2, 4].includes(count)) return null;\n          return <ProductGrid key={index} products={products} count={count} indices={indices} />;\n        }\n        return <div key={index} dangerouslySetInnerHTML={{ __html: part }} />;\n      })}\n    </>\n  );\n}\n\nexport default function CenterTemplate({ post }: CenterTemplateProps) {\n  const postProducts = post.products ?? [];\n  const author = post.author ? getAuthor(post.author) : null;\n\n  // Split content into thirds: ~33% / ~67% / rest\n  const h2Blocks = (post.content || '').split(/(?=<h2[\\s>])/);\n  const total = h2Blocks.length;\n  const cut1 = Math.max(1, Math.floor(total * 0.33));\n  const cut2 = Math.max(cut1 + 1, Math.floor(total * 0.67));\n  const firstThird  = h2Blocks.slice(0, cut1).join('');\n  const secondThird = h2Blocks.slice(cut1, cut2).join('');\n  const lastThird   = h2Blocks.slice(cut2).join('');\n\n  if (post.isMDX) {\n    return (\n      <div className=\"min-h-screen bg-background\">\n        <ShareButton url={post.canonical} title={post.title} />\n        <Lightbox />\n\n        <div className=\"w-full\">\n          <div className=\"text-center py-12 md:py-16 px-6\" style={{ backgroundColor: '#f9fafb' }}>\n            {post.category && <p className=\"font-ui text-sm uppercase tracking-wider text-gray-600 mb-4\">{post.category}</p>}\n            <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-6\" style={{ color: '#252220' }}>{post.title}</h1>\n            <p className=\"font-ui text-sm uppercase tracking-wide mb-2\" style={{ color: '#252220' }}>BY {post.author}</p>\n            <p className=\"font-ui text-sm text-gray-600\">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>\n          </div>\n          <div className=\"w-full\"><img src={post.image} alt={post.imageAlt || post.title} className=\"w-full h-auto\" /></div>\n        </div>\n\n        <div className=\"w-full flex justify-center mt-12\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n            <article className=\"prose-content-magazine\">\n              <MDXContent source={post.content} products={postProducts} topic={post.topic} />\n            </article>\n          </div>\n        </div>\n\n        {author && <AuthorCard author={author} />}\n        <AboutEEAT />\n        <ReadMoreSection currentSlug={post.slug} />\n        <div className=\"w-full\"><InlineNewsletter /></div>\n        <FinalNewsletter />\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n      <ShareButton url={post.canonical} title={post.title} />\n      <Lightbox />\n\n      {/* Hero */}\n      <div className=\"w-full\">\n        <div className=\"text-center py-12 md:py-16 px-6\" style={{ backgroundColor: '#f9fafb' }}>\n          {post.category && <p className=\"font-ui text-sm uppercase tracking-wider text-gray-600 mb-4\">{post.category}</p>}\n          <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-6\" style={{ color: '#252220' }}>{post.title}</h1>\n          <p className=\"font-ui text-sm uppercase tracking-wide mb-2\" style={{ color: '#252220' }}>BY {post.author}</p>\n          <p className=\"font-ui text-sm text-gray-600\">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>\n        </div>\n        <div className=\"w-full\"><img src={post.image} alt={post.imageAlt || post.title} className=\"w-full h-auto\" /></div>\n      </div>\n\n      <div className=\"w-full flex justify-center mt-12\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <div className=\"mb-8\">\n            <Breadcrumbs items={[{ label: 'Blog', href: '/blog' }]} currentPage={post.title} includeSchema={false} />\n          </div>\n          <div className=\"block lg:hidden mb-8\">\n            <TableOfContents content={post.content} />\n          </div>\n\n          <div>\n            {post.tldr && <WrapUp tldr={post.tldr} />}\n            <article className=\"prose-content-magazine\">\n              {/* First third ~33% */}\n              {renderContentWithProducts(firstThird, post.products)}\n            </article>\n          </div>\n        </div>\n      </div>\n\n      {/* Inline newsletter 1  at ~33% */}\n      <div className=\"w-full my-10\">\n        <InlineNewsletter />\n      </div>\n\n      <div className=\"w-full flex justify-center\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <article className=\"prose-content-magazine\">\n            {/* Second third ~33–67% */}\n            {renderContentWithProducts(secondThird, post.products)}\n\n            {post.carouselImages && post.carouselImages.length > 0 && (\n              <div className=\"my-12\"><ImageCarousel images={post.carouselImages} /></div>\n            )}\n          </article>\n        </div>\n      </div>\n\n      {/* Inline newsletter 2  at ~67% */}\n      <div className=\"w-full my-10\">\n        <InlineNewsletter />\n      </div>\n\n      <div className=\"w-full flex justify-center\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <article className=\"prose-content-magazine\">\n            {/* Last third ~67–100% */}\n            {renderContentWithProducts(lastThird, post.products)}\n          </article>\n        </div>\n      </div>\n\n      {author && <AuthorCard author={author} />}\n      <AboutEEAT />\n      <ReadMoreSection currentSlug={post.slug} />\n      <div className=\"w-full\"><InlineNewsletter /></div>\n      <FinalNewsletter />\n    </div>\n  );\n}"
