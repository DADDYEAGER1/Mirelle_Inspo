      "path": "src/app/shop/templates/ShopTemplate.tsx",
      "content": "// src/app/shop/templates/ShopTemplate.tsx\n// One template handles review, comparison, and best-of posts.\n// Flags in frontmatter (showComparison, showProscons, winnerIndex) activate components.\n\nimport { ShopPost } from '@/types/shop';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport WinnerBadge from '@/components/shop/WinnerBadge';\nimport ShopProductGrid from '@/components/shop/ShopProductGrid';\nimport ComparisonTable from '@/components/shop/ComparisonTable';\nimport ProsConsBlock from '@/components/shop/ProsConsBlock';\nimport ShopTableOfContents from '@/components/shop/ShopTableOfContents';\nimport ShopInlineCTA from '@/components/shop/ShopInlineCTA';\nimport ShopFinalCTA from '@/components/shop/ShopFinalCTA';\nimport ShopFAQ from '@/components/shop/ShopFAQ';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport AboutEEAT from '@/components/Blog/AboutEEAT';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { authors } from '@/data/authors';\n\ninterface ShopTemplateProps {\n  post: ShopPost;\n}\n\n// ─── Render HTML content with inline product grid injection ───────────────────\n// Supports {{PRODUCTS:count:i,j,k}} placeholders in content\n\nfunction renderContentWithProducts(\n  html: string,\n  products: ShopPost['products']\n): React.ReactNode {\n  if (!products || products.length === 0) {\n    return <div dangerouslySetInnerHTML={{ __html: html }} />;\n  }\n\n  const parts = html.split(/({{PRODUCTS:\\d+:[\\d,]+}})/g);\n\n  if (parts.length === 1) {\n    return <div dangerouslySetInnerHTML={{ __html: html }} />;\n  }\n\n  return (\n    <>\n      {parts.map((part, index) => {\n        const match = part.match(/^{{PRODUCTS:(\\d+):([\\d,]+)}}$/);\n        if (match) {\n          const count = parseInt(match[1]) as 1 | 2 | 3 | 4;\n          const indices = match[2].split(',').map(i => parseInt(i.trim()));\n          if (![1, 2, 3, 4].includes(count)) return null;\n          return (\n            <ShopProductGrid\n              key={index}\n              products={products}\n              count={count}\n              indices={indices}\n            />\n          );\n        }\n        return <div key={index} dangerouslySetInnerHTML={{ __html: part }} />;\n      })}\n    </>\n  );\n}\n\n// ─── Split content into sections for inline CTA injection ─────────────────────\n\nfunction splitContent(html: string) {\n  const h2Blocks = html.split(/(?=<h2[\\s>])/);\n  const total = h2Blocks.length;\n\n  const q1 = Math.max(1, Math.floor(total * 0.3));\n  const q2 = Math.max(2, Math.floor(total * 0.6));\n\n  return {\n    first:     h2Blocks.slice(0, q1).join(''),\n    middle:    h2Blocks.slice(q1, q2).join(''),\n    remaining: h2Blocks.slice(q2).join(''),\n  };\n}\n\n// ─── Template ─────────────────────────────────────────────────────────────────\n\nexport default function ShopTemplate({ post }: ShopTemplateProps) {\n  const products   = post.products ?? [];\n  const winner     = post.winnerIndex !== undefined ? products[post.winnerIndex] : undefined;\n  const { first, middle, remaining } = splitContent(post.content);\n\n  // Resolve author slug → full Author object, fallback to jyoti-mirelle if slug doesn't match\n  const author = authors.find(a => a.slug === post.author)\n    ?? authors.find(a => a.slug === 'jyoti-mirelle');\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n\n      {/* Inline newsletter  top of page */}\n      <div className=\"w-full\">\n        <InlineNewsletter />\n      </div>\n\n      {/* Hero  text only, no image. post.image is reserved for card thumbnail + OG/social meta. */}\n      <div className=\"w-full\">\n        <div\n          className=\"text-center py-12 md:py-16 px-6\"\n          style={{ backgroundColor: '#f9fafb' }}\n        >\n          {post.category && (\n            <p className=\"font-ui text-sm uppercase tracking-wider text-gray-500 mb-4\">\n              {post.category}\n            </p>\n          )}\n          <h1\n            className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-6 max-w-3xl mx-auto\"\n            style={{ color: '#252220' }}\n          >\n            {post.title}\n          </h1>\n          <p className=\"font-ui text-sm uppercase tracking-wide mb-2\" style={{ color: '#252220' }}>\n            BY {author?.fullName ?? 'Mirellé'}\n          </p>\n          <p className=\"font-ui text-sm text-gray-500\">\n            {new Date(post.date).toLocaleDateString('en-US', {\n              year: 'numeric',\n              month: 'long',\n              day: 'numeric',\n            })}\n            {post.readTime && ` · ${post.readTime}`}\n          </p>\n        </div>\n      </div>\n\n      {/* Body */}\n      <div className=\"w-full flex justify-center mt-12\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n\n          {/* Breadcrumbs */}\n          <div className=\"mb-8\">\n            <Breadcrumbs\n              items={[{ label: 'Shop', href: '/shop' }]}\n              currentPage={post.title}\n              includeSchema={false}\n            />\n          </div>\n\n          {/* Mobile TOC */}\n          <div className=\"block lg:hidden mb-8\">\n            <ShopTableOfContents content={post.content} />\n          </div>\n\n          {/* Winner badge  shown below hero, above content */}\n          {winner && (\n            <WinnerBadge product={winner} />\n          )}\n\n          {/*\n            Main layout: content + sticky sidebar.\n            Fix: items-stretch (instead of items-start) makes the flex row's height\n            equal to its tallest child. Combined with self-start + h-fit on the\n            content column, this guarantees the row container is always at least as\n            tall as the article, giving the sticky sidebar enough scroll room to\n            track properly even on short posts  instead of running out of space\n            and scrolling away early.\n          */}\n          <div className=\"flex gap-12 items-stretch\">\n\n            {/* Content column */}\n            <div className=\"flex-1 min-w-0 self-start\">\n              <article className=\"prose-content-magazine\">\n\n                {/* First section */}\n                {renderContentWithProducts(first, products)}\n\n                {/* Mid-article inline CTA  fires after first section */}\n                {winner && (\n                  <ShopInlineCTA\n                    product={winner}\n                    headline=\"Featured Pick\"\n                  />\n                )}\n\n                {/* Middle section */}\n                {renderContentWithProducts(middle, products)}\n\n                {/* Comparison table  activated by showComparison flag */}\n                {post.showComparison && post.comparisonTable && (\n                  <ComparisonTable\n                    table={post.comparisonTable}\n                    caption={post.comparisonCaption}\n                  />\n                )}\n\n                {/* Remaining content */}\n                {renderContentWithProducts(remaining, products)}\n\n                {/* Pros/Cons  activated by showProscons flag, renders per product */}\n                {post.showProscons && products.length > 0 && (\n                  <div className=\"my-12 space-y-6\">\n                    <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400\">\n                      Pros & Cons\n                    </p>\n                    {products.map((product, i) => (\n                      <ProsConsBlock key={i} product={product} showName />\n                    ))}\n                  </div>\n                )}\n\n              </article>\n\n              {/* Mid-page newsletter */}\n              <div className=\"my-12 -mx-6 md:-mx-12 lg:-mx-16\">\n                <InlineNewsletter />\n              </div>\n\n              {/* Final CTA  replaces generic conclusion */}\n              {products.length > 0 && (\n                <ShopFinalCTA\n                  products={products}\n                  winnerIndex={post.winnerIndex}\n                />\n              )}\n\n              {/* FAQ */}\n              {post.faqs && post.faqs.length > 0 && (\n                <ShopFAQ faqs={post.faqs} />\n              )}\n\n            </div>\n\n            {/* Sticky sidebar  desktop only */}\n            <aside\n              className=\"hidden lg:block w-[260px] flex-shrink-0 self-start space-y-6\"\n              style={{ position: 'sticky', top: '6rem' }}\n            >\n              <ShopTableOfContents content={post.content} />\n\n              {/* Sidebar winner CTA */}\n              {winner && (\n                <div className=\"border border-gray-200 bg-white p-5\">\n                  <p className=\"font-ui text-[11px] uppercase tracking-widest text-gray-400 mb-3\">\n                    {winner.badge || 'Top Pick'}\n                  </p>\n                  <img\n                    src={winner.image}\n                    alt={winner.name}\n                    className=\"w-full aspect-square object-cover mb-4\"\n                    loading=\"lazy\"\n                  />\n                  <p className=\"font-heading text-[16px] leading-snug mb-1\" style={{ color: '#252220' }}>\n                    {winner.name}\n                  </p>\n                  <p className=\"font-ui text-sm font-semibold mb-4\" style={{ color: '#252220' }}>\n                    {winner.price}\n                  </p>\n                  <a\n                    href={winner.link}\n                    target=\"_blank\"\n                    rel=\"noopener noreferrer sponsored\"\n                    className=\"block w-full text-center py-2.5 px-4 bg-[#f9fafb] text-[#252220] border border-[#252220] font-ui text-[11px] uppercase tracking-widest hover:opacity-80 transition-opacity duration-200\"\n                  >\n                    Shop Now →\n                  </a>\n                </div>\n              )}\n            </aside>\n          </div>\n\n        </div>\n      </div>\n\n      {/* Author card  matches blog placement */}\n      {author && <AuthorCard author={author} />}\n\n      {/* Footer components */}\n      <AboutEEAT />\n      <FinalNewsletter />\n    </div>\n  );\n}"
    },
