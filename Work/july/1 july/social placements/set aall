      "path": "src/components/business/BusinessTemplate.tsx",
      "content": "'use client';\n\n// src/components/business/BusinessTemplate.tsx\nimport { useState } from 'react';\nimport Image from 'next/image';\nimport { MDXRemote, MDXRemoteSerializeResult } from 'next-mdx-remote';\nimport { BusinessPost } from '@/types/business';\nimport { Author } from '@/types/author';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport AuthorCard from '@/components/Blog/AuthorCard';\n\ninterface BusinessTemplateProps {\n  post: BusinessPost;\n  mdxSource?: MDXRemoteSerializeResult;\n  author?: Author;\n}\n\nfunction FAQAccordion({ faqs }: { faqs: BusinessPost['faqSchema'] }) {\n  const [openIndex, setOpenIndex] = useState<number | null>(null);\n  return (\n    <div className=\"divide-y divide-[#E0E0E0]\">\n      {faqs.map((faq, i) => (\n        <div key={i} className=\"py-5\">\n          <button\n            onClick={() => setOpenIndex(openIndex === i ? null : i)}\n            className=\"w-full flex items-start justify-between gap-4 text-left\"\n            aria-expanded={openIndex === i}\n          >\n            <span className=\"font-heading text-h4-mobile md:text-h4 text-foreground\">{faq.question}</span>\n            <span className=\"font-ui text-ui text-[#666666] flex-shrink-0 mt-1\">{openIndex === i ? '−' : '+'}</span>\n          </button>\n          {openIndex === i && (\n            <p className=\"mt-4 font-body text-body text-foreground leading-relaxed\">{faq.answer}</p>\n          )}\n        </div>\n      ))}\n    </div>\n  );\n}\n\nexport default function BusinessTemplate({ post, mdxSource, author }: BusinessTemplateProps) {\n  const emailSubject = encodeURIComponent(`Collaboration Enquiry  ${post.region}`);\n  const emailHref = `mailto:${post.contact.email}?subject=${emailSubject}`;\n  const whatsappHref = post.contact.whatsapp\n    ? `https://wa.me/${post.contact.whatsapp.replace(/\\D/g, '')}`\n    : null;\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n\n      {/* 1. HERO */}\n      <section className=\"w-full\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n            <div className=\"mb-8\">\n              <Breadcrumbs items={[{ label: 'Business', href: '/business' }]} currentPage={post.region} includeSchema={false} />\n            </div>\n            <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">{post.city} · {post.country}</p>\n            <h1 className=\"font-heading text-h1-mobile md:text-h1 text-foreground max-w-[700px] leading-tight mb-8\">{post.title}</h1>\n            <div className=\"max-w-[700px] border-l-2 border-foreground pl-6 mb-10 business-tldr\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-2\">TL;DR</p>\n              <p className=\"font-body text-body-lg text-foreground leading-relaxed\">{post.tldr}</p>\n            </div>\n            <a href={emailHref} className=\"inline-block font-ui text-ui uppercase tracking-wider bg-foreground text-background px-8 py-4 hover:opacity-80 transition-opacity\">\n              Get in Touch\n            </a>\n          </div>\n        </div>\n      </section>\n\n      {/* 1.5 PAIN BLOCK */}\n      {post.painPoint && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"max-w-[700px]\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">The Problem</p>\n                <p className=\"font-heading text-h2-mobile md:text-h2 text-foreground leading-tight\">{post.painPoint}</p>\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* 2. SERVICES */}\n      {post.services.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">What We Offer</p>\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10\">\n                {post.services.map((service, i) => (\n                  <div key={i} className=\"border-t border-[#E0E0E0] pt-6\">\n                    <h2 className=\"font-heading text-h3-mobile md:text-h3 text-foreground mb-3\">{service.title}</h2>\n                    <p className=\"font-body text-body text-foreground leading-relaxed\">{service.description}</p>\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* 2.5 STATS */}\n      {post.statBlock && post.statBlock.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-10\">\n                {post.statBlock.map((item, i) => (\n                  <div key={i} className=\"border-t border-[#E0E0E0] pt-6\">\n                    <p className=\"font-heading text-h2-mobile md:text-h2 text-foreground mb-2\">{item.stat}</p>\n                    <p className=\"font-body text-body text-[#666666] leading-relaxed\">{item.context}</p>\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* 3. GALLERY */}\n      {post.galleryImages && post.galleryImages.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">Our Work</p>\n              <div className=\"columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4\">\n                {post.galleryImages.map((img, i) => (\n                  <div key={i} className=\"break-inside-avoid overflow-hidden\">\n                    <Image src={img.url} alt={img.alt} width={img.width || 800} height={img.height || 1000} className=\"w-full h-auto object-cover\" sizes=\"(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw\" />\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {/* 4. BODY CONTENT + ABOUT */}\n      <section className=\"w-full border-t border-[#E0E0E0]\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n            <div className=\"max-w-[700px]\">\n              <article className=\"prose-content-magazine mb-16 business-about\">\n                {post.isMDX && mdxSource ? (\n                  <MDXRemote {...mdxSource} />\n                ) : (\n                  <div dangerouslySetInnerHTML={{ __html: post.content }} />\n                )}\n              </article>\n              <div className=\"border-t border-[#E0E0E0] pt-10\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-4\">About Mirellé</p>\n                <h2 className=\"font-heading text-h2-mobile md:text-h2 text-foreground mb-4\">An editorial nail platform</h2>\n                <p className=\"font-body text-body text-foreground leading-relaxed\">\n                  Mirellé is a nail inspiration and editorial platform dedicated to the art, aesthetics, and culture of nails. We produce original content trends, editorials, and campaign direction for brands and salons that hold a standard. Based online, working globally.\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* 5. FAQ */}\n      {post.faqSchema.length > 0 && (\n        <section className=\"w-full border-t border-[#E0E0E0]\">\n          <div className=\"w-full flex justify-center\">\n            <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-12 md:py-16\">\n              <div className=\"max-w-[700px]\">\n                <p className=\"font-ui text-ui uppercase tracking-wider text-[#666666] mb-8\">Frequently Asked</p>\n                <FAQAccordion faqs={post.faqSchema} />\n              </div>\n            </div>\n          </div>\n        </section>\n      )}\n\n      {author && <AuthorCard author={author} />}\n\n      {/* 7. CTA */}\n      <section className=\"w-full border-t border-[#E0E0E0] bg-foreground\">\n        <div className=\"w-full flex justify-center\">\n          <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16 py-16 md:py-24\">\n            <p className=\"font-ui text-ui uppercase tracking-wider text-background opacity-60 mb-6\">Work with us · {post.region}</p>\n            <h2 className=\"font-heading text-h1-mobile md:text-h1 text-background max-w-[600px] leading-tight mb-10\">Let's make something worth looking at.</h2>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <a href={emailHref} className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\">Email Us</a>\n              {whatsappHref && (\n                <a href={whatsappHref} target=\"_blank\" rel=\"noopener noreferrer\" className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\">WhatsApp</a>\n              )}\n              {post.contact.instagram && (\n                <a href={post.contact.instagram} target=\"_blank\" rel=\"noopener noreferrer\" className=\"inline-block font-ui text-ui uppercase tracking-wider border border-background text-background px-8 py-4 hover:bg-background hover:text-foreground transition-colors\">Instagram</a>\n              )}\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}"
