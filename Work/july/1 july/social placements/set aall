      "path": "src/components/Inspo/InspoClient.tsx",
      "content": "// src/components/Inspo/InspoClient.tsx\n'use client';\n\nimport { useState, useRef, useEffect } from 'react';\nimport Link from 'next/link';\nimport Image from 'next/image';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport AdUnit from '@/components/AdUnit';\nimport type { DesignData, DesignImage } from '@/types/inspo';\n\ninterface InspoClientProps {\n  designData: DesignData;\n  initialImages: DesignImage[];\n  relatedDesigns: DesignData[];\n  breadcrumbItems: Array<{ label: string; href: string }>;\n}\n\nexport default function InspoClient({ designData, initialImages, relatedDesigns, breadcrumbItems }: InspoClientProps) {\n  const [selectedImage, setSelectedImage] = useState<DesignImage | null>(null);\n  const [filter, setFilter] = useState<'all' | 'premium'>('all');\n  const [sortBy, setSortBy] = useState<'trending' | 'newest' | 'popular'>('trending');\n  const [displayCount, setDisplayCount] = useState(20);\n  const [likedImages, setLikedImages] = useState<Set<string>>(new Set());\n  const [savedImages, setSavedImages] = useState<Set<string>>(new Set());\n  const [aboutOpen, setAboutOpen] = useState(false);\n  const loadMoreRef = useRef<HTMLDivElement>(null);\n\n  const filteredImages = filter === 'premium' ? initialImages.filter(img => img.isPremium) : initialImages;\n  const sortedImages = [...filteredImages].sort((a, b) => {\n    if (sortBy === 'popular') return (likedImages.has(b.id) ? 1 : 0) - (likedImages.has(a.id) ? 1 : 0);\n    return 0;\n  });\n  const displayedImages = sortedImages.slice(0, displayCount);\n  const hasMore = displayCount < sortedImages.length;\n\n  // Mid-content ad  inject after 50% of displayed images\n  const midPoint = Math.floor(displayedImages.length / 2);\n\n  useEffect(() => {\n    const observer = new IntersectionObserver(\n      (entries) => { if (entries[0].isIntersecting && hasMore) setDisplayCount(prev => prev + 20); },\n      { threshold: 0.1 }\n    );\n    if (loadMoreRef.current) observer.observe(loadMoreRef.current);\n    return () => observer.disconnect();\n  }, [hasMore]);\n\n  useEffect(() => {\n    if (!selectedImage) return;\n    const handleKey = (e: KeyboardEvent) => {\n      if (e.key === 'Escape') { setSelectedImage(null); return; }\n      const ci = displayedImages.findIndex(img => img.id === selectedImage.id);\n      if (e.key === 'ArrowLeft') setSelectedImage(displayedImages[ci > 0 ? ci - 1 : displayedImages.length - 1]);\n      if (e.key === 'ArrowRight') setSelectedImage(displayedImages[ci < displayedImages.length - 1 ? ci + 1 : 0]);\n    };\n    window.addEventListener('keydown', handleKey);\n    document.body.style.overflow = 'hidden';\n    return () => { window.removeEventListener('keydown', handleKey); document.body.style.overflow = 'unset'; };\n  }, [selectedImage, displayedImages]);\n\n  useEffect(() => {\n    if (!selectedImage) return;\n    let startX = 0;\n    const onStart = (e: TouchEvent) => { startX = e.changedTouches[0].screenX; };\n    const onEnd = (e: TouchEvent) => {\n      const diff = startX - e.changedTouches[0].screenX;\n      const ci = displayedImages.findIndex(img => img.id === selectedImage.id);\n      if (diff > 50) setSelectedImage(displayedImages[ci < displayedImages.length - 1 ? ci + 1 : 0]);\n      if (diff < -50) setSelectedImage(displayedImages[ci > 0 ? ci - 1 : displayedImages.length - 1]);\n    };\n    window.addEventListener('touchstart', onStart);\n    window.addEventListener('touchend', onEnd);\n    return () => { window.removeEventListener('touchstart', onStart); window.removeEventListener('touchend', onEnd); };\n  }, [selectedImage, displayedImages]);\n\n  const handleLike = (id: string) => setLikedImages(prev => { const s = new Set(prev); s.has(id) ? s.delete(id) : s.add(id); return s; });\n  const handleSave = (id: string) => setSavedImages(prev => { const s = new Set(prev); s.has(id) ? s.delete(id) : s.add(id); return s; });\n  const handleShare = async () => {\n    if (navigator.share) { try { await navigator.share({ title: designData.displayName, text: designData.description, url: window.location.href }); } catch {} }\n    else { navigator.clipboard.writeText(window.location.href); alert('Link copied!'); }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-cyan-50\">\n      {/* Breadcrumbs */}\n      <div className=\"bg-white border-b border-gray-200 shadow-sm\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4\">\n          <Breadcrumbs items={breadcrumbItems} currentPage={designData.displayName} />\n        </div>\n      </div>\n\n      {/* Hero */}\n      <section className=\"relative overflow-hidden\">\n        <div className=\"relative h-[60vh] md:h-[70vh] min-h-[500px]\">\n          {designData.heroImage.startsWith('/') ? (\n            <Image src={designData.heroImage} alt={`${designData.displayName} nail designs inspiration`} fill priority className=\"object-cover\" sizes=\"100vw\" />\n          ) : (\n            <div className=\"absolute inset-0 bg-cover bg-center\" style={{ backgroundImage: `url(${designData.heroImage})` }} />\n          )}\n          <div className=\"absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/80\" />\n          <div className=\"relative h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col justify-center text-white\">\n            <div className=\"inline-flex w-fit items-center gap-2 bg-white/10 backdrop-blur-md border border-white/30 px-5 py-2 mb-6 text-sm font-semibold uppercase tracking-wider rounded-full\">\n              <span>{designData.category}</span><span>•</span><span>{designData.year}</span>\n            </div>\n            <h1 className=\"font-display text-5xl md:text-6xl lg:text-7xl font-bold mb-6 tracking-tight\">{designData.displayName}</h1>\n            <p className=\"text-xl md:text-2xl text-white/90 mb-8 max-w-3xl font-light\">{designData.description}</p>\n            <div className=\"flex gap-4 mb-8 te