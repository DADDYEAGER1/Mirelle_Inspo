 resolveAuthor(report.author || '');\n  const authorFullName = resolvedAuthor?.fullName || 'Gaurav Verma';\n  const authorUrl =\n    resolvedAuthor?.authorPageUrl || 'https://mirelleinspo.com/authors/ri-mirelle';\n \n  return {\n    title: report.title,\n    description:\n      report.excerpt ||\n      `${report.title}  a data-driven nail trend report by Gaurav Verma at Mirellé Inspo.`,\n    authors: [{ name: authorFullName, url: authorUrl }],\n    creator: authorFullName,\n    publisher: 'Mirellé Inspo',\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: report.title,\n      description:\n        report.excerpt ||\n        `${report.title}  data-driven nail trend research from Mirellé Inspo.`,\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      type: 'article',\n      locale: 'en_US',\n      images: [\n        {\n          url: imageUrl,\n          width: report.imageWidth || 1200,\n          height: report.imageHeight || 630,\n          alt: report.imageAlt || report.title,\n        },\n      ],\n      publishedTime: report.date,\n      modifiedTime: report.dateModified || report.date,\n      authors: [authorUrl],\n      section: report.category || 'Trend Reports',\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: report.title,\n      description:\n        report.excerpt ||\n        `${report.title}  data-driven nail trend research from Mirellé Inspo.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    robots: {\n      index: true,\n      follow: true,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n    other: {\n      'article:published_time': report.date,\n      'article:modified_time': report.dateModified || report.date,\n      'article:author': authorUrl,\n      'article:section': report.category || 'Trend Reports',\n    },\n  };\n}\n \n\nexport default async function TrendReportPage({ params }: PageProps) {\n  const { slug } = await params;\n  const report = await getReport(slug);\n  if (!report) notFound();\n\n  const author = report.author ? getAuthor(report.author) : null;\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    headline: report.title,\n    description: report.excerpt,\n    datePublished: report.date,\n    dateModified: report.dateModified || report.date,\n    author: { '@type': 'Person', name: report.author },\n    publisher: {\n      '@type': 'Organization',\n      name: 'Mirellé Inspo',\n      logo: { '@type': 'ImageObject', url: 'https://mirelleinspo.com/logo.png' },\n    },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://mirelleinspo.com/trend-reports/${slug}` },\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },\n      { '@type': 'ListItem', position: 2, name: 'Trend Reports', item: 'https://mirelleinspo.com/trend-reports' },\n      { '@type': 'ListItem', position: 3, name: report.title },\n    ],\n  };\n\n  const faqSchema = report.faqs && report.faqs.length > 0\n    ? {\n        '@context': 'https://schema.org',\n        '@type': 'FAQPage',\n        mainEntity: report.faqs.map((faq) => ({\n          '@type': 'Question',\n          name: faq.question,\n          acceptedAnswer: { '@type': 'Answer', text: faq.answer },\n        })),\n      }\n    : null;\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n      {faqSchema && (\n        <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(faqSchema) }} />\n      )}\n\n      <div className=\"min-h-screen bg-background\">\n        <div className=\"w-full px-6 md:px-[12px] py-8 md:py-12\">\n          <p className=\"text-sm uppercase tracking-wide text-gray-700 mb-4\">{report.category}</p>\n          <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\">{report.title}</h1>\n          <div className=\"text-sm text-gray-700 mb-8\">\n            <p className=\"uppercase tracking-wide mb-1\">BY {report.author}</p>\n            <time dateTime={report.date} className=\"text-gray-600\">\n              {new Date(report.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}\n            </time>\n          </div>\n        </div>\n\n        <div className=\"w-full flex flex-col items-start\">\n          <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16\">\n            <div className=\"mb-8\">\n              <Breadcrumbs\n                items={[{ label: 'Trend Reports', href: '/trend-reports' }]}\n                currentPage={report.title}\n                includeSchema={false}\n              />\n            </div>\n            <article className=\"prose-content-magazine\">\n              <MDXRemote source={report.content} components={mdxComponents} />\n            </article>\n\n            {report.faqs && report.faqs.length > 0 && (\n              <ReportFAQAccordion faqs={report.faqs} />\n            )}\n          </div>\n\n          <div className=\"w-full my-12\">\n            <ReportInlineNewsletter />\n          </div>\n        </div>\n\n        {author && <AuthorCard author={author} />}\n        <ReportAbout />\n        <ReportFinalNewsletter />\n        <ReportReadMore currentSlug={report.slug} />\n      </div>\n    </>\n  );\n}"
