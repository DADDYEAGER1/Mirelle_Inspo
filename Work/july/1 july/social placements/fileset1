      "path": "src/components/ui/GlassCard.tsx",
      "content": "import { ReactNode } from 'react';\n\ninterface GlassCardProps {\n  children: ReactNode;\n  className?: string;\n  variant?: 'default' | 'dark' | 'accent';\n}\n\nexport default function GlassCard({\n  children,\n  className = '',\n  variant = 'default',\n}: GlassCardProps) {\n  const getVariantClasses = () => {\n    switch (variant) {\n      case 'dark':\n        return 'glass-card-dark';\n      case 'accent':\n        return 'glass-card-accent';\n      case 'default':\n      default:\n        return 'glass-card';\n    }\n  };\n\n  return (\n    <div\n      className={`${getVariantClasses()} rounded-2xl p-6 shadow-editorial ${className}`}\n    >\n      {children}\n    </div>\n  );\n}\n"
    },
