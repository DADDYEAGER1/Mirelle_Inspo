      "path": "src/components/Blog/ShareButton.tsx",
      "content": "'use client';\n\nimport { useState, useRef, useEffect } from 'react';\nimport { Link2, Check } from 'lucide-react';\n\ninterface ShareButtonProps {\n  url: string;\n  title: string;\n}\n\n// Inline brand marks (lucide has no brand icons for these)\nconst XIcon = () => (\n  <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"currentColor\">\n    <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\" />\n  </svg>\n);\n\nconst FacebookIcon = () => (\n  <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"currentColor\">\n    <path d=\"M22 12.06C22 6.505 17.523 2 12 2S2 6.505 2 12.06c0 5.022 3.657 9.184 8.438 9.94v-7.03H7.898v-2.91h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.773-1.63 1.563v1.875h2.773l-.443 2.91h-2.33V22c4.78-.756 8.437-4.918 8.437-9.94z\" />\n  </svg>\n);\n\nconst PinterestIcon = () => (\n  <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"currentColor\">\n    <path d=\"M12.017 2C6.484 2 2 6.485 2 12.017c0 4.243 2.636 7.866 6.357 9.32-.088-.79-.167-2.005.035-2.868.183-.78 1.18-4.97 1.18-4.97s-.3-.605-.3-1.498c0-1.404.814-2.452 1.828-2.452.862 0 1.279.647 1.279 1.422 0 .867-.553 2.16-.838 3.358-.238 1.002.503 1.82 1.49 1.82 1.789 0 3.165-1.887 3.165-4.605 0-2.407-1.73-4.09-4.196-4.09-2.86 0-4.54 2.144-4.54 4.36 0 .863.328 1.79.738 2.293a.3.3 0 0 1 .069.286c-.076.32-.246.998-.28 1.137-.043.183-.143.222-.33.134-1.234-.575-2.005-2.378-2.005-3.827 0-3.117 2.264-5.98 6.529-5.98 3.428 0 6.094 2.443 6.094 5.706 0 3.404-2.146 6.144-5.124 6.144-1.001 0-1.943-.52-2.265-1.135 0 0-.496 1.886-.616 2.348-.222.855-.823 1.928-1.225 2.582.923.286 1.902.44 2.92.44 5.532 0 10.016-4.485 10.016-10.017C22.034 6.485 17.55 2 12.017 2z\" />\n  </svg>\n);\n\nconst LinkedInIcon = () => (\n  <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"currentColor\">\n    <path d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.114 20.452H3.558V9h3.556v11.452z\" />\n  </svg>\n);\n\nconst RedditIcon = () => (\n  <svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"currentColor\">\n    <path d=\"M12 2C6.477 2 2 6.477 2 12c0 2.85 1.187 5.42 3.094 7.26-.022.184-.034.37-.034.557 0 2.484 2.798 4.5 6.25 4.5.39 0 .77-.025 1.14-.072.41.146.85.225 1.31.225.918 0 1.74-.32 2.39-.84a4.55 4.55 0 0 0 1.61.293c2.485 0 4.5-1.62 4.5-3.62 0-.43-.09-.84-.255-1.22A9.96 9.96 0 0 0 22 12c0-5.523-4.477-10-10-10zm5.5 8a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm-11 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm5.5 8.5c-1.96 0-3.55-.84-3.55-1.88s1.59-1.88 3.55-1.88 3.55.84 3.55 1.88-1.59 1.88-3.55 1.88z\" />\n  </svg>\n);\n\nexport default function ShareButton({ url, title }: ShareButtonProps) {\n  const [open, setOpen] = useState(false);\n  const [copied, setCopied] = useState(false);\n  const wrapRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    function handleClickOutside(e: MouseEvent) {\n      if (wrapRef.current && !wrapRef.current.contains(e.target as Node)) {\n        setOpen(false);\n      }\n    }\n    document.addEventListener('mousedown', handleClickOutside);\n    return () => document.removeEventListener('mousedown', handleClickOutside);\n  }, []);\n\n  const encodedUrl = encodeURIComponent(url);\n  const encodedTitle = encodeURIComponent(title);\n\n  function isMobile() {\n    if (typeof navigator === 'undefined') return false;\n    return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);\n  }\n\n  function openShare(href: string) {\n    if (isMobile()) {\n      // Plain navigation lets iOS/Android hand off to the installed\n      // app via universal/app links. Desktop-style popup params\n      // (width/height) are ignored on mobile anyway and instead force\n      // a generic browser tab, breaking the app handoff.\n      window.open(href, '_blank');\n    } else {\n      window.open(href, '_blank', 'noopener,noreferrer,width=600,height=600');\n    }\n  }\n\n  async function handleCopy() {\n    try {\n      await navigator.clipboard.writeText(url);\n      setCopied(true);\n      setTimeout(() => setCopied(false), 2000);\n    } catch {\n      // clipboard unavailable, silently ignore\n    }\n  }\n\n  const actions = [\n    {\n      key: 'copy',\n      label: copied ? 'Copied' : 'Copy link',\n      icon: copied ? <Check size={18} /> : <Link2 size={18} />,\n      onClick: handleCopy,\n    },\n    {\n      key: 'x',\n      label: 'X',\n      icon: <XIcon />,\n      onClick: () => openShare(`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`),\n    },\n    {\n      key: 'facebook',\n      label: 'Facebook',\n      icon: <FacebookIcon />,\n      onClick: () => openShare(`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`),\n    },\n    {\n      key: 'pinterest',\n      label: 'Pinterest',\n      icon: <PinterestIcon />,\n      onClick: () => openShare(`https://pinterest.com/pin/create/button/?url=${encodedUrl}&description=${encodedTitle}`),\n    },\n    {\n      key: 'linkedin',\n      label: 'LinkedIn',\n      icon: <LinkedInIcon />,\n      onClick: () => openShare(`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`),\n    },\n    {\n      key: 'reddit',\n      label: 'Reddit',\n      icon: <RedditIcon />,\n      onClick: () => openShare(`https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`),\n    },\n  ];\n\n  return (\n    <div\n      ref={wrapRef}\n      className=\"fixed z-40\"\n      style={{ bottom: '84px', right: '16px' }}\n    >\n      {/* Expanded action stack */}\n      {open && (\n        <div\n          className=\"flex flex-col items-center gap-2 mb-3\"\n          role=\"menu\"\n          aria-label=\"Share this post\"\n        >\n          {actions.map((action, i) => (\n            <button\n              key={action.key}\n              onClick={action.onClick}\n              role=\"menuitem\"\n              aria-label={action.label}\n              title={action.label}\n              className=\"w-11 h-11 rounded-full flex items-center justify-center shadow-md border transition-transform hover:scale-105 active:scale-95\"\n              style={{\n                backgroundColor: 'var(--background)',\n                color: 'var(--foreground)',\n                borderColor: 'rgba(37,34,32,0.15)',\n                animation: `shareFadeIn 0.18s ease-out ${i * 0.03}s both`,\n              }}\n            >\n              {action.icon}\n            </button>\n          ))}\n        </div>\n      )}\n\n      {/* Main trigger */}\n      <button\n        onClick={() => setOpen(o => !o)}\n        aria-label={open ? 'Close share menu' : 'Share this post'}\n        aria-expanded={open}\n        className=\"w-12 h-12 rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-105 active:scale-95\"\n        style={{\n          backgroundColor: 'var(--foreground)',\n          color: 'var(--background)',\n        }}\n      >\n        <svg\n          viewBox=\"0 0 24 24\"\n          width=\"20\"\n          height=\"20\"\n          fill=\"none\"\n          stroke=\"currentColor\"\n          strokeWidth=\"2\"\n          strokeLinecap=\"round\"\n          strokeLinejoin=\"round\"\n          style={{ transform: open ? 'rotate(45deg)' : 'none', transition: 'transform 0.2s ease' }}\n        >\n          <circle cx=\"18\" cy=\"5\" r=\"3\" />\n          <circle cx=\"6\" cy=\"12\" r=\"3\" />\n          <circle cx=\"18\" cy=\"19\" r=\"3\" />\n          <line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\" />\n          <line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\" />\n        </svg>\n      </button>\n\n      <style jsx>{`\n        @keyframes shareFadeIn {\n          from {\n            opacity: 0;\n            transform: translateY(6px) scale(0.9);\n          }\n          to {\n            opacity: 1;\n            transform: translateY(0) scale(1);\n          }\n        }\n      `}</style>\n    </div>\n  );\n}"
    },
