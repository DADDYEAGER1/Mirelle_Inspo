      "path": "src/app/work-nails/[slug]/templates/CenterTemplate.tsx",
      "content": "// src/app/work-nails/[slug]/templates/CenterTemplate.tsx\nimport { WorkNailsPost } from '@/types/workNails';\nimport MDXContent from './MDXContent';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport AboutEEAT from '@/components/Blog/AboutEEAT';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport ReadMoreSection from '@/components/Blog/ReadMoreSection';\nimport TableOfContents from '@/components/Blog/TableOfContents';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\n\ninterface CenterTemplateProps {\n  post: WorkNailsPost;\n}\n\n/**\n * Splits raw MDX source into N roughly-equal parts by h2 headings.\n * Returns an array of MDX strings safe to pass to <MDXContent source={...} />.\n */\nfunction splitMDXByH2(source: string, parts: number): string[] {\n  // Split on h2 markdown headings (## ...) keeping the delimiter\n  const blocks = source.split(/(?=^## )/m);\n  const total = blocks.length;\n\n  if (total <= parts) {\n    // Not enough headings to split — return whole content in first slot\n    return [source, ...Array(parts - 1).fill('')];\n  }\n\n  const chunkSize = Math.ceil(total / parts);\n  const result: string[] = [];\n  for (let i = 0; i < parts; i++) {\n    result.push(blocks.slice(i * chunkSize, (i + 1) * chunkSize).join(''));\n  }\n  return result;\n}\n\nexport default function CenterTemplate({ post }: CenterTemplateProps) {\n  const postProducts = post.products ?? [];\n  const author = post.author ? getAuthor(post.author) : null;\n\n  const [firstThird, secondThird, lastThird] = splitMDXByH2(post.content, 3);\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n      {/* Hero */}\n      <div className=\"w-full\">\n        <div className=\"text-center py-12 md:py-16 px-6\" style={{ backgroundColor: '#f9fafb' }}>\n          {post.category && (\n            <p className=\"font-ui text-sm uppercase tracking-wider text-gray-600 mb-4\">\n              {post.category}\n            </p>\n          )}\n          <h1\n            className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-6\"\n            style={{ color: '#252220' }}\n          >\n            {post.title}\n          </h1>\n          <p className=\"font-ui text-sm uppercase tracking-wide mb-2\" style={{ color: '#252220' }}>\n            BY {post.author}\n          </p>\n          <p className=\"font-ui text-sm text-gray-600\">\n            {new Date(post.date).toLocaleDateString('en-US', {\n              year: 'numeric',\n              month: 'long',\n              day: 'numeric',\n            })}\n          </p>\n        </div>\n        <div className=\"w-full\">\n          <img src={post.image} alt={post.imageAlt || post.title} className=\"w-full h-auto\" />\n        </div>\n      </div>\n\n      <div className=\"w-full flex justify-center mt-12\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <div className=\"mb-8\">\n            <Breadcrumbs\n              items={[{ label: 'Work Nails', href: '/work-nails' }]}\n              currentPage={post.title}\n              includeSchema={false}\n            />\n          </div>\n          <div className=\"block lg:hidden mb-8\">\n            <TableOfContents content={post.content} />\n          </div>\n\n          <div className=\"flex gap-12 items-start\">\n            <div className=\"flex-1 min-w-0\">\n              <article className=\"prose-content-magazine\">\n                {/* First third ~33% */}\n                <MDXContent source={firstThird} products={postProducts} />\n              </article>\n            </div>\n\n            {/* Desktop sidebar TOC only */}\n            <aside\n              className=\"hidden lg:flex lg:flex-col gap-6 flex-shrink-0 self-start\"\n              style={{ position: 'sticky', top: '6rem' }}\n            >\n              <TableOfContents content={post.content} />\n            </aside>\n          </div>\n        </div>\n      </div>\n\n      {/* Inline newsletter 1 — at ~33% */}\n      <div className=\"w-full my-10\">\n        <InlineNewsletter />\n      </div>\n\n      <div className=\"w-full flex justify-center\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <article className=\"prose-content-magazine\">\n            {/* Second third ~33–67% */}\n            <MDXContent source={secondThird} products={postProducts} />\n          </article>\n        </div>\n      </div>\n\n      {/* Inline newsletter 2 — at ~67% */}\n      <div className=\"w-full my-10\">\n        <InlineNewsletter />\n      </div>\n\n      <div className=\"w-full flex justify-center\">\n        <div className=\"w-full max-w-7xl px-6 md:px-12 lg:px-16\">\n          <article className=\"prose-content-magazine\">\n            {/* Last third ~67–100% */}\n            <MDXContent source={lastThird} products={postProducts} />\n          </article>\n        </div>\n      </div>\n\n      {author && <AuthorCard author={author} />}\n      <AboutEEAT />\n      <ReadMoreSection currentSlug={post.slug} />\n      <div className=\"w-full\">\n        <InlineNewsletter />\n      </div>\n      <FinalNewsletter />\n    </div>\n  );\n}"
    },
