      "path": "src/app/topics/[slug]/page.tsx",
      "content": "// src/app/topics/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { getTopic, getAllTopicSlugs } from '@/lib/topic';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport type { Metadata } from 'next';\nimport Link from 'next/link';\nimport { resolveAuthor } from '@/data/authors';\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\nexport async function generateStaticParams() {\n  const slugs = await getAllTopicSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\n \nexport async function generateMetadata({\n  params,\n}: {\n  params: Promise<{ slug: string }>;\n}): Promise<Metadata> {\n  const { slug } = await params;\n  const topic = await getTopic(slug);\n \n  if (!topic) {\n    return {\n      title: 'Topic Not Found',\n      robots: { index: false, follow: false },\n    };\n  }\n \n  const canonicalUrl = `https://mirelleinspo.com/topics/${slug}`;\n  const imageUrl = topic.image\n    ? `https://mirelleinspo.com${topic.image}`\n    : 'https://mirelleinspo.com/logo.png';\n  const resolvedAuthor = resolveAuthor(topic.author || '');\n  const authorFullName = resolvedAuthor?.fullName || 'Jyotika Verma';\n  const authorUrl =\n    resolvedAuthor?.authorPageUrl || 'https://mirelleinspo.com/authors/jyoti-mirelle';\n \n  return {\n    title: topic.title,\n    description:\n      topic.excerpt ||\n      `${topic.title} — an in-depth editorial guide from Mirellé Inspo.`,\n    authors: [{ name: authorFullName, url: authorUrl }],\n    creator: authorFullName,\n    publisher: 'Mirellé Inspo',\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: topic.title,\n      description:\n        topic.excerpt ||\n        `${topic.title} — an in-depth editorial guide from Mirellé Inspo.`,\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      type: 'article',\n      locale: 'en_US',\n      images: [\n        {\n          url: imageUrl,\n          width: topic.imageWidth || 1200,\n          height: topic.imageHeight || 630,\n          alt: topic.imageAlt || topic.title,\n        },\n      ],\n      publishedTime: topic.date,\n      modifiedTime: topic.dateModified || topic.date,\n      authors: [authorUrl],\n      section: topic.category || 'Nail Art',\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: topic.title,\n      description:\n        topic.excerpt ||\n        `${topic.title} — an in-depth editorial guide from Mirellé Inspo.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    robots: {\n      index: true,\n      follow: true,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n    other: {\n      'article:published_time': topic.date,\n      'article:modified_time': topic.dateModified || topic.date,\n      'article:author': authorUrl,\n      'article:section': topic.category || 'Nail Art',\n    },\n  };\n}\n \n\nexport default async function TopicPage({ params }: PageProps) {\n  const { slug } = await params;\n  const topic = await getTopic(slug);\n  if (!topic) notFound();\n\n  const author = topic.author ? getAuthor(topic.author) : null;\n\n  // Split content into thirds: 33% / 67% / rest\n  const h2Blocks = topic.content.split(/(?=<h2[\\s>])/);\n  const total = h2Blocks.length;\n  const cut1 = Math.max(1, Math.floor(total * 0.33));\n  const cut2 = Math.max(cut1 + 1, Math.floor(total * 0.67));\n  const firstThird  = h2Blocks.slice(0, cut1).join('');\n  const secondThird = h2Blocks.slice(cut1, cut2).join('');\n  const lastThird   = h2Blocks.slice(cut2).join('');\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    '@id': `https://mirelleinspo.com/topics/${slug}#article`,\n    headline: topic.title,\n    description: topic.excerpt,\n    image: topic.image ? `https://mirelleinspo.com${topic.image}` : 'https://mirelleinspo.com/og-default.png',\n    datePublished: topic.date,\n    dateModified: topic.dateModified,\n    author: { '@type': 'Person', name: topic.author },\n    publisher: { '@type': 'Organization', name: 'Mirellé Inspo', logo: { '@type': 'ImageObject', url: 'https://mirelleinspo.com/logo.png' } },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `https://mirelleinspo.com/topics/${slug}` },\n    ...(topic.sameAs && { sameAs: topic.sameAs }),\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },\n      { '@type': 'ListItem', position: 2, name: 'Topics', item: 'https://mirelleinspo.com/topics' },\n      { '@type': 'ListItem', position: 3, name: topic.title, item: `https://mirelleinspo.com/topics/${slug}` },\n    ],\n  };\n\n  const faqSchema = topic.faqItems?.length ? {\n    '@context': 'https://schema.org',\n    '@type': 'FAQPage',\n    mainEntity: topic.faqItems.map((faq: any) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })),\n  } : null;\n\n  const howToSchema = topic.tutorial?.length ? {\n    '@context': 'https://schema.org',\n    '@type': 'HowTo',\n    name: topic.title,\n    description: topic.excerpt,\n    image: topic.image ? `https://mirelleinspo.com${topic.image}` : undefined,\n    step: topic.tutorial.map((step: any, index: number) => ({ '@type': 'HowToStep', position: index + 1, name: step.step, text: step.description, ...(step.image && { image: `https://mirelleinspo.com${step.image}` }) })),\n  } : null;\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n      {faqSchema && <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(faqSchema) }} />}\n      {howToSchema && <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(howToSchema) }} />}\n\n      <main className=\"min-h-screen bg-background\">\n        {/* Header */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20\">\n            <nav className=\"mb-8\" aria-label=\"Breadcrumb\">\n              <ol className=\"flex items-center space-x-2 font-ui text-xs text-foreground/60\">\n                <li><Link href=\"/\" className=\"hover:text-foreground transition-colors\">Home</Link></li>\n                <li>/</li>\n                <li><Link href=\"/topics\" className=\"hover:text-foreground transition-colors\">Topics</Link></li>\n                <li>/</li>\n                <li className=\"text-foreground\">{topic.title}</li>\n              </ol>\n            </nav>\n            <span className=\"font-ui text-xs tracking-wider text-foreground/60 uppercase block mb-6\">{topic.category}</span>\n            <h1 className=\"font-heading text-4xl sm:text-5xl md:text-6xl text-foreground mb-6 leading-tight\">{topic.title}</h1>\n            <p className=\"font-body text-lg md:text-xl text-foreground/70 leading-relaxed mb-8\">{topic.excerpt}</p>\n            <div className=\"flex items-center space-x-4 font-ui text-sm text-foreground/60\">\n              <span>{topic.author}</span>\n              <span>•</span>\n              <span>{topic.readTime}</span>\n              <span>•</span>\n              <time dateTime={topic.date}>{new Date(topic.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>\n            </div>\n          </div>\n        </section>\n\n        {topic.image && (\n          <section className=\"border-b border-foreground/10\">\n            <div className=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12\">\n              <div className=\"relative w-full overflow-hidden bg-foreground/5\">\n                <img src={topic.image} alt={topic.imageAlt || topic.title} className=\"w-full h-auto\" />\n              </div>\n            </div>\n          </section>\n        )}\n\n        {/* First third ~33% */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16\">\n            <article className=\"prose-content-magazine\">\n              <div dangerouslySetInnerHTML={{ __html: firstThird }} />\n            </article>\n          </div>\n        </section>\n\n        {/* Inline newsletter 1 — at ~33% */}\n        <InlineNewsletter />\n\n        {/* Second third ~33–67% */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16\">\n            <article className=\"prose-content-magazine\">\n              <div dangerouslySetInnerHTML={{ __html: secondThird }} />\n            </article>\n          </div>\n        </section>\n\n        {/* Inline newsletter 2 — at ~67% */}\n        <InlineNewsletter />\n\n        {/* Last third ~67–100% */}\n        <section className=\"border-b border-foreground/10\">\n          <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16\">\n            <article className=\"prose-content-magazine\">\n              <div dangerouslySetInnerHTML={{ __html: lastThird }} />\n            </article>\n          </div>\n        </section>\n\n        {author && <AuthorCard author={author} />}\n        {/* <div className=\"w-full\"><InlineNewsletter /></div> */}\n        <FinalNewsletter />\n      </main>\n    </>\n  );\n}"
