      "content": "// src/app/shop/[...slug]/page.tsx\n// URL pattern: /shop/[productType]/[slug]\n\nimport { notFound } from 'next/navigation';\nimport { getShopPost, getAllShopPosts } from '@/lib/shop';\nimport type { Metadata } from 'next';\nimport ShopTemplate from '../templates/ShopTemplate';\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\ninterface PageProps {\n  params: Promise<{\n    slug?: string[]; // expected: [productType, slug]\n  }>;\n}\n\n// ─── Static params ────────────────────────────────────────────────────────────\n\nexport async function generateStaticParams() {\n  const posts = await getAllShopPosts();\n  return posts.map(post => ({\n    slug: [post.productType, post.slug],\n  }));\n}\n\n// ─── Metadata ─────────────────────────────────────────────────────────────────\n\nexport async function generateMetadata({\n  params,\n}: {\n  params: Promise<{ slug: string[] }>;\n}): Promise<Metadata> {\n  const { slug: segments } = await params;\n \n  if (!segments || segments.length !== 2) {\n    return {\n      title: 'Product Not Found',\n      robots: { index: false, follow: false },\n    };\n  }\n \n  const [productType, slug] = segments;\n  const post = await getShopPost(productType, slug);\n \n  if (!post) {\n    return {\n      title: 'Product Not Found',\n      robots: { index: false, follow: false },\n    };\n  }\n \n  const canonicalUrl = `https://mirelleinspo.com/shop/${productType}/${slug}`;\n  const imageUrl = post.image\n    ? `https://mirelleinspo.com${post.image}`\n    : 'https://mirelleinspo.com/logo.png';\n \n  return {\n    title: post.title,\n    description:\n      post.excerpt ||\n      `${post.title} — editor-reviewed and picked by the Mirellé Inspo team.`,\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: post.title,\n      description:\n        post.excerpt ||\n        `${post.title} — editor-reviewed and picked by the Mirellé Inspo team.`,\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      type: 'website',\n      locale: 'en_US',\n      images: [\n        {\n          url: imageUrl,\n          width: post.imageWidth || 1200,\n          height: post.imageHeight || 630,\n          alt: post.imageAlt || post.title,\n        },\n      ],\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: post.title,\n      description:\n        post.excerpt ||\n        `${post.title} — editor-reviewed by Mirellé Inspo.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    robots: {\n      index: true,\n      follow: true,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n  };\n}\n \n \n\n// ─── Page ─────────────────────────────────────────────────────────────────────\n\nexport default async function ShopPostPage({ params }: PageProps) {\n  const { slug: segments } = await params;\n  if (!segments || segments.length !== 2) notFound();\n\n  const [productType, slug] = segments;\n  const post = await getShopPost(productType, slug);\n  if (!post) notFound();\n\n  return <ShopTemplate post={post} />;\n}"
