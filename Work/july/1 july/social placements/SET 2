      "path": "src/app/blog/templates/MDXContent.tsx",
      "content": "import { MDXRemote } from 'next-mdx-remote/rsc';\nimport ProductGrid from '@/components/Blog/ProductGrid';\nimport { Product } from '@/types/blog';\n\ninterface MDXContentProps {\n  source: string;\n  products: Product[];\n  topic?: string;\n}\n\nfunction humanizeTopic(topic: string): string {\n  return topic.replace(/-/g, ' ');\n}\n\nexport default function MDXContent({ source, products, topic }: MDXContentProps) {\n  const mdxComponents = {\n    ProductGrid: (props: any) => (\n      <ProductGrid {...props} products={products} />\n    ),\n    // Auto-wrap every <img> in MDX content with the inspo gallery link,\n    // matching the same behavior as MD posts. Only renders if `topic`\n    // is present in frontmatter  works for any future post automatically.\n    img: (props: any) => {\n      if (!topic) return <img {...props} />;\n      const galleryHref = `/inspo/${topic}-inspiration-gallery`;\n      return (\n        <>\n          <img {...props} />\n          <p className=\"inspo-gallery-link\">\n            <a href={galleryHref}>Explore {humanizeTopic(topic)} inspiration gallery</a>\n          </p>\n        </>\n      );\n    },\n  };\n\n  return (\n    <MDXRemote\n      source={source}\n      components={mdxComponents}\n    />\n  );\n}"
