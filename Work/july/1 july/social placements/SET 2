      "path": "src/app/nail-faqs/[slug]/page.tsx",
      "content": "// src/app/nail-faqs/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { getFaq, getAllFaqSlugs } from '@/lib/faqs';\nimport { MDXRemote } from 'next-mdx-remote/rsc';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport FaqFinalNewsletter from '@/components/Faqs/FaqFinalNewsletter';\nimport FaqAbout from '@/components/Faqs/FaqAbout';\nimport FaqReadMore from '@/components/Faqs/FaqReadMore';\nimport FaqAskQuestion from '@/components/Faqs/FaqAskQuestion';\nimport AuthorCard from '@/components/Blog/AuthorCard';\nimport { getAuthor } from '@/lib/authors';\nimport type { Metadata } from 'next';\nimport { resolveAuthor } from '@/data/authors';\n\nexport const dynamic = 'force-static'\nexport const revalidate = false\n\nconst mdxComponents = {};\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\nexport async function generateStaticParams() {\n  const slugs = await getAllFaqSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\nconst SITE_URL = 'https://mirelleinspo.com';\nconst FALLBACK_OG_IMAGE = `${SITE_URL}/og-default.png`;\n\n\n\nexport async function generateMetadata({\n  params,\n}: {\n  params: Promise<{ slug: string }>;\n}): Promise<Metadata> {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n \n  if (!faq) {\n    return {\n      title: 'FAQ Not Found',\n      robots: { index: false, follow: false },\n    };\n  }\n \n  const canonicalUrl = `https://mirelleinspo.com/nail-faqs/${slug}`;\n  const imageUrl = faq.image\n    ? `https://mirelleinspo.com${faq.image}`\n    : 'https://mirelleinspo.com/logo.png';\n  const resolvedAuthor = resolveAuthor(faq.author || '');\n  const authorFullName = resolvedAuthor?.fullName || 'Jyotika Verma';\n  const authorUrl =\n    resolvedAuthor?.authorPageUrl || 'https://mirelleinspo.com/authors/jyoti-mirelle';\n \n  return {\n    title: faq.title,\n    description:\n      faq.excerpt ||\n      `${faq.title} — a clear, researched answer from Mirellé Inspo.`,\n    authors: [{ name: authorFullName, url: authorUrl }],\n    creator: authorFullName,\n    publisher: 'Mirellé Inspo',\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: faq.title,\n      description:\n        faq.excerpt || `${faq.title} — a clear, researched answer from Mirellé Inspo.`,\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      type: 'article',\n      locale: 'en_US',\n      publishedTime: faq.date,\n      modifiedTime: faq.dateModified || faq.date,\n      authors: [authorUrl],\n      section: faq.category || 'Nail FAQs',\n    },\n    twitter: {\n      card: 'summary',\n      title: faq.title,\n      description:\n        faq.excerpt || `${faq.title} — a clear, researched answer from Mirellé Inspo.`,\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    robots: {\n      index: true,\n      follow: true,\n      googleBot: {\n        index: true,\n        follow: true,\n        'max-image-preview': 'large',\n        'max-snippet': -1,\n      },\n    },\n    other: {\n      'article:published_time': faq.date,\n      'article:modified_time': faq.dateModified || faq.date,\n      'article:author': authorUrl,\n      'article:section': faq.category || 'Nail FAQs',\n    },\n  };\n}\n \n\nexport default async function NailFaqPage({ params }: PageProps) {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n  if (!faq) notFound();\n\n  const author = faq.author ? getAuthor(faq.author) : null;\n\n  const articleSchema = {\n    '@context': 'https://schema.org', '@type': 'Article',\n    headline: faq.title, description: faq.excerpt, image: FALLBACK_OG_IMAGE,\n    datePublished: faq.date, dateModified: faq.dateModified || faq.date,\n    author: { '@type': 'Person', name: faq.author },\n    publisher: { '@type': 'Organization', name: 'Mirellé Inspo', logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` } },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/nail-faqs/${slug}` },\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org', '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },\n      { '@type': 'ListItem', position: 2, name: 'Nail FAQs', item: `${SITE_URL}/nail-faqs` },\n      { '@type': 'ListItem', position: 3, name: faq.title },\n    ],\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n\n      <div className=\"min-h-screen bg-background\">\n        <div className=\"w-full flex flex-col items-start\">\n          <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16 py-8 md:py-12\">\n            <div className=\"mb-6\">\n              <Breadcrumbs items={[{ label: 'Nail FAQs', href: '/nail-faqs' }]} currentPage={faq.title} includeSchema={false} />\n            </div>\n            <p className=\"text-sm uppercase tracking-wide text-gray-700 mb-4\">{faq.category}</p>\n            <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\">{faq.title}</h1>\n            <div className=\"text-sm text-gray-700 mb-8\">\n              <p className=\"uppercase tracking-wide mb-1\">BY {faq.author}</p>\n              <time dateTime={faq.date} className=\"text-gray-600\">\n                {new Date(faq.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}\n              </time>\n            </div>\n            <article className=\"prose-content-magazine\">\n              <MDXRemote source={faq.content} components={mdxComponents} />\n            </article>\n            <FaqAskQuestion />\n          </div>\n        </div>\n        {author && <AuthorCard author={author} />}\n        <FaqAbout />\n        <FaqAskQuestion />\n        <FaqFinalNewsletter />\n        <FaqReadMore currentSlug={faq.slug} />\n      </div>\n    </>\n  );\n}"
