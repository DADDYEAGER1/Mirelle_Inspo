{/* Button */}\n          <Link \n            href=\"/subscribe\"\n            className=\"bg-foreground text-white px-4 py-2 font-ui text-xs uppercase tracking-wider hover:opacity-80 transition-opacity inline-block text-center\"\n          >\n            SUBSCRIBE NOW\n          </Link>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
