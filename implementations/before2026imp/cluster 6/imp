**Optional**: Add category validation script that runs before build:

**File**: `scripts/validate-categories.js`

```javascript
const fs = require('fs');
const path = require('path');
const matter = require('gray-matter');

const VALID_CATEGORIES = [
  'Tutorial',
  'Seasonal Nail Trends',
  'Nail Care Guide',
  'Nail Art Techniques',
  'Product Reviews',
  'Inspiration Gallery'
];

const blogsDir = path.join(__dirname, '../src/content/blogs');
const files = fs.readdirSync(blogsDir).filter(f => f.endsWith('.md'));

let errors = [];

files.forEach(file => {
  const content = fs.readFileSync(path.join(blogsDir, file), 'utf8');
  const { data } = matter(content);
  
  if (!data.category) {
    errors.push(`${file}: Missing category`);
  } else if (!VALID_CATEGORIES.includes(data.category)) {
    errors.push(`${file}: Invalid category "${data.category}"`);
  }
});

if (errors.length > 0) {
  console.error('\n❌ Category validation errors:\n');
  errors.forEach(err => console.error(`  ${err}`));
  process.exit(1);
} else {
  console.log('✅ All categories valid');
}
```

Add to `package.json`:
```json
{
  "scripts": {
    "validate": "node scripts/validate-categories.js",
    "build": "npm run validate && next build"
  }
}
```

