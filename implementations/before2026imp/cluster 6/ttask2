const fs = require('fs');
const path = require('path');

const componentsDir = path.join(__dirname, '../src/components');
const pagesDir = path.join(__dirname, '../src/app');

function findFontSizes(dir, results = new Map()) {
  const files = fs.readdirSync(dir, { withFileTypes: true });
  
  files.forEach(file => {
    const fullPath = path.join(dir, file.name);
    
    if (file.isDirectory()) {
      findFontSizes(fullPath, results);
    } else if (file.name.endsWith('.tsx') || file.name.endsWith('.jsx')) {
      const content = fs.readFileSync(fullPath, 'utf8');
      
      // Find text-* classes
      const matches = content.match(/text-\w+/g);
      if (matches) {
        matches.forEach(match => {
          const count = results.get(match) || 0;
          results.set(match, count + 1);
        });
      }
    }
  });
  
  return results;
}

console.log('🔍 Scanning for font size usage...\n');

const results = new Map();
findFontSizes(componentsDir, results);
findFontSizes(pagesDir, results);

const sorted = Array.from(results.entries())
  .sort((a, b) => b[1] - a[1]);

console.log('Most used font sizes:\n');
sorted.forEach(([size, count]) => {
  if (size.startsWith('text-') && !size.includes('gray') && !size.includes('white')) {
    console.log(`  ${size}: ${count} times`);
  }
});

