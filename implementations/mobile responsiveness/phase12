**Required Changes:**
```css
/* MOBILE-FIRST TYPOGRAPHY SCALE */
/* Base: 16px, perfect for mobile readability */
body {
  font-size: 16px;
  line-height: 1.6;
  -webkit-text-size-adjust: 100%;
  text-size-adjust: 100%;
}

/* Heading scales - mobile-first with clamp() */
h1 {
  font-size: clamp(1.75rem, 8vw, 4.5rem); /* 28px → 72px */
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 1rem;
}

h2 {
  font-size: clamp(1.5rem, 6vw, 3.5rem); /* 24px → 56px */
  line-height: 1.2;
  letter-spacing: -0.01em;
}

h3 {
  font-size: clamp(1.25rem, 4vw, 2.25rem); /* 20px → 36px */
  line-height: 1.3;
}

/* TOUCH TARGETS - Enforce minimum sizes */
button,
a[role="button"],
input[type="button"],
input[type="submit"],
.btn {
  min-height: 48px;
  min-width: 48px;
  padding: 0.75rem 1.5rem;
}

/* Form inputs */
input,
textarea,
select {
  min-height: 48px;
  font-size: 16px; /* Prevents iOS zoom on focus */
  padding: 0.75rem 1rem;
}

/* SAFE AREA INSETS - iPhone notch support */
.safe-area-top {
  padding-top: max(1rem, env(safe-area-inset-top));
}

.safe-area-bottom {
  padding-bottom: max(1rem, env(safe-area-inset-bottom));
}

.safe-area-x {
  padding-left: max(1rem, env(safe-area-inset-left));
  padding-right: max(1rem, env(safe-area-inset-right));
}

/* MOBILE CONTAINER */
.container-mobile {
  padding-left: max(1rem, env(safe-area-inset-left));
  padding-right: max(1rem, env(safe-area-inset-right));
  margin: 0 auto;
  max-width: 100%;
}

@media (min-width: 768px) {
  .container-mobile {
    max-width: 768px;
  }
}

/* TAP FEEDBACK - Better touch response */
* {
  -webkit-tap-highlight-color: rgba(227, 0, 136, 0.15);
  tap-highlight-color: rgba(227, 0, 136, 0.15);
}

/* SMOOTH SCROLLING */
html {
  scroll-behavior: smooth;
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }
}

/* PREVENT HORIZONTAL SCROLL */
body {
  overflow-x: hidden;
  max-width: 100vw;
}

/* EDITORIAL SPACING - Premium feel */
.section-spacing {
  padding-top: clamp(2rem, 8vw, 6rem);
  padding-bottom: clamp(2rem, 8vw, 6rem);
}

/* IMAGE OPTIMIZATION */
img {
  max-width: 100%;
  height: auto;
  display: block;
}

/* PREMIUM CARD SHADOWS - Editorial feel */
.card-shadow {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04),
              0 4px 16px rgba(0, 0, 0, 0.04);
}

.card-shadow-hover {
  transition: box-shadow 0.3s ease;
}

.card-shadow-hover:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08),
              0 8px 32px rgba(0, 0, 0, 0.08);
}
