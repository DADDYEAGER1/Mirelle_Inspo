def process_batch(items, start_idx, batch_num, total_batches):
    """Process a batch of items"""
    end_idx = min(start_idx + BATCH_SIZE, len(items))
    batch_items = items[start_idx:end_idx]
    
    print(f"\n{'='*70}")
    print(f"🔍 PROCESSING BATCH {batch_num}/{total_batches}")
    print(f"{'='*70}")
    print(f"Processing images {start_idx + 1} to {end_idx} of {len(items)}")
    print(f"Output format: {output_format.upper()}")
    print(f"Dimension mode: {'Crop to JSON dimensions' if use_json_dimensions else 'Upscale only (no cropping)'}\n")
    
    for i, item in enumerate(batch_items, start_idx + 1):
        img_id = item.get('id')
        url = item.get('url')
        dimensions_obj = item.get('dimensions', {})
        
        # Extract filename from URL
        filename = extract_filename_from_url(url)
        
        # Parse dimensions
        dimensions = parse_dimensions_from_object(dimensions_obj)
        if not dimensions:
            print(f"⚠ Invalid dimensions for ID {img_id}, using 1080x1920")
            dimensions = (1080, 1920)
        
        # Add filename and dimensions to queue for file watcher
        filename_queue.put((filename, dimensions))
        
        # Extract search query from filename
        search_query = extract_search_query(filename)
        
        dim_info = f"Target: {dimensions[0]}x{dimensions[1]}" if use_json_dimensions else "Upscale only"
        print(f"\n[SEARCH {i}/{len(items)}] ID: {img_id} | {dim_info}")
        print(f"   Filename: {filename}")
        search_pinterest(search_query)
        
        # Wait before next search (except for last one in batch)
        if i < end_idx:
            print(f"   Waiting {WAIT_TIME_BETWEEN_SEARCHES} seconds before next search...")
            time.sleep(WAIT_TIME_BETWEEN_SEARCHES)
    
    print(f"\n✓ Search completed for batch {batch_num}")
    return end_idx

def process_category(selected_json, first_run=False):
    """Process a complete category (JSON file)"""
    global processing_active, output_format, use_json_dimensions, selected_output_folder
    
    json_file_path = Path(BASE_JSON_PATH) / selected_json['file']
    selected_output_folder = Path(BASE_OUTPUT_PATH) / selected_json['folder']
    
    # Create output folder if doesn't exist
    selected_output_folder.mkdir(parents=True, exist_ok=True)
    
    print(f"\n✓ Selected: {selected_json['name']}")
    print(f"✓ JSON file: {json_file_path}")
    print(f"✓ Output folder: {selected_output_folder}")
    
    # Load JSON file
    try:
        with open(json_file_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
            items = data.get('images', [])
    except Exception as e:
        print(f"Error reading JSON file: {e}")
        return False
    
    total_items = len(items)
    total_batches = (total_items + BATCH_SIZE - 1) // BATCH_SIZE
    
    print(f"\nTotal images in JSON: {total_items}")
    print(f"Batch size: {BATCH_SIZE} images")
    print(f"Total batches: {total_batches}")
    
    # Ask user for format and dimension preferences only on first run
    if first_run:
        output_format_choice = get_output_format()
        dimension_choice = get_dimension_preference()
        return output_format_choice, dimension_choice
    
    try:
        current_idx = 0
        batch_num = 1
        
        while current_idx < total_items:
            # Process batch
            current_idx = process_batch(items, current_idx, batch_num, total_batches)
            batch_num += 1
            
            # Wait for current batch to complete
            print(f"\n⏳ Waiting for batch downloads to complete...")
            filename_queue.join()
            
            # Check if there are more batches
            if current_idx < total_items:
                print(f"\n{'='*70}")
                print(f"✓ Batch completed! ({current_idx}/{total_items} images processed)")
                print(f"{'='*70}")
                response = input("\nContinue with next batch? (yes/no): ").strip().lower()
                
                if response not in ['yes', 'y']:
                    print("\n⚠ Stopping at user request.")
                    return False
            else:
                print(f"\n{'='*70}")
                print(f"🎉 ALL IMAGES FROM '{selected_json['name'].upper()}' COMPLETED!")
                print(f"{'='*70}\n")
                return True
        
    except KeyboardInterrupt:
        print("\n\n⚠ Script interrupted by user!")
        return False

def main():
    global processing_active, output_format, use_json_dimensions
    
    print(f"\n{'='*70}")
    print(f"🎯 PINTEREST IMAGE PROCESSOR WITH SMART CROPPING")
    print(f"{'='*70}")
    
    # Select first JSON file
    selected_json = select_json_file()
    
    # Get format and dimension preferences on first run
    format_choice, dimension_choice = process_category(selected_json, first_run=True)
    output_format = format_choice
    use_json_dimensions = dimension_choice
    
    # Start file watcher thread
    print(f"\n{'='*70}")
    print("👀 Starting file watcher thread...")
    print(f"{'='*70}")
    watcher = threading.Thread(target=file_watcher_thread, daemon=True)
    watcher.start()
    
    try:
        # Process the first category
        category_completed = process_category(selected_json)
        
        # Loop to allow processing multiple categories
        while category_completed:
            print(f"\n{'='*70}")
            response = input("Do you want to process another category? (yes/no): ").strip().lower()
            
            if response not in ['yes', 'y']:
                print("\n✓ Exiting script. Thank you!")
                break
            
            # Select next JSON file
            selected_json = select_json_file()
            
            # Process the next category
            category_completed = process_category(selected_json)
        
        # Signal that we're done
        processing_active = False
        watcher.join(timeout=5)
        
    except KeyboardInterrupt:
        print("\n\n⚠ Script interrupted by user!")
        processing_active = False
        watcher.join(timeout=5)

if __name__ == "__main__":
    main()
