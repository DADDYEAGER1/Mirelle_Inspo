// ── PERSON SCHEMA — JYOTIKA VERMA ────────────────────────────────────────────

export function generateJyotiSchema() {
  const author = authors.find((a) => a.slug === 'jyoti-mirelle')!;
  return {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': JYOTI_ID,
    'name': author.fullName,
    'givenName': 'Jyotika',
    'familyName': 'Verma',
    'alternateName': 'Jyoti',
    'url': author.authorPageUrl,
    'image': `${BASE_URL}${author.image}`,
    'jobTitle': author.role,
    'description': author.bio,
    'worksFor': { '@id': ORG_ID },
    'knowsAbout': author.knowsAbout,
    'sameAs': [
      author.instagram,
      author.linkedin,
    ].filter(Boolean),
  };
}

// ── PERSON SCHEMA — GAURAV VERMA ─────────────────────────────────────────────

export function generateRiSchema() {
  const author = authors.find((a) => a.slug === 'ri-mirelle')!;
  return {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': RI_ID,
    'name': author.fullName,
    'givenName': 'Gaurav',
    'familyName': 'Verma',
    'alternateName': 'Ri',
    'url': author.authorPageUrl,
    'image': `${BASE_URL}${author.image}`,
    'jobTitle': author.role,
    'description': author.bio,
