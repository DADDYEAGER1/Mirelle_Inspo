      author.linkedin,
    ].filter(Boolean),
  };
}

// ── RESOLVE AUTHOR SCHEMA from frontmatter string ─────────────────────────────
// Used by blog/[...slug], work-nails/[slug], etc. to pick the right Person schema

export function resolveAuthorSchema(authorString: string) {
  const author = resolveAuthor(authorString);
  if (!author) return null;
  return author.slug === 'ri-mirelle' ? generateRiSchema() : generateJyotiSchema();
}

export function resolveAuthorId(authorString: string): string {
  const author = resolveAuthor(authorString);
  if (!author) return JYOTI_ID; // default to Jyoti
  return author.slug === 'ri-mirelle' ? RI_ID : JYOTI_ID;
}

