// src/lib/generateSchemas.ts

import { BlogPost, BlogMetadata, TutorialMetadata } from '@/types/blog';
import { Author } from '@/types/author';
import { authors, resolveAuthor } from '@/data/authors';
import { generateAboutEntities } from './entityMapping';

const BASE_URL = 'https://mirelleinspo.com';

// ── Shared constants ───────────────────────────────────────────────────────────

const ORG_ID   = `${BASE_URL}/#organization`;
const SITE_ID  = `${BASE_URL}/#website`;
const JYOTI_ID = `${BASE_URL}/authors/jyoti-mirelle#person`;
const RI_ID    = `${BASE_URL}/authors/ri-mirelle#person`;

// ── Reusable types (exported for page use) ────────────────────────────────────

export interface FAQItem       { question: string; answer: string }
export interface TutorialStep  { position: number; name: string; text: string; image?: string }
export interface VideoMetadata { name: string; description: string; thumbnailUrl: string; uploadDate: string; duration?: string; embedUrl?: string }
export interface GalleryImage  { url: string; alt: string; width?: number; height?: number; caption?: string }
export interface EventData     { name: string; startDate: string; endDate: string; eventStatus: string; eventAttendanceMode: string; isVirtual: boolean }

export interface SchemaConfig {
  post: BlogPost;
  slug: string;
  faqItems?: FAQItem[];
  tutorialSteps?: TutorialStep[];
  tutorialMetadata?: TutorialMetadata;
  videoMetadata?: VideoMetadata;
  galleryImages?: GalleryImage[];
  eventData?: EventData;
}

