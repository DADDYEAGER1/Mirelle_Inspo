      "content": "// src/types/author.ts\n\nexport interface Author {\n  slug: string;\n  fullName: string;          // real legal name — used in schema\n  displayName: string;       // short name used in UI e.g. \"Jyoti\"\n  role: string;              // job title for schema jobTitle field\n  bio: string;               // 2-3 sentences — AuthorCard, blog posts\n  longBio: string;           // full bio — /authors/[slug] page\n  image: string;             // e.g. /images/team/ri-mirelle.webp\n  authorPageUrl: string;     // canonical author page URL\n  instagram?: string;\n  linkedin?: string;\n  youtube?: string;\n  twitter?: string;\n  knowsAbout: string[];      // schema knowsAbout topics array\n}\n\nexport interface AuthorWithStats extends Author {\n  postCount: number;\n}"
