      "path": "src/app/blog/[...slug]/page.tsx",
      "content": "// src/app/blog/[...slug]/page.tsx\n\nimport { notFound } from 'next/navigation';\nimport { getBlogPost, getAllBlogPosts, getPillarClusterPosts } from '@/lib/blog';\nimport type { Metadata } from 'next';\nimport { generateSchemas } from '@/lib/generateSchemas';\nimport { resolveAuthor } from '@/data/authors';\nimport Link from 'next/link';\n\nimport CenterTemplate from '../templates/CenterTemplate';\nimport SplitLeftTemplate from '../templates/SplitLeftTemplate';\nimport SplitRightTemplate from '../templates/SplitRightTemplate';\nimport GridTemplate from '../templates/GridTemplate';\n\nexport const dynamic = 'force-static';\nexport const revalidate = false;\n\ninterface PageProps {\n  params: Promise<{ slug?: string[] }>;\n}\n\n// ─── Static Params ────────────────────────────────────────────────────────────\n\nexport async function generateStaticParams() {\n  const allPosts = await getAllBlogPosts();\n  const paths: { slug: string[] }[] = [];\n  const registeredTopics = new Set<string>();\n\n  for (const post of allPosts) {\n    if (post.topic) {\n      paths.push({ slug: [post.topic, post.slug] });\n      if (post.topicalMap?.position === 'pillar' && !registeredTopics.has(post.topic)) {\n        paths.push({ slug: [post.topic] });\n        registeredTopics.add(post.topic);\n      }\n    } else {\n      paths.push({ slug: [post.slug] });\n    }\n  }\n\n  return paths;\n}\n\n// ─── Metadata ─────────────────────────────────────────────────────────────────\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug: segments } = await params;\n\n  if (!segments || segments.length === 0) return { title: 'Not Found' };\n\n  if (segments.length === 1) {\n    const [segment] = segments;\n    const allPosts = await getAllBlogPosts();\n\n    const pillar = allPosts.find(\n      (p) => p.topic === segment && p.topicalMap?.position === 'pillar'\n    );\n\n    if (pillar) {\n      return {\n        title: pillar.title,\n        description: pillar.excerpt,\n        alternates: { canonical: `https://mirelleinspo.com/blog/${segment}` },\n        robots: { index: true, follow: true },\n      };\n    }\n\n    const post = await getBlogPost(segment);\n    if (!post) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n    const canonicalUrl = post.{author.displayName}canonical || `https://mirelleinspo.com/blog/${segment}`;\n    const imageUrl = post.image\n      ? `https://mirelleinspo.com${post.image}`\n      : 'https://mirelleinspo.com/logo.png';\n\n    return {author.displayName}(post, canonicalUrl, imageUrl, post.imageAlt || post.title);\n  }\n\n  if (segments.length === 2) {\n    const [topic, postSlug] = segments;\n    const post = await getBlogPost(postSlug);\n    if (!post) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n    const canonicalUrl =\n      post.canonical || `https://mirelleinspo.com/blog/${topic}/${postSlug}`;\n    const imageUrl = post.image\n      ? `https://mirelleinspo.com${post.image}`\n      : 'https://mirelleinspo.com/logo.png';\n\n    return {author.displayName}(post, canonicalUrl, imageUrl, post.imageAlt || post.title);\n  }\n\n  return { title: 'Not Found', robots: { index: false, follow: false } };\n}\n\n// ─── Page ─────────────────────────────────────────────────────────────────────\n\nexport default async function BlogCatchAllPage({ params }: PageProps) {\n  const { slug: segments } = await params;\n\n  if (!segments || segments.length === 0) notFound();\n\n  if (segments.length === 1) {\n    const [segment] = segments;\n    const allPosts = await getAllBlogPosts();\n\n    const pillarPost = allPosts.find(\n      (p) => p.topic === segment && p.topicalMap?.position === 'pillar'\n    );\n\n    if (pillarPost) return <PillarHub topic={segment} />;\n\n    const post = await getBlogPost(segment);\n    if (!post) notFound();\n\n    return <PostPage post={post} slug={segment} />;\n  }\n\n  if (segments.length === 2) {\n    const [topic, postSlug] = segments;\n    const post = await getBlogPost(postSlug);\n    if (!post) notFound();\n    if (post.topic && post.topic !== topic) notFound();\n\n    return <PostPage post={post} slug={postSlug} />;\n  }\n\n  notFound();\n}\n\n// ─── Post Renderer ────────────────────────────────────────────────────────────\n\nasync function PostPage({ post, slug }: { post: any; slug: string }) {\n  const schemas = generateSchemas({ post, slug });\n\n  const templates: Record<string, any> = {\n    center: CenterTemplate,\n    'split-left': SplitLeftTemplate,\n    'split-right': SplitRightTemplate,\n    grid: GridTemplate,\n  };\n\n  const Template = templates[post.template || 'center'];\n\n  const postWithCoverImage = {\n    ...post,\n    coverImage: post.image || '/images/default-blog.jpg',\n  };\n\n  return (\n    <>\n      {/* Article schema */}\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.articleSchema) }}\n      />\n      {/* Breadcrumb schema */}\n      <script\n        type=\"application/ld+json\"\n        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.breadcrumbSchema) }}\n      />\n      {/* Optional schemas — only render if they exist */}\n      {schemas.faqSchema && (\n        <script\n          type=\"application/ld+json\"\n          dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.faqSchema) }}\n        />\n      )}\n      {schemas.howToSchema && (\n        <script\n          type=\"application/ld+json\"\n          dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.howToSchema) }}\n        />\n      )}\n      {schemas.videoSchema && (\n        <script\n          type=\"application/ld+json\"\n          dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.videoSchema) }}\n        />\n      )}\n      {schemas.imageGallerySchema && (\n        <script\n          type=\"application/ld+json\"\n          dangerouslySetInnerHTML={{ __html: JSON.stringify(schemas.imageGallerySchema) }}\n        />\n      )}\n      <Template post={postWithCoverImage} />\n    </>\n  );\n}\n\n// ─── Pillar Hub Renderer ──────────────────────────────────────────────────────\n\nasync function PillarHub({ topic }: { topic: string }) {\n  const allPosts = await getAllBlogPosts();\n  const pillar = allPosts.find(\n    (p) => p.topic === topic && p.topicalMap?.position === 'pillar'\n  );\n\n  if (!pillar) notFound();\n\n  const data = await getPillarClusterPosts(pillar.slug);\n  if (!data) notFound();\n\n  const { clusters } = data;\n\n  return (\n    <main className=\"max-w-4xl mx-auto px-4 py-12\">\n      <div className=\"mb-12\">\n        <p className=\"text-sm uppercase tracking-widest text-gray-400 mb-2\">Topic Hub</p>\n        <h1 className=\"text-4xl font-bold mb-4\">{pillar.title}</h1>\n        {pillar.excerpt && <p className=\"text-lg text-gray-600\">{pillar.excerpt}</p>}\n      </div>\n\n      {clusters.length > 0 && (\n        <section>\n          <h2 className=\"text-xl font-semibold mb-6 border-b pb-2\">\n            All Posts in This Topic\n          </h2>\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n            {clusters.map((post) => (\n              <Link\n                key={post.slug}\n                href={`/blog/${topic}/${post.slug}`}\n                className=\"group block border rounded-xl p-5 hover:shadow-md transition-shadow\"\n              >\n                <p className=\"text-xs text-gray-400 mb-1\">{post.readTime}</p>\n                <h3 className=\"font-semibold text-lg group-hover:underline\">{post.title}</h3>\n                {post.excerpt && (\n                  <p className=\"text-sm text-gray-500 mt-2 line-clamp-2\">{post.excerpt}</p>\n                )}\n              </Link>\n            ))}\n          </div>\n        </section>\n      )}\n    </main>\n  );\n}\n\n// ─── Metadata Helper ──────────────────────────────────────────────────────────\n\nfunction buildPostMetadata(post: any, canonicalUrl: string, imageUrl: string, imageAltText: string): Metadata {\n  const resolvedAuthor = resolveAuthor(post.author || '');\n  const authorFullName = resolvedAuthor?.fullName || 'Jyotika Verma';\n  const authorUrl = resolvedAuthor?.authorPageUrl || 'https://mirelleinspo.com/authors/jyoti-mirelle';\n \n  return {\n    title: post.title,\n    description:\n      post.excerpt ||\n      `${post.title} — nail art inspiration, tutorials, and trend analysis from Mirellé Inspo.`,\n    authors: [{ name: authorFullName, url: authorUrl }],\n    creator: authorFullName,\n    publisher: 'Mirellé Inspo',\n    alternates: { canonical: canonicalUrl },\n    robots: {\n      index: true,\n      follow: true,\n      nocache: false,\n      googleBot: { index: true, follow: true, 'max-video-preview': -1, 'max-image-preview': 'large', 'max-snippet': -1 },\n    },\n    openGraph: {\n      title: post.title,\n      description: post.excerpt || `${post.title} — nail inspiration from Mirellé Inspo.`,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirellé Inspo',\n      locale: 'en_US',\n      images: [{ url: imageUrl, width: post.imageWidth || 1200, height: post.imageHeight || 630, alt: imageAltText, type: 'image/jpeg' }],\n      publishedTime: post.date,\n      modifiedTime: post.dateModified || post.date,\n      authors: [authorUrl],\n      section: post.category || 'Nail Art',\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: post.title,\n      description: post.excerpt || `${post.title} — nail inspiration from Mirellé Inspo.`,\n      images: [imageUrl],\n      creator: '@mirelleinspo',\n      site: '@mirelleinspo',\n    },\n    other: {\n      'article:published_time': post.date,\n      'article:modified_time': post.dateModified || post.date,\n      'article:author': authorUrl,\n      'article:section': post.category || 'Nail Art',\n      ...(post.readTime && { 'twitter:label1': 'Reading time', 'twitter:data1': post.readTime }),\n    },\n  };\n}\n "
    }
  ],
