      "path": "src/components/Footer.tsx",
      "content": "'use client';\nimport Link from 'next/link';\nimport Image from 'next/image';\nimport { useState } from 'react';\n\n// Accordion Section Component for Mobile\nfunction AccordionSection({ \n  title, \n  children, \n  defaultOpen = false \n}: { \n  title: string; \n  children: React.ReactNode; \n  defaultOpen?: boolean;\n}) {\n  const [isOpen, setIsOpen] = useState(defaultOpen);\n\n  return (\n    <div className=\"border-b border-[#f9fafb]/20 lg:border-none\">\n      <button\n        onClick={() => setIsOpen(!isOpen)}\n        className=\"w-full py-4 flex items-center justify-between text-left lg:cursor-default\"\n        aria-expanded={isOpen}\n      >\n        <h3 className=\"font-ui text-base uppercase tracking-wider text-[#f9fafb]\">\n          {title}\n        </h3>\n        <svg\n          className={`w-5 h-5 transition-transform duration-200 lg:hidden ${\n            isOpen ? 'rotate-180' : ''\n          }`}\n          fill=\"none\"\n          stroke=\"currentColor\"\n          viewBox=\"0 0 24 24\"\n        >\n          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n        </svg>\n      </button>\n      <div\n        className={`overflow-hidden transition-all duration-300 ease-in-out lg:block lg:max-h-none ${\n          isOpen ? 'max-h-96 pb-4' : 'max-h-0'\n        }`}\n      >\n        {children}\n      </div>\n    </div>\n  );\n}\n\nexport default function Footer() {\n  const currentYear = new Date().getFullYear();\n\n  return (\n    <footer className=\"bg-[#252220] text-[#f9fafb]\">\n      {/* Main Footer Content */}\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12\">\n        \n       {/* Logo & Description - Always Visible */}\n        <div className=\"mb-8 pb-6 border-b border-[#f9fafb]/20\">\n          <Link href=\"/\" className=\"flex items-center space-x-2 mb-4\">\n            <Image \n              src=\"/logo.png\" \n              alt=\"Mirell\u00e9 Inspo\" \n              width={32} \n              height={32}\n              className=\"lg:w-10 lg:h-10\"\n            />\n            <span className=\"font-brand text-xl lg:text-2xl\" data-logo=\"true\">Mirell\u00e9 Inspo</span>\n          </Link>\n\n          <p className=\"font-body text-[#f9fafb]/70 text-sm lg:text-base max-w-md leading-relaxed\">\n            Your trusted source for curated nail trends, honest product reviews, and artist discoveries. \n            We find the best so you don't have to scroll for hours.\n          </p>\n        </div>\n\n        {/* Social Icons - Always Visible on Mobile */}\n        <div className=\"mb-6 pb-6 border-b border-[#f9fafb]/20\">\n          <h3 className=\"font-ui text-sm uppercase tracking-wider mb-3 text-[#f9fafb]\">\n            Follow Us\n          </h3>\n          <div className=\"flex space-x-5\">\n            <a \n              href=\"https://in.pinterest.com/mirelle_inspo/\" \n              target=\"_blank\" \n              rel=\"noopener noreferrer\"\n              className=\"text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors\"\n              aria-label=\"Pinterest\"\n            >\n              <svg className=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path d=\"M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z\"/>\n              </svg>\n            </a>\n            <a \n              href=\"https://instagram.com/mirelle_inspo\" \n              target=\"_blank\" \n              rel=\"noopener noreferrer\"\n              className=\"text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors\"\n              aria-label=\"Instagram\"\n            >\n              <svg className=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z\"/>\n              </svg>\n            </a>\n            <a \n              href=\"https://x.com/mirelleinspo\" \n              target=\"_blank\" \n              rel=\"noopener noreferrer\"\n              className=\"text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors\"\n              aria-label=\"X (Twitter)\"\n            >\n              <svg className=\"w-6 h-6\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n              </svg>\n            </a>\n          </div>\n        </div>\n\n        {/* Collapsible Sections - Mobile / Multi-Column Desktop */}\n        <div className=\"lg:grid lg:grid-cols-5 lg:gap-8\">\n          \n          {/* Explore Section */}\n          <AccordionSection title=\"Explore\">\n            <ul className=\"space-y-3\">\n              <li>\n                <Link href=\"/blog\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Articles\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/shop\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Shop\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/inspo\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Designs\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Long Reads\n                </Link>\n              </li>\n              {/* <li>\n                <Link href=\"/posts\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Posts\n                </Link>\n              </li> */}\n            </ul>\n          </AccordionSection>\n\n          {/* Designs Section */}\n          <AccordionSection title=\"Designs\">\n            <ul className=\"space-y-3\">\n              <li>\n                <Link href=\"/inspo/valentine-nails-2026\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Valentine Nails 2026\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/inspo/french-tip-nails-2026\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  French Tip Nails 2026\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/inspo/almond-nails-2026\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Almond Nails 2026\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/inspo/coffin-ballerina-nails-2026\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Coffin Ballerina Nails 2026\n                </Link>\n              </li>\n            </ul>\n          </AccordionSection>\n\n          {/* Long Reads Section */}\n          <AccordionSection title=\"Long Reads\">\n            <ul className=\"space-y-3\">\n              <li>\n                <Link href=\"/topics/seasonal-trends\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Seasonal Trends\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics/nail-care-guide\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Nail Care Guide\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics/nail-art-guides\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Nail Art Guide\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics/modern-women\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Professional Nails\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics/at-home-hacks\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  At-Home Hacks\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/topics/skin-tones\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Skin Tones\n                </Link>\n              </li>\n            </ul>\n          </AccordionSection>\n\n          {/* Company Section */}\n          <AccordionSection title=\"Company\">\n            <ul className=\"space-y-3\">\n              <li>\n                <Link href=\"/about\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  About Us\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/contact\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Contact\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/work-with-us\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Work With Us\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/privacy-policy\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Privacy Policy\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/terms\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Terms & Conditions\n                </Link>\n              </li>\n            </ul>\n          </AccordionSection>\n\n          {/* Trending Valentine Nails Section */}\n          <AccordionSection title=\"Trending Valentine Nails\">\n            <ul className=\"space-y-3\">\n              <li>\n                <Link href=\"/blog/valentine-nails-2026\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Valentine Nails 2026\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/blog/pink-cat-eye-valentine-nails\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Pink Cat Eye Valentine Nails\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/blog/tomato-red-valentine-nails\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Tomato Red Valentine Nails\n                </Link>\n              </li>\n              <li>\n                <Link href=\"/blog/valentine-french-tip-nails\" className=\"font-body text-[#f9fafb]/70 hover:text-[#f9fafb] transition-colors text-sm block\">\n                  Valentine French Tip Nails\n                </Link>\n              </li>\n            </ul>\n          </AccordionSection>\n        </div>\n      </div>\n\n      {/* Bottom Copyright Bar */}\n      <div className=\"border-t border-[#f9fafb]/20\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6\">\n          <div className=\"text-center lg:text-left\">\n            <p className=\"font-body text-[#f9fafb]/50 text-xs lg:text-sm\">\n              \u00a9 {currentYear} Mirell\u00e9 Inspo. All rights reserved. | Curated Nail Trends & Product Reviews\n            </p>\n            <p className=\"font-body text-[#f9fafb]/40 text-xs mt-2\">\n              Made with \ud83d\udc85 for nail enthusiasts\n            </p>\n          </div>\n        </div>\n      </div>\n    </footer>\n  );\n}"
