### DATA STRUCTURE

Hardcode all event and post data in the component file. Use this exact TypeScript shape:

```typescript
interface CarouselPost {
  id: string;
  title: string;
  slug: string;         // full path e.g. '/blog/my-post-slug'
  heroImage: string;    // image src path or URL
}

interface EventCategory {
  name: string;         // display name e.g. 'Floral Milk Nails'
  posts: CarouselPost[]; // hand-picked posts for this category
}

interface TimelineEvent {
  id: string;
  name: string;
  date: string;         // ISO date string 'YYYY-MM-DD'
  season: string;       // e.g. "Spring '26"
  status: 'past' | 'now' | 'upcoming';
