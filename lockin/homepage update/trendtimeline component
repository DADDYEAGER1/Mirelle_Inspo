function TimelineTrack({
  events,
  selectedId,
  onSelect,
}: {
  events: TimelineEvent[];
  selectedId: string;
  onSelect: (ev: TimelineEvent) => void;
}) {
  const trackRef = useRef<HTMLDivElement>(null);
  const isDragging = useRef(false);
  const startX = useRef(0);
  const scrollLeft = useRef(0);

  // Auto-scroll to now on mount
  useEffect(() => {
    const nowIdx = events.findIndex((e) => e.status === 'now');
    if (nowIdx < 0 || !trackRef.current) return;
    const el = trackRef.current.querySelector(`[data-event-id="${events[nowIdx].id}"]`) as HTMLElement;
    if (el) {
      const containerW = trackRef.current.offsetWidth;
      const elLeft = el.offsetLeft;
      trackRef.current.scrollLeft = elLeft - containerW / 2 + el.offsetWidth / 2;
    }
  }, [events]);

  const onMouseDown = (e: React.MouseEvent) => {
    isDragging.current = true;
    startX.current = e.pageX - (trackRef.current?.offsetLeft ?? 0);
    scrollLeft.current = trackRef.current?.scrollLeft ?? 0;
  };
  const onMouseMove = (e: React.MouseEvent) => {
    if (!isDragging.current || !trackRef.current) return;
    e.preventDefault();
    const x = e.pageX - (trackRef.current.offsetLeft ?? 0);
    trackRef.current.scrollLeft = scrollLeft.current - (x - startX.current) * 1.2;
  };
  const stopDrag = () => { isDragging.current = false; };

  // Progress: ratio of now event position
  const nowIdx = events.findIndex((e) => e.status === 'now');
  const progressRatio = nowIdx >= 0 ? (nowIdx + 0.5) / events.length : 0;

  const seasonGroups = getSeasonGroups();

  return (
    <div
      style={{
        position: 'relative',
        height: '130px',
        borderTop: '1px solid rgba(37,34,32,0.10)',
        background: 'var(--background)',
        overflow: 'hidden',
