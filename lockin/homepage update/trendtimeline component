                    <div
                      style={{
                        position: 'absolute',
                        width: '18px',
                        height: '18px',
                        borderRadius: '50%',
                        border: '1px solid rgba(37,34,32,0.3)',
                        animation: 'timelinePulse 2s ease-in-out infinite',
                      }}
                    />
                  )}
                  <div
                    style={{
                      width: isSelected ? `${selectedSize}px` : `${dotSize}px`,
                      height: isSelected ? `${selectedSize}px` : `${dotSize}px`,
                      borderRadius: '50%',
                      background: isPast
                        ? 'rgba(37,34,32,0.25)'
                        : isNow
                        ? 'var(--foreground)'
                        : 'transparent',
                      border: isUpcoming
                        ? '1px dashed rgba(37,34,32,0.35)'
                        : isSelected
                        ? '2px solid var(--foreground)'
                        : 'none',
                      transition: 'width 300ms ease, height 300ms ease',
                      flexShrink: 0,
                    }}
                  />
                </div>

                {/* Label */}
                <span
                  style={{
                    fontFamily: 'var(--font-ui)',
                    fontSize: '8px',
                    letterSpacing: '0.1em',
                    textTransform: 'uppercase',
                    color: 'var(--foreground)',
                    opacity: isSelected ? 0.9 : isPast ? 0.35 : isNow ? 0.8 : 0.45,
                    textAlign: 'center',
                    lineHeight: 1.3,
                    maxWidth: '80px',
                  }}
                >
                  {ev.name}
                </span>
                <span
                  style={{
                    fontFamily: 'var(--font-ui)',
                    fontSize: '7px',
                    letterSpacing: '0.06em',
                    color: 'var(--foreground)',
                    opacity: 0.25,
                    marginTop: '2px',
                  }}
                >
                  {new Date(ev.date).toLocaleDateString('en-US', { month: 'short', year: '2-digit' })}
                </span>
              </div>
            );
          })}
        </div>
      </div>

      {/* Progress bar at bottom */}
      <div
        style={{
          position: 'absolute',
          bottom: 0,
          left: 0,
          height: '1px',
          width: `${progressRatio * 100}%`,
          background: 'rgba(37,34,32,0.35)',
          transition: 'width 500ms ease',
        }}
      />
    </div>
  );
}

// ─── EVENT PANEL ─────────────────────────────────────────────────────────────

function EventPanel({
  event,
  onCategorySelect,
}: {
  event: TimelineEvent;
  onCategorySelect: (cat: EventCategory) => void;
}) {
  const isNow = event.status === 'now';
  const isUpcoming = event.status === 'upcoming';

  const eyebrow = isNow ? '● Now Trending' : isUpcoming ? 'Coming Up' : 'Season Recap';

  return (
    <div
      style={{
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'center',
        justifyContent: 'center',
        height: '100%',
        padding: '32px 24px',
        textAlign: 'center',
      }}
    >
      {/* Eyebrow */}
      <span
        style={{
          fontFamily: 'var(--font-ui)',
          fontSize: '9px',
          letterSpacing: '0.18em',
          textTransform: 'uppercase',
          color: 'var(--foreground)',
          opacity: 0.45,
          marginBottom: '20px',
          display: 'flex',
          alignItems: 'center',
          gap: '6px',
        }}
      >
        {isNow ? (
          <>
            <span
              style={{
                display: 'inline-block',
                width: '5px',
                height: '5px',
                borderRadius: '50%',
                background: 'var(--foreground)',
                animation: 'pulse 2s cubic-bezier(0.4,0,0.6,1) infinite',
              }}
            />
            Now Trending
          </>
        ) : (
          eyebrow
        )}
      </span>

      {/* Title */}
      <h1
        style={{
          fontFamily: 'var(--font-heading)',
          fontSize: 'clamp(32px, 5vw, 64px)',
          fontWeight: 400,
          lineHeight: 1.1,
          letterSpacing: '-0.01em',
          color: 'var(--foreground)',
          margin: '0 0 12px',
          maxWidth: '700px',
        }}
      >
        {event.name}
      </h1>

      {/* Season tag */}
      <span
        style={{
          fontFamily: 'var(--font-ui)',
          fontSize: '9px',
          letterSpacing: '0.14em',
          textTransform: 'uppercase',
          color: 'var(--foreground)',
          opacity: 0.35,
          marginBottom: '18px',
        }}
      >
        {event.season}
      </span>

      {/* Description */}
      <p
        style={{
          fontFamily: 'var(--font-body)',
          fontStyle: 'italic',
          fontSize: 'clamp(14px, 1.5vw, 16px)',
          lineHeight: 1.7,
          color: 'var(--foreground)',
          opacity: 0.6,
          maxWidth: '540px',
          margin: 0,
        }}
      >
        {event.desc}
      </p>

      {/* Countdown */}
      {isUpcoming && <CountdownTimer dateStr={event.date} />}

      {/* Category cards */}
      <CategoryCards
        categories={event.categories}
        status={event.status}
        onSelect={onCategorySelect}
      />
    </div>
  );
}

// ─── MAIN COMPONENT ──────────────────────────────────────────────────────────

export default function TrendTimelineHero() {
  const nowEvent = EVENTS.find((e) => e.status === 'now') ?? EVENTS[0];
  const [selectedEvent, setSelectedEvent] = useState<TimelineEvent>(nowEvent);
  const [activeCategory, setActiveCategory] = useState<EventCategory | null>(null);
  const [panelVisible, setPanelVisible] = useState(true);
  const [carouselVisible, setCarouselVisible] = useState(false);
  const currentSeason = getCurrentSeason();

  const handleEventSelect = useCallback((ev: TimelineEvent) => {
    if (ev.id === selectedEvent.id && !activeCategory) return;
    setPanelVisible(false);
    setCarouselVisible(false);
    setTimeout(() => {
      setSelectedEvent(ev);
      setActiveCategory(null);
      setPanelVisible(true);
    }, 260);
  }, [selectedEvent.id, activeCategory]);

  const handleCategorySelect = useCallback((cat: EventCategory) => {
    setPanelVisible(false);
    setTimeout(() => {
      setActiveCategory(cat);
      setCarouselVisible(true);
    }, 260);
  }, []);

  const handleBack = useCallback(() => {
    setCarouselVisible(false);
    setTimeout(() => {
      setActiveCategory(null);
      setPanelVisible(true);
    }, 260);
  }, []);

  return (
    <>
      <style>{`
        @keyframes timelinePulse {
          0%, 100% { transform: scale(1); opacity: 0.4; }
          50% { transform: scale(1.6); opacity: 0; }
        }
        @keyframes blinkDot {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.2; }
        }
        .panel-enter {
          animation: panelFadeIn 0.5s cubic-bezier(.22,1,.36,1) forwards;
        }
        @keyframes panelFadeIn {
          from { opacity: 0; transform: translateY(12px); }
          to { opacity: 1; transform: translateY(0); }
        }
        div::-webkit-scrollbar { display: none; }
      `}</style>

      <section
        style={{
          height: '100vh',
          display: 'flex',
          flexDirection: 'column',
          background: 'var(--background)',
          overflow: 'hidden',
        }}
      >
        {/* ── TOP BAR ─────────────────────────────── */}
        <div
          style={{
            height: '44px',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'space-between',
            padding: '0 32px',
            borderBottom: '1px solid rgba(37,34,32,0.10)',
            flexShrink: 0,
          }}
        >
          <span
            style={{
              fontFamily: 'var(--font-ui)',
              fontSize: '9px',
              letterSpacing: '0.16em',
              textTransform: 'uppercase',
              color: 'var(--foreground)',
              opacity: 0.4,
            }}
          >
            Nail Trend Index · 2025–2026
          </span>

          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <span
              style={{
                display: 'inline-block',
                width: '5px',
                height: '5px',
                borderRadius: '50%',
                background: 'var(--foreground)',
                animation: 'blinkDot 1.8s ease-in-out infinite',
              }}
            />
            <span
              style={{
                fontFamily: 'var(--font-ui)',
                fontSize: '9px',
                letterSpacing: '0.14em',
                textTransform: 'uppercase',
                color: 'var(--foreground)',
                opacity: 0.5,
              }}
            >
              Now In · {currentSeason}
            </span>
          </div>
        </div>

        {/* ── CONTENT STAGE ───────────────────────── */}
        <div
          style={{
            flex: 1,
            position: 'relative',
            overflow: 'hidden',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
          }}
        >
          {/* Event panel */}
          <div
            className={panelVisible ? 'panel-enter' : ''}
            style={{
              position: 'absolute',
              inset: 0,
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              opacity: panelVisible ? 1 : 0,
              pointerEvents: panelVisible && !activeCategory ? 'auto' : 'none',
              transition: 'opacity 260ms ease',
            }}
          >
            {!activeCategory && (
              <EventPanel
                event={selectedEvent}
                onCategorySelect={handleCategorySelect}
              />
            )}
          </div>

          {/* Carousel panel */}
          <div
            className={carouselVisible ? 'panel-enter' : ''}
            style={{
              position: 'absolute',
              inset: 0,
              opacity: carouselVisible ? 1 : 0,
              pointerEvents: carouselVisible ? 'auto' : 'none',
              transition: 'opacity 260ms ease',
            }}
          >
            {activeCategory && (
              <CarouselView category={activeCategory} onBack={handleBack} />
            )}
          </div>
        </div>

        {/* ── TIMELINE TRACK ──────────────────────── */}
        <TimelineTrack
          events={EVENTS}
          selectedId={selectedEvent.id}
          onSelect={handleEventSelect}
        />
      </section>
    </>
  );
}
