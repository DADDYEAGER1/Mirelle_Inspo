    flexShrink: 0,
    position: 'relative',
    overflow: 'hidden',
    borderRadius: '4px',
    background: 'rgba(37,34,32,0.05)',
    border: '1px solid rgba(37,34,32,0.08)',
    transition: 'border-color 220ms ease, transform 220ms ease',
    cursor: href || onClick ? 'pointer' : 'default',
    display: 'block',
    textDecoration: 'none',
    color: 'inherit',
    width: '100%',
    height: '100%',
  };

  const inner = (
    <>
      {/* Image fills entire card */}
      {imageSrc && (
        <Image
          src={imageSrc}
          alt={imageAlt}
          fill
          style={{ objectFit: 'cover' }}
          sizes="(max-width: 768px) 45vw, 22vw"
        />
