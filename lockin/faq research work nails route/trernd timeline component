// ─── HELPERS ─────────────────────────────────────────────────────────────────

function getCurrentSeason(): string {
  const month = new Date().getMonth() + 1;
  if (month >= 3 && month <= 5) return "Spring '26";
  if (month >= 6 && month <= 8) return "Summer '26";
  if (month >= 9 && month <= 11) return "Fall '26";
  return "Winter '26";
}

function getTimeUntil(dateStr: string) {
  const target = new Date(dateStr).getTime();
  const now = Date.now();
  const diff = Math.max(0, target - now);
  const weeks = Math.floor(diff / (1000 * 60 * 60 * 24 * 7));
  const days = Math.floor((diff % (1000 * 60 * 60 * 24 * 7)) / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
  const secs = Math.floor((diff % (1000 * 60)) / 1000);
  return { weeks, days, hours, mins, secs };
}

function isWithinWindow(event: TimelineEvent): boolean {
  if (event.status === 'now') return true;
  const target = new Date(event.date).getTime();
  const now = Date.now();
  const diff = Math.abs(target - now);
  const thirtyDays = 30 * 24 * 60 * 60 * 1000;
  return diff <= thirtyDays;
}

function isCardAccessible(event: TimelineEvent): boolean {
  const hasContent = event.editSlug !== null || event.gallerySlug !== null;
  return hasContent && isWithinWindow(event);
}

function getSeasonGroups() {
  const groups: { season: string; events: TimelineEvent[] }[] = [];
  EVENTS.forEach((ev) => {
    const last = groups[groups.length - 1];
    if (last && last.season === ev.season) {
      last.events.push(ev);
    } else {
      groups.push({ season: ev.season, events: [ev] });
    }
  });
  return groups;
}

// ─── SUB-COMPONENTS ──────────────────────────────────────────────────────────

function CountdownTimer({ dateStr }: { dateStr: string }) {
  const [time, setTime] = useState(getTimeUntil(dateStr));

  useEffect(() => {
    const id = setInterval(() => setTime(getTimeUntil(dateStr)), 1000);
    return () => clearInterval(id);
  }, [dateStr]);

  const units = [
    { label: 'Weeks', value: time.weeks },
    { label: 'Days', value: time.days },
    { label: 'Hours', value: time.hours },
    { label: 'Min', value: time.mins },
    { label: 'Sec', value: time.secs },
  ];

  return (
    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '0', marginTop: '28px' }}>
      {units.map((u, i) => (
        <div key={u.label} style={{ display: 'flex', alignItems: 'center' }}>
          <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', padding: '0 16px' }}>
            <span style={{
              fontFamily: 'var(--font-ui)',
              fontSize: 'clamp(22px, 3vw, 36px)',
              fontWeight: 400,
              letterSpacing: '-0.02em',
              color: 'var(--foreground)',
              fontVariantNumeric: 'tabular-nums',
              lineHeight: 1,
            }}>
              {String(u.value).padStart(2, '0')}
            </span>
            <span style={{
              fontFamily: 'var(--font-ui)',
              fontSize: '9px',
              letterSpacing: '0.12em',
              textTransform: 'uppercase',
              color: 'var(--foreground)',
              opacity: 0.35,
              marginTop: '5px',
            }}>
              {u.label}
            </span>
          </div>
          {i < units.length - 1 && (
            <span style={{ color: 'var(--foreground)', opacity: 0.15, fontSize: '20px', userSelect: 'none' }}>|</span>
          )}
        </div>
      ))}
    </div>
  );
}

function EventCards({
  event,
  onCardClick,
}: {
  event: TimelineEvent;
  onCardClick: (type: CardType) => void;
}) {
  const accessible = isCardAccessible(event);

  const cards = [
    { type: 'edit' as CardType, label: 'The Edit', hasSlug: !!event.editSlug },
    { type: 'gallery' as CardType, label: 'Inspo Gallery', hasSlug: !!event.gallerySlug },
  ];

  return (
    <div style={{
      display: 'flex',
      gap: '12px',
      justifyContent: 'center',
      marginTop: '32px',
    }}>
      {cards.map(({ type, label, hasSlug }) => {
        const clickable = accessible && hasSlug;
        return (
          <button
            key={type}
            onClick={() => clickable && onCardClick(type)}
            disabled={!clickable}
            style={{
              fontFamily: 'var(--font-ui)',
              fontSize: '10px',
              letterSpacing: '0.14em',
              textTransform: 'uppercase',
              padding: '11px 28px',
              border: `1px solid ${clickable ? 'rgba(37,34,32,0.45)' : 'rgba(37,34,32,0.15)'}`,
              background: 'transparent',
              color: clickable ? 'var(--foreground)' : 'rgba(37,34,32,0.25)',
              cursor: clickable ? 'pointer' : 'not-allowed',
              borderRadius: '2px',
              transition: 'border-color 220ms ease, background 220ms ease',
            }}
            onMouseEnter={(e) => {
              if (clickable) {
                (e.currentTarget as HTMLButtonElement).style.borderColor = 'var(--foreground)';
                (e.currentTarget as HTMLButtonElement).style.background = 'rgba(37,34,32,0.04)';
              }
            }}
            onMouseLeave={(e) => {
              if (clickable) {
                (e.currentTarget as HTMLButtonElement).style.borderColor = 'rgba(37,34,32,0.45)';
                (e.currentTarget as HTMLButtonElement).style.background = 'transparent';
              }
            }}
          >
            {!accessible ? 'Coming Soon' : label}
          </button>
        );
      })}
    </div>
  );
}

// ─── SHARED PORTRAIT CARD ────────────────────────────────────────────────────
// Used by both EditCarousel and InspoGalleryCarousel
