                    transition: 'border-color 220ms ease, background 220ms ease',
                    gap: '8px',
                  }}
                  onMouseEnter={(e) => {
                    (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(37,34,32,0.5)';
                    (e.currentTarget as HTMLAnchorElement).style.background = 'rgba(37,34,32,0.02)';
                  }}
                  onMouseLeave={(e) => {
                    (e.currentTarget as HTMLAnchorElement).style.borderColor = 'rgba(37,34,32,0.22)';
                    (e.currentTarget as HTMLAnchorElement).style.background = 'transparent';
                  }}
                >
                  <span style={{ fontFamily: 'var(--font-ui)', fontSize: '16px', opacity: 0.3, color: 'var(--foreground)' }}>→</span>
                  <span style={{
                    fontFamily: 'var(--font-ui)', fontSize: '9px',
                    letterSpacing: '0.14em', textTransform: 'uppercase',
                    color: 'var(--foreground)', opacity: 0.4, textAlign: 'center', padding: '0 12px',
                  }}>
                    View Full Gallery
                  </span>
                </Link>
              </div>
            </>
          )}
        </CarouselGrid>
      </div>
    </div>
  );
}

// ─── TIMELINE TRACK ──────────────────────────────────────────────────────────

function TimelineTrack({
  events,
  selectedId,
  onSelect,
}: {
  events: TimelineEvent[];
  selectedId: string;
  onSelect: (ev: TimelineEvent) => void;
}) {
  const trackRef = useRef<HTMLDivElement>(null);
  const isDragging = useRef(false);
  const startX = useRef(0);
  const scrollLeft = useRef(0);

  useEffect(() => {
    const nowIdx = events.findIndex((e) => e.status === 'now');
    if (nowIdx < 0 || !trackRef.current) return;
    const el = trackRef.current.querySelector(`[data-event-id="${events[nowIdx].id}"]`) as HTMLElement;
    if (el) {
      const containerW = trackRef.current.offsetWidth;
      trackRef.current.scrollLeft = el.offsetLeft - containerW / 2 + el.offsetWidth / 2;
    }
  }, [events]);

  const onMouseDown = (e: React.MouseEvent) => {
    isDragging.current = true;
    startX.current = e.pageX - (trackRef.current?.offsetLeft ?? 0);
    scrollLeft.current = trackRef.current?.scrollLeft ?? 0;
  };
  const onMouseMove = (e: React.MouseEvent) => {
    if (!isDragging.current || !trackRef.current) return;
    e.preventDefault();
    const x = e.pageX - trackRef.current.offsetLeft;
    trackRef.current.scrollLeft = scrollLeft.current - (x - startX.current) * 1.2;
  };
  const stopDrag = () => { isDragging.current = false; };

  const nowIdx = events.findIndex((e) => e.status === 'now');
  const progressRatio = nowIdx >= 0 ? (nowIdx + 0.5) / events.length : 0;
  const seasonGroups = getSeasonGroups();

  return (
    <div style={{
      position: 'relative',
      height: '130px',
      borderTop: '1px solid rgba(37,34,32,0.10)',
      background: 'var(--background)',
      overflow: 'hidden',
    }}>
      {/* Fades */}
      <div style={{ position: 'absolute', left: 0, top: 0, bottom: 0, width: '80px', background: 'linear-gradient(to right, var(--background), transparent)', zIndex: 3, pointerEvents: 'none' }} />
      <div style={{ position: 'absolute', right: 0, top: 0, bottom: 0, width: '80px', background: 'linear-gradient(to left, var(--background), transparent)', zIndex: 3, pointerEvents: 'none' }} />

      <div
        ref={trackRef}
        onMouseDown={onMouseDown}
        onMouseMove={onMouseMove}
        onMouseUp={stopDrag}
        onMouseLeave={stopDrag}
        style={{
          overflowX: 'auto', overflowY: 'hidden', height: '100%',
          scrollbarWidth: 'none', cursor: 'grab', userSelect: 'none', position: 'relative',
        }}
      >
        <div style={{
          display: 'flex', alignItems: 'center', height: '100%',
          padding: '0 120px', minWidth: 'max-content', position: 'relative',
        }}>
          <div style={{
            position: 'absolute',
            top: '50%',
            transform: 'translateY(-50%)',
            left: '120px', right: '120px',
            height: '1px',
            background: 'rgba(37,34,32,0.15)',
          }} />

          {seasonGroups.map((group, gIdx) => {
            const firstIdx = events.findIndex((e) => e.id === group.events[0].id);
            const lastIdx = events.findIndex((e) => e.id === group.events[group.events.length - 1].id);
            return (
              <div
                key={`${group.season}-${gIdx}`}
                style={{
                  position: 'absolute',
                  bottom: '12px',
                  left: `calc(120px + ${firstIdx * 120}px)`,
                  width: `${(lastIdx - firstIdx + 1) * 120}px`,
                  display: 'flex',
                  justifyContent: 'center',
                  pointerEvents: 'none',
                }}
              >
                <span style={{
                  fontFamily: 'var(--font-ui)',
                  fontSize: '8px',
                  letterSpacing: '0.14em',
                  textTransform: 'uppercase',
                  color: 'var(--foreground)',
                  opacity: 0.25,
                }}>
                  {group.season}
                </span>
              </div>
            );
          })}

          {events.map((ev) => {
            const isSelected = ev.id === selectedId;
            const isNow = ev.status === 'now';
            const isPast = ev.status === 'past';
            const isUpcoming = ev.status === 'upcoming';
            const dotSize = ev.isMajor ? 10 : 7;

            return (
              <div
                key={ev.id}
                data-event-id={ev.id}
                onClick={() => onSelect(ev)}
                style={{
                  display: 'flex',
                  flexDirection: 'column',
                  alignItems: 'center',
                  width: '120px',
                  flexShrink: 0,
                  cursor: 'pointer',
                  position: 'relative',
                  height: '100%',
                  justifyContent: 'center',
                }}
              >
                <div style={{
                  display: 'flex',
                  flexDirection: 'column',
                  alignItems: 'center',
                  position: 'absolute',
                  top: '10px',
                  left: 0,
                  right: 0,
                }}>
                  <span style={{
                    fontFamily: 'var(--font-ui)',
                    fontSize: '8px',
                    letterSpacing: '0.1em',
                    textTransform: 'uppercase',
                    color: 'var(--foreground)',
                    opacity: isSelected ? 0.9 : isPast ? 0.35 : isNow ? 0.8 : 0.45,
                    textAlign: 'center',
                    lineHeight: 1.3,
                    maxWidth: '90px',
                    fontWeight: isSelected || isNow ? 500 : 400,
                  }}>
                    {ev.name}
                  </span>
                  <span style={{
                    fontFamily: 'var(--font-ui)',
                    fontSize: '7px',
                    letterSpacing: '0.06em',
                    color: 'var(--foreground)',
                    opacity: 0.25,
                    marginTop: '2px',
                  }}>
                    {new Date(ev.date).toLocaleDateString('en-US', { month: 'short', year: '2-digit' })}
                  </span>
                </div>

                <div style={{
                  position: 'relative',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  zIndex: 1,
                  width: '30px',
                  height: '30px',
                }}>
                  {isSelected && (
                    <>
                      <div style={{ position: 'absolute', width: '28px', height: '28px', borderRadius: '50%', border: '1px solid rgba(37,34,32,0.15)' }} />
                      <div style={{ position: 'absolute', width: '20px', height: '20px', borderRadius: '50%', border: '1px solid rgba(37,34,32,0.3)' }} />
                    </>
                  )}
                  {isNow && !isSelected && (
                    <div style={{
                      position: 'absolute', width: '18px', height: '18px',
                      borderRadius: '50%', border: '1px solid rgba(37,34,32,0.3)',
                      animation: 'timelinePulse 2s ease-in-out infinite',
                    }} />
                  )}
                  <div style={{
                    width: isSelected ? '14px' : `${dotSize}px`,
                    height: isSelected ? '14px' : `${dotSize}px`,
                    borderRadius: '50%',
                    background: isPast ? 'rgba(37,34,32,0.25)' : isNow ? 'var(--foreground)' : 'transparent',
                    border: isUpcoming ? '1px dashed rgba(37,34,32,0.35)' : isSelected ? '2px solid var(--foreground)' : 'none',
                    transition: 'width 300ms ease, height 300ms ease',
                    flexShrink: 0,
                  }} />
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <div style={{
        position: 'absolute', bottom: 0, left: 0,
        height: '1px', width: `${progressRatio * 100}%`,
        background: 'rgba(37,34,32,0.35)', transition: 'width 500ms ease',
      }} />
    </div>
  );
}

// ─── EVENT PANEL ─────────────────────────────────────────────────────────────

function EventPanel({
  event,
  onCardClick,
}: {
  event: TimelineEvent;
  onCardClick: (type: CardType) => void;
}) {
  const isNow = event.status === 'now';
  const isUpcoming = event.status === 'upcoming';
  const eyebrow = isNow ? '● Now Trending' : isUpcoming ? 'Coming Up' : 'Season Recap';

  return (
    <div style={{
      display: 'flex', flexDirection: 'column', alignItems: 'center',
      justifyContent: 'center', height: '100%', padding: '32px 24px', textAlign: 'center',
    }}>
      <span style={{
        fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.18em',
        textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.45,
        marginBottom: '20px', display: 'flex', alignItems: 'center', gap: '6px',
      }}>
        {isNow ? (
          <>
            <span style={{
              display: 'inline-block', width: '5px', height: '5px', borderRadius: '50%',
              background: 'var(--foreground)', animation: 'pulse 2s cubic-bezier(0.4,0,0.6,1) infinite',
            }} />
            Now Trending
          </>
        ) : eyebrow}
      </span>

      <h1 style={{
        fontFamily: 'var(--font-heading)', fontSize: 'clamp(32px, 5vw, 64px)',
        fontWeight: 400, lineHeight: 1.1, letterSpacing: '-0.01em',
        color: 'var(--foreground)', margin: '0 0 12px', maxWidth: '700px',
      }}>
        {event.name}
      </h1>

      <span style={{
        fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.14em',
        textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.35, marginBottom: '18px',
      }}>
        {event.season}
      </span>

      <p style={{
        fontFamily: 'var(--font-body)', fontStyle: 'italic',
        fontSize: 'clamp(14px, 1.5vw, 16px)', lineHeight: 1.7,
        color: 'var(--foreground)', opacity: 0.6, maxWidth: '540px', margin: 0,
      }}>
        {event.desc}
      </p>

      {isUpcoming && <CountdownTimer dateStr={event.date} />}

      <EventCards event={event} onCardClick={onCardClick} />
    </div>
  );
}

// ─── MAIN COMPONENT ──────────────────────────────────────────────────────────

export default function TrendTimelineHero() {
  const nowEvent = EVENTS.find((e) => e.status === 'now') ?? EVENTS[0];
  const [selectedEvent, setSelectedEvent] = useState<TimelineEvent>(nowEvent);
  const [activeCard, setActiveCard] = useState<CardType>(null);
  const [panelVisible, setPanelVisible] = useState(true);
  const [carouselVisible, setCarouselVisible] = useState(false);
  const currentSeason = getCurrentSeason();

  const handleEventSelect = useCallback((ev: TimelineEvent) => {
    if (ev.id === selectedEvent.id && !activeCard) return;
    setPanelVisible(false);
    setCarouselVisible(false);
    setTimeout(() => {
      setSelectedEvent(ev);
      setActiveCard(null);
      setPanelVisible(true);
    }, 260);
  }, [selectedEvent.id, activeCard]);

  const handleCardClick = useCallback((type: CardType) => {
    setPanelVisible(false);
    setTimeout(() => {
      setActiveCard(type);
      setCarouselVisible(true);
    }, 260);
  }, []);

  const handleBack = useCallback(() => {
    setCarouselVisible(false);
    setTimeout(() => {
      setActiveCard(null);
      setPanelVisible(true);
    }, 260);
  }, []);

  return (
    <>
      <style>{`
        @keyframes timelinePulse {
          0%, 100% { transform: scale(1); opacity: 0.4; }
          50% { transform: scale(1.6); opacity: 0; }
        }
        @keyframes blinkDot {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.2; }
        }
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.4; }
        }
        .panel-enter {
          animation: panelFadeIn 0.5s cubic-bezier(.22,1,.36,1) forwards;
        }
        @keyframes panelFadeIn {
          from { opacity: 0; transform: translateY(12px); }
          to { opacity: 1; transform: translateY(0); }
        }
        div::-webkit-scrollbar { display: none; }
      `}</style>

      <section style={{
        height: '100vh', display: 'flex', flexDirection: 'column',
        background: 'var(--background)', overflow: 'hidden',
      }}>
        {/* TOP BAR */}
        <div style={{
          height: '44px', display: 'flex', alignItems: 'center',
          justifyContent: 'space-between', padding: '0 32px',
          borderBottom: '1px solid rgba(37,34,32,0.10)', flexShrink: 0,
        }}>
          <span style={{
            fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.16em',
            textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.4,
          }}>
            Nail Trend Index · 2025–2026
          </span>
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <span style={{
              display: 'inline-block', width: '5px', height: '5px', borderRadius: '50%',
              background: 'var(--foreground)', animation: 'blinkDot 1.8s ease-in-out infinite',
            }} />
            <span style={{
              fontFamily: 'var(--font-ui)', fontSize: '9px', letterSpacing: '0.14em',
              textTransform: 'uppercase', color: 'var(--foreground)', opacity: 0.5,
            }}>
              Now In · {currentSeason}
            </span>
          </div>
        </div>

        {/* CONTENT STAGE */}
        <div style={{
          flex: 1, position: 'relative', overflow: 'hidden',
          display: 'flex', alignItems: 'center', justifyContent: 'center',
        }}>
          {/* Event panel */}
          <div
            className={panelVisible ? 'panel-enter' : ''}
            style={{
              position: 'absolute', inset: 0,
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              opacity: panelVisible ? 1 : 0,
              pointerEvents: panelVisible && !activeCard ? 'auto' : 'none',
              transition: 'opacity 260ms ease',
            }}
          >
            {!activeCard && (
              <EventPanel event={selectedEvent} onCardClick={handleCardClick} />
            )}
          </div>

          {/* Carousel panel */}
          <div
            className={carouselVisible ? 'panel-enter' : ''}
            style={{
              position: 'absolute', inset: 0,
              opacity: carouselVisible ? 1 : 0,
              pointerEvents: carouselVisible ? 'auto' : 'none',
              transition: 'opacity 260ms ease',
            }}
          >
            {activeCard === 'edit' && selectedEvent.editSlug && (
              <EditCarousel editSlug={selectedEvent.editSlug} onBack={handleBack} />
            )}
            {activeCard === 'gallery' && selectedEvent.gallerySlug && (
              <InspoGalleryCarousel gallerySlug={selectedEvent.gallerySlug} onBack={handleBack} />
            )}
          </div>
        </div>

        {/* TIMELINE TRACK */}
        <TimelineTrack
          events={EVENTS}
          selectedId={selectedEvent.id}
          onSelect={handleEventSelect}
        />
      </section>
    </>
  );
}
