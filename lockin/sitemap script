const fs = require('fs');
const path = require('path');
const matter = require('gray-matter');

const SITE_URL = 'https://mirelleinspo.com';
const PUBLIC_DIR = path.join(process.cwd(), 'public');

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function getCurrentSeason() {
  const month = new Date().getMonth();
  if (month >= 2 && month <= 4) return 'spring';
  if (month >= 5 && month <= 7) return 'summer';
  if (month >= 8 && month <= 10) return 'fall';
  return 'winter';
}

function createSitemap(urls) {
  return `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${urls.map(url => `  <url>
    <loc>${url.loc}</loc>
    <lastmod>${url.lastmod || new Date().toISOString()}</lastmod>
    <changefreq>${url.changefreq || 'weekly'}</changefreq>
    <priority>${url.priority || 0.7}</priority>
  </url>`).join('\n')}
</urlset>`;
}

function createSitemapIndex(sitemaps) {
  return `<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${sitemaps.map(sitemap => `  <sitemap>
    <loc>${SITE_URL}/${sitemap}</loc>
    <lastmod>${new Date().toISOString()}</lastmod>
  </sitemap>`).join('\n')}
</sitemapindex>`;
}

function createImageSitemap(images) {
  return `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
${images.map(img => `  <url>
    <loc>${img.pageUrl}</loc>
    <image:image>
      <image:loc>${img.imageUrl}</image:loc>
      <image:title>${escapeXml(img.title)}</image:title>
      ${img.caption ? `<image:caption>${escapeXml(img.caption)}</image:caption>` : ''}
    </image:image>
  </url>`).join('\n')}
</urlset>`;
}

function escapeXml(str) {
  if (!str) return '';
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}

function readContentFiles(dir) {
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter(f => f.endsWith('.md') || f.endsWith('.mdx'));
}

function resolveImageUrl(imageUrl, baseImagePath) {
  if (!imageUrl) return null;
  if (imageUrl.startsWith('http')) return imageUrl;
  if (imageUrl.startsWith('/')) return `${SITE_URL}${imageUrl}`;
  return `${SITE_URL}${baseImagePath}/${imageUrl}`;
}

function extractImagesFromContent(content, slug, frontmatter, baseImagePath) {
  const images = [];
  const seen = new Set();

  const addImage = (imageUrl, alt, type) => {
    const url = resolveImageUrl(imageUrl, baseImagePath);
    if (url && !seen.has(url)) {
      images.push({ url, alt, type });
      seen.add(url);
    }
  };

  if (frontmatter.image) {
    addImage(frontmatter.image, frontmatter.imageAlt || `${slug.replace(/-/g, ' ')} featured image`, 'hero');
  }

  (frontmatter.galleryImages || []).forEach(img => {
    addImage(img.url || img.src || img, img.alt || `${slug.replace(/-/g, ' ')} gallery image`, 'gallery');
  });

  (frontmatter.carouselImages || []).forEach(img => {
    addImage(img.src || img.url || img, img.alt || `${slug.replace(/-/g, ' ')} carousel image`, 'carousel');
  });

  const mdImageRegex = /!\[([^\]]*)\]\(([^)]+)\)/g;
  let match;
  while ((match = mdImageRegex.exec(content)) !== null) {
    addImage(match[2], match[1] || `${slug.replace(/-/g, ' ')} image`, 'markdown');
  }

  const htmlMatches = content.match(/<img[^>]+>/gi) || [];
  htmlMatches.forEach(imgTag => {
    const srcMatch = imgTag.match(/src=["']([^"']+)["']/i);
    const altMatch = imgTag.match(/alt=["']([^"']*)["']/i);
    if (srcMatch) {
      addImage(srcMatch[1], altMatch ? altMatch[1] : `${slug.replace(/-/g, ' ')} image`, 'html');
    }
  });

  return images.filter(img => img.url.startsWith(`${SITE_URL}/images/`));
}

// ─── PAGE SITEMAP ─────────────────────────────────────────────────────────────

function generatePageSitemap(label, dir, urlPrefix, listPagePriority, itemPriority) {
  console.log(`📄 Generating ${label} sitemap...`);
  try {
    const files = readContentFiles(dir);
    if (files.length === 0) {
      console.warn(`⚠️  No files found in ${dir}  generating listing page only`);
    }

    const urls = [
      {
        loc: `${SITE_URL}/${urlPrefix}`,
        changefreq: 'daily',
        priority: listPagePriority,
        lastmod: new Date().toISOString(),
      },
      ...files.map(file => {
        const slug = file.replace(/\.mdx?$/, '');
        const filePath = path.join(dir, file);
        const fileContent = fs.readFileSync(filePath, 'utf8');
        const { data } = matter(fileContent);
        return {
          loc: `${SITE_URL}/${urlPrefix}/${slug}`,
          changefreq: 'weekly',
          priority: itemPriority,
          lastmod: data.dateModified || data.date || new Date().toISOString(),
        };
      }),
    ];

    const xml = createSitemap(urls);
    fs.writeFileSync(path.join(PUBLIC_DIR, `sitemap-${urlPrefix}.xml`), xml);
    console.log(`✅ sitemap-${urlPrefix}.xml created (${files.length} items)`);
  } catch (error) {
    console.error(`❌ Error generating ${label} sitemap:`, error.message);
  }
}

// ─── IMAGE SITEMAP ────────────────────────────────────────────────────────────

function generateImageSitemapForCategory(label, dir, urlPrefix, baseImagePath) {
  console.log(`📸 Generating ${label} image sitemap...`);
  try {
    const files = readContentFiles(dir);
    if (files.length === 0) {
      console.warn(`⚠️  No files found in ${dir}`);
      return null;
    }

    const allImages = [];
    const currentYear = new Date().getFullYear();
    const season = getCurrentSeason();

    files.forEach(file => {
      const slug = file.replace(/\.mdx?$/, '');
      const filePath = path.join(dir, file);
      const fileContent = fs.readFileSync(filePath, 'utf8');
      const { data, content } = matter(fileContent);
      const images = extractImagesFromContent(content, slug, data, `${baseImagePath}/${slug}`);

      if (images.length > 0) {
        const cleanTitle = data.title || slug.replace(/-/g, ' ');
        images.forEach(img => {
          allImages.push({
            pageUrl: `${SITE_URL}/${urlPrefix}/${slug}`,
            imageUrl: img.url,
            title: `${cleanTitle} - ${img.type} image`,
            caption: img.alt || `${cleanTitle} - nail art inspiration for ${season} ${currentYear}`,
          });
        });
        console.log(`   ✔ ${slug}: ${images.length} image(s)`);
      }
    });

    if (allImages.length === 0) {
      console.warn(`⚠️  No images found for ${label}`);
      return null;
    }

    const sitemapFileName = `sitemap-images-${urlPrefix}.xml`;
    fs.writeFileSync(path.join(PUBLIC_DIR, sitemapFileName), createImageSitemap(allImages));
    console.log(`✅ ${sitemapFileName} created (${allImages.length} images)`);
    return sitemapFileName;
  } catch (error) {
    console.error(`❌ Error generating ${label} image sitemap:`, error.message);
    return null;
  }
}

// ─── INSPO SITEMAPS (JSON based) ──────────────────────────────────────────────

function generateInspoSitemap() {
  console.log('📄 Generating inspo sitemap...');
  try {
    const inspoDir = path.join(process.cwd(), 'src/content/inspo-images');
    const files = fs.readdirSync(inspoDir).filter(f => f.endsWith('.json'));

    const urls = [
      { loc: `${SITE_URL}/inspo`, changefreq: 'daily', priority: 0.9, lastmod: new Date().toISOString() },
      ...files.map(file => ({
        loc: `${SITE_URL}/inspo/${file.replace('.json', '')}`,
        changefreq: 'weekly',
        priority: 0.8,
        lastmod: new Date().toISOString(),
      })),
    ];

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-inspo.xml'), createSitemap(urls));
    console.log(`✅ sitemap-inspo.xml created (${files.length} categories)`);
  } catch (error) {
    console.error('❌ Error generating inspo sitemap:', error.message);
  }
}

function generateInspoImageSitemap() {
  console.log('📸 Generating inspo image sitemap...');
  try {
    const inspoJsonDir = path.join(process.cwd(), 'src/content/inspo-images');
    if (!fs.existsSync(inspoJsonDir)) return null;

    const jsonFiles = fs.readdirSync(inspoJsonDir).filter(f => f.endsWith('.json'));
    const inspoImages = [];
    const currentYear = new Date().getFullYear();
    const season = getCurrentSeason();

    jsonFiles.forEach(jsonFile => {
      const category = jsonFile.replace('.json', '');
      const jsonPath = path.join(inspoJsonDir, jsonFile);
      try {
        const data = JSON.parse(fs.readFileSync(jsonPath, 'utf8'));
        const images = Array.isArray(data) ? data : data.images ? data.images : Object.values(data);

        images.forEach((image, index) => {
          let imageUrl = typeof image === 'string' ? image : image.url || image.src || image.image;
          if (!imageUrl) return;
          if (imageUrl.startsWith('/')) imageUrl = `${SITE_URL}${imageUrl}`;
          else if (!imageUrl.startsWith('http')) imageUrl = `${SITE_URL}/inspo/${category}/${imageUrl}`;

          const altText = typeof image === 'object' ? (image.alt || image.altText || image.description) : null;
          inspoImages.push({
            pageUrl: `${SITE_URL}/inspo/${category}`,
            imageUrl,
            title: `${category.replace(/-/g, ' ')} nail inspiration ${index + 1}`,
            caption: altText || `${category.replace(/-/g, ' ')} nail art design - trending style for ${season} ${currentYear}`,
          });
        });
      } catch (error) {
        console.error(`   ❌ ${category}:`, error.message);
      }
    });

    if (inspoImages.length === 0) return null;

    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-images-inspo.xml'), createImageSitemap(inspoImages));
    console.log(`✅ sitemap-images-inspo.xml created (${inspoImages.length} images)`);
    return 'sitemap-images-inspo.xml';
  } catch (error) {
    console.error('❌ Error generating inspo image sitemap:', error.message);
    return null;
  }
}

// ─── BUSINESS SITEMAPS (granular: index → country → state → clientType → slugs) ──

function generateBusinessSitemaps() {
  console.log('📄 Generating business sitemaps...');
  try {
    const businessDir = path.join(process.cwd(), 'src/content/business');
    const generatedSitemaps = [];

    if (!fs.existsSync(businessDir)) {
      fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-business-index.xml'), createSitemapIndex([]));
      console.log('✅ sitemap-business-index.xml created (no content yet)');
      return ['sitemap-business-index.xml'];
    }

    const countries = fs.readdirSync(businessDir).filter(f =>
      fs.statSync(path.join(businessDir, f)).isDirectory()
    );

    // Also generate a top-level page sitemap for /business + country landing pages
    const rootPageUrls = [
      { loc: `${SITE_URL}/business`, changefreq: 'daily', priority: 0.9, lastmod: new Date().toISOString() },
    ];

    countries.forEach(country => {
      const countrySlug = country.toLowerCase();
      const countryDir = path.join(businessDir, country);

      rootPageUrls.push({
        loc: `${SITE_URL}/business/${countrySlug}`,
        changefreq: 'weekly',
        priority: 0.8,
        lastmod: new Date().toISOString(),
      });

      const states = fs.readdirSync(countryDir).filter(f =>
        fs.statSync(path.join(countryDir, f)).isDirectory()
      );

      // Per-country sitemap  state landing pages
      const countryUrls = [];

      states.forEach(state => {
        const stateSlug = state.toLowerCase();
        const stateDir = path.join(countryDir, state);
        const files = readContentFiles(stateDir);

        countryUrls.push({
          loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}`,
          changefreq: 'weekly',
          priority: 0.8,
          lastmod: new Date().toISOString(),
        });

        // Group files by clientType from frontmatter
        const byClientType = {};
        files.forEach(file => {
          const slug = file.replace(/\.mdx?$/, '');
          const filePath = path.join(stateDir, file);
          const fileContent = fs.readFileSync(filePath, 'utf8');
          const { data } = matter(fileContent);
          const clientType = (data.clientType || 'general').toLowerCase();
          if (!byClientType[clientType]) byClientType[clientType] = [];
          byClientType[clientType].push({ slug, data });
        });

        // Per-state sitemap  clientType landing pages
        const stateUrls = [];
        Object.entries(byClientType).forEach(([clientType, posts]) => {
          stateUrls.push({
            loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}/${clientType}`,
            changefreq: 'weekly',
            priority: 0.7,
            lastmod: new Date().toISOString(),
          });

          // Per-clientType sitemap  individual post slugs
          const clientTypeUrls = posts.map(({ slug, data }) => ({
            loc: `${SITE_URL}/business/${countrySlug}/${stateSlug}/${clientType}/${slug}`,
            changefreq: 'weekly',
            priority: 0.7,
            lastmod: data.dateModified || data.date || new Date().toISOString(),
          }));

          const clientTypeSitemapName = `sitemap-business-${countrySlug}-${stateSlug}-${clientType}.xml`;
          fs.writeFileSync(path.join(PUBLIC_DIR, clientTypeSitemapName), createSitemap(clientTypeUrls));
          console.log(`✅ ${clientTypeSitemapName} created (${clientTypeUrls.length} URLs)`);
          generatedSitemaps.push(clientTypeSitemapName);
        });

        const stateSitemapName = `sitemap-business-${countrySlug}-${stateSlug}.xml`;
        fs.writeFileSync(path.join(PUBLIC_DIR, stateSitemapName), createSitemap(stateUrls));
        console.log(`✅ ${stateSitemapName} created (${stateUrls.length} URLs)`);
        generatedSitemaps.push(stateSitemapName);
      });

      const countrySitemapName = `sitemap-business-${countrySlug}.xml`;
      fs.writeFileSync(path.join(PUBLIC_DIR, countrySitemapName), createSitemap(countryUrls));
      console.log(`✅ ${countrySitemapName} created (${countryUrls.length} URLs)`);
      generatedSitemaps.push(countrySitemapName);
    });

    // Root page sitemap
    const rootPageSitemapName = 'sitemap-business-root.xml';
    fs.writeFileSync(path.join(PUBLIC_DIR, rootPageSitemapName), createSitemap(rootPageUrls));
    console.log(`✅ ${rootPageSitemapName} created`);
    generatedSitemaps.push(rootPageSitemapName);

    // Root index  proper sitemapindex pointing to all child sitemaps
    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-business-index.xml'), createSitemapIndex(generatedSitemaps));
    console.log(`✅ sitemap-business-index.xml created (index of ${generatedSitemaps.length} sitemaps)`);
    generatedSitemaps.unshift('sitemap-business-index.xml');

    return generatedSitemaps;
  } catch (error) {
    console.error('❌ Error generating business sitemaps:', error.message);
    return [];
  }
}



// ─── MAIN ─────────────────────────────────────────────────────────────────────

async function main() {
  console.log('🚀 Starting sitemap generation...\n');

  if (!fs.existsSync(PUBLIC_DIR)) {
    fs.mkdirSync(PUBLIC_DIR, { recursive: true });
  }

  // ── Page sitemaps ──
  generatePageSitemap('blog',          path.join(process.cwd(), 'src/content/blogs'),      'blog',          0.9, 0.8);
  generatePageSitemap('topics',        path.join(process.cwd(), 'src/content/topics'),     'topics',        0.8, 0.7);
  generatePageSitemap('spotlights',    path.join(process.cwd(), 'src/content/spotlights'), 'spotlight',     0.8, 0.7);
  generatePageSitemap('work-nails',    path.join(process.cwd(), 'src/content/work-nails'), 'work-nails',    0.8, 0.7);
  generatePageSitemap('nail-faqs',     path.join(process.cwd(), 'src/content/faqs'),       'nail-faqs',     0.8, 0.7);
  generatePageSitemap('trend-reports', path.join(process.cwd(), 'src/content/reports'),    'trend-reports', 0.8, 0.7);
  generateInspoSitemap();
  const businessSitemaps = generateBusinessSitemaps();

  // ── Image sitemaps ──
  const imageSitemaps = [];

  const blogImgs        = generateImageSitemapForCategory('blog',          path.join(process.cwd(), 'src/content/blogs'),      'blog',          '/images/blog');
  const topicsImgs      = generateImageSitemapForCategory('topics',        path.join(process.cwd(), 'src/content/topics'),     'topics',        '/images/topics');
  const spotlightImgs   = generateImageSitemapForCategory('spotlights',    path.join(process.cwd(), 'src/content/spotlights'), 'spotlight',     '/images/spotlights');
  const workNailsImgs   = generateImageSitemapForCategory('work-nails',    path.join(process.cwd(), 'src/content/work-nails'), 'work-nails',    '/images/work-nails');
  const inspoImgs       = generateInspoImageSitemap();

  if (blogImgs)        imageSitemaps.push(blogImgs);
  if (topicsImgs)      imageSitemaps.push(topicsImgs);
  if (spotlightImgs)   imageSitemaps.push(spotlightImgs);
  if (workNailsImgs)   imageSitemaps.push(workNailsImgs);
  if (inspoImgs)       imageSitemaps.push(inspoImgs);

  if (imageSitemaps.length > 0) {
    fs.writeFileSync(path.join(PUBLIC_DIR, 'sitemap-images-index.xml'), createSitemapIndex(imageSitemaps));
    console.log('✅ sitemap-images-index.xml created');
  }

  console.log('\n✅ All sitemaps generated!');
  console.log('\n📋 Generated sitemaps:');
  console.log('   • sitemap-blog.xml');
  console.log('   • sitemap-topics.xml');
  console.log('   • sitemap-spotlight.xml');
  console.log('   • sitemap-work-nails.xml');
  console.log('   • sitemap-nail-faqs.xml');
  console.log('   • sitemap-trend-reports.xml');
  console.log('   • sitemap-inspo.xml');
  businessSitemaps.forEach(s => console.log(`   • ${s}`));
  console.log('   • sitemap-images-blog.xml');
  console.log('   • sitemap-images-topics.xml');
  console.log('   • sitemap-images-spotlight.xml');
  console.log('   • sitemap-images-work-nails.xml');
  console.log('   • sitemap-images-inspo.xml');
  console.log('   • sitemap-images-index.xml');
}

main().catch(error => {
  console.error('❌ Fatal error:', error);
  process.exit(1);
});
