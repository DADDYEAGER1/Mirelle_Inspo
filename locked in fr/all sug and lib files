      "path": "src/app/business/[country]/[state]/[clientType]/[slug]/page.tsx",
      "content": "// src/app/business/[country]/[state]/[clientType]/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { Metadata } from 'next';\nimport { serialize } from 'next-mdx-remote/serialize';\nimport { getBusinessPost, getAllBusinessPosts } from '@/lib/business';\nimport { getAuthor } from '@/lib/authors';\nimport BusinessTemplate from '@/components/business/BusinessTemplate';\nimport { ClientType } from '@/types/business';\n\n\nexport const revalidate = false;\n// ─── Static Params ────────────────────────────────────────────────────────────\n\nexport async function generateStaticParams() {\n  const posts = await getAllBusinessPosts();\n  return posts.map(post => ({\n    country:    post.countrySlug,\n    state:      post.stateSlug,\n    clientType: post.clientType,\n    slug:       post.slug,\n  }));\n}\n\n// ─── Metadata ─────────────────────────────────────────────────────────────────\n\nexport async function generateMetadata(\n  { params }: { params: Promise<{ country: string; state: string; clientType: string; slug: string }> }\n): Promise<Metadata> {\n  const { slug } = await params;\n  const post = await getBusinessPost(slug);\n  if (!post) return {};\n\n  return {\n    title:       post.title,\n    description: post.excerpt,\n    authors: [{ name: post.author || 'Mirellé' }],\n    creator: post.author || 'Mirellé',\n    publisher: 'Mirellé',\n    robots: post.noIndex\n      ? { index: false, follow: false }\n      : { index: true,  follow: true },\n    alternates: {\n      canonical: post.canonical,\n      languages: { [post.regionCode]: post.canonical },\n    },\n    openGraph: {\n      title:       post.title,\n      description: post.excerpt,\n      url:         post.canonical,\n      type:        'website',\n      siteName:    'Mirellé',\n      locale:      post.locale,\n    },\n    twitter: {\n      card:        'summary_large_image',\n      title:       post.title,\n      description: post.excerpt,\n    },\n  };\n}\n\n// ─── JSON-LD ──────────────────────────────────────────────────────────────────\n\nfunction generateSchemas(post: NonNullable<Awaited<ReturnType<typeof getBusinessPost>>>) {\n  const schemas = [];\n\n  schemas.push({\n    '@context': 'https://schema.org',\n    '@type': post.schemaType || 'ProfessionalService',\n    '@id': post.canonical,\n    name: 'Mirellé',\n    description: post.excerpt,\n    url: post.canonical,\n    logo: 'https://mirelleinspo.com/images/logo.png',\n    sameAs: ['https://instagram.com/mirelleinspo', 'https://pinterest.com/mirelleinspo'],\n    areaServed: {\n      '@type': 'State',\n      name: post.state,\n      containedInPlace: { '@type': 'Country', name: post.country },\n    },\n    hasOfferCatalog: {\n      '@type': 'OfferCatalog',\n      name: `Nail Editorial Services · ${post.region}`,\n      itemListElement: post.services.map(s => ({\n        '@type': 'Offer',\n        itemOffered: { '@type': 'Service', name: s.title, description: s.description },\n      })),\n    },\n    contactPoint: { '@type': 'ContactPoint', email: post.contact.email, contactType: 'customer service' },\n    author: {\n      '@type': 'Person',\n      name: post.author || 'Mirellé',\n      url: `https://mirelleinspo.com/authors/${post.author}`,\n    },\n  });\n\n  if (post.faqSchema.length > 0) {\n    schemas.push({\n      '@context': 'https://schema.org',\n      '@type': 'FAQPage',\n      mainEntity: post.faqSchema.map(faq => ({\n        '@type': 'Question',\n        name: faq.question,\n        acceptedAnswer: { '@type': 'Answer', text: faq.answer },\n      })),\n    });\n  }\n\n  schemas.push({\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home',          item: 'https://mirelleinspo.com' },\n      { '@type': 'ListItem', position: 2, name: 'Business',      item: 'https://mirelleinspo.com/business' },\n      { '@type': 'ListItem', position: 3, name: post.country,    item: `https://mirelleinspo.com/business/${post.countrySlug}` },\n      { '@type': 'ListItem', position: 4, name: post.state,      item: `https://mirelleinspo.com/business/${post.countrySlug}/${post.stateSlug}` },\n      { '@type': 'ListItem', position: 5, name: post.clientType, item: `https://mirelleinspo.com/business/${post.countrySlug}/${post.stateSlug}/${post.clientType}` },\n      { '@type': 'ListItem', position: 6, name: post.title,      item: post.canonical },\n    ],\n  });\n\n  if (post.speakable) {\n    schemas.push({\n      '@context': 'https://schema.org',\n      '@type': 'WebPage',\n      name: post.title,\n      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.business-tldr', '.business-about'] },\n      url: post.canonical,\n    });\n  }\n\n  return schemas;\n}\n\n// ─── Page ─────────────────────────────────────────────────────────────────────\n\nexport default async function BusinessSlugPage(\n  { params }: { params: Promise<{ country: string; state: string; clientType: string; slug: string }> }\n) {\n  const { country, state, clientType, slug } = await params;\n  const validTypes: ClientType[] = ['influencer', 'brand', 'nail-tech', 'salon'];\n  if (!validTypes.includes(clientType as ClientType)) notFound();\n\n  const post = await getBusinessPost(slug);\n  if (!post) notFound();\n\n  if (\n    post.countrySlug !== country ||\n    post.stateSlug   !== state   ||\n    post.clientType  !== clientType\n  ) {\n    notFound();\n  }\n\n  const schemas = generateSchemas(post);\n  const mdxSource = post.isMDX ? await serialize(post.content) : undefined;\n  const author = post.author ? getAuthor(post.author) : null;\n\n  return (\n    <>\n      {schemas.map((schema, i) => (\n        <script key={i} type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }} />\n      ))}\n      <BusinessTemplate post={post} mdxSource={mdxSource} author={author ?? undefined} />\n    </>\n  );\n}"
