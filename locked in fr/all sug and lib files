      "content": "// src/lib/authors.ts\n\nimport 'server-only';\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\nimport { authors } from '@/data/authors';\nimport { Author, AuthorWithStats } from '@/types/author';\n\n// ─── Cache ───────────────────────────────────────────────────────────────────\n\ninterface CacheEntry<T> {\n  data: T;\n  timestamp: number;\n}\n\nclass AuthorCache {\n  private cache = new Map<string, CacheEntry<any>>();\n  private readonly TTL = 3600000; // 1 hour\n\n  get<T>(key: string): T | null {\n    const entry = this.cache.get(key);\n    if (!entry) return null;\n    if (Date.now() - entry.timestamp > this.TTL) {\n      this.cache.delete(key);\n      return null;\n    }\n    return entry.data as T;\n  }\n\n  set<T>(key: string, data: T): void {\n    this.cache.set(key, { data, timestamp: Date.now() });\n  }\n\n  clear(): void {\n    this.cache.clear();\n  }\n}\n\nconst authorCache = new AuthorCache();\n\n// ─── Content directories to scan ─────────────────────────────────────────────\n\nconst CONTENT_DIRS: { dir: string; type: string; urlBase: string }[] = [\n  { dir: 'src/content/blogs',       type: 'blog',      urlBase: '/blog'          },\n  { dir: 'src/content/faqs',        type: 'faq',       urlBase: '/nail-faqs'     },\n  { dir: 'src/content/work-nails',  type: 'work-nail', urlBase: '/work-nails'    },\n  { dir: 'src/content/spotlights',  type: 'spotlight', urlBase: '/spotlight'     },\n  { dir: 'src/content/topics',      type: 'topic',     urlBase: '/topics'        },\n  { dir: 'src/content/reports',     type: 'report',    urlBase: '/trend-reports' },\n  { dir: 'src/content/business',    type: 'business',  urlBase: '/business'      },\n];\n\n// ─── Helpers ─────────────────────────────────────────────────────────────────\n\nfunction getAllFilesRecursive(dir: string): string[] {\n  let results: string[] = [];\n  let entries: fs.Dirent[];\n\n  try {\n    entries = fs.readdirSync(dir, { withFileTypes: true });\n  } catch {\n    return [];\n  }\n\n  for (const entry of entries) {\n    const fullPath = path.join(dir, entry.name);\n    if (entry.isDirectory()) {\n      results = results.concat(getAllFilesRecursive(fullPath));\n    } else if (\n      entry.isFile() &&\n      (entry.name.endsWith('.md') || entry.name.endsWith('.mdx'))\n    ) {\n      results.push(fullPath);\n    }\n  }\n\n  return results;\n}\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\nexport interface AuthorPost {\n  slug: string;\n  title: string;\n  excerpt: string;\n  date: string;\n  image?: string;\n  type: string;\n  url: string;\n}\n\n// ─── Public API ───────────────────────────────────────────────────────────────\n\nexport function getAuthor(slug: string): Author | null {\n  return authors.find(a => a.slug === slug) ?? null;\n}\n\nexport function getAllAuthors(): Author[] {\n  return authors;\n}\n\nexport async function getPostsByAuthor(authorSlug: string): Promise<AuthorPost[]> {\n  const cacheKey = `author-posts:${authorSlug}`;\n\n  const cached = authorCache.get<AuthorPost[]>(cacheKey);\n  if (cached) return cached;\n\n  const posts: AuthorPost[] = [];\n\n  for (const { dir, type, urlBase } of CONTENT_DIRS) {\n    const absDir = path.join(process.cwd(), dir);\n    const files = getAllFilesRecursive(absDir);\n\n    for (const filePath of files) {\n      try {\n        const raw = fs.readFileSync(filePath, 'utf8');\n        const { data } = matter(raw);\n\n        if (data.author !== authorSlug) continue;\n\n        // Use relative path from content dir to preserve subfolder structure\n        const relativePath = path.relative(absDir, filePath);\n        const urlPath = relativePath.replace(/\\.mdx?$/, '').replace(/\\\\/g, '/');\n        const slug = path.basename(filePath).replace(/\\.mdx?$/, '');\n\n        // Business URLs are built from frontmatter fields\n        const url = type === 'business'\n          ? `/business/${data.countrySlug}/${data.stateSlug}/${data.clientType}/${slug}`\n          : `${urlBase}/${urlPath}`;\n\n        posts.push({\n          slug,\n          title:   data.title   || 'Untitled',\n          excerpt: data.excerpt || '',\n          date:    data.date    || new Date().toISOString(),\n          image:   data.image   || undefined,\n          type,\n          url,\n        });\n      } catch {\n        // skip unreadable files\n      }\n    }\n  }\n\n  // Sort newest first\n  posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n\n  authorCache.set(cacheKey, posts);\n  return posts;\n}\n\nexport async function getAllAuthorsWithStats(): Promise<AuthorWithStats[]> {\n  const cacheKey = 'all-authors-with-stats';\n\n  const cached = authorCache.get<AuthorWithStats[]>(cacheKey);\n  if (cached) return cached;\n\n  const result: AuthorWithStats[] = await Promise.all(\n    authors.map(async author => {\n      const posts = await getPostsByAuthor(author.slug);\n      return { ...author, postCount: posts.length };\n    })\n  );\n\n  authorCache.set(cacheKey, result);\n  return result;\n}\n\nexport function clearAuthorCache(): void {\n  authorCache.clear();\n}"
