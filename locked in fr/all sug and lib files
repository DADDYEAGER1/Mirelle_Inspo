      "path": "src/middleware.ts",
      "content": "import { NextRequest, NextResponse } from 'next/server';\n\nconst BLOCKED_COUNTRIES = ['SG', 'CN'];\n\nconst BOT_PATTERNS = /Baiduspider|YandexBot|SemrushBot|AhrefsBot|MJ12bot|DotBot/i;\n\nexport function middleware(req: NextRequest) {\n  const country = (req as any).geo?.country ?? '';\n  const ua = req.headers.get('user-agent') ?? '';\n\n  if (BLOCKED_COUNTRIES.includes(country) || BOT_PATTERNS.test(ua)) {\n    return new NextResponse('Access denied', { status: 403 });\n  }\n\n  return NextResponse.next();\n}\n\nexport const config = {\n  matcher: '/((?!_next/static|_next/image|favicon.ico).*)',\n};"
