      "content": "// src/types/reports.ts\n\nexport interface ReportMetadata {\n  slug: string;\n  title: string;\n  excerpt: string;\n  date: string;\n  dateModified?: string;\n  author: string;\n  category: string;\n  image: string;\n  imageAlt?: string;\n  imageWidth?: number;\n  imageHeight?: number;\n  imageCaption?: string;\n  readTime?: number | string;\n  wordCount?: number;\n  canonical?: string;\n  tags?: string[];\n  topicalMap?: {\n    position?: string;\n    parentPillar?: string;\n    relatedClusters?: string[];\n    primaryKeyword?: string;\n    searchIntent?: string;\n    topicalBoundary?: string;\n    hierarchyLevel?: number;\n    secondaryKeywords?: string[];\n    contentType?: string;\n    semanticRelationships?: {\n      technique?: string[];\n      style?: string[];\n      occasions?: string[];\n      relatedTechniques?: string[];\n    };\n    contentMetrics?: {\n      technicalComplexity?: string;\n      timeToImplement?: string;\n      requiredSkills?: string[];\n      requiredTools?: string[];\n    };\n  };\n  navigationContext?: {\n    pillarPost?: {\n      slug: string;\n      title: string;\n    };\n  };\n}\n\nexport interface Report extends ReportMetadata {\n  content: string; // raw MDX string\n}\n\nexport interface ReportCategory {\n  name: string;\n  slug: string;\n  count: number;\n}"
