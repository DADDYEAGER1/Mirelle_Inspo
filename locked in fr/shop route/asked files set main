      "path": "src/app/globals.css",
      "content": "@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:wght@400;600;700&display=swap');\n\n@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n/* ============================================\n   FONT FACE DECLARATIONS\n   ============================================ */\n\n/* Larken - Headings & Titles */\n@font-face {\n  font-family: 'Larken';\n  src: url('/fonts/LarkenDEMO-Regular.otf') format('opentype');\n  font-weight: normal;\n  font-style: normal;\n  font-display: swap;\n}\n\n/* General Sans - UI Elements (categories, nav, labels) */\n@font-face {\n  font-family: 'General Sans';\n  src: url('/fonts/GeneralSans-Regular.otf') format('opentype');\n  font-weight: normal;\n  font-style: normal;\n  font-display: swap;\n}\n\n/* ============================================\n   CSS VARIABLES\n   ============================================ */\n\n:root {\n  /* Fonts */\n  --font-heading: 'Larken', 'Georgia', serif;\n  --font-body: 'Crimson Text', 'Georgia', serif;\n  --font-ui: 'General Sans', system-ui, sans-serif;\n  --font-brand: 'Larken', 'Georgia', serif;\n  \n  /* NEW BRAND COLORS */\n  --background: #f9fafb;\n  --foreground: #252220;\n  \n  /* OLD COLORS (temporary - remove after migration) */\n  --accent: #E30088;\n  --accent-light: #FF1AA3;\n  --accent-dark: #B0006B;\n}\n\n/* ============================================\n   GLOBAL RESETS & BASE STYLES\n   ============================================ */\n\n* {\n  box-sizing: border-box;\n  padding: 0;\n  margin: 0;\n}\n\nhtml,\nbody {\n  max-width: 100vw;\n  overflow-x: hidden;\n  font-family: var(--font-body);\n  font-weight: normal;\n}\n\nbody {\n  color: var(--foreground);\n  background: var(--background);\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* ============================================\n   REMOVE ALL LINK UNDERLINES\n   ============================================ */\n\na {\n  color: inherit;\n  text-decoration: none;\n  font-weight: normal;\n}\n\n/* ============================================\n   REMOVE BOLD FROM ALL HEADINGS & ELEMENTS\n   ============================================ */\n\n/* h1, h2, h3, h4, h5, h6,\nstrong, b,\n.font-bold {\n  font-weight: normal !important;\n} */\n\n/* Exception: Logo in header can be bold */\n.logo-text,\n[data-logo=\"true\"] {\n  font-weight: bold !important;\n}\n\n/* ============================================\n   UTILITY CLASSES\n   ============================================ */\n\n.font-heading {\n  font-family: var(--font-heading);\n}\n\n.font-body {\n  font-family: var(--font-body);\n}\n\n.font-ui {\n  font-family: var(--font-ui);\n}\n\n.font-brand {\n  font-family: var(--font-brand);\n}\n\n/* ============================================\n   ANIMATIONS\n   ============================================ */\n\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes slideIn {\n  from {\n    opacity: 0;\n    transform: translateX(-20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n@keyframes pulse {\n  0%, 100% {\n    opacity: 1;\n  }\n  50% {\n    opacity: 0.5;\n  }\n}\n\n.animate-fadeIn {\n  animation: fadeIn 0.6s ease-out;\n}\n\n.animate-slideIn {\n  animation: slideIn 0.6s ease-out;\n}\n\n.animate-pulse {\n  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n}\n\n/* ============================================\n   SCROLLBAR STYLING\n   ============================================ */\n\n::-webkit-scrollbar {\n  width: 10px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--background);\n}\n\n::-webkit-scrollbar-thumb {\n  background: #888;\n  border-radius: 5px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #555;\n}\n\n/* ============================================\n   SELECTION STYLING\n   ============================================ */\n\n::selection {\n  background-color: var(--foreground);\n  color: var(--background);\n}\n\n::-moz-selection {\n  background-color: var(--foreground);\n  color: var(--background);\n}\n\n\n/* ============================================\n   center blog template styles\n   ============================================ */\n\n   /* Blog Post Prose Styles */\n.prose-content p {\n  font-family: var(--font-body);\n  font-size: 18px;\n  line-height: 1.7;\n  color: var(--foreground);\n  margin-bottom: 24px;\n}\n\n.prose-content a {\n  color: var(--foreground);\n  text-decoration: none;\n}\n\n.prose-content a:hover {\n  color: #666;\n}\n\n.prose-content strong {\n  font-weight: 600;\n}\n\n.prose-content h2 {\n  font-family: var(--font-heading);\n  font-size: 36px;\n  margin-top: 48px;\n  margin-bottom: 24px;\n}\n\n.prose-content h3 {\n  font-family: var(--font-heading);\n  font-size: 28px;\n  margin-top: 36px;\n  margin-bottom: 20px;\n}\n\n.prose-content img {\n  border-radius: 8px;\n  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n  margin: 48px 0;\n}\n\n@media (max-width: 768px) {\n  .prose-content p {\n    font-size: 16px;\n    margin-bottom: 20px;\n  }\n  \n  .prose-content h2 {\n    font-size: 26px;\n    margin-top: 32px;\n  }\n  \n  .prose-content h3 {\n    font-size: 22px;\n    margin-top: 24px;\n  }\n  \n  .prose-content img {\n    margin: 32px 0;\n  }\n}\n/* ============================================\n   STANDARDIZED TYPOGRAPHY CLASSES\n   USE THESE IN ALL NEW COMPONENTS\n   ============================================ */\n\n/* Heading Classes - Responsive */\n.heading-1 {\n  @apply text-h1-mobile md:text-h1 font-heading;\n}\n\n.heading-2 {\n  @apply text-h2-mobile md:text-h2 font-heading;\n}\n\n.heading-3 {\n  @apply text-h3-mobile md:text-h3 font-heading;\n}\n\n.heading-4 {\n  @apply text-h4-mobile md:text-h4 font-heading;\n}\n\n/* Body Text Classes */\n.body-text {\n  @apply text-body font-body;\n}\n\n.body-large {\n  @apply text-body-lg font-body;\n}\n\n.body-small {\n  @apply text-body-sm font-body;\n}\n\n/* UI Element Classes */\n.ui-text {\n  @apply text-ui font-ui;\n}\n\n.ui-text-small {\n  @apply text-ui-xs font-ui;\n}\n\n/* Context-Specific Classes */\n.nav-link {\n  @apply text-ui font-ui;\n}\n\n.button-text {\n  @apply text-ui font-ui;\n}\n\n.card-title {\n  @apply text-h3-mobile md:text-h3 font-heading;\n}\n\n.card-body {\n  @apply text-body-sm font-body;\n}\n\n.label-text {\n  @apply text-ui-xs font-ui;\n}\n\n/* ============================================\n   UPDATE EXISTING BLOG PROSE TO MATCH\n   ============================================ */\n.prose-content-magazine h2 {\n  font-family: 'Larken', 'Georgia', serif !important;\n  font-size: 32px !important;\n  line-height: 1.3 !important;\n  margin-top: 3rem !important;\n  margin-bottom: 1.5rem !important;\n  font-weight: 400 !important;\n  text-align: left !important;\n}\n\n.prose-content-magazine div h2,\n.prose-content-magazine h2 {\n  font-family: 'Larken', 'Georgia', serif !important;\n  font-size: 32px !important;\n  line-height: 1.3 !important;\n  margin-top: 3rem !important;\n  margin-bottom: 1.5rem !important;\n  font-weight: 400 !important;\n  text-align: left !important;\n}\n\n.prose-content-magazine div h3,\n.prose-content-magazine h3 {\n  font-family: 'Larken', 'Georgia', serif !important;\n  font-size: 24px !important;\n  line-height: 1.4 !important;\n  margin-top: 2.5rem !important;\n  margin-bottom: 1rem !important;\n  font-weight: 400 !important;\n  text-align: left !important;\n}\n\n.prose-content p {\n  font-family: var(--font-body);\n  font-size: 20px;  /* Updated from 18px */\n  line-height: 1.7;\n  color: var(--foreground);\n  margin-bottom: 24px;\n}\n\n.prose-content h2 {\n  font-family: var(--font-heading);\n  font-size: 32px;  /* Updated from 36px */\n  line-height: 1.3;\n  margin-top: 48px;\n  margin-bottom: 24px;\n}\n\n.prose-content h3 {\n  font-family: var(--font-heading);\n  font-size: 24px;  /* Updated from 28px */\n  line-height: 1.4;\n  margin-top: 36px;\n  margin-botto