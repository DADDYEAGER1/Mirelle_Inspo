      "path": "src/lib/reports.ts",
      "content": "// src/lib/reports.ts\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\nimport { Report, ReportMetadata, ReportCategory } from '@/types/reports';\nconst reportsDirectory = path.join(process.cwd(), 'src/content/reports');\n\nexport async function getAllReportSlugs(): Promise<string[]> {\n  if (!fs.existsSync(reportsDirectory)) return [];\n  return fs\n    .readdirSync(reportsDirectory)\n    .filter((f) => f.endsWith('.mdx'))\n    .map((f) => f.replace(/\\.mdx$/, ''));\n}\n\nexport async function getReport(slug: string): Promise< Report | null> {\n  try {\n    const fullPath = path.join(reportsDirectory, `${slug}.mdx`);\n    if (!fs.existsSync(fullPath)) return null;\n\n    const fileContents = fs.readFileSync(fullPath, 'utf8');\n    const { data, content } = matter(fileContents);\n\n    return {\n      slug,\n      title: data.title || '',\n      excerpt: data.excerpt || '',\n      date: data.date || new Date().toISOString(),\n      dateModified: data.dateModified,\n      author: data.author || 'Mirellé',\n      category: data.category || 'UNCATEGORIZED',\n      image: data.image || '/images/default-report.jpg',\n      imageAlt: data.imageAlt,\n      imageWidth: data.imageWidth,\n      imageHeight: data.imageHeight,\n      imageCaption: data.imageCaption,\n      readTime: data.readTime,\n      wordCount: data.wordCount,\n      canonical: data.canonical || `https://mirelleinspo.com/trend-reports/${slug}`,\n      tags: data.tags,\n      topicalMap: data.topicalMap,\n      navigationContext: data.navigationContext,\n      content, // raw MDX  no remark processing\n    };\n  } catch (error) {\n    console.error(`Error loading faq ${slug}:`, error);\n    return null;\n  }\n}\n\nexport async function getAllReports(): Promise<ReportMetadata[]> {\n  const slugs = await getAllReportSlugs();\n  const faqs = await Promise.all(\n    slugs.map(async (slug) => {\n      const report = await getReport(slug);\n      if (!report) return null;\n      const { content, ...metadata } = report;\n      return metadata;\n    })\n  );\n  return faqs\n    .filter((f): f is ReportMetadata => f !== null)\n    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n}\n\nexport async function getReportsByCategory(categorySlug: string): Promise<ReportMetadata[]> {\n  const allFaqs = await getAllReports();\n  const normalize = (s: string) => s.toLowerCase().replace(/\\s+/g, '-');\n  return allFaqs.filter((f) => normalize(f.category) === categorySlug.toLowerCase());\n}\n\nexport async function getAllReportCategories(): Promise<ReportCategory[]> {\n  const allFaqs = await getAllReports();\n  const map = new Map<string, number>();\n  allFaqs.forEach((f) => map.set(f.category, (map.get(f.category) || 0) + 1));\n  return Array.from(map.entries())\n    .map(([name, count]) => ({ name, slug: name.toLowerCase().replace(/\\s+/g, '-'), count }))\n    .sort((a, b) => a.name.localeCompare(b.name));\n}\n\nexport async function getRelatedReports(currentSlug: string, limit = 3): Promise<ReportMetadata[]> {\n  const current = await getReport(currentSlug);\n  if (!current) return [];\n  const all = await getAllReports();\n  const others = all.filter((f) => f.slug !== currentSlug);\n  const sameCategory = others.filter((f) => f.category === current.category);\n  const rest = others.filter((f) => f.category !== current.category);\n  return [...sameCategory, ...rest].slice(0, limit);\n}\n\nexport async function getPaginatedReports(page = 1, perPage = 12) {\n  const all = await getAllReports();\n  const total = all.length;\n  const totalPages = Math.ceil(total / perPage);\n  const start = (page - 1) * perPage;\n  return {\n    faqs: all.slice(start, start + perPage),\n    currentPage: page,\n    totalPages,\n    totalFaqs: total,\n    hasNextPage: page < totalPages,\n    hasPreviousPage: page > 1,\n  };\n}"
    },
