      "content": "// src/app/work-nails/[slug]/templates/SplitLeftTemplate.tsx\nimport { WorkNailsPost } from '@/types/workNails';\nimport MDXContent from './MDXContent';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport InlineNewsletter from '@/components/Blog/InlineNewsletter';\nimport AboutEEAT from '@/components/Blog/AboutEEAT';\nimport FinalNewsletter from '@/components/Blog/FinalNewsletter';\nimport ReadMoreSection from '@/components/Blog/ReadMoreSection';\nimport TableOfContents from '@/components/Blog/TableOfContents';\n\ninterface SplitLeftTemplateProps {\n  post: WorkNailsPost;\n}\n\nexport default function SplitLeftTemplate({ post }: SplitLeftTemplateProps) {\n  const postProducts = post.products ?? [];\n\n  return (\n    <div className=\"min-h-screen bg-background\">\n      {/* Inline Newsletter */}\n      <div className=\"w-full\">\n        <InlineNewsletter />\n      </div>\n\n      {/* Hero - Split Left */}\n      <div className=\"w-full\">\n        {/* Desktop: 50/50 split */}\n        <div className=\"hidden md:grid md:grid-cols-2 h-[600px]\">\n          <div\n            className=\"flex items-center justify-center p-12\"\n            style={{ backgroundColor: '#f9fafb' }}\n          >\n            <div className=\"text-center\">\n              {post.category && (\n                <p className=\"font-ui text-sm uppercase tracking-wider text-gray-600 mb-4\">\n                  {post.category}\n                </p>\n              )}\n              <h1\n                className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\"\n                style={{ color: '#252220' }}\n              >\n                {post.title}\n              </h1>\n              <p\n                className=\"font-ui text-sm uppercase tracking-wide mb-2\"\n                style={{ color: '#252220' }}\n              >\n                BY {post.author}\n              </p>\n              <p className=\"font-ui text-sm text-gray-600\">\n                {new Date(post.date).toLocaleDateString('en-US', {\n                  year: 'numeric',\n                  month: 'long',\n                  day: 'numeric',\n                })}\n              </p>\n            </div>\n          </div>\n\n          <div\n            className=\"flex items-center justify-center p-12 overflow-hidden\"\n            style={{ backgroundColor: '#f9fafb' }}\n          >\n            {post.image && (\n              <img\n                src={post.image}\n                alt={post.imageAlt || post.title}\n                className=\"w-full h-full object-contain\"\n              />\n            )}\n          </div>\n        </div>\n\n        {/* Mobile: Stacked */}\n        <div className=\"md:hidden w-full\">\n          <div\n            className=\"text-center py-8 px-6\"\n            style={{ backgroundColor: '#f9fafb' }}\n          >\n            {post.category && (\n              <p className=\"font-ui text-xs uppercase tracking-wider text-gray-600 mb-3\">\n                {post.category}\n              </p>\n            )}\n            <h1\n              className=\"font-heading text-[36px] mb-3\"\n              style={{ color: '#252220' }}\n            >\n              {post.title}\n            </h1>\n            <p\n              className=\"font-ui text-xs uppercase tracking-wide mb-2\"\n              style={{ color: '#252220' }}\n            >\n              BY {post.author}\n            </p>\n            <p className=\"font-ui text-xs text-gray-600\">\n              {new Date(post.date).toLocaleDateString('en-US', {\n                year: 'numeric',\n                month: 'long',\n                day: 'numeric',\n              })}\n            </p>\n          </div>\n          {post.image && (\n            <img\n              src={post.image}\n              alt={post.imageAlt || post.title}\n              className=\"w-full h-auto\"\n            />\n          )}\n        </div>\n      </div>\n\n      {/* Article Content - centered like spotlight */}\n      <div className=\"w-full flex flex-col items-center\">\n        <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16 mt-12\">\n\n          {/* Breadcrumbs */}\n          <div className=\"mb-8\">\n            <Breadcrumbs\n              items={[{ label: 'Work Nails', href: '/work-nails' }]}\n              currentPage={post.title}\n              includeSchema={false}\n            />\n          </div>\n\n          {/* TOC  mobile only */}\n          <div className=\"block md:hidden mb-8\">\n            <TableOfContents content={post.content} />\n          </div>\n\n          {/* Article Content */}\n          <article className=\"prose-content-magazine\">\n            <MDXContent source={post.content} products={postProducts} />\n          </article>\n        </div>\n\n        {/* Full width newsletter break */}\n        <div className=\"w-full my-12\">\n          <InlineNewsletter />\n        </div>\n      </div>\n\n      <AboutEEAT />\n      <FinalNewsletter />\n      <ReadMoreSection currentSlug={post.slug} />\n    </div>\n  );\n}"
