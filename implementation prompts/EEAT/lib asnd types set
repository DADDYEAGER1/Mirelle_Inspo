      "content": "// src/types/business.ts\n\nexport type ClientType = 'influencer' | 'brand' | 'nail-tech' | 'salon';\n\nexport interface BusinessFAQ {\n  question: string;\n  answer: string;\n}\n\nexport interface BusinessService {\n  title: string;\n  description: string;\n}\n\nexport interface BusinessContact {\n  email: string;\n  whatsapp?: string;\n  instagram?: string;\n}\n\nexport interface BusinessGalleryImage {\n  url: string;\n  alt: string;\n  width?: number;\n  height?: number;\n}\n\nexport interface BusinessMetadata {\n  slug: string;\n  title: string;\n  excerpt: string;\n  date: string;\n  dateModified?: string;\n  author: string;\n\n  // Region\n  region: string;\n  regionCode: string;\n  language: string;\n  locale: string;\n  city: string;\n  country: string;\n  countrySlug: string;   // e.g. 'india', 'united-kingdom'\n  state: string;         // e.g. 'Maharashtra'\n  stateSlug: string;     // e.g. 'maharashtra'\n  stateCode: string;     // e.g. 'MH', 'CA'\n  clientType: ClientType; // 'influencer' | 'brand' | 'nail-tech' | 'salon'\n\n  // SEO\n  canonical: string;\n  targetKeyword: string;\n  secondaryKeywords?: string[];\n  searchIntent?: 'informational' | 'transactional' | 'navigational' | 'commercial';\n  noIndex?: boolean;\n\n  // GEO/AEO\n  tldr: string;\n  entityType?: string;\n  speakable?: boolean;\n\n  // Contact\n  contact: BusinessContact;\n\n  // Services\n  services: BusinessService[];\n\n  // Schema\n  schemaType?: 'ProfessionalService' | 'LocalBusiness';\n\n  // Display\n  template?: 'business';\n\n  postType?: 'client-acquisition' | 'deliverable';\n  painPoint?: string;\n  statBlock?: { stat: string; context: string }[];\n\n  url: string;\n}\n\nexport interface BusinessPost extends BusinessMetadata {\n  content: string;\n  isMDX?: boolean;\n  faqSchema: BusinessFAQ[];\n  galleryImages?: BusinessGalleryImage[];\n}"
