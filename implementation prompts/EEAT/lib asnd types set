      "path": "src/lib/business.ts",
      "content": "// src/lib/business.ts\nimport fs from 'fs';\nimport path from 'path';\nimport matter from 'gray-matter';\nimport { marked } from 'marked';\nimport { BusinessPost, BusinessMetadata, ClientType } from '@/types/business';\n\n// ─── Marked config ────────────────────────────────────────────────────────────\n\nmarked.setOptions({ breaks: true, gfm: true });\n\nconst renderer = new marked.Renderer();\n\nrenderer.html = (html: string) => html.replace(/src=\"images\\//g, 'src=\"/images/');\nrenderer.image = (href: string, title: string | null, text: string) => {\n  const fixedHref = href.startsWith('images/') ? `/${href}` : href;\n  const titleAttr = title ? ` title=\"${title}\"` : '';\n  return `<img src=\"${fixedHref}\" alt=\"${text}\"${titleAttr} loading=\"lazy\" />`;\n};\n\nmarked.use({ renderer });\n\n// ─── Paths ────────────────────────────────────────────────────────────────────\n\nconst BUSINESS_DIRECTORY = path.join(process.cwd(), 'src/content/business');\n\n// ─── Helpers ──────────────────────────────────────────────────────────────────\n\n/**\n * Recursively walks src/content/business/[country]/[state]/\n * and returns absolute file paths + slug for every .md / .mdx file found.\n * Folder structure: content/business/india/maharashtra/my-post.md\n */\nfunction getAllBusinessFiles(): { filePath: string; slug: string }[] {\n  const results: { filePath: string; slug: string }[] = [];\n\n  function walk(dir: string) {\n    let entries: fs.Dirent[];\n    try {\n      entries = fs.readdirSync(dir, { withFileTypes: true });\n    } catch {\n      return;\n    }\n    for (const entry of entries) {\n      const fullPath = path.join(dir, entry.name);\n      if (entry.isDirectory()) {\n        walk(fullPath);\n      } else if (entry.isFile() && (entry.name.endsWith('.md') || entry.name.endsWith('.mdx'))) {\n        const slug = entry.name.replace(/\\.mdx?$/, '');\n        results.push({ filePath: fullPath, slug });\n      }\n    }\n  }\n\n  walk(BUSINESS_DIRECTORY);\n  return results;\n}\n\n/**\n * Finds a post file by slug anywhere in the country/state subfolder tree.\n */\nfunction resolveFilePath(slug: string): { filePath: string; isMDX: boolean } | null {\n  const files = getAllBusinessFiles();\n  const match = files.find(f => f.slug === slug);\n  if (!match) return null;\n  return { filePath: match.filePath, isMDX: match.filePath.endsWith('.mdx') };\n}\n\nfunction toSlug(str: string): string {\n  return str.toLowerCase().trim().replace(/\\s+/g, '-').replace(/[^a-z0-9-]/g, '');\n}\n\n// ─── Cache ────────────────────────────────────────────────────────────────────\n\ninterface CacheEntry<T> {\n  data: T;\n  timestamp: number;\n}\n\nclass BusinessCache {\n  private cache = new Map<string, CacheEntry<unknown>>();\n  private readonly TTL = 3600000;\n\n  get<T>(key: string): T | null {\n    const entry = this.cache.get(key);\n    if (!entry) return null;\n    if (Date.now() - entry.timestamp > this.TTL) {\n      this.cache.delete(key);\n      return null;\n    }\n    return entry.data as T;\n  }\n\n  set<T>(key: string, data: T): void {\n    this.cache.set(key, { data, timestamp: Date.now() });\n  }\n\n  clear(): void {\n    this.cache.clear();\n  }\n}\n\nconst businessCache = new BusinessCache();\n\n// ─── Parse metadata ───────────────────────────────────────────────────────────\n\nfunction parseMetadata(slug: string, data: Record<string, unknown>): BusinessMetadata {\n  const countrySlug = (data.countrySlug as string) || toSlug((data.country as string) || '');\n  const stateSlug   = (data.stateSlug as string)   || toSlug((data.state as string)   || '');\n  const clientType  = (data.clientType as ClientType) || 'salon';\n\n  return {\n    slug,\n    title:             (data.title as string)             || 'Untitled',\n    excerpt:           (data.excerpt as string)           || '',\n    date:              (data.date as string)              || new Date().toISOString(),\n    dateModified:      data.dateModified as string | undefined,\n    author:            (data.author as string)            || 'Mirellé Team',\n    region:            (data.region as string)            || '',\n    regionCode:        (data.regionCode as string)        || '',\n    language:          (data.language as string)          || 'en',\n    locale:            (data.locale as string)            || 'en_GB',\n    city:              (data.city as string)              || '',\n    country:           (data.country as string)           || '',\n    countrySlug,\n    state:             (data.state as string)             || '',\n    stateSlug,\n    stateCode:         (data.stateCode as string)         || '',\n    clientType,\n    canonical:         (data.canonical as string)         || `https://mirelleinspo.com/business/${countrySlug}/${stateSlug}/${clientType}/${slug}`,\n    targetKeyword:     (data.targetKeyword as string)     || '',\n    secondaryKeywords: (data.secondaryKeywords as string[]) || [],\n    searchIntent:      data.searchIntent as BusinessMetadata['searchIntent'],\n    noIndex:           (data.noIndex as boolean)          ?? false,\n    tldr:              (data.tldr as string)              || '',\n    entityType:        (data.entityType as string)        || 'EditorialNailPlatform',\n    speakable:         (data.speakable as boolean)        ?? true,\n    contact:           (data.contact as BusinessMetadata['contact']) || { email: '' },\n    services:          (data.services as BusinessMetadata['services']) || [],\n    schemaType:        (data.schemaType as BusinessMetadata['schemaType']) || 'ProfessionalService',\n    template:          'business' as const,\n    url:               `https://mirelleinspo.com/business/${countrySlug}/${stateSlug}/${clientType}/${slug}`,\n    postType:          (data.postType as BusinessMetadata['postType']) || 'client-acquisition',\n    painPoint:         (data.painPoint as string)         || '',\n    statBlock:         (data.statBlock as BusinessMetadata['statBlock']) || [],\n  };\n}\n\n// ─── Public API ───────────────────────────────────────────────────────────────\n\nexport async function getAllBusinessPosts(): Promise<BusinessMetadata[]> {\n  const cacheKey = 'all-business-posts';\n  const cached = businessCache.get<BusinessMetadata[]>(cacheKey);\n  if (cached) return cached;\n\n  try {\n    const files = getAllBusinessFiles();\n    const posts = files\n      .map(({ filePath, slug }) => {\n        const content  = fs.readFileSync(filePath, 'utf8');\n        const { data } = matter(content);\n        return parseMetadata(slug, data);\n      })\n      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n\n    businessCache.set(cacheKey, posts);\n    return posts;\n  } catch (error) {\n    console.error('Error reading business posts:', error);\n    return [];\n  }\n}\n\nexport async function getBusinessPost(slug: string): Promise<BusinessPost | null> {\n  const cacheKey = `business-post:${slug}`;\n  const cached = businessCache.get<BusinessPost>(cacheKey);\n  if (cached) return cached;\n\n  try {\n    const resolved = resolveFilePath(slug);\n    if (!resolved) {\n      console.error(`Business post not found: ${slug}`);\n      return null;\n    }\n\n    const { filePath, isMDX } = resolved;\n    const fileContent = fs.readFileSync(filePath, 'utf8');\n    const { data, content: rawContent } = matter(fileContent);\n\n    let htmlContent: string;\n\n    if (isMDX) {\n      htmlContent = rawContent;\n    } else {\n      let compiled = await marked(rawContent);\n      compiled = compiled.replace(\n        /<h2>(.*?)<\\/h2>/g,\n        (_match, text) => {\n          const id = text\n            .replace(/<[^>]*>/g, '')\n            .toLowerCase()\n            .replace(/[^a-z0-9]+/g, '-')\n            .replace(/^-+|-+$/g, '');\n          return `<h2 id=\"${id}\">${text}</h2>`;\n        }\n      );\n      htmlContent = compiled;\n    }\n\n    const meta = parseMetadata(slug, data);\n\n    const post: BusinessPost = {\n      ...meta,\n      content:       htmlContent,\n      isMDX,\n      faqSchema:     (data.faqSchema as BusinessPost['faqSchema'])         || [],\n      galleryImages: (data.galleryImages as BusinessPost['galleryImages']) || [],\n    };\n\n    businessCache.set(cacheKey, post);\n    return post;\n  } catch (error) {\n    console.error(`Error reading business post ${slug}:`, error);\n    return null;\n  }\n}\n\nexport async function getAllBusinessSlugs(): Promise<string[]> {\n  try {\n    return getAllBusinessFiles().map(f => f.slug);\n  } catch (error) {\n    console.error('Error reading business slugs:', error);\n    return [];\n  }\n}\n\n// ─── Grouped helpers ──────────────────────────────────────────────────────────\n\n/** All unique countries with slug */\nexport async function getBusinessCountries(): Promise<{ country: string; countrySlug: string }[]> {\n  const posts = await getAllBusinessPosts();\n  const seen = new Map<string, string>();\n  for (const p of posts) {\n    if (!seen.has(p.countrySlug)) seen.set(p.countrySlug, p.country);\n  }\n  return Array.from(seen.entries())\n    .map(([countrySlug, country]) => ({ country, countrySlug }))\n    .sort((a, b) => a.country.localeCompare(b.country));\n}\n\n/** All unique states within a country */\nexport async function getBusinessStates(\n  countrySlug: string\n): Promise<{ state: string; stateSlug: string; stateCode: string }[]> {\n  const posts = await getAllBusinessPosts();\n  const filtered = posts.filter(p => p.countrySlug === countrySlug);\n  const seen = new Map<string, { state: string; stateCode: string }>();\n  for (const p of filtered) {\n    if (!seen.has(p.stateSlug)) seen.set(p.stateSlug, { state: p.state, stateCode: p.stateCode });\n  }\n  return Array.from(seen.entries())\n    .map(([stateSlug, { state, stateCode }]) => ({ state, stateSlug, stateCode }))\n    .sort((a, b) => a.state.localeCompare(b.state));\n}\n\n/** All client types available for a country+state */\nexport async function getBusinessClientTypes(\n  countrySlug: string,\n  stateSlug: string\n): Promise<ClientType[]> {\n  const posts = await getAllBusinessPosts();\n  const types = new Set<ClientType>();\n  for (const p of posts) {\n    if (p.countrySlug === countrySlug && p.stateSlug === stateSlug) {\n      types.add(p.clientType);\n    }\n  }\n  return Array.from(types);\n}\n\n/** All posts for a specific country + state + clientType */\nexport async function getBusinessPostsByClientType(\n  countrySlug: string,\n  stateSlug: string,\n  clientType: ClientType\n): Promise<BusinessMetadata[]> {\n  const posts = await getAllBusinessPosts();\n  return posts.filter(\n    p => p.countrySlug === countrySlug &&\n         p.stateSlug   === stateSlug   &&\n         p.clientType  === clientType\n  );\n}\n\n/** Legacy  grouped by country (kept for carousel compat) */\nexport async function getBusinessPostsByCountry(): Promise<Record<string, BusinessMetadata[]>> {\n  const allPosts = await getAllBusinessPosts();\n  return allPosts.reduce<Record<string, BusinessMetadata[]>>((acc, post) => {\n    const country = post.country || 'Other';\n    if (!acc[country]) acc[country] = [];\n    acc[country].push(post);\n    return acc;\n  }, {});\n}\n\nexport function clearBusinessCache(): void {\n  businessCache.clear();\n}"
