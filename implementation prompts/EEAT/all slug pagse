      "path": "src/app/nail-faqs/[slug]/page.tsx",
      "content": "// src/app/nail-faqs/[slug]/page.tsx\nimport { notFound } from 'next/navigation';\nimport { getFaq, getAllFaqSlugs } from '@/lib/faqs';\nimport { MDXRemote } from 'next-mdx-remote/rsc';\nimport Breadcrumbs from '@/components/Breadcrumbs';\nimport FaqInlineNewsletter from '@/components/Faqs/FaqInlineNewsletter';\nimport FaqFinalNewsletter from '@/components/Faqs/FaqFinalNewsletter';\nimport FaqAbout from '@/components/Faqs/FaqAbout';\nimport FaqReadMore from '@/components/Faqs/FaqReadMore';\nimport type { Metadata } from 'next';\n\nconst mdxComponents = {\n  FaqInlineNewsletter,\n};\n\ninterface PageProps {\n  params: Promise<{ slug: string }>;\n}\n\nexport const revalidate = 604800;\n\nexport async function generateStaticParams() {\n  const slugs = await getAllFaqSlugs();\n  return slugs.map((slug) => ({ slug }));\n}\n\nconst SITE_URL = 'https://mirelleinspo.com';\nconst FALLBACK_OG_IMAGE = `${SITE_URL}/og-default.png`;\n\nexport async function generateMetadata({ params }: PageProps): Promise<Metadata> {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n  if (!faq) return { title: 'Not Found', robots: { index: false, follow: false } };\n\n  const canonicalUrl = faq.canonical || `${SITE_URL}/nail-faqs/${slug}`;\n\n  return {\n    title: `${faq.title} | Mirell\u00e9`,\n    description: faq.excerpt,\n    authors: [{ name: faq.author }],\n    alternates: { canonical: canonicalUrl },\n    openGraph: {\n      title: faq.title,\n      description: faq.excerpt,\n      type: 'article',\n      url: canonicalUrl,\n      siteName: 'Mirell\u00e9',\n      images: [{ url: FALLBACK_OG_IMAGE, alt: faq.title }],\n      publishedTime: faq.date,\n      modifiedTime: faq.dateModified || faq.date,\n      authors: [faq.author],\n      section: faq.category,\n    },\n    twitter: {\n      card: 'summary_large_image',\n      title: faq.title,\n      description: faq.excerpt,\n      images: [FALLBACK_OG_IMAGE],\n    },\n  };\n}\n\nexport default async function NailFaqPage({ params }: PageProps) {\n  const { slug } = await params;\n  const faq = await getFaq(slug);\n  if (!faq) notFound();\n\n  const articleSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'Article',\n    headline: faq.title,\n    description: faq.excerpt,\n    image: FALLBACK_OG_IMAGE,\n    datePublished: faq.date,\n    dateModified: faq.dateModified || faq.date,\n    author: { '@type': 'Person', name: faq.author },\n    publisher: {\n      '@type': 'Organization',\n      name: 'Mirell\u00e9 Inspo',\n      logo: { '@type': 'ImageObject', url: `${SITE_URL}/logo.png` },\n    },\n    mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/nail-faqs/${slug}` },\n  };\n\n  const breadcrumbSchema = {\n    '@context': 'https://schema.org',\n    '@type': 'BreadcrumbList',\n    itemListElement: [\n      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },\n      { '@type': 'ListItem', position: 2, name: 'Nail FAQs', item: `${SITE_URL}/nail-faqs` },\n      { '@type': 'ListItem', position: 3, name: faq.title },\n    ],\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(articleSchema) }} />\n      <script type=\"application/ld+json\" dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }} />\n\n      <div className=\"min-h-screen bg-background\">\n        {/* Hero */}\n        <div className=\"w-full px-[6px] md:px-[12px] py-8 md:py-12\">\n          <p className=\"text-sm uppercase tracking-wide text-gray-700 mb-4\">{faq.category}</p>\n          <h1 className=\"font-heading text-[36px] md:text-[42px] leading-tight mb-4\">{faq.title}</h1>\n          <div className=\"text-sm text-gray-700 mb-8\">\n            <p className=\"uppercase tracking-wide mb-1\">BY {faq.author}</p>\n            <time dateTime={faq.date} className=\"text-gray-600\">\n              {new Date(faq.date).toLocaleDateString('en-US', {\n                month: 'long',\n                day: 'numeric',\n                year: 'numeric',\n              })}\n            </time>\n          </div>\n        </div>\n\n        {/* Content */}\n        <div className=\"w-full flex flex-col items-start\">\n          <div className=\"w-full max-w-[700px] px-6 md:px-12 lg:px-16\">\n            <div className=\"mb-8\">\n              <Breadcrumbs\n                items={[{ label: 'Nail FAQs', href: '/nail-faqs' }]}\n                currentPage={faq.title}\n                includeSchema={false}\n              />\n            </div>\n            <article className=\"prose-content-magazine\">\n              <MDXRemote source={faq.content} components={mdxComponents} />\n            </article>\n          </div>\n\n          <div className=\"w-full my-12\">\n            <FaqInlineNewsletter />\n          </div>\n        </div>\n\n        <FaqFinalNewsletter />\n        <FaqAbout />\n        <FaqReadMore currentSlug={faq.slug} />\n      </div>\n    </>\n  );\n}"
    },
