'use client';

// src/app/nail-encyclopedia/EncyclopediaClient.tsx
// Handles search, filter, and sidebar navigation — all in browser.
// The heavy data work already happened on the server.

import { useState, useMemo, useRef } from 'react';
import Link from 'next/link';
import { EncyclopediaSection, EncyclopediaEntry } from '@/lib/encyclopedia';

interface Props {
  sections: EncyclopediaSection[];
}

const CONTENT_TYPE_LABELS: Record<EncyclopediaEntry['contentType'], string> = {
  blog: 'Guide',
  faq: 'FAQ',
  'work-nails': 'Work',
  topic: 'Topic',
  spotlight: 'Spotlight',
};

export default function EncyclopediaClient({ sections }: Props) {
  const [query, setQuery] = useState('');
  const [activeFilter, setActiveFilter] = useState<string>('all');
  const sectionRefs = useRef<Record<string, HTMLElement | null>>({});

  // Filter types for the tabs
  const filterOptions = [
    { value: 'all', label: 'All' },
    { value: 'blog', label: 'Guides' },
    { value: 'faq', label: 'FAQs' },
    { value: 'work-nails', label: 'Work Nails' },
    { value: 'topic', label: 'Topics' },
    { value: 'spotlight', label: 'Spotlights' },
  ];

  // Derived sections after search + filter
  const filteredSections = useMemo(() => {
    const q = query.toLowerCase().trim();
    return sections
      .map((section) => ({
        ...section,
        entries: section.entries.filter((entry) => {
          const matchesFilter =
            activeFilter === 'all' || entry.contentType === activeFilter;
          const matchesQuery =
            !q ||
            entry.title.toLowerCase().includes(q) ||
            entry.excerpt.toLowerCase().includes(q) ||
            (entry.tags || []).some((tag) => tag.toLowerCase().includes(q));
          return matchesFilter && matchesQuery;
        }),
      }))
      .filter((s) => s.entries.length > 0);
  }, [sections, query, activeFilter]);

  const totalVisible = filteredSections.reduce((sum, s) => sum + s.entries.length, 0);

  function scrollToSection(id: string) {
    const el = sectionRefs.current[id];
    if (el) {
      const offset = 24;
      const top = el.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    }
  }

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      {/* ── Search ── */}
      <div className="relative mb-6">
        <span className="absolute left-4 top-1/2 -translate-y-1/2 text-foreground/30 font-ui text-sm pointer-events-none">
          ↳
        </span>
        <input
          type="search"
          value={query}
          onChange={(e) => setQuery(e.target.value)}
          placeholder="Search any nail term, shape, technique or style…"
          className="w-full pl-9 pr-4 py-3 bg-background border border-foreground/15 font-ui text-sm text-foreground placeholder:text-foreground/30 focus:outline-none focus:border-foreground/40 transition-colors"
          aria-label="Search encyclopedia"
        />
      </div>

      {/* ── Filter tabs ── */}
      <div className="flex flex-wrap gap-2 mb-8 border-b border-foreground/10 pb-6">
        {filterOptions.map((opt) => (
          <button
            key={opt.value}
            onClick={() => setActiveFilter(opt.value)}
            className={`font-ui text-xs tracking-wider uppercase px-4 py-2 border transition-colors ${
              activeFilter === opt.value
                ? 'border-foreground bg-foreground text-background'
                : 'border-foreground/20 text-foreground/50 hover:border-foreground/50 hover:text-foreground'
            }`}
          >
            {opt.label}
          </button>
        ))}
        <span className="font-ui text-xs text-foreground/30 self-center ml-auto">
          {totalVisible} {totalVisible === 1 ? 'entry' : 'entries'}
        </span>
      </div>

      {/* ── Two-column layout ── */}
      <div className="flex gap-12 lg:gap-16 items-start">

        {/* ── Sidebar ── */}
        <aside className="hidden lg:block w-48 flex-shrink-0 sticky top-8">
          <p className="font-ui text-xs tracking-widest uppercase text-foreground/30 mb-4">
            Sections
          </p>
          <nav aria-label="Encyclopedia sections">
            <ul className="space-y-1">
              {filteredSections.map((section) => (
                <li key={section.id}>
                  <button
                    onClick={() => scrollToSection(section.id)}
                    className="group w-full text-left font-ui text-xs text-foreground/50 hover:text-foreground transition-colors py-1 flex items-center justify-between gap-2"
                  >
                    <span className="group-hover:underline underline-offset-2">
                      {section.title}
                    </span>
                    <span className="text-foreground/25 flex-shrink-0">
                      {section.entries.length}
                    </span>
                  </button>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        {/* ── Main content ── */}
        <div className="flex-1 min-w-0">
          {filteredSections.length === 0 ? (
            <div className="py-20 text-center">
              <p className="font-body text-lg text-foreground/40">
                No entries found for &ldquo;{query}&rdquo;
              </p>
              <button
                onClick={() => { setQuery(''); setActiveFilter('all'); }}
                className="font-ui text-xs uppercase tracking-wider text-foreground/40 hover:text-foreground mt-4 underline underline-offset-2 transition-colors"
              >
                Clear search
              </button>
            </div>
          ) : (
            filteredSections.map((section, sectionIndex) => (
              <section
                key={section.id}
                id={section.id}
                ref={(el) => { sectionRefs.current[section.id] = el; }}
                className={sectionIndex > 0 ? 'mt-16' : ''}
                aria-labelledby={`section-heading-${section.id}`}
              >
                {/* Section header */}
                <div className="flex items-baseline justify-between mb-6 pb-3 border-b border-foreground/10">
                  <h2
                    id={`section-heading-${section.id}`}
                    className="font-ui text-xs tracking-widest uppercase text-foreground"
                  >
                    {section.title}
                  </h2>
                  <span className="font-ui text-xs text-foreground/30">
                    {section.entries.length} {section.entries.length === 1 ? 'entry' : 'entries'}
                  </span>
                </div>

                {/* Entry cards */}
                <div className="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-px bg-foreground/8">
                  {section.entries.map((entry) => (
                    <EntryCard key={entry.canonical} entry={entry} />
                  ))}
                </div>
              </section>
            ))
          )}
        </div>
      </div>
    </div>
  );
}

// ─── Entry card ───────────────────────────────────────────────────────────────
function EntryCard({ entry }: { entry: EncyclopediaEntry }) {
  const label = CONTENT_TYPE_LABELS[entry.contentType];

  return (
    <Link
      href={entry.canonical}
      className="group block bg-background p-5 hover:bg-foreground/[0.02] transition-colors"
    >
      {/* Type label */}
      <span className="font-ui text-xs tracking-widest uppercase text-foreground/30 block mb-2">
        {label}
      </span>

      {/* Title */}
      <h3 className="font-heading text-lg text-foreground leading-snug mb-3 group-hover:opacity-70 transition-opacity">
        {entry.title}
      </h3>

      {/* Excerpt */}
      {entry.excerpt && (
        <p className="font-body text-sm text-foreground/55 leading-relaxed line-clamp-3 mb-4">
          {entry.excerpt}
        </p>
      )}

      {/* Arrow link */}
      <span className="font-ui text-xs uppercase tracking-wider text-foreground/30 group-hover:text-foreground transition-colors">
        Read →
      </span>
    </Link>
  );
}




// src/app/nail-encyclopedia/page.tsx
// Server component — all data reading happens at build time, zero runtime cost.

import { getEncyclopediaData, EncyclopediaEntry, EncyclopediaSection } from '@/lib/encyclopedia';
import type { Metadata } from 'next';
import Link from 'next/link';
import EncyclopediaClient from './EncyclopediaClient';

export const revalidate = 604800; // rebuild weekly

export const metadata: Metadata = {
  title: 'The Nail Encyclopedia — Every Shape, Technique & Style | Mirellé',
  description:
    'The complete nail reference — every shape, technique, aesthetic, colour, occasion and care guide on Mirellé in one place. Your starting point for wherever you want to go.',
  alternates: {
    canonical: 'https://mirelleinspo.com/nail-encyclopedia',
  },
  openGraph: {
    title: 'The Nail Encyclopedia | Mirellé',
    description:
      'Every nail shape, technique, aesthetic, colour guide and FAQ on Mirellé — one page, everything linked.',
    url: 'https://mirelleinspo.com/nail-encyclopedia',
    siteName: 'Mirellé',
    type: 'website',
  },
  twitter: {
    card: 'summary_large_image',
    title: 'The Nail Encyclopedia | Mirellé',
    description: 'Every nail topic on Mirellé in one place.',
    site: '@mirelleinspo',
  },
};

export default function NailEncyclopediaPage() {
  const data = getEncyclopediaData();

  // Schema — DefinedTermSet tells Google + AI agents this is a structured knowledge base
  const schemaDefinedTermSet = {
    '@context': 'https://schema.org',
    '@type': 'DefinedTermSet',
    '@id': 'https://mirelleinspo.com/nail-encyclopedia',
    name: 'The Mirellé Nail Encyclopedia',
    description:
      'A comprehensive reference of nail shapes, techniques, aesthetics, colours, occasions and care guides curated by the Mirellé editorial team.',
    url: 'https://mirelleinspo.com/nail-encyclopedia',
    publisher: {
      '@type': 'Organization',
      name: 'Mirellé',
      url: 'https://mirelleinspo.com',
    },
    hasDefinedTerm: data.sections.flatMap((section) =>
      section.entries.map((entry) => ({
        '@type': 'DefinedTerm',
        name: entry.title,
        description: entry.excerpt,
        url: entry.canonical,
        inDefinedTermSet: 'https://mirelleinspo.com/nail-encyclopedia',
      }))
    ),
  };

  const breadcrumbSchema = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mirelleinspo.com' },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Nail Encyclopedia',
        item: 'https://mirelleinspo.com/nail-encyclopedia',
      },
    ],
  };

  return (
    <>
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: JSON.stringify(schemaDefinedTermSet) }}
      />
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: JSON.stringify(breadcrumbSchema) }}
      />

      <main className="min-h-screen bg-background">
        {/* ── Breadcrumb ── */}
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
          <nav aria-label="Breadcrumb">
            <ol className="flex items-center gap-2 font-ui text-xs text-foreground/50">
              <li>
                <Link href="/" className="hover:text-foreground transition-colors">
                  Home
                </Link>
              </li>
              <li>/</li>
              <li className="text-foreground">Nail Encyclopedia</li>
            </ol>
          </nav>
        </div>

        {/* ── Hero ── */}
        <section className="border-b border-foreground/10">
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
            <span className="font-ui text-xs tracking-widest uppercase text-foreground/40 block mb-4">
              Mirellé · Complete Reference
            </span>
            <h1 className="font-heading text-5xl md:text-6xl lg:text-7xl text-foreground mb-5 leading-none">
              The Nail Encyclopedia
            </h1>
            <p className="font-body text-lg md:text-xl text-foreground/60 max-w-2xl leading-relaxed mb-10">
              Every shape, technique, aesthetic, colour and care guide — with everything we've
              written about it. Your starting point for wherever you want to go.
            </p>

            {/* Stats */}
            <div className="flex flex-wrap gap-10">
              <div>
                <p className="font-heading text-3xl text-foreground">{data.totalEntries}+</p>
                <p className="font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1">
                  Articles & guides
                </p>
              </div>
              <div>
                <p className="font-heading text-3xl text-foreground">{data.totalSections}</p>
                <p className="font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1">
                  Sections
                </p>
              </div>
              <div>
                <p className="font-heading text-3xl text-foreground">{data.imageCount.toLocaleString()}+</p>
                <p className="font-ui text-xs uppercase tracking-widest text-foreground/40 mt-1">
                  Inspo images
                </p>
              </div>
            </div>
          </div>
        </section>

        {/* ── Body: sidebar + content (client handles search/filter) ── */}
        <EncyclopediaClient sections={data.sections} />
      </main>
    </>
  );
}
