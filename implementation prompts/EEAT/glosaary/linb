// src/lib/encyclopedia.ts
// Reads all content files at build time and organises them into encyclopedia sections.
// No API calls, no cost. Runs during next build automatically.

import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';

export interface EncyclopediaEntry {
  title: string;
  excerpt: string;
  canonical: string;
  slug: string;
  contentType: 'blog' | 'faq' | 'work-nails' | 'topic' | 'spotlight';
  tags?: string[];
  image?: string;
  imageAlt?: string;
}

export interface EncyclopediaSection {
  id: string;
  title: string;
  entries: EncyclopediaEntry[];
}

// ─── Section definitions ────────────────────────────────────────────────────
