// ─── Business page exclusion ─────────────────────────────────────────────────
const BUSINESS_KEYWORDS =
  /\b(georgia|atlanta|augusta|savannah|columbus|marietta|buckhead|roswell|midtown|sandy springs|gwinnett|decatur|shelby township|michigan)\b/i;

// ─── Internal types ───────────────────────────────────────────────────────────
interface RawEntry {
  title: string;
  excerpt: string;
  canonical: string;
  slug: string;
  contentType: EncyclopediaEntry['contentType'];
  tags: string[];
  image?: string;
  imageAlt?: string;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function readContentDir(
  dirPath: string,
  contentType: EncyclopediaEntry['contentType'],
  slugPrefix: string
): RawEntry[] {
  if (!fs.existsSync(dirPath)) return [];

  const entries: RawEntry[] = [];

  function walk(dir: string) {
    const items = fs.readdirSync(dir);
    for (const item of items) {
      const fullPath = path.join(dir, item);
      const stat = fs.statSync(fullPath);
      if (stat.isDirectory()) {
        walk(fullPath);
      } else if (item.endsWith('.md') || item.endsWith('.mdx')) {
        try {
          const raw = fs.readFileSync(fullPath, 'utf-8');
          const { data } = matter(raw);

          // Skip business pages
          const titleAndCanon = (data.title || '') + ' ' + (data.canonical || '');
          if (BUSINESS_KEYWORDS.test(titleAndCanon)) continue;

          // Skip if no title
          if (!data.title) continue;

          const slug = data.slug || item.replace(/\.mdx?$/, '');
          const canonical =
            data.canonical || `https://mirelleinspo.com/${slugPrefix}/${slug}`;

          entries.push({
            title: data.title,
            excerpt: data.excerpt || '',
            canonical,
            slug,
            contentType,
            tags: Array.isArray(data.tags) ? data.tags : [],
            image: data.image,
            imageAlt: data.imageAlt,
          });
        } catch {
          // skip malformed files
        }
      }
    }
  }

  walk(dirPath);
  return entries;
}

// ─── Image counter ────────────────────────────────────────────────────────────
const IMAGE_EXTENSIONS = new Set(['.jpg', '.jpeg', '.webp', '.png', '.gif', '.avif']);

function countImages(dirs: string[]): number {
  let count = 0;
  function walk(dir: string) {
    if (!fs.existsSync(dir)) return;
    for (const item of fs.readdirSync(dir)) {
      const full = path.join(dir, item);
      if (fs.statSync(full).isDirectory()) {
        walk(full);
      } else if (IMAGE_EXTENSIONS.has(path.extname(item).toLowerCase())) {
        count++;
      }
    }
  }
  dirs.forEach(walk);
  return count;
}

// ─── Main export ──────────────────────────────────────────────────────────────
export interface EncyclopediaData {
  sections: EncyclopediaSection[];
  totalEntries: number;
  totalSections: number;
  imageCount: number; // static number you update manually
}

export function getEncyclopediaData(): EncyclopediaData {
  const contentRoot = path.join(process.cwd(), 'src', 'content');

  // Read every content type
  const allEntries: RawEntry[] = [
    ...readContentDir(path.join(contentRoot, 'blogs'), 'blog', 'blog'),
    ...readContentDir(path.join(contentRoot, 'faqs'), 'faq', 'nail-faqs'),
    ...readContentDir(path.join(contentRoot, 'work-nails'), 'work-nails', 'work-nails'),
    ...readContentDir(path.join(contentRoot, 'topics'), 'topic', 'topics'),
    ...readContentDir(path.join(contentRoot, 'spotlights'), 'spotlight', 'spotlight'),
    // inspo-images are JSON galleries — we link to the inspo section pages, not individual files
  ];

  // Remove duplicates by canonical URL
  const seen = new Set<string>();
  const unique = allEntries.filter((e) => {
    if (seen.has(e.canonical)) return false;
    seen.add(e.canonical);
    return true;
  });

  // Assign each entry to its first matching section
  const sectionMap = new Map<string, RawEntry[]>();
  SECTIONS.forEach((s) => sectionMap.set(s.id, []));

  for (const entry of unique) {
    let assigned = false;
    for (const section of SECTIONS) {
      if (section.match(entry)) {
        sectionMap.get(section.id)!.push(entry);
        assigned = true;
        break;
      }
    }
    // If nothing matched, drop into FAQs as a catch-all
    if (!assigned) {
      sectionMap.get('nail-faqs')!.push(entry);
    }
  }

  // Build final sections, sorted alphabetically within each
  const sections: EncyclopediaSection[] = SECTIONS.map((s) => ({
    id: s.id,
    title: s.title,
    entries: (sectionMap.get(s.id) || []).sort((a, b) =>
      a.title.localeCompare(b.title)
    ),
  })).filter((s) => s.entries.length > 0);

  const totalEntries = sections.reduce((sum, s) => sum + s.entries.length, 0);

  // Image count — reads directly from your public image folders at build time
  const imageCount = countImages([
    path.join(process.cwd(), 'public', 'images'),
    path.join(process.cwd(), 'public', 'inspo'),
  ]);

  return {
    sections,
    totalEntries,
    totalSections: sections.length,
    imageCount,
  };
}
